```go
func hasPath(board [][]rune, player byte, startRows []int, startCols []int, isO bool) bool {
    rows := len(board)
    if rows == 0 {
        return false
    }
    cols := len(board[0])
    
    visited := make([][]bool, rows)
    for i := range visited {
        visited[i] = make([]bool, cols)
    }
    
    type pos struct{ r, c int }
    var queue []pos
    
    for _, r := range startRows {
        for _, c := range startCols {
            if board[r][c] == player {
                visited[r][c] = true
                queue = append(queue, pos{r, c})
            }
        }
    }
    
    dirs := [][2]int{
        {0, -1}, {0, 1},
        {-1, 0}, {-1, 1},
        {1, -1}, {1, 0},
    }
    
    for len(queue) > 0 {
        curr := queue[0]
        queue = queue[1:]
        
        if isO {
            if curr.r == rows-1 {
                return true
            }
        } else {
            if curr.c == cols-1 {
                return true
            }
        }
        
        for _, d := range dirs {
            nr, nc := curr.r+d[0], curr.c+d[1]
            if nr >= 0 && nr < rows && nc >= 0 && nc < cols && !visited[nr][nc] && board[nr][nc] == player {
                visited[nr][nc] = true
                queue = append(queue, pos{nr, nc})
            }
        }
    }
    return false
}
