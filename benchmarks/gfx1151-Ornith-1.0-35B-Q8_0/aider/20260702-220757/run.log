```js
export class List {
  constructor(items = []) {
    this.items = items;
  }

  append(list) {
    // Add all items in the second list to the end of the first list
    for (let i = 0; i < list.items.length; i++) {
      this.items[this.items.length] = list.items[i];
    }
    return this;
  }

  concat(lists) {
    // Combine all items in all lists into one flattened list
    let result = [];
    for (let i = 0; i < this.items.length; i++) {
      result[result.length] = this.items[i];
    }
    for (let i = 0; i < lists.items.length; i++) {
      const innerList = lists.items[i];
      for (let j = 0; j < innerList.items.length; j++) {
        result[result.length] = innerList.items[j];
      }
    }
    return new List(result);
  }

  filter(predicate) {
    let result = [];
    for (let i = 0; i < this.items.length; i++) {
      if (predicate(this.items[i])) {
        result[result.length] = this.items[i];
      }
    }
    return new List(result);
  }

  length() {
    let count = 0;
    for (let i = 0; i < this.items.length; i++) {
      count++;
    }
    return count;
  }

  map(fn) {
    let result = [];
    for (let i = 0; i < this.items.length; i++) {
      result[result.length] = fn(this.items[i]);
    }
    return new List(result);
  }

  foldl(fn, initial) {
    let acc = initial;
    for (let i = 0; i < this.items.length; i++) {
      acc = fn(acc, this.items[i]);
    }
    return acc;
  }

  foldr(fn, initial) {
    let acc = initial;
    for (let i = this.items.length - 1; i >= 0; i--) {
      acc = fn(acc, this.items[i]);
    }
    return acc;
  }

  reverse() {
    let result = [];
    for (let i = this.items.length - 1; i >= 0; i--) {
      result[result.length] = this.items[i];
    }
    return new List(result);
  }
}
