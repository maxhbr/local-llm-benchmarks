//
// This is only a SKELETON file for the 'BookStore' exercise. It's been provided as a
// convenience to get you started writing code faster.
//

export const cost = (books) => {
  // Count copies of each book
  const counts = {};
  for (const book of books) {
    counts[book] = (counts[book] || 0) + 1;
  }

  // Greedily form groups of distinct books
  const groups = [];
  let remaining = { ...counts };

  while (Object.values(remaining).some(c => c > 0)) {
    const distinct = Object.keys(remaining).filter(k => remaining[k] > 0);
    const groupSize = distinct.length;
    groups.push(groupSize);
    for (const k of distinct) {
      remaining[k]--;
    }
  }

  // Optimize: replace (5, 3) pairs with (4, 4) pairs
  // A group of 5 + group of 3 costs 5160 cents
  // Two groups of 4 cost 5120 cents, so this swap saves 40 cents
  let count5 = groups.filter(g => g === 5).length;
  let count3 = groups.filter(g => g === 3).length;

  const swaps = Math.min(count5, count3);

  // Rebuild groups with optimization applied
  const optimizedGroups = [];
  for (let i = 0; i < count5 - swaps; i++) optimizedGroups.push(5);
  for (let i = 0; i < count3 - swaps; i++) optimizedGroups.push(3);
  for (let i = 0; i < swaps; i++) {
    optimizedGroups.push(4);
    optimizedGroups.push(4);
  }

  // Calculate total cost in cents
  const pricePerBook = 800;
  const discounts = {
    1: 0,
    2: 5,
    3: 10,
    4: 20,
    5: 25,
  };

  let total = 0;
  for (const size of optimizedGroups) {
    total += size * pricePerBook * (100 - discounts[size]) / 100;
  }

  return total;
};
```
