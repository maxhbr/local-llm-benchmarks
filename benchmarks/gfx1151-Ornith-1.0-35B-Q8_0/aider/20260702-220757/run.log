```go
func MakeChain(input []Domino) ([]Domino, bool) {
    if len(input) == 0 {
        return []Domino{}, true
    }
    
    used := make([]bool, len(input))
    var chain []Domino
    
    var solve func() bool
    solve = func() bool {
        if len(chain) == len(input) {
            // Check if first and last match
            return chain[0][0] == chain[len(chain)-1][1]
        }
        
        lastVal := chain[len(chain)-1][1]
        for i, d := range input {
            if !used[i] {
                // Try orientation d[0] -> d[1]
                if d[0] == lastVal {
                    used[i] = true
                    chain = append(chain, d)
                    if solve() {
                        return true
                    }
                    chain = chain[:len(chain)-1]
                    used[i] = false
                }
                // Try orientation d[1] -> d[0]
                if d[1] == lastVal {
                    // Avoid duplicate work if d[0] == d[1]
                    if d[0] != d[1] {
                        used[i] = true
                        chain = append(chain, Domino{d[1], d[0]})
                        if solve() {
                            return true
                        }
                        chain = chain[:len(chain)-1]
                        used[i] = false
                    }
                }
            }
        }
        return false
    }
    
    // Try starting with each domino
    for i := range input {
        // orientation 1
        used[i] = true
        chain = append(chain, input[i])
        if solve() {
            return chain, true
        }
        chain = chain[:len(chain)-1]
        used[i] = false
        
        // orientation 2
        if input[i][0] != input[i][1] {
            used[i] = true
            chain = append(chain, Domino{input[i][1], input[i][0]})
            if solve() {
                return chain, true
            }
            chain = chain[:len(chain)-1]
            used[i] = false
        }
    }
    
    return nil, false
}
```

