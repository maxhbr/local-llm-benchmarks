```cpp
#include "all_your_base.h"
#include <algorithm>
#include <stdexcept>

namespace all_your_base {

std::vector<unsigned int> convert(unsigned int from_base, const std::vector<unsigned int>& digits, unsigned int to_base) {
    if (from_base < 2) {
        throw std::invalid_argument("Input base must be >= 2.");
    }
    if (to_base < 2) {
        throw std::invalid_argument("Output base must be >= 2.");
    }

    unsigned int value = 0;
    for (unsigned int d : digits) {
        if (d >= from_base) {
            throw std::invalid_argument("All digits must be >= 0 and < input base.");
        }
        value = value * from_base + d;
    }

    if (value == 0) {
        if (digits.empty()) {
            return {};
        }
        return {0};
    }

    std::vector<unsigned int> result;
    while (value > 0) {
        result.push_back(value % to_base);
        value /= to_base;
    }
    std::reverse(result.begin(), result.end());
    return result;
}

}  // namespace all_your_base
