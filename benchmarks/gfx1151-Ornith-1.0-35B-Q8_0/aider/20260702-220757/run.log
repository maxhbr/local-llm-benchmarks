class BowlingGame:
    def __init__(self):
        self._rolls = []

    def roll(self, pins):
        if pins < 0:
            raise ValueError("pins cannot be negative")
        if pins > 10:
            raise ValueError("pins cannot exceed 10")
        if self._game_over():
            raise ValueError("cannot roll after game is over")
            
        if len(self._rolls) >= 2 and self._in_tenth_frame():
            f1 = self._rolls[-2]
            f2 = self._rolls[-1]
            if f1 != 10 and f1 + f2 < 10:
                raise IndexError("cannot throw bonus with an open tenth frame")
                
        self._rolls.append(pins)

    def score(self):
        if not self._game_over():
            raise ValueError("score cannot be taken until the end of the game")
        total = 0
        roll_idx = 0
        for _ in range(10):
            if self._rolls[roll_idx] == 10:
                total += 10 + self._rolls[roll_idx+1] + self._rolls[roll_idx+2]
                roll_idx += 1
            elif self._rolls[roll_idx] + self._rolls[roll_idx+1] == 10:
                total += 10 + self._rolls[roll_idx+2]
                roll_idx += 2
            else:
                total += self._rolls[roll_idx] + self._rolls[roll_idx+1]
                roll_idx += 2
        return total

    def _game_over(self):
        rolls = self._rolls
        frame = 0
        idx = 0
        while frame < 10:
            if idx >= len(rolls):
                return False
            if frame < 9:
                if rolls[idx] == 10:
                    idx += 1
                else:
                    if idx + 1 >= len(rolls):
                        return False
                    if rolls[idx] + rolls[idx+1] > 10:
                        raise ValueError("pins cannot exceed 10 in a frame")
                    idx += 2
                frame += 1
            else:
                if idx + 1 >= len(rolls):
                    return False
                first = rolls[idx]
                second = rolls[idx+1]
                if first == 10:
                    if idx + 2 >= len(rolls):
                        return False
                    return idx + 3 <= len(rolls)
                else:
                    if first + second > 10:
                        raise ValueError("pins cannot exceed 10 in a frame")
                    if first + second == 10:
                        return idx + 3 <= len(rolls)
                    else:
                        return True
        return False

    def _in_tenth_frame(self):
        idx = 0
        for _ in range(9):
            if idx >= len(self._rolls):
                return False
            idx += 1 if self._rolls[idx] == 10 else 2
        return idx == len(self._rolls)
```

