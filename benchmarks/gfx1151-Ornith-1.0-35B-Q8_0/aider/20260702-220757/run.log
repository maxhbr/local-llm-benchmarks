I will implement the standard dynamic programming solution for 0/1 knapsack.
DP array `dp[w]` = max value for weight `w`.
Iterate over items, for each item iterate `w` from `maximum_weight` down to `item.weight`:
`dp[w] = max(dp[w], dp[w - item.weight] + item.value);`

Let's prepare `knapsack.h`:
```cpp
#ifndef KNAPSACK_H
#define KNAPSACK_H

#include <vector>

namespace knapsack
{

struct Item
{
    int weight;
    int value;
};

int maximum_value(int maximum_weight, const std::vector<Item>& items);

} // namespace knapsack

#endif // KNAPSACK_H
```

And `knapsack.cpp`:
```cpp
#include "knapsack.h"
#include <vector>
#include <algorithm>

namespace knapsack
{

int maximum_value(int maximum_weight, const std::vector<Item>& items)
{
    std::vector<int> dp(maximum_weight + 1, 0);
    for (const auto& item : items) {
        for (int w = maximum_weight; w >= item.weight; --w) {
            dp[w] = std::max(dp[w], dp[w - item.weight] + item.value);
        }
    }
    return dp[maximum_weight];
}

} // namespace knapsack
```

