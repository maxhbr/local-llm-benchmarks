export const combinations = ({ sum, size, exclude = [] }) => {
  const results = [];
  
  const find = (start, currentSum, currentCombo) => {
    if (currentCombo.length === size) {
      if (currentSum === sum) {
        results.push(currentCombo);
      }
      return;
    }
    
    for (let i = start; i <= 9; i++) {
      if (exclude.includes(i)) continue;
      if (currentSum + i > sum) break;
      
      // Optimization: check if remaining digits can still reach sum
      // Not strictly necessary for size <= 9, but good practice.
      // We'll keep it simple.
      
      find(i + 1, currentSum + i, [...currentCombo, i]);
    }
  };
  
  find(1, 0, []);
  return results;
};
```

