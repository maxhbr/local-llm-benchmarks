namespace grade_school {

void school::add(const std::string& name, int grade) {
    // Check if student already exists in any grade
    for (const auto& pair : db_) {
        for (const auto& student : pair.second) {
            if (student == name) {
                return; // duplicate, do nothing
            }
        }
    }
    db_[grade].push_back(name);
    // Sort within grade
    std::sort(db_[grade].begin(), db_[grade].end());
}

std::vector<std::string> school::roster() const {
    std::vector<std::string> result;
    for (const auto& pair : db_) {
        for (const auto& student : pair.second) {
            result.push_back(student);
        }
    }
    return result;
}

std::vector<std::string> school::grade(int grade) const {
    auto it = db_.find(grade);
    if (it != db_.end()) {
        return it->second;
    }
    return {};
}

}  // namespace grade_school
