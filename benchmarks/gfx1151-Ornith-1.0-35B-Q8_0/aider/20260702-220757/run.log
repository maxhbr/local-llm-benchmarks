```go
package connect

func ResultOf(lines []string) (string, error) {
	board := parseBoard(lines)
	if len(board) == 0 {
		return "", nil
	}

	if hasPath(board, 'O', true) {
		return "O", nil
	}
	if hasPath(board, 'X', false) {
		return "X", nil
	}
	return "", nil
}

func parseBoard(lines []string) [][]rune {
	var board [][]rune
	for _, line := range lines {
		var row []rune
		for _, ch := range line {
			if ch != ' ' {
				row = append(row, ch)
			}
		}
		if len(row) > 0 {
			board = append(board, row)
		}
	}
	return board
}

func hasPath(board [][]rune, player rune, isO bool) bool {
	rows := len(board)
	cols := len(board[0])
	visited := make([][]bool, rows)
	for i := range visited {
		visited[i] = make([]bool, cols)
	}

	type pos struct{ r, c int }
	var queue []pos

	for c := 0; c < cols; c++ {
		if board[0][c] == player && !visited[0][c] {
			visited[0][c] = true
			queue = append(queue, pos{0, c})
		}
	}
	for r := 0; r < rows; r++ {
		if board[r][0] == player && !visited[r][0] {
			visited[r][0] = true
			queue = append(queue, pos{r, 0})
		}
	}

	dirs := [][2]int{
		{0, -1}, {0, 1},
		{-1, 0}, {-1, 1},
		{1, -1}, {1, 0},
	}

	for len(queue) > 0 {
		curr := queue[0]
		queue = queue[1:]

		if isO && curr.r == rows-1 {
			return true
		}
		if !isO && curr.c == cols-1 {
			return true
		}

		for _, d := range dirs {
			nr, nc := curr.r+d[0], curr.c+d[1]
			if nr >= 0 && nr < rows && nc >= 0 && nc < cols && !visited[nr][nc] && board[nr][nc] == player {
				visited[nr][nc] = true
				queue = append(queue, pos{nr, nc})
			}
		}
	}
	return false
}
```
