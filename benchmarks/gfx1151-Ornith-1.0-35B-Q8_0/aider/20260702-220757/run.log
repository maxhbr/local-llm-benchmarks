```go
package wordy

import (
	"strconv"
	"strings"
)

func Answer(question string) (int, bool) {
	if !strings.HasPrefix(question, "What is ") || !strings.HasSuffix(question, "?") {
		return 0, false
	}
	inner := question[len("What is "):len(question)-1]
	tokens := strings.Fields(inner)
	if len(tokens) == 0 {
		return 0, false
	}

	result, err := strconv.Atoi(tokens[0])
	if err != nil {
		return 0, false
	}

	i := 1
	for i < len(tokens) {
		op := tokens[i]
		var nextOp string
		if op == "plus" || op == "minus" {
			nextOp = op
			i++
		} else if op == "multiplied" || op == "divided" {
			if i+1 >= len(tokens) || tokens[i+1] != "by" {
				return 0, false
			}
			nextOp = op
			i += 2
		} else {
			return 0, false
		}

		if i >= len(tokens) {
			return 0, false
		}
		operand, err := strconv.Atoi(tokens[i])
		if err != nil {
			return 0, false
		}

		switch nextOp {
		case "plus":
			result += operand
		case "minus":
			result -= operand
		case "multiplied":
			result *= operand
		case "divided":
			result /= operand
		}
		i++
	}

	return result, true
}
```
