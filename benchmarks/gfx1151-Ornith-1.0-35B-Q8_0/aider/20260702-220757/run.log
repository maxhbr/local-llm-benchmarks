  const swaps = Math.min(sizeCounts[5] || 0, sizeCounts[3] || 0);

  // Rebuild groups with optimization applied
  const optimizedGroups = [];
  for (let i = 0; i < (sizeCounts[5] || 0) - swaps; i++) optimizedGroups.push(5);
  for (let i = 0; i < (sizeCounts[3] || 0) - swaps; i++) optimizedGroups.push(3);
  for (let i = 0; i < swaps; i++) {
