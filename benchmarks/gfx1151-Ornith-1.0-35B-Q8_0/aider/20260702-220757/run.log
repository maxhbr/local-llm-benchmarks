                } else {
                    tail_ = current->prev_;
                }
                delete current;
                --size_;
                return true;
            }
            current = current->next_;
        }
        return false;
    }

private:
    Node* head_;
    Node* tail_;
    std::size_t size_;
};

}  // namespace linked_list
