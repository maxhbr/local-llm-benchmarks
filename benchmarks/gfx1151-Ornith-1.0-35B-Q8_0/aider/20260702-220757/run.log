import java.util.ArrayList;
import java.util.List;

public class SgfParsing {
    public SgfNode parse(String input) throws SgfParsingException {
        if (input == null || input.isEmpty()) {
            throw new SgfParsingException("tree with no nodes");
        }
        Parser parser = new Parser(input);
        SgfNode root = parser.parseTree();
        if (parser.pos < input.length()) {
            throw new SgfParsingException("tree with no nodes");
        }
        return root;
    }

    private static class Parser {
        private final String input;
        private int pos;

        Parser(String input) {
            this.input = input;
            this.pos = 0;
        }

        SgfNode parseTree() throws SgfParsingException {
            expect('(');
            SgfNode root = parseNode();
            while (pos < input.length() && input.charAt(pos) == '(') {
                root.addChild(parseTree());
            }
            expect(')');
            return root;
        }

        SgfNode parseNode() throws SgfParsingException {
            expect(';');
            SgfNode node = new SgfNode();
            if (pos < input.length()) {
                char c = input.charAt(pos);
                if (Character.isLowerCase(c)) {
                    throw new SgfParsingException("property must be in uppercase");
                }
                if (c != ';' && c != '(' && c != ')') {
                    parseProperties(node);
                }
            }
            return node;
        }

        void parseProperties(SgfNode node) throws SgfParsingException {
            String key = parseKey();
            List<String> values = parseValues();
            if (node.hasProperty(key)) {
                throw new SgfParsingException("duplicate key");
            }
            for (String v : values) {
                node.addProperty(key, v);
            }
            while (pos < input.length() && Character.isUpperCase(input.charAt(pos))) {
                key = parseKey();
                values = parseValues();
                if (node.hasProperty(key)) {
                    throw new SgfParsingException("duplicate key");
                }
                for (String v : values) {
                    node.addProperty(key, v);
                }
            }
        }

        String parseKey() throws SgfParsingException {
            int start = pos;
            while (pos < input.length() && Character.isUpperCase(input.charAt(pos))) {
                pos++;
            }
            if (pos == start) {
                throw new SgfParsingException("property must be in uppercase");
            }
            return input.substring(start, pos);
        }

        List<String> parseValues() throws SgfParsingException {
            List<String> values = new ArrayList<>();
            while (pos < input.length() && input.charAt(pos) == '[') {
                values.add(parseValue());
            }
            if (values.isEmpty()) {
                throw new SgfParsingException("property without values");
            }
            return values;
        }

        String parseValue() throws SgfParsingException {
            expect('[');
            StringBuilder sb = new StringBuilder();
            while (pos < input.length() && input.charAt(pos) != ']') {
                char c = input.charAt(pos);
                if (c == '\\') {
                    pos++;
                    if (pos >= input.length()) {
                        throw new SgfParsingException("unterminated string");
                    }
                    c = input.charAt(pos);
                    if (c == '\n') {
                        // removed
                    } else if (Character.isWhitespace(c)) {
                        sb.append(' ');
                    } else {
                        sb.append(c);
                    }
                } else if (c == '\n') {
                    sb.append(c);
                } else if (Character.isWhitespace(c)) {
                    sb.append(' ');
                } else {
                    sb.append(c);
                }
                pos++;
            }
            expect(']');
            return sb.toString();
        }

        void expect(char c) throws SgfParsingException {
            if (pos >= input.length() || input.charAt(pos) != c) {
                throw new SgfParsingException("expected " + c);
            }
            pos++;
        }
    }
}
```

