```go
package say

import "strings"

var small = []string{
        "zero", "one", "two", "three", "four", "five", "six", "seven", "eight", "nine",
        "ten", "eleven", "twelve", "thirteen", "fourteen", "fifteen", "sixteen",
        "seventeen", "eighteen", "nineteen",
}

var tens = []string{
        "", "", "twenty", "thirty", "forty", "fifty", "sixty", "seventy", "eighty", "ninety",
}

func sayChunk(n int64) string {
        if n == 0 {
                return ""
        }
        if n >= 100 {
                h := n / 100
                r := n % 100
                res := small[h] + " hundred"
                if r > 0 {
                        res += " " + sayChunk(r)
                }
                return res
        }
        if n < 20 {
                return small[n]
        }
        t := n / 10
        o := n % 10
        res := tens[t]
        if o > 0 {
                res += "-" + small[o]
        }
        return res
}

func Say(n int64) (string, bool) {
        if n < 0 || n > 999999999999 {
                return "", false
        }
        if n == 0 {
                return "zero", true
        }

        var parts []string
        scales := []struct {
                val    int64
                suffix string
        }{
                {1000000000, "billion"},
                {1000000, "million"},
                {1000, "thousand"},
        }

        for _, s := range scales {
                if n >= s.val {
                        count := n / s.val
                        parts = append(parts, sayChunk(count)+" "+s.suffix)
                        n %= s.val
                }
        }
        if n > 0 {
                parts = append(parts, sayChunk(n))
        }

        return strings.Join(parts, " "), true
}
```

