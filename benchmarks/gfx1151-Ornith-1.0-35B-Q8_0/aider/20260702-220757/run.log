GoCounting.java
```java
import java.awt.Point;
import java.util.Collections;
import java.util.HashMap;
import java.util.HashSet;
import java.util.LinkedList;
import java.util.Map;
import java.util.Queue;
import java.util.Set;

class GoCounting {

    private final char[][] board;
    private final int width;
    private final int height;

    GoCounting(String board) {
        if (board == null || board.isEmpty()) {
            this.board = new char[0][0];
            this.width = 0;
            this.height = 0;
            return;
        }
        String[] rows = board.split("\n");
        this.height = rows.length;
        this.width = rows[0].length();
        this.board = new char[height][width];
        for (int y = 0; y < height; y++) {
            String row = rows[y];
            for (int x = 0; x < width; x++) {
                this.board[y][x] = row.charAt(x);
            }
        }
    }

    private void validateCoord(int x, int y) {
        if (x < 0 || x >= width || y < 0 || y >= height) {
            throw new IllegalArgumentException("Invalid coordinate");
        }
    }

    Player getTerritoryOwner(int x, int y) {
        validateCoord(x, y);
        if (board[y][x] != ' ') {
            return Player.NONE;
        }
        Set<Point> territory = getTerritory(x, y);
        return territory.isEmpty() ? Player.NONE : determineOwner(territory);
    }

    Set<Point> getTerritory(int x, int y) {
        validateCoord(x, y);
        if (board[y][x] != ' ') {
            return Collections.emptySet();
        }
        Set<Point> territory = new HashSet<>();
        Set<Point> visited = new HashSet<>();
        Queue<Point> queue = new LinkedList<>();
        queue.add(new Point(x, y));
        visited.add(new Point(x, y));

        int[] dx = {0, 0, 1, -1};
        int[] dy = {1, -1, 0, 0};

        while (!queue.isEmpty()) {
            Point p = queue.poll();
            territory.add(p);
            for (int i = 0; i < 4; i++) {
                int nx = p.x + dx[i];
                int ny = p.y + dy[i];
                if (nx >= 0 && nx < width && ny >= 0 && ny < height) {
                    if (board[ny][nx] == ' ' && !visited.contains(new Point(nx, ny))) {
                        visited.add(new Point(nx, ny));
                        queue.add(new Point(nx, ny));
                    }
                }
            }
        }
        return territory;
    }

    private Player determineOwner(Set<Point> territory) {
        Set<Player> owners = new HashSet<>();
        int[] dx = {0, 0, 1, -1};
        int[] dy = {1, -1, 0, 0};
        for (Point p : territory) {
            for (int i = 0; i < 4; i++) {
                int nx = p.x + dx[i];
                int ny = p.y + dy[i];
                if (nx >= 0 && nx < width && ny >= 0 && ny < height) {
                    char c = board[ny][nx];
                    if (c == 'B') owners.add(Player.BLACK);
                    else if (c == 'W') owners.add(Player.WHITE);
                }
            }
        }
        if (owners.size() == 1) {
            return owners.iterator().next();
        }
        return Player.NONE;
    }

    Map<Player, Set<Point>> getTerritories() {
        Map<Player, Set<Point>> result = new HashMap<>();
        result.put(Player.BLACK, new HashSet<>());
        result.put(Player.WHITE, new HashSet<>());
        result.put(Player.NONE, new HashSet<>());

        Set<Point> visited = new HashSet<>();
        for (int y = 0; y < height; y++) {
            for (int x = 0; x < width; x++) {
                if (board[y][x] == ' ' && !visited.contains(new Point(x, y))) {
                    Set<Point> territory = getTerritory(x, y);
                    Player owner = determineOwner(territory);
                    result.get(owner).addAll(territory);
                    visited.addAll(territory);
                }
            }
        }
        return result;
    }
}
