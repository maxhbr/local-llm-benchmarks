```go
package robot

import "fmt"

// See defs.go for other definitions

// Step 1

func Right() {
        // Turn right: N->E, E->S, S->W, W->N
}

func Left() {
        // Turn left: N->W, W->S, S->E, E->N
}

func Advance() {
        // Move forward in current direction
}

func (d Dir) String() string {
        switch d {
        case N:
                return "N"
        case E:
                return "E"
        case S:
                return "S"
        case W:
                return "W"
        }
        return ""
}

// Step 2

func StartRobot(command chan Command, action chan Action) {
        for cmd := range command {
                switch cmd {
                case 'R':
                        action <- right
                case 'L':
                        action <- left
                case 'A':
                        action <- advance
                }
        }
        close(action)
}

func Room(extent Rect, robot Step2Robot, action chan Action, report chan Step2Robot) {
        for act := range action {
                switch act {
                case right:
                        robot.Dir = Dir((int(robot.Dir) + 1) % 4)
                case left:
                        robot.Dir = Dir((int(robot.Dir) + 3) % 4)
                case advance:
                        newX, newY := robot.X, robot.Y
                        switch robot.Dir {
                        case N:
                                newY++
                        case E:
                                newX++
                        case S:
                                newY--
                        case W:
                                newX--
                        }
                        if newX >= extent.Min.X && newX <= extent.Max.X &&
                                newY >= extent.Min.Y && newY <= extent.Max.Y {
                                robot.X, robot.Y = newX, newY
                        }
                }
        }
        report <- robot
}

// Step 3

func StartRobot3(name, script string, action chan Action3, log chan string) {
        for _, c := range script {
                switch c {
                case 'R':
                        action <- Action3{Name: name, Action: right}
                case 'L':
                        action <- Action3{Name: name, Action: left}
                case 'A':
                        action <- Action3{Name: name, Action: advance}
                default:
                        log <- fmt.Sprintf("undefined command: %c", c)
                        return
                }
        }
}

func Room3(extent Rect, robots []Step3Robot, action chan Action3, rep chan []Step3Robot, log chan string) {
        nameToIdx := make(map[string]int)
        for i, r := range robots {
                if r.Name == "" {
                        log <- "unnamed robot"
                } else if _, exists := nameToIdx[r.Name]; exists {
                        log <- fmt.Sprintf("duplicate robot name: %s", r.Name)
                } else {
                        nameToIdx[r.Name] = i
                }
                if r.X < extent.Min.X || r.X > extent.Max.X || r.Y < extent.Min.Y || r.Y > extent.Max.Y {
                        log <- fmt.Sprintf("robot %s placed outside room", r.Name)
                }
                for j := 0; j < i; j++ {
                        if robots[j].X == r.X && robots[j].Y == r.Y {
                                log <- fmt.Sprintf("robots at same place: %s and %s", robots[j].Name, r.Name)
                        }
                }
        }

        for a3 := range action {
                idx, exists := nameToIdx[a3.Name]
                if !exists {
                        log <- fmt.Sprintf("unknown robot: %s", a3.Name)
                        continue
                }
                r := &robots[idx]
                switch a3.Action {
                case right:
                        r.Dir = Dir((int(r.Dir) + 1) % 4)
                case left:
                        r.Dir = Dir((int(r.Dir) + 3) % 4)
                case advance:
                        newX, newY := r.X, r.Y
                        switch r.Dir {
                        case N:
                                newY++
                        case E:
                                newX++
                        case S:
                                newY--
                        case W:
                                newX--
                        }
                        moved := true
                        if newX < extent.Min.X || newX > extent.Max.X || newY < extent.Min.Y || newY > extent.Max.Y {
                                log <- fmt.Sprintf("robot %s attempted to walk into wall", r.Name)
                                moved = false
                        } else {
                                for i, other := range robots {
                                        if i != idx && other.X == newX && other.Y == newY {
                                                log <- fmt.Sprintf("robot %s attempted to walk into robot %s", r.Name, other.Name)
                                                moved = false
                                                break
                                        }
                                }
                        }
                        if moved {
                                r.X, r.Y = newX, newY
                        }
                }
        }

        rep <- robots
}
```

