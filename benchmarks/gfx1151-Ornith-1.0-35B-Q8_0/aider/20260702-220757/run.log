Here is the refactored version of `markdown.go`. I've restructured it to process the input line-by-line instead of character-by-character, extracted helper functions for inline formatting and header level counting, and replaced the fragile state machine with a clear `switch` statement. I also added comments documenting the refactoring decisions.

markdown.go
```go
package markdown

import (
	"fmt"
	"strings"
)

// Render translates markdown to HTML
func Render(markdown string) string {
	// Refactored: process line by line instead of character by character for clarity.
	lines := strings.Split(markdown, "\n")
	var html strings.Builder
	inList := false

	for _, line := range lines {
		// Apply inline formatting first so headers and list items get formatted correctly
		line = renderInline(line)

		switch {
		case strings.HasPrefix(line, "#"):
			// Close any open list before starting a header
			if inList {
				html.WriteString("</ul>")
				inList = false
			}
			level := countLeadingChars(line, '#')
			content := strings.TrimSpace(line[level:])
			html.WriteString(fmt.Sprintf("<h%d>%s</h%d>", level, content, level))

		case strings.HasPrefix(line, "* "):
			// Open list on first item, then just add list items
			if !inList {
				html.WriteString("<ul>")
				inList = true
			}
			content := strings.TrimSpace(line[2:])
			html.WriteString(fmt.Sprintf("<li>%s</li>", content))

		case line == "":
			// Empty line closes any open list
			if inList {
				html.WriteString("</ul>")
				inList = false
			}

		default:
			// Any other non-empty line closes a list and wraps in a paragraph
			if inList {
				html.WriteString("</ul>")
				inList = false
			}
			html.WriteString(fmt.Sprintf("<p>%s</p>", line))
		}
	}

	// Close any list that remains open at the end of the document
	if inList {
		html.WriteString("</ul>")
	}

	return html.String()
}

// countLeadingChars counts consecutive occurrences of a character at the start of a string.
// Used to determine heading level from leading '#' characters.
func countLeadingChars(s string, c byte) int {
	count := 0
	for _, ch := range s {
		if byte(ch) == c {
			count++
		} else {
			break
		}
	}
	return count
}

// renderInline converts markdown inline syntax to HTML.
// Preserves the original pairing behavior where the first '__' becomes <strong>,
// the second becomes </strong>, and similarly for '_' with <em>.
func renderInline(s string) string {
	s = strings.Replace(s, "__", "<strong>", 1)
	s = strings.Replace(s, "__", "</strong>", 1)
	s = strings.Replace(s, "_", "<em>", 1)
	s = strings.Replace(s, "_", "</em>", 1)
	return s
}
```
