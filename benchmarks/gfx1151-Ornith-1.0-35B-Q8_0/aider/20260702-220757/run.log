def translate(text):
    words = text.split()
    return ' '.join(translate_word(w) for w in words)


def translate_word(word):
    # Rule 1: starts with vowel sound
    if word[0] in 'aeiou' or word.startswith('xr') or word.startswith('yt'):
        return word + 'ay'

    # Find the consonant cluster split point
    i = 0
    while i < len(word):
        if word[i] in 'aeiou':
            # Rule 3: "qu" — the 'u' after 'q' is not a vowel sound
            if word[i] == 'u' and i > 0 and word[i - 1] == 'q':
                i += 1
                continue
            break
        # Rule 4: 'y' after consonants acts as a vowel
        if word[i] == 'y' and i > 0:
            break
        i += 1

    return word[i:] + word[:i] + 'ay'
