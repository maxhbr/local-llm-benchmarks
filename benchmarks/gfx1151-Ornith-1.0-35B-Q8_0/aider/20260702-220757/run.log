        private final String input;
        private int pos;

        Parser(String input) {
            this.input = input;
            this.pos = 0;
        }

        SgfNode parseTree() throws SgfParsingException {
            expect('(');
            SgfNode root = parseNode();
            while (pos < input.length()) {
                char c = input.charAt(pos);
                if (c == ';') {
                    root.addChild(parseNode());
                } else if (c == '(') {
                    root.addChild(parseTree());
                } else if (c == ')') {
                    break;
                } else {
