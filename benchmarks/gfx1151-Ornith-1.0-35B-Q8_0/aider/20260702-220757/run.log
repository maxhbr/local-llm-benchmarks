public static class Cell<T> {
    List<ComputeCell<T>> listeners = new ArrayList<>();
    T getValue() { ... }
}

public static class InputCell<T> extends Cell<T> {
    T value;
    void setValue(T newValue) {
        if (!Objects.equals(value, newValue)) {
            value = newValue;
            for (ComputeCell<T> listener : listeners) {
                listener.propagate();
            }
        }
    }
}

public static class ComputeCell<T> extends Cell<T> {
    Function<List<T>, T> function;
    List<Cell<T>> inputCells;
    T value;
    List<Consumer<T>> callbacks = new ArrayList<>();
    
    ComputeCell(Function<List<T>, T> function, List<Cell<T>> cells) {
        this.function = function;
        this.inputCells = cells;
        // compute initial value
        this.value = function.apply(getValues(cells));
        // register as listener on all input cells
        for (Cell<T> cell : cells) {
            cell.listeners.add(this);
        }
    }
    
    void propagate() {
        T newValue = function.apply(getValues(inputCells));
        if (!Objects.equals(value, newValue)) {
            value = newValue;
            for (ComputeCell<T> listener : listeners) {
                listener.propagate();
            }
        }
    }
    
    void addCallback(Consumer<T> callback) {
        callbacks.add(callback);
    }
    
    void removeCallback(Consumer<T> callback) {
        callbacks.remove(callback);
    }
    
    void fireCallbacks(T oldValue, T newValue) {
        if (!Objects.equals(oldValue, newValue)) {
            for (Consumer<T> callback : callbacks) {
                callback.accept(newValue);
            }
        }
    }
}
