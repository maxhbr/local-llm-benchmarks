#include <ctime>
#include <string>
#include <sstream>
#include <iomanip>

namespace meetup {

int get_day_of_week(int year, int month, int day) {
    struct tm tm = {};
    tm.tm_year = year - 1900;
    tm.tm_mon = month - 1;
    tm.tm_mday = day;
    tm.tm_hour = 12;
    tm.tm_isdst = 0;
    mktime(&tm);
    return tm.tm_wday;
}

std::string schedule_to_date(int year, int month, const std::string& schedule, const std::string& weekday) {
    int target_wday = -1;
    if (weekday == "Monday") target_wday = 1;
    else if (weekday == "Tuesday") target_wday = 2;
    else if (weekday == "Wednesday") target_wday = 3;
    else if (weekday == "Thursday") target_wday = 4;
    else if (weekday == "Friday") target_wday = 5;
    else if (weekday == "Saturday") target_wday = 6;
    else if (weekday == "Sunday") target_wday = 0;
    
    int start_day, end_day;
    
    if (schedule == "teenth") {
        start_day = 13;
        end_day = 19;
    } else if (schedule == "last") {
        int days_in_month[] = {31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31};
        int dim = days_in_month[month - 1];
        if (month == 2 && ((year % 4 == 0 && year % 100 != 0) || year % 400 == 0)) {
            dim = 29;
        }
        start_day = dim - 6;
        end_day = dim;
    } else {
        int week_num;
        if (schedule == "first") week_num = 0;
        else if (schedule == "second") week_num = 1;
        else if (schedule == "third") week_num = 2;
        else if (schedule == "fourth") week_num = 3;
        start_day = week_num * 7 + 1;
        end_day = start_day + 6;
    }
    
    for (int day = start_day; day <= end_day; day++) {
        if (get_day_of_week(year, month, day) == target_wday) {
            std::ostringstream oss;
            oss << year << "-" << std::setfill('0') << std::setw(2) << month << "-" << std::setfill('0') << std::setw(2) << day;
            return oss.str();
        }
    }
    
    return "";
}

}  // namespace meetup
```

