import java.util.ArrayList;
import java.util.HashMap;
import java.util.List;
import java.util.Map;
import java.util.Objects;
import java.util.function.Consumer;
import java.util.function.Function;

public class React {

    private static final List<ComputeCell<?>> ALL_COMPUTE_CELLS = new ArrayList<>();

    public static class Cell<T> {
        final List<ComputeCell<T>> listeners = new ArrayList<>();

        public T getValue() {
            throw new UnsupportedOperationException("Please implement the Cell.getValue() method");
        }
    }

    public static class InputCell<T> extends Cell<T> {
        T value;

        InputCell(T initialValue) {
            this.value = initialValue;
        }

        public void setValue(T newValue) {
            if (!Objects.equals(value, newValue)) {
                // Save old values of all compute cells
                Map<ComputeCell<?>, Object> oldValues = new HashMap<>();
                for (ComputeCell<?> cc : ALL_COMPUTE_CELLS) {
                    oldValues.put(cc, cc.getValue());
                }

                value = newValue;

                // Propagate
                for (ComputeCell<T> listener : listeners) {
                    listener.propagate();
                }

                // Fire callbacks
                for (ComputeCell<?> cc : ALL_COMPUTE_CELLS) {
                    cc.fireCallbacks(oldValues.get(cc));
                }
            }
        }
    }

    public static class ComputeCell<T> extends Cell<T> {
        final Function<List<T>, T> function;
        final List<Cell<T>> inputCells;
        T value;
        final List<Consumer<T>> callbacks = new ArrayList<>();

        ComputeCell(Function<List<T>, T> function, List<Cell<T>> cells) {
            this.function = function;
            this.inputCells = cells;
            this.value = function.apply(getValues(cells));
            ALL_COMPUTE_CELLS.add(this);
            for (Cell<T> cell : cells) {
                ((Cell<T>) cell).listeners.add(this);
            }
        }

        public T getValue() {
            return value;
        }

        void propagate() {
            T newValue = function.apply(getValues(inputCells));
            if (!Objects.equals(value, newValue)) {
                value = newValue;
                for (ComputeCell<T> listener : listeners) {
                    listener.propagate();
                }
            }
        }

        void fireCallbacks(Object oldValue) {
            if (!Objects.equals(oldValue, value)) {
                for (Consumer<T> callback : callbacks) {
                    callback.accept(value);
                }
            }
        }

        public void addCallback(Consumer<T> callback) {
            callbacks.add(callback);
        }

        public void removeCallback(Consumer<T> callback) {
            callbacks.remove(callback);
        }
    }

    private static <T> List<T> getValues(List<Cell<T>> cells) {
        List<T> result = new ArrayList<>();
        for (Cell<T> cell : cells) {
            result.add(cell.getValue());
        }
        return result;
    }

    public static <T> InputCell<T> inputCell(T initialValue) {
