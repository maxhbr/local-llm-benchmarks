```go
package robot

import "fmt"

// See defs.go for other definitions

// Step 1
// Define N, E, S, W here.
const (
	N Dir = iota
	E
	S
	W
)

var (
	currentDir = N
	currentPos Point
)

func Right() {
	currentDir = Dir(int(currentDir+1) % 4)
}

func Left() {
	currentDir = Dir(int(currentDir+3) % 4)
}

func Advance() {
	switch currentDir {
	case N:
		currentPos.Y++
	case E:
		currentPos.X++
	case S:
		currentPos.Y--
	case W:
		currentPos.X--
	}
}

func (d Dir) String() string {
	return []string{"N", "E", "S", "W"}[d]
}

// Step 2
// Define Action type here.
type Action struct {
	Dir     Dir
	Advance bool
}

func StartRobot(command chan Command, action chan Action) {
	dir := N
	for cmd := range command {
		switch cmd {
		case Right:
			dir = Dir(int(dir+1) % 4)
			action <- Action{Dir: dir}
		case Left:
			dir = Dir(int(dir+3) % 4)
			action <- Action{Dir: dir}
		case Advance:
			action <- Action{Dir: dir, Advance: true}
		}
	}
}

func Room(extent Rect, robot Step2Robot, action chan Action, report chan Step2Robot) {
	for act := range action {
		if act.Advance {
			nextX, nextY := robot.X, robot.Y
			switch act.Dir {
			case N:
				nextY++
			case E:
				nextX++
			case S:
				nextY--
			case W:
				nextX--
			}
			if nextX >= extent.Min.X && nextX <= extent.Max.X &&
				nextY >= extent.Min.Y && nextY <= extent.Max.Y {
				robot.X = nextX
				robot.Y = nextY
			}
		} else {
			robot.Dir = act.Dir
		}
	}
	report <- robot
}

// Step 3
// Define Action3 type here.
type Action3 struct {
	Name    string
	Dir     Dir
	Advance bool
}

func StartRobot3(name, script string, action chan Action3, log chan string) {
	dir := N
	for _, cmd := range script {
		switch cmd {
		case 'R':
			dir = Dir(int(dir+1) % 4)
			action <- Action3{Name: name, Dir: dir}
		case 'L':
			dir = Dir(int(dir+3) % 4)
			action <- Action3{Name: name, Dir: dir}
		case 'A':
			action <- Action3{Name: name, Dir: dir, Advance: true}
		default:
			log <- fmt.Sprintf("undefined command in script for robot %s", name)
		}
	}
}

func Room3(extent Rect, robots []Step3Robot, action chan Action3, rep chan []Step3Robot, log chan string) {
	for _, r := range robots {
		if r.Name == "" {
			log <- "robot without a name"
		}
	}
	for i := 0; i < len(robots); i++ {
		for j := i + 1; j < len(robots); j++ {
			if robots[i].Name == "" || robots[j].Name == "" {
				continue
			}
			if robots[i].Name == robots[j].Name {
				log <- fmt.Sprintf("duplicate robot name %s", robots[i].Name)
			}
			if robots[i].X == robots[j].X && robots[i].Y == robots[j].Y {
				log <- "robots placed at the same place"
			}
		}
	}
	for _, r := range robots {
		if r.Name == "" {
			continue
		}
		if r.X < extent.Min.X || r.X > extent.Max.X || r.Y < extent.Min.Y || r.Y > extent.Max.Y {
			log <- "robot placed outside of room"
		}
	}

	nameToIdx := make(map[string]int)
	for i, r := range robots {
		if r.Name != "" {
			nameToIdx[r.Name] = i
		}
	}

	for act := range action {
		idx, ok := nameToIdx[act.Name]
		if !ok {
			log <- fmt.Sprintf("action from unknown robot %s", act.Name)
			continue
		}
		r := &robots[idx]
		if act.Advance {
			nextX, nextY := r.X, r.Y
			switch act.Dir {
			case N:
				nextY++
			case E:
				nextX++
			case S:
				nextY--
			case W:
				nextX--
			}
			inRoom := nextX >= extent.Min.X && nextX <= extent.Max.X &&
				nextY >= extent.Min.Y && nextY <= extent.Max.Y
			if !inRoom {
				log <- fmt.Sprintf("robot %s attempted to advance into a wall", act.Name)
				continue
			}
			collision := false
			for i, other := range robots {
				if i == idx || other.Name == "" {
					continue
				}
				if other.X == nextX && other.Y == nextY {
					collision = true
					break
				}
			}
			if collision {
				log <- fmt.Sprintf("robot %s attempted to advance into another robot", act.Name)
				continue
			}
			r.X = nextX
			r.Y = nextY
		} else {
			r.Dir = act.Dir
		}
	}
	rep <- robots
}
