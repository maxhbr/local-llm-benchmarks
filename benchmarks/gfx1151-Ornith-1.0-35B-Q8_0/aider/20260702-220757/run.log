#if !defined(MEETUP_H)
#define MEETUP_H

#include <string>
#include <ctime>
#include <boost/date_time/gregorian/gregorian.hpp>

namespace meetup {

class scheduler {
public:
    scheduler(boost::gregorian::month m, int y) : month_(m), year_(y) {}

    boost::gregorian::date monteenth() const { return day("teenth", "Monday"); }
    boost::gregorian::date tuesteenth() const { return day("teenth", "Tuesday"); }
    boost::gregorian::date wednesteenth() const { return day("teenth", "Wednesday"); }
    boost::gregorian::date thursteenth() const { return day("teenth", "Thursday"); }
    boost::gregorian::date friteenth() const { return day("teenth", "Friday"); }
    boost::gregorian::date saturteenth() const { return day("teenth", "Saturday"); }
    boost::gregorian::date sunteenth() const { return day("teenth", "Sunday"); }

    boost::gregorian::date first_monday() const { return day("first", "Monday"); }
    boost::gregorian::date first_tuesday() const { return day("first", "Tuesday"); }
    boost::gregorian::date first_wednesday() const { return day("first", "Wednesday"); }
    boost::gregorian::date first_thursday() const { return day("first", "Thursday"); }
    boost::gregorian::date first_friday() const { return day("first", "Friday"); }
    boost::gregorian::date first_saturday() const { return day("first", "Saturday"); }
    boost::gregorian::date first_sunday() const { return day("first", "Sunday"); }

    boost::gregorian::date second_monday() const { return day("second", "Monday"); }
    boost::gregorian::date second_tuesday() const { return day("second", "Tuesday"); }
    boost::gregorian::date second_wednesday() const { return day("second", "Wednesday"); }
    boost::gregorian::date second_thursday() const { return day("second", "Thursday"); }
    boost::gregorian::date second_friday() const { return day("second", "Friday"); }
    boost::gregorian::date second_saturday() const { return day("second", "Saturday"); }
    boost::gregorian::date second_sunday() const { return day("second", "Sunday"); }

    boost::gregorian::date third_monday() const { return day("third", "Monday"); }
    boost::gregorian::date third_tuesday() const { return day("third", "Tuesday"); }
    boost::gregorian::date third_wednesday() const { return day("third", "Wednesday"); }
    boost::gregorian::date third_thursday() const { return day("third", "Thursday"); }
    boost::gregorian::date third_friday() const { return day("third", "Friday"); }
    boost::gregorian::date third_saturday() const { return day("third", "Saturday"); }
    boost::gregorian::date third_sunday() const { return day("third", "Sunday"); }

    boost::gregorian::date fourth_monday() const { return day("fourth", "Monday"); }
    boost::gregorian::date fourth_tuesday() const { return day("fourth", "Tuesday"); }
    boost::gregorian::date fourth_wednesday() const { return day("fourth", "Wednesday"); }
    boost::gregorian::date fourth_thursday() const { return day("fourth", "Thursday"); }
    boost::gregorian::date fourth_friday() const { return day("fourth", "Friday"); }
    boost::gregorian::date fourth_saturday() const { return day("fourth", "Saturday"); }
    boost::gregorian::date fourth_sunday() const { return day("fourth", "Sunday"); }

    boost::gregorian::date last_monday() const { return day("last", "Monday"); }
    boost::gregorian::date last_tuesday() const { return day("last", "Tuesday"); }
    boost::gregorian::date last_wednesday() const { return day("last", "Wednesday"); }
    boost::gregorian::date last_thursday() const { return day("last", "Thursday"); }
    boost::gregorian::date last_friday() const { return day("last", "Friday"); }
    boost::gregorian::date last_saturday() const { return day("last", "Saturday"); }
    boost::gregorian::date last_sunday() const { return day("last", "Sunday"); }

private:
    boost::gregorian::month month_;
    int year_;

    boost::gregorian::date day(const std::string& schedule, const std::string& weekday) const {
        int target_wday = -1;
        if (weekday == "Monday") target_wday = 1;
        else if (weekday == "Tuesday") target_wday = 2;
        else if (weekday == "Wednesday") target_wday = 3;
        else if (weekday == "Thursday") target_wday = 4;
        else if (weekday == "Friday") target_wday = 5;
        else if (weekday == "Saturday") target_wday = 6;
        else if (weekday == "Sunday") target_wday = 0;

        int start_day = 0;
        int end_day = 0;

        if (schedule == "teenth") {
            start_day = 13;
            end_day = 19;
        } else if (schedule == "last") {
            static const int days_in_month[] = {31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31};
            int dim = days_in_month[static_cast<int>(month_) - 1];
            if (static_cast<int>(month_) == 2 && ((year_ % 4 == 0 && year_ % 100 != 0) || year_ % 400 == 0)) {
                dim = 29;
            }
            start_day = dim - 6;
            end_day = dim;
        } else {
            int week_num = 0;
            if (schedule == "first") week_num = 0;
            else if (schedule == "second") week_num = 1;
            else if (schedule == "third") week_num = 2;
            else if (schedule == "fourth") week_num = 3;
            start_day = week_num * 7 + 1;
            end_day = start_day + 6;
        }

        for (int d = start_day; d <= end_day; ++d) {
            if (get_day_of_week(year_, static_cast<int>(month_), d) == target_wday) {
                return boost::gregorian::date(year_, static_cast<int>(month_), d);
            }
        }

        return boost::gregorian::date();
    }

    int get_day_of_week(int year, int month, int day) const {
        struct tm tm = {};
        tm.tm_year = year - 1900;
        tm.tm_mon = month - 1;
        tm.tm_mday = day;
        tm.tm_hour = 12;
        tm.tm_isdst = 0;
        mktime(&tm);
        return tm.tm_wday;
    }
};

}  // namespace meetup

#endif // MEETUP_H
```
