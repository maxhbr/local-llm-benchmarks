bowling.py
```python
class BowlingGame:
    def __init__(self):
        self._rolls = []

    def roll(self, pins):
        if pins < 0:
            raise ValueError("pins cannot be negative")
        if pins > 10:
            raise ValueError("pins cannot exceed 10")
        
        if self._game_over():
            if self._in_tenth_frame():
                frame_rolls = self._tenth_frame_rolls()
                if len(frame_rolls) == 2:
                    first, second = frame_rolls
                    if first != 10 and first + second < 10:
                        raise IndexError("cannot throw bonus with an open tenth frame")
            raise ValueError("cannot roll after game is over")
        
        frame, rolls_in_frame = self._current_frame_info()
        
        if frame < 9:
            if rolls_in_frame == 1:
                if self._rolls[-1] + pins > 10:
                    raise ValueError("pins cannot exceed 10 in a frame")
        else:
            # 10th frame
            if rolls_in_frame == 1:
                if self._rolls[-1] != 10 and self._rolls[-1] + pins > 10:
                    raise ValueError("pins cannot exceed 10 in a frame")
            elif rolls_in_frame == 2:
                if self._rolls[-2] == 10 and self._rolls[-1] != 10 and self._rolls[-1] + pins > 10:
                    raise ValueError("pins cannot exceed 10 in a frame")
        
        self._rolls.append(pins)

    def _current_frame_info(self):
        rolls = self._rolls
        idx = 0
        for frame in range(10):
            if idx >= len(rolls):
                return frame, 0
            if frame < 9:
                if rolls[idx] == 10:
                    idx += 1
                else:
                    if idx + 1 >= len(rolls):
                        return frame, 1
                    idx += 2
            else:
                count = len(rolls) - idx
                return frame, count
        return 10, 0

    def _tenth_frame_rolls(self):
        idx = 0
        for _ in range(9):
            if idx >= len(self._rolls):
                return []
            idx += 1 if self._rolls[idx] == 10 else 2
        return self._rolls[idx:]

    def _in_tenth_frame(self):
        return len(self._tenth_frame_rolls()) > 0

    def score(self):
        if not self._game_over():
            raise ValueError("score cannot be taken until the end of the game")
        total = 0
        roll_idx = 0
        for _ in range(10):
            if self._rolls[roll_idx] == 10:
                total += 10 + self._rolls[roll_idx+1] + self._rolls[roll_idx+2]
                roll_idx += 1
            elif self._rolls[roll_idx] + self._rolls[roll_idx+1] == 10:
                total += 10 + self._rolls[roll_idx+2]
                roll_idx += 2
            else:
                total += self._rolls[roll_idx] + self._rolls[roll_idx+1]
                roll_idx += 2
        return total

    def _game_over(self):
        rolls = self._rolls
        frame = 0
        idx = 0
        while frame < 10:
            if idx >= len(rolls):
                return False
            if frame < 9:
                if rolls[idx] == 10:
                    idx += 1
                else:
                    if idx + 1 >= len(rolls):
                        return False
                    if rolls[idx] + rolls[idx+1] > 10:
                        raise ValueError("pins cannot exceed 10 in a frame")
                    idx += 2
                frame += 1
            else:
                if idx + 1 >= len(rolls):
                    return False
                first = rolls[idx]
                second = rolls[idx+1]
                if first == 10:
                    if idx + 2 >= len(rolls):
                        return False
                    return idx + 3 <= len(rolls)
                else:
                    if first + second > 10:
                        raise ValueError("pins cannot exceed 10 in a frame")
                    if first + second == 10:
                        return idx + 3 <= len(rolls)
                    else:
                        return True
        return False
```
