use std::cell::RefCell;
use std::collections::HashSet;
use std::sync::atomic::{AtomicU64, Ordering};
use std::sync::Mutex;
use std::time::SystemTime;

static USED_NAMES: Mutex<HashSet<String>> = Mutex::new(HashSet::new());
static COUNTER: AtomicU64 = AtomicU64::new(0);

pub struct Robot {
    name: RefCell<Option<String>>,
}

impl Robot {
    pub fn new() -> Self {
        Robot {
            name: RefCell::new(None),
        }
    }

    pub fn name(&self) -> &str {
        let mut name_opt = self.name.borrow_mut();
        if name_opt.is_none() {
            *name_opt = Some(generate_unique_name());
        }
        name_opt.as_ref().unwrap()
    }

    pub fn reset_name(&mut self) {
        *self.name.borrow_mut() = None;
    }
}

fn generate_unique_name() -> String {
    loop {
        let name = generate_random_name();
        let mut used = USED_NAMES.lock().unwrap();
        if used.insert(name.clone()) {
            return name;
        }
    }
}

fn generate_random_name() -> String {
    let time_nanos = SystemTime::now()
        .duration_since(SystemTime::UNIX_EPOCH)
        .unwrap()
        .as_nanos() as u64;
    let counter = COUNTER.fetch_add(1, Ordering::Relaxed);
    let mut state = time_nanos ^ counter;

    let c1 = ((state % 26) as u8) + b'A';
    state = state.wrapping_mul(6364136223846793005).wrapping_add(1442695040888963407);

    let c2 = ((state % 26) as u8) + b'A';
    state = state.wrapping_mul(6364136223846793005).wrapping_add(1442695040888963407);

    let d1 = ((state % 10) as u8) + b'0';
    state = state.wrapping_mul(6364136223846793005).wrapping_add(1442695040888963407);

    let d2 = ((state % 10) as u8) + b'0';
    state = state.wrapping_mul(6364136223846793005).wrapping_add(1442695040888963407);

    let d3 = ((state % 10) as u8) + b'0';

    format!("{}{}{}{}{}", c1 as char, c2 as char, d1 as char, d2 as char, d3 as char)
}
```
