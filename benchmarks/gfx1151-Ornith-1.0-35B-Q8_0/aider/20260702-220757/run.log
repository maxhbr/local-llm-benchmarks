        chain.add(first);
        used[0] = true;
        if (buildChain(inputDominoes, used, chain)) {
            return chain;
        }
        
        // Try flipped first domino
        chain.set(0, new Domino(first.right, first.left));
        if (buildChain(inputDominoes, used, chain)) {
            return chain;
        }
        
        throw new ChainNotFoundException("No chain can be formed");
    }
    
    private boolean buildChain(List<Domino> input, boolean[] used, List<Domino> chain) {
        if (chain.size() == input.size()) {
            // Check if closed
            return chain.get(0).left == chain.get(chain.size() - 1).right;
        }
        
        int currentEnd = chain.get(chain.size() - 1).right;
