#!/usr/bin/env node

const fs = require('fs');
const path = require('path');

/**
 * Reads the given file and returns lines.
 *
 * This function works regardless of POSIX (LF) or windows (CRLF) encoding.
 *
 * @param {string} file path to file
 * @returns {string[]} the lines
 */
function readLines(file) {
  const data = fs.readFileSync(path.resolve(file), { encoding: 'utf-8' });
  return data.split(/\r?\n/);
}

const VALID_OPTIONS = [
  'n', // add line numbers
  'l', // print file names where pattern is found
  'i', // ignore case
  'v', // reverse files results
  'x', // match entire line
];

const ARGS = process.argv;

// Parse arguments
const args = ARGS.slice(2);
const flags = [];
let searchString = '';
const files = [];

let idx = 0;
while (idx < args.length && args[idx].startsWith('-')) {
  const flagStr = args[idx].slice(1);
  for (const ch of flagStr) {
    if (VALID_OPTIONS.includes(ch)) {
      flags.push(ch);
    }
  }
  idx++;
}
if (idx < args.length) {
  searchString = args[idx++];
}
while (idx < args.length) {
  files.push(args[idx++]);
}

const opts = {
  n: flags.includes('n'),
  l: flags.includes('l'),
  i: flags.includes('i'),
  v: flags.includes('v'),
  x: flags.includes('x'),
};

for (const file of files) {
  const lines = readLines(file);
  let found = false;
  
  for (let lineNum = 1; lineNum <= lines.length; lineNum++) {
    const line = lines[lineNum - 1];
    let match;
    
    if (opts.x) {
      match = opts.i 
        ? line.toLowerCase() === searchString.toLowerCase()
        : line === searchString;
    } else {
      match = opts.i
        ? line.toLowerCase().includes(searchString.toLowerCase())
        : line.includes(searchString);
    }
    
    if (opts.v) {
      match = !match;
    }
    
    if (match) {
      found = true;
      if (opts.l) {
        console.log(file);
        break;
      }
      
      let out = '';
      if (files.length > 1) out += file + ':';
      if (opts.n) out += lineNum + ':';
      out += line;
      console.log(out);
    }
  }
}
```

