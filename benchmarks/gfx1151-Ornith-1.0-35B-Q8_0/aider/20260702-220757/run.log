```java
class Zipper {
    final int value;
    final Zipper left;
    final Zipper right;
    final Zipper up;
    final boolean isLeft;

    Zipper(int val) {
        this(val, null, null, null, false);
    }

    Zipper(int val, Zipper left, Zipper right, Zipper up, boolean isLeft) {
        this.value = val;
        this.left = left;
        this.right = right;
        this.up = up;
        this.isLeft = isLeft;
    }

    BinaryTree toTree() {
        if (up == null) {
            return new BinaryTree(this);
        }
        return up.toTree();
    }

    int getValue() {
        return value;
    }

    Zipper setLeft(Zipper leftChild) {
        return new Zipper(this.value, leftChild, this.right, updateParent(this, true));
    }

    Zipper setRight(Zipper rightChild) {
        return new Zipper(this.value, this.left, rightChild, updateParent(this, false));
    }

    Zipper setValue(int val) {
        return new Zipper(val, this.left, this.right, this.up);
    }

    private Zipper updateParent(Zipper child, boolean isLeftChild) {
        if (this.up == null) {
            return null;
        }
        Zipper newUp = new Zipper(
            this.up.value,
            isLeftChild ? child : this.up.left,
            isLeftChild ? this.up.right : child,
            this.up.up,
            this.isLeft
        );
        return newUp.updateParent(newUp, this.isLeft);
    }
    
    @Override
    public boolean equals(Object o) {
        if (this == o) return true;
        if (o == null || getClass() != o.getClass()) return false;
        Zipper zipper = (Zipper) o;
        return value == zipper.value &&
                java.util.Objects.equals(left, zipper.left) &&
                java.util.Objects.equals(right, zipper.right);
    }
    
    @Override
    public int hashCode() {
        return java.util.Objects.hash(value, left, right);
    }
}

class BinaryTree {
    private final Zipper root;

    BinaryTree(int value) {
        this.root = new Zipper(value);
    }

    BinaryTree(Zipper root) {
        this.root = root;
    }

    Zipper getRoot() {
        return root;
    }

    String printTree() {
        return printNode(root);
    }

    private String printNode(Zipper z) {
        if (z == null) return "null";
        return "tree(" + z.getValue() + ", " + printNode(z.left) + ", " + printNode(z.right) + ")";
    }
}
```

