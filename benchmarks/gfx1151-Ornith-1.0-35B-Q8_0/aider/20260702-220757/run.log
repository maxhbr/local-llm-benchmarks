```go
package robot

import "fmt"

// See defs.go for other definitions

// Step 1

func Right() {
        // Uses package-level state
}

func Left() {
        // Uses package-level state
}

func Advance() {
        // Uses package-level state
}

func (d Dir) String() string {
        switch d {
        case N:
                return "N"
        case E:
                return "E"
        case S:
                return "S"
        case W:
                return "W"
        }
        return ""
}

// Step 2

func StartRobot(command chan Command, action chan Action) {
        for cmd := range command {
                switch cmd {
                case 'R':
                        action <- right
                case 'L':
                        action <- left
                case 'A':
                        action <- advance
                }
        }
        close(action)
}

func Room(extent Rect, robot Step2Robot, action chan Action, report chan Step2Robot) {
        for act := range action {
                switch act {
                case right:
                        robot.Dir = Dir((int(robot.Dir) + 1) % 4)
                case left:
                        robot.Dir = Dir((int(robot.Dir) + 3) % 4)
                case advance:
                        newX, newY := robot.X, robot.Y
                        switch robot.Dir {
                        case N:
                                newY++
                        case E:
                                newX++
                        case S:
                                newY--
                        case W:
                                newX--
                        }
                        if newX >= extent.Min.X && newX <= extent.Max.X &&
                                newY >= extent.Min.Y && newY <= extent.Max.Y {
                                robot.X, robot.Y = newX, newY
                        }
                }
        }
        report <- robot
}

// Step 3

func StartRobot3(name, script string, action chan Action3, log chan string) {
        for _, c := range script {
                a3 := Action3{
                        Name: name,
                        Pos:  Point{}, // Will be updated by room
                }
                switch c {
                case 'R':
                        a3.Action = right
                case 'L':
                        a3.Action = left
                case 'A':
                        a3.Action = advance
                default:
                        log <- fmt.Sprintf("undefined command: %c", c)
                        return
                }
                action <- a3
        }
}

func Room3(extent Rect, robots []Step3Robot, action chan Action3, rep chan []Step3Robot, log chan string) {
        // Build map of name -> index
        nameToIdx := make(map[string]int)
        for i, r := range robots {
                if r.Name == "" {
                        log <- "unnamed robot"
                } else {
                        if _, exists := nameToIdx[r.Name]; exists {
                                log <- fmt.Sprintf("duplicate robot name: %s", r.Name)
                        } else {
                                nameToIdx[r.Name] = i
                        }
                }
                // Check if robot is in the room
                if r.X < extent.Min.X || r.X > extent.Max.X || r.Y < extent.Min.Y || r.Y > extent.Max.Y {
                        log <- fmt.Sprintf("robot %s placed outside room", r.Name)
                }
                // Check if robot is at same place as another
                for j := 0; j < i; j++ {
                        if robots[j].X == r.X && robots[j].Y == r.Y {
                                log <- fmt.Sprintf("robot %s placed at same place as %s", r.Name, robots[j].Name)
                        }
                }
        }

        for a3 := range action {
                idx, exists := nameToIdx[a3.Name]
                if !exists {
                        log <- fmt.Sprintf("unknown robot name: %s", a3.Name)
                        continue
                }
                robot := &robots[idx]
                a3.Pos = Point{X: robot.X, Y: robot.Y}
                a3.Action = a3.Action // copy
                switch a3.Action {
                case right:
                        robot.Dir = Dir((int(robot.Dir) + 1) % 4)
                case left:
                        robot.Dir = Dir((int(robot.Dir) + 3) % 4)
                case advance:
                        newX, newY := robot.X, robot.Y
                        switch robot.Dir {
                        case N:
                                newY++
                        case E:
                                newX++
                        case S:
                                newY--
                        case W:
                                newX--
                        }
                        // Check walls
                        if newX < extent.Min.X || newX > extent.Max.X || newY < extent.Min.Y || newY > extent.Max.Y {
                                log <- fmt.Sprintf("robot %s attempted to walk into wall", robot.Name)
                                continue
                        }
                        // Check other robots
                        collision := false
                        for i, r := range robots {
                                if i != idx && r.X == newX && r.Y == newY {
                                        log <- fmt.Sprintf("robot %s attempted to walk into robot %s", robot.Name, r.Name)
                                        collision = true
                                        break
                                }
                        }
                        if !collision {
                                robot.X, robot.Y = newX, newY
                        }
                }
        }

        rep <- robots
}
```

