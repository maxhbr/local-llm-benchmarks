```
//
// This is only a SKELETON file for the 'Bottle Song' exercise. It's been provided as a
// convenience to get you started writing code faster.
//

const NUMBER_WORDS = [
  'no',
  'one',
  'two',
  'three',
  'four',
  'five',
  'six',
  'seven',
  'eight',
  'nine',
  'ten',
];

const numberToWord = (n) => {
  return NUMBER_WORDS[n];
};

const capitalize = (s) => {
  return s.charAt(0).toUpperCase() + s.slice(1);
};

const bottleLine = (count) => {
  const word = numberToWord(count);
  const bottle = count === 1 ? 'bottle' : 'bottles';
  return `${capitalize(word)} green ${bottle} hanging on the wall,`;
};

const finalLine = (count) => {
  const word = numberToWord(count);
  const bottle = count === 1 ? 'bottle' : 'bottles';
  return `There'll be ${word} green ${bottle} hanging on the wall.`;
};

const verse = (count) => {
  return [
    bottleLine(count),
    bottleLine(count),
    'And if one green bottle should accidentally fall,',
    finalLine(count - 1),
  ];
};

export const recite = (initialBottlesCount, takeDownCount) => {
  const verses = [];
  for (let i = 0; i < takeDownCount; i++) {
    if (verses.length > 0) verses.push('');
    verses.push(...verse(initialBottlesCount - i));
  }
  return verses;
};
