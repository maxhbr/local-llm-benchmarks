class Dominoes {

    public List<Domino> formChain(List<Domino> inputDominoes) throws ChainNotFoundException {
        if (inputDominoes == null || inputDominoes.isEmpty()) {
            return new ArrayList<>();
        }
        
        List<Domino> chain = new ArrayList<>();
        boolean[] used = new boolean[inputDominoes.size()];
        
        // Try starting with each domino, but actually we can just fix the first one
        // because any valid chain can be rotated to start with any domino.
        // However, we still need to try both orientations of the first domino.
        // Wait, fixing the first domino is valid for finding *a* chain.
        
