```python
def transpose(text):
    lines = text.split('\n')
    if not lines:
        return ''
    max_len = max(len(line) for line in lines)
    result = []
    for c in range(max_len):
        # Find the last row that has a character at column c
        r_max = -1
        for r in range(len(lines) - 1, -1, -1):
            if len(lines[r]) > c:
                r_max = r
                break
        if r_max == -1:
            continue
        row_chars = []
        for r in range(r_max + 1):
            if len(lines[r]) > c:
                row_chars.append(lines[r][c])
            else:
                row_chars.append(' ')
        result.append(''.join(row_chars))
    return '\n'.join(result)
```

