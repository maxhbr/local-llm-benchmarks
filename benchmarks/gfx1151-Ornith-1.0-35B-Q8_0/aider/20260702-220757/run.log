                op := tokens[i]
                var nextOp string
                if op == "plus" || op == "minus" {
                        nextOp = op
                        i++
                } else if op == "multiplied" || op == "divided" {
                        if i+1 >= len(tokens) || tokens[i+1] != "by" {
                                return 0, false
                        }
                        if op == "multiplied" {
                                nextOp = "multiplied"
                        } else {
                                nextOp = "divided"
                        }
                        i += 2
                } else {
                        return 0, false
                }

                if i >= len(tokens) {
                        return 0, false
                }
                operand, err := strconv.Atoi(tokens[i])
                if err != nil {
                        return 0, false
                }

                switch nextOp {
                case "plus":
                        result += operand
                case "minus":
                        result -= operand
                case "multiplied":
                        result *= operand
                case "divided":
                        result /= operand
                }
                i++
        }

        return result, true
}
