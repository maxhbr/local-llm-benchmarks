```go
package dominoes

// Define the Domino type here.
type Domino [2]int

func MakeChain(input []Domino) ([]Domino, bool) {
	if len(input) == 0 {
		return []Domino{}, true
	}

	counts := make(map[int]int)
	for _, d := range input {
		counts[d[0]]++
		counts[d[1]]++
	}
	for _, c := range counts {
		if c%2 != 0 {
			return nil, false
		}
	}

	used := make([]bool, len(input))
	var chain []Domino

	var solve func() bool
	solve = func() bool {
		if len(chain) == len(input) {
			return chain[0][0] == chain[len(chain)-1][1]
		}

		lastVal := chain[len(chain)-1][1]
		for i, d := range input {
			if !used[i] {
				if d[0] == lastVal {
					used[i] = true
					chain = append(chain, d)
					if solve() {
						return true
					}
					chain = chain[:len(chain)-1]
					used[i] = false
				}
				if d[1] == lastVal && d[0] != d[1] {
					used[i] = true
					chain = append(chain, Domino{d[1], d[0]})
					if solve() {
						return true
					}
					chain = chain[:len(chain)-1]
					used[i] = false
				}
			}
		}
		return false
	}

	for i := range input {
		used[i] = true
		chain = append(chain, input[i])
		if solve() {
			return chain, true
		}
		chain = chain[:len(chain)-1]
		used[i] = false

		if input[i][0] != input[i][1] {
			used[i] = true
			chain = append(chain, Domino{input[i][1], input[i][0]})
			if solve() {
				return chain, true
			}
			chain = chain[:len(chain)-1]
			used[i] = false
		}
	}

	return nil, false
}
