}

const opts = {
  n: flags.includes('n'),
  l: flags.includes('l'),
  i: flags.includes('i'),
  v: flags.includes('v'),
  x: flags.includes('x'),
};

for (const file of files) {
  let lines;
  try {
    lines = readLines(file);
  } catch (e) {
    continue;
  }

  for (let lineNum = 1; lineNum <= lines.length; lineNum++) {
    const line = lines[lineNum - 1];
    let match;

    if (opts.x) {
      match = opts.i
        ? line.toLowerCase() === searchString.toLowerCase()
        : line === searchString;
    } else {
      match = opts.i
        ? line.toLowerCase().includes(searchString.toLowerCase())
        : line.includes(searchString);
    }

    if (opts.v) {
      match = !match;
    }

