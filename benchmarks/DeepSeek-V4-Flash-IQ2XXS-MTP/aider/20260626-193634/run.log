        let mut prev_lowercase = false;
        for (i, &ch) in word_chars.iter().enumerate() {
            if i == 0 {
                let first = ch.to_uppercase().next().unwrap_or(ch);
                result.push(first);
                prev_lowercase = ch.is_lowercase();
            } else {
                if ch.is_uppercase() && prev_lowercase {
                    result.push(ch);
                    prev_lowercase = false;
                } else {
