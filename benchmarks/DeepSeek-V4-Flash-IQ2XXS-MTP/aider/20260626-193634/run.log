```
//
// This is only a SKELETON file for the 'Twelve Days' exercise. It's been provided as a
// convenience to get you started writing code faster.
//

export const recite = (start, end) => {
  const dayNames = ['first', 'second', 'third', 'fourth', 'fifth', 'sixth', 'seventh', 'eighth', 'ninth', 'tenth', 'eleventh', 'twelfth'];
  const giftPhrases = [
    'a Partridge in a Pear Tree',
    'two Turtle Doves',
    'three French Hens',
    'four Calling Birds',
    'five Gold Rings',
    'six Geese-a-Laying',
    'seven Swans-a-Swimming',
    'eight Maids-a-Milking',
    'nine Ladies Dancing',
    'ten Lords-a-Leaping',
    'eleven Pipers Piping',
    'twelve Drummers Drumming'
  ];

  const startDay = start || 1;
  const endDay = end || startDay;
  const verses = [];
  for (let day = startDay; day <= endDay; day++) {
    const dayName = dayNames[day - 1];
    const gifts = giftPhrases.slice(0, day).reverse();
    const lastGift = gifts.pop();
    let giftsStr;
    if (gifts.length === 0) {
      giftsStr = lastGift;
    } else {
      giftsStr = gifts.join(', ') + ', and ' + lastGift;
    }
    const verse = `On the ${dayName} day of Christmas my true love gave to me: ${giftsStr}.\n`;
    verses.push(verse);
  }
  return verses.join('\n\n');
};
```
