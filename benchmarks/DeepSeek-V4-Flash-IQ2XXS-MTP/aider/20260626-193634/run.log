class Scale:
    def __init__(self, tonic):
        self.tonic = tonic.strip()
        letter = self.tonic[0]
        accidental = self.tonic[1] if len(self.tonic) > 1 else None

        # Determine whether to use sharps or flats
        if accidental == '#':
            self._use_sharps = True
        elif accidental == 'b':
            self._use_sharps = False
        else:
            # natural note
            if letter.isupper():
                # major key – only F major uses flats
                self._use_sharps = letter != 'F'
            else:
                # minor key – a, e, b use sharps; d, g, c, f use flats
                self._use_sharps = letter in ('a', 'e', 'b')

        # Build the chromatic note list
        if self._use_sharps:
            self._base = ["A", "A#", "B", "C", "C#", "D", "D#", "E", "F", "F#", "G", "G#"]
        else:
            self._base = ["A", "Bb", "B", "C", "Db", "D", "Eb", "E", "F", "Gb", "G", "Ab"]

        # Normalise the tonic to uppercase letter + accidental
        upper_letter = letter.upper()
        if accidental:
            self._tonic_note = upper_letter + accidental
        else:
            self._tonic_note = upper_letter

    def chromatic(self):
        base = self._base
        tonic_note = self._tonic_note
        idx = base.index(tonic_note)
        return base[idx:] + base[:idx]

    def interval(self, intervals):
        base = self._base
        tonic_note = self._tonic_note
        idx = base.index(tonic_note)
        result = [tonic_note]
        cur = idx
        step_map = {'m': 1, 'M': 2, 'A': 3}
        for ch in intervals:
            step = step_map[ch]
            cur = (cur + step) % 12
            result.append(base[cur])
        return result
