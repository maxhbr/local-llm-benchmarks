```javascript
export const recite = () => {
  const dayNames = ['first', 'second', 'third', 'fourth', 'fifth', 'sixth', 'seventh', 'eighth', 'ninth', 
'tenth', 'eleventh', 'twelfth'];
  const giftPhrases = [
    'a Partridge in a Pear Tree',
    'two Turtle Doves',
    'three French Hens',
    'four Calling Birds',
    'five Gold Rings',
    'six Geese-a-Laying',
    'seven Swans-a-Swimming',
    'eight Maids-a-Milking',
    'nine Ladies Dancing',
    'ten Lords-a-Leaping',
    'eleven Pipers Piping',
    'twelve Drummers Drumming'
  ];
  const verses = [];
  for (let day = 1; day <= 12; day++) {
    const dayName = dayNames[day - 1];
    const gifts = giftPhrases.slice(0, day).reverse();
    const lastGift = gifts.pop();
    let giftsStr;
    if (gifts.length === 0) {
      giftsStr = lastGift;
    } else {
      giftsStr = gifts.join(', ') + ', and ' + lastGift;
    }
    const verse = `On the ${dayName} day of Christmas my true love gave to me: ${giftsStr}.`;
    verses.push(verse);
  }
  return verses;
};
```

Make sure we handle day correctly: for day=1, slice(0,1) gives [a Partridge], reverse same, pop returns lastGift,
gifts.length==0 => giftsStr = lastGift => correct.

