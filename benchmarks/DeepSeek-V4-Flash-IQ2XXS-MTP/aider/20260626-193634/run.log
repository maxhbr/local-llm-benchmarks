    let all_uppercase = word.chars().filter(|c| c.is_alphabetic()).all(|c| 
c.is_uppercase());
    let word_chars: Vec<char> = word.chars().collect();
    if all_uppercase {
        // take only first char (uppercase)
        let first = 
word_chars[0].to_uppercase().next().unwrap_or(word_chars[0]);
        result.push(first);
    } else {
        // mixed case or all lowercase
