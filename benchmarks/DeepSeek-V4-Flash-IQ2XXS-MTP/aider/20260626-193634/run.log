import java.util.Collection;
import java.util.HashSet;
import java.util.Set;

class CustomSet<T> {
    private Set<T> elements; // or HashSet<T>

    CustomSet() {
        elements = new HashSet<>();
    }

    CustomSet(Collection<T> data) {
        elements = new HashSet<>();
        if (data != null) {
            elements.addAll(data);
        }
    }

    boolean isEmpty() {
        return elements.isEmpty();
    }

    boolean contains(T element) {
        return elements.contains(element);
    }

    boolean isDisjoint(CustomSet<T> other) {
        for (T e : elements) {
            if (other.contains(e)) {
                return false;
            }
        }
        return true;
    }

    boolean add(T element) {
        return elements.add(element);
    }

    @Override
    public boolean equals(Object obj) {
        if (obj == this) return true;
        if (!(obj instanceof CustomSet)) return false;
        CustomSet<?> other = (CustomSet<?>) obj;
        return elements.equals(other.elements);
    }

    @Override
    public int hashCode() {
        return elements.hashCode();
    }

    CustomSet<T> getIntersection(CustomSet<T> other) {
        CustomSet<T> result = new CustomSet<>();
        for (T e : elements) {
            if (other.contains(e)) {
                result.add(e);
            }
        }
        return result;
    }

    CustomSet<T> getUnion(CustomSet<T> other) {
        CustomSet<T> result = new CustomSet<>();
        result.elements.addAll(this.elements);
        result.elements.addAll(other.elements);
        return result;
    }

    CustomSet<T> getDifference(CustomSet<T> other) {
        CustomSet<T> result = new CustomSet<>();
        for (T e : elements) {
            if (!other.contains(e)) {
                result.add(e);
            }
        }
        return result;
    }

    boolean isSubset(CustomSet<T> other) {
        for (T e : elements) {
            if (!other.contains(e)) {
                return false;
            }
        }
        return true;
    }
}
```

