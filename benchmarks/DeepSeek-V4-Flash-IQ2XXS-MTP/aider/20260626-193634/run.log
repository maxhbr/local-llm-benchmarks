```
pub fn abbreviate(phrase: &str) -> String {
    let mut result = String::new();
    let mut word = String::new();

    for ch in phrase.chars() {
        if ch.is_whitespace() || ch == '-' {
            if !word.is_empty() {
                add_word_abbreviation(&mut result, &word);
                word.clear();
            }
        } else if ch.is_alphanumeric() {
            word.push(ch);
        }
        // ignore other punctuation
    }

    if !word.is_empty() {
        add_word_abbreviation(&mut result, &word);
    }

    result
}

fn add_word_abbreviation(result: &mut String, word: &str) {
    if word.is_empty() {
        return;
    }

    let word_chars: Vec<char> = word.chars().collect();
    // Determine if all letters in the word are uppercase (excluding 
non-letters)
    let all_uppercase = word_chars.iter().filter(|c| 
c.is_alphabetic()).all(|c| c.is_uppercase());

    if all_uppercase {
        // For all-uppercase words, take only the first character
        let first = 
word_chars[0].to_uppercase().next().unwrap_or(word_chars[0]);
        result.push(first);
    } else {
        // Mixed case (or all lowercase): take first letter, and then any 
uppercase
        // letter that follows a lowercase letter (camel-case boundary)
        let mut prev_lowercase = false;
        for (i, &ch) in word_chars.iter().enumerate() {
            if i == 0 {
                let first = ch.to_uppercase().next().unwrap_or(ch);
                result.push(first);
                prev_lowercase = ch.is_lowercase();
            } else {
                if ch.is_uppercase() && prev_lowercase {
                    result.push(ch);
                    prev_lowercase = false;
                } else {
                    prev_lowercase = ch.is_lowercase();
                }
            }
        }
    }
}
