import java.util.*;

class Alphametics {
    private List<String> leftWords;
    private String rightWord;
    private char[] lettersArray;
    private Map<Character, Integer> letterToIndex;
    private Set<Character> leadingLetters;

    Alphametics(String userInput) {
        parse(userInput);
        Set<Character> letterSet = new HashSet<>();
        for (String w : leftWords) {
            for (char c : w.toCharArray()) letterSet.add(c);
        }
        for (char c : rightWord.toCharArray()) letterSet.add(c);

        int n = letterSet.size();
        lettersArray = new char[n];
        letterToIndex = new HashMap<>();
        int idx = 0;
        for (char c : letterSet) {
            lettersArray[idx] = c;
            letterToIndex.put(c, idx);
            idx++;
        }

        leadingLetters = new HashSet<>();
        for (String w : leftWords) {
            if (w.length() > 1) leadingLetters.add(w.charAt(0));
        }
        if (rightWord.length() > 1) leadingLetters.add(rightWord.charAt(0));
    }

    Map<Character, Integer> solve() throws UnsolvablePuzzleException {
        int n = lettersArray.length;
        if (n > 10) throw new UnsolvablePuzzleException();

        int[] assignment = new int[n];
        Arrays.fill(assignment, -1);
        boolean[] used = new boolean[10];
        Map<Character, Integer> resultMap = new HashMap<>();

        boolean solved = solveHelper(0, assignment, used, resultMap);
        if (!solved) throw new UnsolvablePuzzleException();
        return resultMap;
    }

    private boolean solveHelper(int idx, int[] assignment, boolean[] used,
                                Map<Character, Integer> resultMap) {
        if (idx == lettersArray.length) {
            if (checkSum(assignment)) {
                for (int i = 0; i < lettersArray.length; i++) {
                    resultMap.put(lettersArray[i], assignment[i]);
                }
                return true;
            }
            return false;
        }

        char c = lettersArray[idx];
        boolean isLeading = leadingLetters.contains(c);

        for (int digit = 0; digit <= 9; digit++) {
            if (used[digit]) continue;
            if (isLeading && digit == 0) continue;

            assignment[idx] = digit;
            used[digit] = true;
            if (solveHelper(idx + 1, assignment, used, resultMap)) return true;
            used[digit] = false;
            assignment[idx] = -1;
        }
        return false;
    }

    private boolean checkSum(int[] assignment) {
        long leftSum = 0;
        for (String w : leftWords) {
            leftSum += wordValue(w, assignment);
        }
        long rightVal = wordValue(rightWord, assignment);
        return leftSum == rightVal;
    }

    private long wordValue(String word, int[] assignment) {
        long val = 0;
        for (int i = 0; i < word.length(); i++) {
            char c = word.charAt(i);
            int idx = letterToIndex.get(c);
            int digit = assignment[idx];
            val = val * 10 + digit;
        }
        return val;
    }

    private void parse(String input) {
        String cleaned = input.replaceAll("\\s+", "");
        String[] sides = cleaned.split("=");
        if (sides.length != 2) throw new IllegalArgumentException("Invalid puzzle format");
        String leftSide = sides[0];
        String rightSide = sides[1];
        leftWords = Arrays.asList(leftSide.split("\\+"));
        rightWord = rightSide;
    }
}
