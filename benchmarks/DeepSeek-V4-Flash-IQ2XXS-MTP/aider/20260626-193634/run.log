crypto_square.go
```
package cryptosquare

import (
	"math"
	"strings"
	"unicode"
)

func Encode(pt string) string {
	var normalized strings.Builder
	for _, r := range pt {
		if unicode.IsLetter(r) || unicode.IsDigit(r) {
			normalized.WriteRune(unicode.ToLower(r))
		}
	}
	norm := normalized.String()
	L := len(norm)
	if L == 0 {
		return ""
	}

	c := int(math.Ceil(math.Sqrt(float64(L))))
	r := int(math.Ceil(float64(L) / float64(c)))

	total := r * c
	padded := norm + strings.Repeat(" ", total-L)

	var encoded strings.Builder
	encoded.Grow(total)
	for col := 0; col < c; col++ {
		for row := 0; row < r; row++ {
			idx := row*c + col
			encoded.WriteByte(padded[idx])
		}
	}
	enc := encoded.String()

	chunks := make([]string, c)
	for i := 0; i < c; i++ {
		start := i * r
		chunks[i] = enc[start : start+r]
	}
	return strings.Join(chunks, " ")
}
```
