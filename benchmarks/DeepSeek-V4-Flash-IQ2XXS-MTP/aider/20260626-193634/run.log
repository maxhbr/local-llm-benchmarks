function buildVerse(day) {
   const dayName = dayNames[day-1];
   const gifts = giftPhrases.slice(0, day).reverse();
   const lastGift = gifts.pop();
   let giftsStr;
   if (gifts.length === 0) {
      giftsStr = lastGift;
   } else {
      giftsStr = gifts.join(', ') + ', and ' + lastGift;
   }
   return `On the ${dayName} day of Christmas my true love gave to me: 
${giftsStr}.\n`;
}
```

