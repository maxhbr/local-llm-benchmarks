pub fn abbreviate(phrase: &str) -> String {
    let mut result = String::new();
    let mut word = String::new();

    for ch in phrase.chars() {
        if ch.is_whitespace() || ch == '-' {
            if !word.is_empty() {
                add_word_abbreviation(&mut result, &word);
                word.clear();
            }
        } else if ch.is_alphanumeric() {
            word.push(ch);
        }
        // any other punctuation is simply ignored
    }

    if !word.is_empty() {
        add_word_abbreviation(&mut result, &word);
    }

    result
}

fn add_word_abbreviation(result: &mut String, word: &str) {
    if word.is_empty() {
        return;
    }

    let word_chars: Vec<char> = word.chars().collect();
    // Determine if all letters in the word are uppercase (ignoring non‑letters)
    let all_uppercase = word_chars
        .iter()
        .filter(|c| c.is_alphabetic())
        .all(|c| c.is_uppercase());

    if all_uppercase {
        // For an all‑uppercase word, take only the first character
        let first = word_chars[0]
            .to_uppercase()
            .next()
            .unwrap_or(word_chars[0]);
        result.push(first);
