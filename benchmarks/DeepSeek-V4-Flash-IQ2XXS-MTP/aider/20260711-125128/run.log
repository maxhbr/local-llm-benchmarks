namespace Bankaccount {
void Bankaccount::open() {
    std::lock_guard<std::mutex> lock(mtx);
    if (openFlag) {
        throw std::runtime_error("account already open");
    }
    openFlag = true;
    bal = 0.0;
}

void Bankaccount::close() {
