import java.util.ArrayList;
import java.util.List;

class BowlingGame {
    private List<Integer> rolls;

    public BowlingGame() {
        rolls = new ArrayList<>();
    }

    void roll(int pins) {
        rolls.add(pins);
    }

    int score() {
        int total = 0;
        int rollIndex = 0;
        for (int frame = 0; frame < 10; frame++) {
            if (frame == 9) { // last frame
                // sum remaining rolls
                for (int i = rollIndex; i < rolls.size(); i++) {
                    total += rolls.get(i);
                }
                break;
            }
            // check strike
            if (rolls.get(rollIndex) == 10) {
                total += 10 + rolls.get(rollIndex+1) + rolls.get(rollIndex+2);
                rollIndex += 1;
            } else {
                int first = rolls.get(rollIndex);
                int second = rolls.get(rollIndex+1);
                int frameScore = first + second;
                if (frameScore == 10) {
                    // spare
                    total += 10 + rolls.get(rollIndex+2);
                } else {
                    total += frameScore;
                }
                rollIndex += 2;
            }
        }
        return total;
    }
}
