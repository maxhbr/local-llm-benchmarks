package transpose

func Transpose(input []string) []string {
    if len(input) == 0 {
        return []string{}
    }
    // convert to rune slices
    runeRows := make([][]rune, len(input))
    maxLen := 0
    for i, s := range input {
        runeRows[i] = []rune(s)
        if len(runeRows[i]) > maxLen {
            maxLen = len(runeRows[i])
        }
    }
    if maxLen == 0 {
        // all rows empty
        return []string{}
    }
    result := make([]string, maxLen)
    for col := 0; col < maxLen; col++ {
        // find first and last row with char at col
        first := -1
        last := -1
        for i, row := range runeRows {
            if col < len(row) {
                if first == -1 {
                    first = i
                }
                last = i
            }
        }
        // if first == -1, column has no chars (shouldn't happen because maxLen ensures at least one row has that length)
        // but handle gracefully
        if first == -1 {
            // No characters at this column? Should not happen, but fallback: all rows missing => result row empty?
            result[col] = ""
            continue
        }
        // Build string
        var b strings.Builder
        // rows before first
        for i := 0; i < first; i++ {
            b.WriteRune(' ')
        }
        // rows from first to last inclusive
        for i := first; i <= last; i++ {
            row := runeRows[i]
            if col < len(row) {
                b.WriteRune(row[col])
            } else {
                b.WriteRune(' ')
            }
        }
        result[col] = b.String()
    }
    return result
}

