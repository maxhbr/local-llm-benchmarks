private RollContext getContext() {
    int i = 0;
    for (int frame = 0; frame < 10; frame++) {
        if (i >= rolls.size()) {
            // No rolls for this frame yet.
            // The next roll will be first roll of frame 'frame'.
            RollContext ctx = new RollContext();
            ctx.frame = frame;
            ctx.rollInFrame = 0;
            ctx.isBonusRoll = false;
            return ctx;
        }
        if (frame == 9) {
            // tenth frame
            int first = rolls.get(i);
            i++;
            if (i >= rolls.size()) {
                // we have only the first roll. Next roll is second roll (if not strike) or first bonus roll (if strike).
                // If first == 10, then the next roll is a bonus roll (first bonus). 
                // If first != 10, next roll is second roll of tenth frame (not bonus).
                RollContext ctx = new RollContext();
                ctx.frame = frame;
                ctx.isBonusRoll = (first == 10);
                ctx.rollInFrame = 1;
                return ctx;
            }
            // we have at least two rolls for tenth frame.
            if (first == 10) {
                // first roll is strike, second roll is first bonus roll.
                // need third roll possibly.
                // i currently points to second roll (index after first).
                // we need to determine if third roll needed.
                // If we have third roll (i < rolls.size()), then after second bonus, we are done? Actually after two bonus rolls, frame complete.
                // If i < rolls.size(), then we have second bonus roll already.
                // So we need to determine if next roll is third roll (second bonus) or beyond.
                // Let's increment i to simulate.
                i++; // consume second roll
                if (i >= rolls.size()) {
                    // we have first two rolls, need third roll (second bonus).
                    RollContext ctx = new RollContext();
                    ctx.frame = frame;
                    ctx.isBonusRoll = true;
                    ctx.rollInFrame = 2;
                    return ctx;
                }
                // we have third roll, so tenth frame complete. Continue after loop.
                i++; // consume third roll
                // after third, i may be < rolls.size() (extra rolls) or == rolls.size().
                // If i == rolls.size(), game complete; if i < rolls.size(), extra rolls.
                // We'll break and let outer handle.
                break;
            } else {
                // first roll not strike
                int second = rolls.get(i);
                i++; // consume second roll
                if (first + second == 10) {
                    // spare, need bonus roll
                    if (i >= rolls.size()) {
                        // need bonus roll
                        RollContext ctx = new RollContext();
                        ctx.frame = frame;
                        ctx.isBonusRoll = true;
                        ctx.rollInFrame = 2;
                        return ctx;
                    }
                    // we have bonus roll, consume it
                    i++; // consume bonus roll
                    // after that, tenth frame complete.
                    break;
                } else {
                    // open frame, no bonus roll
                    // tenth frame complete (2 rolls)
                    break;
                }
            }
        } else {
            // frames 0-8
            int first = rolls.get(i);
            i++;
            if (first == 10) {
                // strike, frame complete after one roll
            } else {
                // need second roll
                if (i >= rolls.size()) {
                    // need second roll
                    RollContext ctx = new RollContext();
                    ctx.frame = frame;
                    ctx.rollInFrame = 1;
                    ctx.isBonusRoll = false;
                    return ctx;
                }
                i++; // consume second roll
            }
        }
    }
    // If we finish loop, either game is complete or extra rolls.
    // If i == rolls.size(), game complete.
    // If i < rolls.size(), extra rolls, game complete.
    // Return null to indicate game complete.
    return null;
}
