use std::time::SystemTime;

const KEY_MIN_LENGTH: usize = 100;

pub fn encode(key: &str, s: &str) -> Option<String> {
    if key.is_empty() {
        return None;
    }
    let key_bytes: Vec<u8> = key
        .chars()
        .map(|c| {
            if c.is_ascii_lowercase() {
                Some(c as u8 - b'a')
            } else {
                None
            }
        })
        .collect::<Option<Vec<_>>>()?;
    let s_bytes: Vec<u8> = s
        .chars()
        .map(|c| {
            if c.is_ascii_lowercase() {
                Some(c as u8 - b'a')
            } else {
                None
            }
        })
        .collect::<Option<Vec<_>>>()?;

    let mut result = String::with_capacity(s.len());
    for (i, &p) in s_bytes.iter().enumerate() {
        let k = key_bytes[i % key_bytes.len()];
        let shifted = (p + k) % 26;
        result.push((b'a' + shifted) as char);
    }
    Some(result)
}

pub fn decode(key: &str, s: &str) -> Option<String> {
    if key.is_empty() {
        return None;
    }
    let key_bytes: Vec<u8> = key
        .chars()
        .map(|c| {
            if c.is_ascii_lowercase() {
                Some(c as u8 - b'a')
            } else {
                None
            }
        })
        .collect::<Option<Vec<_>>>()?;
    let s_bytes: Vec<u8> = s
        .chars()
        .map(|c| {
            if c.is_ascii_lowercase() {
                Some(c as u8 - b'a')
            } else {
                None
            }
        })
        .collect::<Option<Vec<_>>>()?;

    let mut result = String::with_capacity(s.len());
    for (i, &c) in s_bytes.iter().enumerate() {
        let k = key_bytes[i % key_bytes.len()];
        let shifted = (26 + c - k) % 26; // avoid underflow
        result.push((b'a' + shifted) as char);
    }
    Some(result)
}

fn generate_random_key(length: usize) -> String {
    let seed = SystemTime::now()
        .duration_since(SystemTime::UNIX_EPOCH)
        .unwrap()
        .as_nanos() as u64;
    let mut state = seed;
    let mut key = String::with_capacity(length);
    for _ in 0..length {
        state = state.wrapping_mul(6364136223846793005).wrapping_add(1);
        let idx = ((state >> 56) as u8) % 26;
        key.push((b'a' + idx) as char);
    }
    key
}

pub fn encode_random(s: &str) -> (String, String) {
    let key = generate_random_key(KEY_MIN_LENGTH);
    let encoded = encode(&key, s).expect("encode_random: s contains non-lowercase letters");
    (key, encoded)
}
