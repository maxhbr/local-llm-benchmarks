package alphametics

import (
        "errors"
        "strings"
)

func Solve(puzzle string) (map[string]int, error) {
        eqIdx := strings.Index(puzzle, "==")
        if eqIdx == -1 {
                return nil, errors.New("no equation")
        }
        left := strings.TrimSpace(puzzle[:eqIdx])
        right := strings.TrimSpace(puzzle[eqIdx+2:])
        leftWords := strings.Split(left, "+")
        // trim spaces
        words := make([]string, 0, len(leftWords)+1)
        for _, w := range leftWords {
                w = strings.TrimSpace(w)
                if w != "" {
                        words = append(words, w)
                }
        }
        rightWord := strings.TrimSpace(right)
        if rightWord == "" {
                return nil, errors.New("no right word")
        }
        // collect letters
        letterSet := make(map[byte]bool)
        allWords := append(words, rightWord)
        for _, w := range allWords {
                for i := 0; i < len(w); i++ {
                        letterSet[w[i]] = true
                }
        }
        letters := make([]byte, 0, len(letterSet))
        for ch := range letterSet {
                letters = append(letters, ch)
        }
        if len(letters) > 10 {
                return nil, errors.New("too many distinct letters")
        }
        // create index map
        letterIdx := make(map[byte]int)
        for i, ch := range letters {
                letterIdx[ch] = i
        }
        // leading letters set
        leadingLetters := make(map[byte]bool)
        for _, w := range allWords {
                if len(w) > 0 {
                        leadingLetters[w[0]] = true
                }
        }
        // digit assignments
        assign := make([]int, len(letters))
        used := [10]bool{}
        var solution map[string]int
        var found bool
        var backtrack func(idx int)
        backtrack = func(idx int) {
                if idx == len(letters) {
                        // check sum
                        leftSum := 0
                        for _, w := range words {
                                val := 0
                                for i := 0; i < len(w); i++ {
                                        ch := w[i]
                                        digit := assign[letterIdx[ch]]
                                        val = val*10 + digit
                                }
                                leftSum += val
                        }
                        rightVal := 0
                        for i := 0; i < len(rightWord); i++ {
                                ch := rightWord[i]
                                digit := assign[letterIdx[ch]]
                                rightVal = rightVal*10 + digit
                        }
                        if leftSum == rightVal {
                                // build solution map
                                sol := make(map[string]int)
                                for i, ch := range letters {
                                        sol[string(ch)] = assign[i]
                                }
                                solution = sol
                                found = true
                        }
                        return
                }
                ch := letters[idx]
                for d := 0; d < 10; d++ {
                        if used[d] {
                                continue
                        }
                        // leading zero check
                        if leadingLetters[ch] && d == 0 {
                                continue
                        }
                        used[d] = true
                        assign[idx] = d
                        backtrack(idx + 1)
                        if found {
                                return
                        }
                        used[d] = false
                }
        }
        backtrack(0)
        if !found {
                return nil, errors.New("no solution")
        }
        return solution, nil
}
```

