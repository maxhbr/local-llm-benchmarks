Implementation details:

```
namespace zebra_puzzle {

namespace {
    const int RED=0, GREEN=1, IVORY=2, YELLOW=3, BLUE=4;
    const int ENGLISH=0, SPANIARD=1, UKRAINIAN=2, JAPANESE=3, NORWEGIAN=4;
    const int COFFEE=0, TEA=1, MILK=2, ORANGE_JUICE=3, WATER=4;
    const int DOG=0, HORSE=1, FOX=2, SNAIL=3, ZEBRA=4;
    const int DANCING=0, PAINTING=1, READING=2, FOOTBALL=3, CHESS=4;

    int indexOf(const std::array<int,5>& arr, int val) {
        for (int i=0;i<5;++i) if (arr[i]==val) return i;
        return -1;
    }

    std::string nationalityName(int nat) {
        switch (nat) {
            case ENGLISH: return "Englishman";
            case SPANIARD: return "Spaniard";
            case UKRAINIAN: return "Ukrainian";
            case JAPANESE: return "Japanese";
            case NORWEGIAN: return "Norwegian";
            default: return "";
        }
    }
}

Solution solve() {
    std::array<int,5> colors = {RED,GREEN,IVORY,YELLOW,BLUE};
    std::sort(colors.begin(), colors.end());
    do {
        // green right of ivory
        int ivIdx = indexOf(colors, IVORY);
        int grIdx = indexOf(colors, GREEN);
        if (grIdx != ivIdx+1) continue;

        std::array<int,5> nationalities = {ENGLISH,SPANIARD,UKRAINIAN,JAPANESE,NORWEGIAN};
        std::sort(nationalities.begin(), nationalities.end());
        do {
            if (nationalities[0] != NORWEGIAN) continue;
            int redIdx = indexOf(colors, RED);
            if (nationalities[redIdx] != ENGLISH) continue;
            int spaniardIdx = indexOf(nationalities, SPANIARD);
            int ukrainianIdx = indexOf(nationalities, UKRAINIAN);
            int japaneseIdx = indexOf(nationalities, JAPANESE);

            std::array<int,5> drinks = {COFFEE,TEA,MILK,ORANGE_JUICE,WATER};
            std::sort(drinks.begin(), drinks.end());
            do {
                int greenIdx = indexOf(colors, GREEN);
                if (drinks[greenIdx] != COFFEE) continue;
                if (drinks[ukrainianIdx] != TEA) continue;
                if (drinks[2] != MILK) continue;

                std::array<int,5> pets = {DOG,HORSE,FOX,SNAIL,ZEBRA};
                std::sort(pets.begin(), pets.end());
                do {
                    if (pets[spaniardIdx] != DOG) continue;
                    int snailIdx = indexOf(pets, SNAIL);
                    int horseIdx = indexOf(pets, HORSE);
                    int foxIdx = indexOf(pets, FOX);

                    std::array<int,5> hobbies = {DANCING,PAINTING,READING,FOOTBALL,CHESS};
                    std::sort(hobbies.begin(), hobbies.end());
                    do {
                        if (hobbies[snailIdx] != DANCING) continue;
                        int painterIdx = indexOf(colors, YELLOW);
                        if (hobbies[painterIdx] != PAINTING) continue;
                        if (hobbies[japaneseIdx] != CHESS) continue;
                        int footballIdx = indexOf(hobbies, FOOTBALL);
                        if (drinks[footballIdx] != ORANGE_JUICE) continue;
                        int readingIdx = indexOf(hobbies, READING);
                        if (std::abs(readingIdx - foxIdx) != 1) continue;
                        if (std::abs(painterIdx - horseIdx) != 1) continue;
                        int blueIdx = indexOf(colors, BLUE);
                        if (std::abs(0 - blueIdx) != 1) continue;

                        // solution found
                        int waterIdx = indexOf(drinks, WATER);
                        std::string drinksWater = nationalityName(nationalities[waterIdx]);
                        int zebraIdx = indexOf(pets, ZEBRA);
                        std::string ownsZebra = nationalityName(nationalities[zebraIdx]);
                        return Solution{drinksWater, ownsZebra};
                    } while (std::next_permutation(hobbies.begin(), hobbies.end()));
                } while (std::next_permutation(pets.begin(), pets.end()));
            } while (std::next_permutation(drinks.begin(), drinks.end()));
        } while (std::next_permutation(nationalities.begin(), nationalities.end()));
    } while (std::next_permutation(colors.begin(), colors.end()));
    // Should never reach here
    return Solution{"",""};
}
} // namespace
```

