fn winning_hands<'a>(hands: &[&'a str]) -> Vec<&'a str> {
    let mut best_score: Option<Vec<u8>> = None;
    let mut result: Vec<&'a str> = vec![];

    for &hand in hands {
        let score = hand_score(hand);
        match best_score {
            None => {
                best_score = Some(score);
                result.push(hand);
            },
            Some(ref best) => {
                if score > *best {
                    best_score = Some(score);
                    result.clear();
                    result.push(hand);
                } else if score == *best {
                    result.push(hand);
                }
            }
        }
    }
    result
}
```

