void roll(int pins) {
    if (pins < 0 || pins > 10) throw new IllegalArgumentException("Pins out of range");
    FrameState state = getCurrentState();
    if (state == null) throw new IllegalStateException("Game already finished");
    // Now validate constraints based on state
    if (state.rollInFrame == 1 && !state.isBonus) {
        // second roll of normal frame (including tenth non-bonus)
        // get first roll score from previous roll (last in list)
        int first = rolls.get(rolls.size() - 1);
        if (first + pins > 10) throw new IllegalArgumentException("Two rolls in a frame cannot score more than 10 points");
    }
    if (state.isBonus && state.rollInFrame == 2 && state.frame == 9) {
        // second bonus roll after a strike in tenth
        // get first bonus roll score (previous roll)
        int firstBonus = rolls.get(rolls.size() - 1);
        if (firstBonus != 10) {
            if (pins == 10) throw new IllegalArgumentException("Second bonus roll cannot be a strike if first bonus roll is not a strike");
            if (firstBonus + pins > 10) throw new IllegalArgumentException("Two bonus rolls after a strike cannot exceed 10 points");
        }
    }
    // also for first bonus roll (rollInFrame==1 && isBonus) no extra constraint beyond pins range
    // also for first roll (rollInFrame==0) no extra constraint
    // also for bonus roll after spare (rollInFrame==2 && isBonus && not strike) no extra constraint (pins range already)
    rolls.add(pins);
}
