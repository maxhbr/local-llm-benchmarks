//
// This is only a SKELETON file for the 'Promises' exercise. It's been provided as a
// convenience to get you started writing code faster.
//

// promisify: turns a callback‑based function into a promise‑based one
export const promisify = (fn) => {
  return (...args) => {
    return new Promise((resolve, reject) => {
      fn(...args, (err, ...rest) => {
        if (err) {
          reject(err);
        } else {
          // If there is exactly one result value, resolve with it;
          // otherwise resolve with an array of all results.
          resolve(rest.length === 1 ? rest[0] : rest);
        }
      });
    });
  };
};

// all: resolves when all promises resolve, rejects as soon as one rejects
export const all = (promises) => {
  return new Promise((resolve, reject) => {
    if (promises === undefined) {
      resolve(undefined);
      return;
    }
    if (!Array.isArray(promises)) {
      reject(new TypeError('input must be an array'));
      return;
    }
    const results = new Array(promises.length);
    let resolvedCount = 0;
    let hasRejected = false;

    if (promises.length === 0) {
      resolve(results);
      return;
    }

    for (let i = 0; i < promises.length; i++) {
      Promise.resolve(promises[i]).then(
        (value) => {
          if (hasRejected) return;
          results[i] = value;
          resolvedCount++;
          if (resolvedCount === promises.length) {
            resolve(results);
          }
        },
        (error) => {
          if (hasRejected) return;
          hasRejected = true;
          reject(error);
        }
      );
    }
  });
};

// allSettled: resolves when every promise settles (resolved or rejected)
export const allSettled = (promises) => {
  return new Promise((resolve) => {
    if (promises === undefined) {
      resolve(undefined);
      return;
    }
    if (!Array.isArray(promises)) {
      resolve([]);
      return;
    }
    const results = new Array(promises.length);
    let settledCount = 0;

    for (let i = 0; i < promises.length; i++) {
      Promise.resolve(promises[i]).then(
        (value) => {
          results[i] = value;
          settledCount++;
          if (settledCount === promises.length) {
            resolve(results);
          }
        },
        (reason) => {
          results[i] = reason;
          settledCount++;
          if (settledCount === promises.length) {
            resolve(results);
          }
        }
      );
    }

    if (promises.length === 0) {
      resolve(results);
    }
  });
};

// race: resolves/rejects with the first settled promise's value/reason
export const race = (promises) => {
  return new Promise((resolve, reject) => {
    if (promises === undefined) {
      resolve(undefined);
      return;
    }
    if (!Array.isArray(promises)) {
      // If the argument is not iterable, the returned promise stays pending.
      return;
    }
    if (promises.length === 0) {
      resolve([]);
      return;
    }
    for (let i = 0; i < promises.length; i++) {
      Promise.resolve(promises[i]).then(resolve, reject);
    }
  });
};

// any: resolves when the first promise resolves; rejects when all reject
export const any = (promises) => {
  return new Promise((resolve, reject) => {
    if (promises === undefined) {
      resolve(undefined);
      return;
    }
    if (!Array.isArray(promises)) {
      reject(new TypeError('input must be an array'));
      return;
    }
    const errors = new Array(promises.length);
    let rejectedCount = 0;
    let resolved = false;

    for (let i = 0; i < promises.length; i++) {
      Promise.resolve(promises[i]).then(
        (value) => {
          if (resolved) return;
          resolved = true;
          resolve(value);
        },
        (reason) => {
          errors[i] = reason;
          rejectedCount++;
          if (rejectedCount === promises.length) {
            reject(errors);
          }
        }
      );
    }

    if (promises.length === 0) {
      reject(errors);
    }
  });
};
