package sublist

// Relation type is defined in relations.go file.

func Sublist(l1, l2 []int) Relation {
        // Check if slices are equal (same length and same elements in order)
        if len(l1) == len(l2) {
                equal := true
                for i := 0; i < len(l1); i++ {
                        if l1[i] != l2[i] {
                                equal = false
                                break
                        }
                }
                if equal {
                        return RelationEqual
                }
        }
        // Check if l1 is sublist of l2
        if isSublist(l1, l2) {
                return RelationSublist
        }
        // Check if l2 is sublist of l1 (i.e., l1 is superlist of l2)
        if isSublist(l2, l1) {
                return RelationSuperlist
        }
        return RelationUnequal
}

// isSublist checks if slice a is a contiguous subslice of slice b.
func isSublist(a, b []int) bool {
        if len(a) == 0 {
                return true
        }
        if len(b) == 0 {
                return false
        }
        if len(a) > len(b) {
                return false
        }
        // Slide over b
        for i := 0; i <= len(b)-len(a); i++ {
                match := true
                for j := 0; j < len(a); j++ {
                        if b[i+j] != a[j] {
                                match = false
                                break
                        }
                }
                if match {
                        return true
                }
        }
        return false
}
```

