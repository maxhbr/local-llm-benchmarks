```
class InputCell:
    def __init__(self, initial_value):
        self._observers = []
        self._value = initial_value
        self._depth = 0

    @property
    def value(self):
        return self._value

    @value.setter
    def value(self, new_value):
        if self._value != new_value:
            self._value = new_value
            # gather all compute cells that depend (directly or indirectly) on this cell
            affected = set()
            queue = list(self._observers)
            while queue:
                cell = queue.pop()
                if cell not in affected:
                    affected.add(cell)
                    for obs in cell._observers:
                        if obs not in affected:
                            queue.append(obs)
            # sort by depth (topological order)
            sorted_cells = sorted(affected, key=lambda c: c._depth)
            # store old values
            old_values = {c: c._value for c in sorted_cells}
            # recompute
            for c in sorted_cells:
                c._recompute_internal()
            # call callbacks for cells whose value changed
            for c in sorted_cells:
                new_val = c._value
                if new_val != old_values[c]:
                    for cb in c._callbacks:
                        cb(new_val)


class ComputeCell:
    def __init__(self, inputs, compute_function):
        self._inputs = inputs
        self._compute_function = compute_function
        self._callbacks = []
        self._observers = []
        input_values = [cell.value for cell in inputs]
        self._value = compute_function(input_values)
        # compute depth
        self._depth = 0
        if inputs:
            self._depth = max(inp._depth for inp in inputs) + 1
        # register as observer of each input cell
        for inp in inputs:
            inp._observers.append(self)

    @property
    def value(self):
        return self._value

    def add_callback(self, callback):
        self._callbacks.append(callback)

    def remove_callback(self, callback):
        if callback in self._callbacks:
            self._callbacks.remove(callback)

    def _recompute_internal(self):
        input_values = [cell.value for cell in self._inputs]
        self._value = self._compute_function(input_values)
```

