package zebra

type Solution struct {
	DrinksWater string
	OwnsZebra   string
}

func SolvePuzzle() Solution {
	colors := []string{"red", "green", "ivory", "yellow", "blue"}
	nationalities := []string{"Englishman", "Spaniard", "Ukrainian", "Norwegian", "Japanese"}
	pets := []string{"dog", "snails", "fox", "horse", "zebra"}
	drinks := []string{"coffee", "tea", "milk", "orange juice", "water"}
	smokes := []string{"Old Gold", "Kools", "Chesterfields", "Lucky Strike", "Parliaments"}

	colorPerms := generatePermutations(colors)
	natPerms := generatePermutations(nationalities)
	petPerms := generatePermutations(pets)
	drinkPerms := generatePermutations(drinks)
	smokePerms := generatePermutations(smokes)

	var validColorPerms [][]string
	for _, cp := range colorPerms {
		// blue must be at position 2 (index 1)
		if cp[1] != "blue" {
			continue
		}
		// green is immediately to the right of ivory
		found := false
		for i := 0; i < len(cp)-1; i++ {
			if cp[i] == "ivory" && cp[i+1] == "green" {
				found = true
				break
			}
		}
		if !found {
			continue
		}
		validColorPerms = append(validColorPerms, cp)
	}

	for _, colorPerm := range validColorPerms {
		for _, natPerm := range natPerms {
			// Englishman lives in the red house
			engIdx := indexOf(natPerm, "Englishman")
			if colorPerm[engIdx] != "red" {
				continue
			}
			// Norwegian lives in the first house
			if natPerm[0] != "Norwegian" {
				continue
			}
			// Norwegian lives next to the blue house (blue is already at position 2)
			if colorPerm[1] != "blue" {
				continue
			}

			for _, petPerm := range petPerms {
				// Spaniard owns the dog
				spanIdx := indexOf(natPerm, "Spaniard")
				if petPerm[spanIdx] != "dog" {
					continue
				}

				for _, drinkPerm := range drinkPerms {
					// Coffee is drunk in the green house
					coffeeIdx := indexOf(drinkPerm, "coffee")
					if colorPerm[coffeeIdx] != "green" {
						continue
					}
					// Ukrainian drinks tea
					ukrIdx := indexOf(natPerm, "Ukrainian")
					if drinkPerm[ukrIdx] != "tea" {
						continue
					}
					// Milk is drunk in the middle house
					if drinkPerm[2] != "milk" {
						continue
					}

					for _, smokePerm := range smokePerms {
						// Old Gold smoker owns snails
						oldGoldIdx := indexOf(smokePerm, "Old Gold")
						if petPerm[oldGoldIdx] != "snails" {
							continue
						}
						// Kools are smoked in the yellow house
						koolsIdx := indexOf(smokePerm, "Kools")
						if colorPerm[koolsIdx] != "yellow" {
							continue
						}
						// Chesterfields smoker lives next to the fox owner
						chesterIdx := indexOf(smokePerm, "Chesterfields")
						foxIdx := indexOf(petPerm, "fox")
						if abs(chesterIdx-foxIdx) != 1 {
							continue
						}
						// Kools are smoked next to the horse
						horseIdx := indexOf(petPerm, "horse")
						if abs(koolsIdx-horseIdx) != 1 {
							continue
						}
						// Lucky Strike smoker drinks orange juice
						luckyIdx := indexOf(smokePerm, "Lucky Strike")
						if drinkPerm[luckyIdx] != "orange juice" {
							continue
						}
						// Japanese smokes Parliaments
						japIdx := indexOf(natPerm, "Japanese")
						if smokePerm[japIdx] != "Parliaments" {
							continue
						}

						// solution found – extract answers
						waterDrinker := ""
						zebraOwner := ""
						for i := 0; i < 5; i++ {
							if drinkPerm[i] == "water" {
								waterDrinker = natPerm[i]
							}
							if petPerm[i] == "zebra" {
								zebraOwner = natPerm[i]
							}
						}
						return Solution{DrinksWater: waterDrinker, OwnsZebra: zebraOwner}
					}
				}
			}
		}
	}
	panic("no solution found")
}

func generatePermutations(values []string) [][]string {
	n := len(values)
	result := [][]string{}
	used := make([]bool, n)
	current := make([]string, n)
	var backtrack func(pos int)
	backtrack = func(pos int) {
		if pos == n {
			perm := make([]string, n)
			copy(perm, current)
			result = append(result, perm)
			return
		}
		for i := 0; i < n; i++ {
			if used[i] {
				continue
			}
			used[i] = true
			current[pos] = values[i]
			backtrack(pos + 1)
			used[i] = false
		}
	}
	backtrack(0)
	return result
}

func indexOf(slice []string, target string) int {
	for i, v := range slice {
		if v == target {
			return i
		}
	}
	return -1
}

func abs(x int) int {
	if x < 0 {
		return -x
	}
	return x
}
