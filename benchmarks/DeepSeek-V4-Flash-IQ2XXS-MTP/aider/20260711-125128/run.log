        cap2 = bucketTwoCap;
        target = desiredLiters;
        startIsOne = startBucket.equals("one");
        solve();
    }

    private void solve() {
        int a0 = startIsOne ? cap1 : 0;
        int b0 = startIsOne ? 0 : cap2;
        State init = new State(a0, b0, 1);
        Queue<State> queue = new ArrayDeque<>();
        queue.add(init);
        Set<Long> visited = new HashSet<>();
        visited.add(pair(a0, b0));

        while (!queue.isEmpty()) {
            State cur = queue.poll();
            int a = cur.a;
            int b = cur.b;
            int moves = cur.moves;

            // Check if we've reached the target
            if (a == target || b == target) {
                totalMoves = moves;
                if (a == target) {
                    finalBucket = "one";
                    otherBucketAmount = b;
                } else {
                    finalBucket = "two";
                    otherBucketAmount = a;
                }
                return;
            }

            // 1. Fill bucket one
            addState(queue, visited, cap1, b, moves + 1);
            // 2. Fill bucket two
            addState(queue, visited, a, cap2, moves + 1);
            // 3. Empty bucket one
            addState(queue, visited, 0, b, moves + 1);
            // 4. Empty bucket two
            addState(queue, visited, a, 0, moves + 1);

            // 5. Pour from bucket one to bucket two
            int pour12 = Math.min(a, cap2 - b);
            if (pour12 > 0) {
                int na = a - pour12;
                int nb = b + pour12;
                addState(queue, visited, na, nb, moves + 1);
            }

            // 6. Pour from bucket two to bucket one
            int pour21 = Math.min(b, cap1 - a);
            if (pour21 > 0) {
                int na = a + pour21;
                int nb = b - pour21;
                addState(queue, visited, na, nb, moves + 1);
            }
        }

        // Should never happen for valid inputs
        throw new RuntimeException("No solution found");
    }

    private void addState(Queue<State> queue, Set<Long> visited, int a, int b, int moves) {
        // Rule: after any action, the starting bucket must not be empty while the other is full
        if (startIsOne && a == 0 && b == cap2) return;
        if (!startIsOne && b == 0 && a == cap1) return;

        long key = pair(a, b);
        if (visited.contains(key)) return;
        visited.add(key);
        queue.add(new State(a, b, moves));
    }

    private static long pair(int a, int b) {
        return ((long) a << 32) | (b & 0xffffffffL);
    }

    int getTotalMoves() {
        return totalMoves;
    }

    String getFinalBucket() {
        return finalBucket;
    }

    int getOtherBucket() {
        return otherBucketAmount;
    }

    private static class State {
        int a, b, moves;

        State(int a, int b, int moves) {
            this.a = a;
            this.b = b;
            this.moves = moves;
        }
    }
}
```

This implementation:

- Uses BFS to find the minimal number of actions.
- Starts with the required fill of the starting bucket (counts as one action).
- Only explores states that do **not** violate the rule (starting bucket empty and other bucket full).
- Returns the total moves, which bucket ends up with the desired liters, and the amount left in the other bucket.
