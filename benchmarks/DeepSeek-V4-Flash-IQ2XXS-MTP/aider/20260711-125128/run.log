package bottlesong

import "fmt"

// Recite generates the verses of Ten Green Bottles.
func Recite(startBottles, takeDown int) []string {
    verses := make([]string, 0, takeDown)
    for i := 0; i < takeDown; i++ {
        current := startBottles - i
        // Build verse for current bottles
        line1 := fmt.Sprintf("%s green %s hanging on the wall,", numberWord(current), bottleOrBottles(current))
        line2 := line1
        line3 := "And if one green bottle should accidentally fall,"
        next := current - 1
        line4 := fmt.Sprintf("There'll be %s green %s hanging on the wall.", numberWord(next), bottleOrBottles(next))
        verse := line1 + "\n" + line2 + "\n" + line3 + "\n" + line4
        verses = append(verses, verse)
    }
    return verses
}

// numberWord returns the word for a number from 0 to 10.
func numberWord(n int) string {
    switch n {
    case 10:
        return "Ten"
    case 9:
        return "Nine"
    case 8:
        return "Eight"
    case 7:
        return "Seven"
    case 6:
        return "Six"
    case 5:
        return "Five"
    case 4:
        return "Four"
    case 3:
        return "Three"
    case 2:
        return "Two"
    case 1:
        return "One"
    case 0:
        return "no"
    default:
        return ""
    }
}

// bottleOrBottles returns "bottle" if n is 1, otherwise "bottles".
func bottleOrBottles(n int) string {
    if n == 1 {
        return "bottle"
    }
    return "bottles"
}

