// generatePermutations returns all permutations of the given slice.
func generatePermutations(values []string) [][]string {
        n := len(values)
        result := [][]string{}
        used := make([]bool, n)
        current := make([]string, n)
        var backtrack func(pos int)
        backtrack = func(pos int) {
                if pos == n {
                        perm := make([]string, n)
                        copy(perm, current)
                        result = append(result, perm)
                        return
                }
                for i := 0; i < n; i++ {
                        if used[i] {
                                continue
                        }
                        used[i] = true
                        current[pos] = values[i]
                        backtrack(pos + 1)
                        used[i] = false
                }
        }
        backtrack(0)
        return result
}

func abs(x int) int {
        if x < 0 {
                return -x
        }
        return x
}

