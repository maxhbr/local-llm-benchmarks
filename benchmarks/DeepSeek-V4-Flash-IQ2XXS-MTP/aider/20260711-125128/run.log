type Matrix struct {
	data [][]int
	rows int
	cols int
}

func New(s string) (Matrix, error) {
	lines := strings.Split(s, "\n")
	var data [][]int
	var width int
	for _, line := range lines {
		trimmed := strings.TrimSpace(line)
		if trimmed == "" {
			continue
		}
		tokens := strings.Fields(trimmed)
		if len(tokens) == 0 {
			continue
		}
		row := make([]int, len(tokens))
		for j, tok := range tokens {
			val, err := strconv.Atoi(tok)
			if err != nil {
				return Matrix{}, fmt.Errorf("invalid number: %s", tok)
			}
			row[j] = val
		}
		if len(data) == 0 {
			width = len(row)
		} else if len(row) != width {
			return Matrix{}, fmt.Errorf("inconsistent column count")
		}
		data = append(data, row)
	}
	if len(data) == 0 {
		return Matrix{}, fmt.Errorf("empty matrix")
	}
	return Matrix{data: data, rows: len(data), cols: width}, nil
}

func (m Matrix) Cols() [][]int {
	cols := make([][]int, m.cols)
	for c := 0; c < m.cols; c++ {
		col := make([]int, m.rows)
		for r := 0; r < m.rows; r++ {
			col[r] = m.data[r][c]
		}
		cols[c] = col
	}
	return cols
}

func (m Matrix) Rows() [][]int {
	rows := make([][]int, m.rows)
	for r := 0; r < m.rows; r++ {
		row := make([]int, m.cols)
		copy(row, m.data[r])
		rows[r] = row
	}
	return rows
}

func (m Matrix) Set(row, col, val int) bool {
	if row < 0 || row >= m.rows || col < 0 || col >= m.cols {
		return false
	}
	m.data[row][col] = val
	return true
}
