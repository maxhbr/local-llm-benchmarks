export const gamestate = (board) => {
  // count
  let countX=0, countO=0;
  for ... as before.

  // Validate turn order (simple count)
  if (countX !== countO && countX !== countO + 1) {
    let msg;
    if (countX > countO + 1) {
      msg = 'Wrong turn order: X went twice';
    } else if (countO > countX) {
      msg = 'Wrong turn order: O started';
    } else {
      msg = 'Invalid board';
    }
    throw new Error(msg);
  }

  // lines definition same
  const lines = ...;

  // Find winning lines
  const winningLines = [];
  for (const line of lines) {
    const [r1,c1,r2,c2,r3,c3] = line;
    const a=board[r1][c1], b=board[r2][c2], c=board[r3][c3];
    if (a !== ' ' && a === b && b === c) {
      winningLines.push({cells: [[r1,c1],[r2,c2],[r3,c3]], player: a});
    }
  }

  // Determine if there are any winners, and ensure they all same
  let winner = null;
  for (const wl of winningLines) {
    if (winner === null) winner = wl.player;
    else if (winner !== wl.player) {
      // multiple winners -> invalid
      throw new Error('Impossible board: game should have ended after the game was won');
    }
  }

  if (winningLines.length > 0) {
    // Determine last move player and last move cell
    const lastPlayer = (countX === countO + 1) ? 'X' : 'O';
    // Find candidate cells for lastPlayer
    const candidates = [];
    for (let i=0;i<3;i++) for (let j=0;j<3;j++) if (board[i][j]===lastPlayer) candidates.push([i,j]);

    // Find cell that appears in all winning lines
    let lastMoveCell = null;
    for (const [r,c] of candidates) {
      let count = 0;
      for (const wl of winningLines) {
        for (const [r2,c2] of wl.cells) {
          if (r2===r && c2===c) { count++; break; }
        }
      }
      if (count === winningLines.length) {
        lastMoveCell = [r,c];
        break;
      }
    }

    if (lastMoveCell === null) {
      // No cell belonging to last player that is in all winning lines -> invalid
      throw new Error('Impossible board: game should have ended after the game was won');
    }

    // Check that all winning lines include lastMoveCell
    // Actually we already verified that count == winningLines.length, so all include it. But we need to also ensure that any winning line that does not contain lastMoveCell does not exist. That is already covered because we 
found lastMoveCell that is in all. However there could be additional winning lines that do not contain it? That would mean we didn't count them. But we already counted all winningLines; if lastMoveCell is in all of them, good.
However there could be a line that is not a winning line? That's fine.

    // Also need to ensure that there is no winning line that existed before last move and is not part of last move. That is exactly what we checked: all winning lines include lastMoveCell. So if any winning line existed 
before, it would contain the last move cell? Actually if the line existed before, it would consist of cells that were already placed; the last move cell would be a new cell (last move) which is not part of that line (unless it
is). So if the line existed before, it wouldn't contain lastMoveCell. But we have checked that all winning lines contain lastMoveCell, so they all must have been created by last move. Thus no prior win.

    // So valid win.
    return 'win';
  }

  // No win
  const total = countX + countO;
  if (total === 9) return 'draw';
  return 'ongoing';
};

