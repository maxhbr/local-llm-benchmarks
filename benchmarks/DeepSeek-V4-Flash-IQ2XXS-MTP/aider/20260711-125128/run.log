```robot_simulator.go
package robot

import "fmt"

// Step 1
// Define N, E, S, W here.
const (
	N Dir = iota
	E
	S
	W
)

var robot Step2Robot

func Right() {
	robot.Dir = (robot.Dir + 1) % 4
}

func Left() {
	robot.Dir = (robot.Dir + 3) % 4
}

func Advance() {
	switch robot.Dir {
	case N:
		robot.Coord.Y++
	case E:
		robot.Coord.X++
	case S:
		robot.Coord.Y--
	case W:
		robot.Coord.X--
	}
}

func (d Dir) String() string {
	switch d {
	case N:
		return "North"
	case E:
		return "East"
	case S:
		return "South"
	case W:
		return "West"
	default:
		return "Unknown"
	}
}

// Step 2
// Define Action type here.
type Action int

const (
	ActionRight Action = iota
	ActionLeft
	ActionAdvance
)

func StartRobot(command chan Command, action chan Action) {
	for cmd := range command {
		switch cmd {
		case Command(0):
			action <- ActionRight
		case Command(1):
			action <- ActionLeft
		case Command(2):
			action <- ActionAdvance
		}
	}
	close(action)
}

func Room(extent Rect, robot Step2Robot, action chan Action, report chan Step2Robot) {
	for act := range action {
		switch act {
		case ActionRight:
			robot.Dir = (robot.Dir + 1) % 4
		case ActionLeft:
			robot.Dir = (robot.Dir + 3) % 4
		case ActionAdvance:
			newCoord := robot.Coord
			switch robot.Dir {
			case N:
				newCoord.Y++
			case E:
				newCoord.X++
			case S:
				newCoord.Y--
			case W:
				newCoord.X--
			}
			if newCoord.X >= extent.Min.X && newCoord.X <= extent.Max.X &&
				newCoord.Y >= extent.Min.Y && newCoord.Y <= extent.Max.Y {
				robot.Coord = newCoord
			}
		}
	}
	report <- robot
}

// Step 3
// Define Action3 type here.
type Action3 struct {
	Name   string
	Action int
}

func StartRobot3(name, script string, action chan Action3, log chan string) {
	if name == "" {
		log <- "A robot without a name"
		return
	}
	for _, ch := range script {
		var act int
		switch ch {
		case 'R':
			act = ActionRight
		case 'L':
			act = ActionLeft
		case 'A':
			act = ActionAdvance
		default:
			log <- fmt.Sprintf("An undefined command in script: %c", ch)
			continue
		}
		action <- Action3{Name: name, Action: act}
	}
}

func Room3(extent Rect, robots []Step3Robot, action chan Action3, rep chan []Step3Robot, log chan string) {
	// Validate initial robots
	nameIndex := make(map[string]int)
	posSet := make(map[Coord]bool)

	for i, r := range robots {
		if r.Name == "" {
			log <- "A robot without a name"
		}
		if _, exists := nameIndex[r.Name]; exists && r.Name != "" {
			log <- "Duplicate robot names"
		}
		nameIndex[r.Name] = i

		if r.Coord.X < extent.Min.X || r.Coord.X > extent.Max.X ||
			r.Coord.Y < extent.Min.Y || r.Coord.Y > extent.Max.Y {
			log <- "A robot placed outside of the room"
		} else {
			if posSet[r.Coord] {
				log <- "Robots placed at the same place"
			}
			posSet[r.Coord] = true
		}
	}

	// Process actions
	for act3 := range action {
		idx, ok := nameIndex[act3.Name]
		if !ok {
			log <- "An action from an unknown robot"
			continue
		}
		r := &robots[idx]
		switch act3.Action {
		case ActionRight:
			r.Dir = (r.Dir + 1) % 4
		case ActionLeft:
			r.Dir = (r.Dir + 3) % 4
		case ActionAdvance:
			newCoord := r.Coord
			switch r.Dir {
			case N:
				newCoord.Y++
			case E:
				newCoord.X++
			case S:
				newCoord.Y--
			case W:
				newCoord.X--
			}
			// wall check
			if newCoord.X < extent.Min.X || newCoord.X > extent.Max.X ||
				newCoord.Y < extent.Min.Y || newCoord.Y > extent.Max.Y {
				log <- "A robot attempting to advance into a wall"
				break
			}
			// collision with another robot
			collision := false
			for j, other := range robots {
				if j != idx && other.Coord == newCoord {
					collision = true
					break
				}
			}
			if collision {
				log <- "A robot attempting to advance into another robot"
				break
			}
			r.Coord = newCoord
		}
	}

	// Send final report
	rep <- robots
}
```
