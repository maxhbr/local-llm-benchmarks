Here's the updated `bottle_song.go` file that outputs each line as a separate element, uses the correct capitalization (uppercase for the first line, lowercase for the last line), and inserts an empty string between verses.

```go
package bottlesong

import "fmt"

// Recite generates the verses of Ten Green Bottles.
func Recite(startBottles, takeDown int) []string {
	var result []string
	for i := 0; i < takeDown; i++ {
		current := startBottles - i
		next := current - 1

		// First line (capitalised)
		line1 := fmt.Sprintf("%s green %s hanging on the wall,",
			capitalWord(current), bottleOrBottles(current))
		line2 := line1
		line3 := "And if one green bottle should accidentally fall,"
		line4 := fmt.Sprintf("There'll be %s green %s hanging on the wall.",
			lowerWord(next), bottleOrBottles(next))

		result = append(result, line1, line2, line3, line4)

		// Add an empty string between verses (but not after the last one)
		if i != takeDown-1 {
			result = append(result, "")
		}
	}
	return result
}

// capitalWord returns the number word with the first letter capitalised.
func capitalWord(n int) string {
	switch n {
	case 10:
		return "Ten"
	case 9:
		return "Nine"
	case 8:
		return "Eight"
	case 7:
		return "Seven"
	case 6:
		return "Six"
	case 5:
		return "Five"
	case 4:
		return "Four"
	case 3:
		return "Three"
	case 2:
		return "Two"
	case 1:
		return "One"
	case 0:
		return "no"
	default:
		return ""
	}
}

// lowerWord returns the number word in all lowercase.
func lowerWord(n int) string {
	switch n {
	case 10:
		return "ten"
	case 9:
		return "nine"
	case 8:
		return "eight"
	case 7:
		return "seven"
	case 6:
		return "six"
	case 5:
		return "five"
	case 4:
		return "four"
	case 3:
		return "three"
	case 2:
		return "two"
	case 1:
		return "one"
	case 0:
		return "no"
	default:
		return ""
	}
}

// bottleOrBottles returns "bottle" if n is 1, otherwise "bottles".
func bottleOrBottles(n int) string {
	if n == 1 {
		return "bottle"
	}
	return "bottles"
}
```
