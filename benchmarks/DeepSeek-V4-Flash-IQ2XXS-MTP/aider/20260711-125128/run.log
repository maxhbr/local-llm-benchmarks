def guess(self, char):
    if self.status != STATUS_ONGOING:
        raise ValueError("The game has already ended.")
    # determine if this is a repeated guess
    is_repeated = char in self.guessed_letters
    # determine if wrong guess
    if is_repeated:
        wrong = True
        # do not add to set
    else:
        self.guessed_letters.add(char)
        wrong = char not in self.word

    # track if already zero before this guess
