/// Given a list of poker hands, return a list of those hands which win.
///
/// Note the type signature: this function should return _the same_ reference to
/// the winning hand(s) as were passed in, not reconstructed strings which happen to be equal.
pub fn winning_hands<'a>(hands: &[&'a str]) -> Vec<&'a str> {
    let mut best_score: Option<Vec<u8>> = None;
    let mut result: Vec<&'a str> = Vec::new();

    for &hand in hands {
        let score = hand_score(hand);
        match best_score {
            None => {
                best_score = Some(score);
                result.push(hand);
            }
            Some(ref best) => {
                if score > *best {
                    best_score = Some(score);
                    result.clear();
                    result.push(hand);
                } else if score == *best {
                    result.push(hand);
                }
            }
        }
    }
    result
}

fn hand_score(hand: &str) -> Vec<u8> {
    let cards: Vec<&str> = hand.split_whitespace().collect();
    let mut ranks: Vec<u8> = Vec::with_capacity(5);
    let mut suits: Vec<u8> = Vec::with_capacity(5);

    for card in cards {
        let chars: Vec<char> = card.chars().collect();
        let len = chars.len();
        let (rank_val, suit_val) = if len == 3 && chars[0] == '1' && chars[1] == '0' {
            // "10" with suit
            let suit_char = chars[2];
            let rank = 10u8;
            let suit = match suit_char {
                'S' => 0,
                'H' => 1,
                'D' => 2,
                'C' => 3,
                _ => panic!("Invalid suit"),
            };
            (rank, suit)
        } else if len == 2 {
            let rank_char = chars[0];
            let suit_char = chars[1];
            let rank = match rank_char {
                '2'..='9' => rank_char as u8 - b'0',
                'T' => 10,
                'J' => 11,
                'Q' => 12,
                'K' => 13,
                'A' => 14,
                _ => panic!("Invalid rank"),
            };
            let suit = match suit_char {
                'S' => 0,
                'H' => 1,
                'D' => 2,
                'C' => 3,
                _ => panic!("Invalid suit"),
            };
            (rank, suit)
        } else {
            panic!("Invalid card format");
        };
        ranks.push(rank_val);
        suits.push(suit_val);
    }

    let flush = suits.iter().all(|&s| s == suits[0]);

    let mut sorted_desc = ranks.clone();
    sorted_desc.sort_unstable();
    sorted_desc.reverse();

    let straight_high = straight_high(&sorted_desc);

    let mut counts = [0u8; 15];
    for &r in &ranks {
        counts[r as usize] += 1;
    }

    let mut quad = 0u8;
    let mut triple = 0u8;
    let mut pairs: Vec<u8> = Vec::new();
    let mut singles: Vec<u8> = Vec::new();

    for rank in (2..=14).rev() {
        let cnt = counts[rank as usize];
        match cnt {
            4 => quad = rank,
            3 => triple = rank,
            2 => pairs.push(rank),
            1 => singles.push(rank),
            _ => {}
        }
    }

    let cat: u8;
    let tie: Vec<u8>;

    if let Some(high) = straight_high {
        if flush {
            cat = 9; // straight flush
            tie = vec![high];
        } else {
            cat = 5; // straight
            tie = vec![high];
        }
    } else if quad != 0 {
        cat = 8; // four of a kind
        tie = vec![quad, singles[0]];
    } else if triple != 0 && pairs.len() == 1 {
        cat = 7; // full house
        tie = vec![triple, pairs[0]];
    } else if flush {
        cat = 6; // flush
        tie = sorted_desc.clone();
    } else if triple != 0 {
        cat = 4; // three of a kind
        let mut t = vec![triple];
        t.extend_from_slice(&singles[..2]);
        tie = t;
    } else if pairs.len() == 2 {
        cat = 3; // two pair
        tie = vec![pairs[0], pairs[1], singles[0]];
    } else if pairs.len() == 1 {
        cat = 2; // one pair
        let mut t = vec![pairs[0]];
        t.extend_from_slice(&singles[..3]);
        tie = t;
    } else {
        cat = 1; // high card
        tie = sorted_desc.clone();
    }

    let mut score = vec![cat];
    score.extend(tie);
    score
}

fn straight_high(sorted: &[u8]) -> Option<u8> {
    if sorted.len() != 5 {
        return None;
    }
    let normal = sorted.windows(2).all(|w| w[0] == w[1] + 1);
    if normal {
        return Some(sorted[0]);
    }
    if sorted[0] == 14 && sorted[1] == 5 && sorted[2] == 4 && sorted[3] == 3 && sorted[4] == 2 {
        return Some(5);
    }
    None
}
