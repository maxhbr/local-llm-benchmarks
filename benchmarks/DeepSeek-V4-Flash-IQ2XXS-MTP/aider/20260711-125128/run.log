fn hand_score(hand: &str) -> Vec<u8> {
    let cards: Vec<&str> = hand.split_whitespace().collect();
    if cards.len() != 5 { panic!("Invalid hand: {}", hand); }
    let mut ranks: Vec<u8> = Vec::with_capacity(5);
    let mut suits: Vec<u8> = Vec::with_capacity(5);
    for card in cards {
        if card.len() < 2 { panic!("Invalid card: {}", card); }
        let rank_char = card.chars().next().unwrap();
        let suit_char = card.chars().nth(1).unwrap();
        let rank = match rank_char {
            '2'..='9' => rank_char as u8 - b'0',
            'T' | 't' => 10,
            'J' | 'j' => 11,
            'Q' | 'q' => 12,
            'K' | 'k' => 13,
            'A' | 'a' => 14,
            _ => panic!("Invalid rank"),
        };
        ranks.push(rank);
        suits.push(match suit_char {
            'S' | 's' => 0,
            'H' | 'h' => 1,
            'D' | 'd' => 2,
            'C' | 'c' => 3,
            _ => panic!("Invalid suit"),
        });
    }
    //...
}
```

