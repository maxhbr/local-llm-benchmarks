func Transpose(input []string) []string {
    if len(input) == 0 {
        return []string{}
    }
    // convert each input line to []rune
    runeRows := make([][]rune, len(input))
    maxLen := 0
    for i, s := range input {
        runeRows[i] = []rune(s)
        if len(runeRows[i]) > maxLen {
            maxLen = len(runeRows[i])
        }
    }
    // for each column index
    result := make([]string, maxLen)
    for col := 0; col < maxLen; col++ {
        var b strings.Builder
        for _, row := range runeRows {
            if col < len(row) {
                b.WriteRune(row[col])
            } else {
                b.WriteRune(' ')
            }
        }
        s := b.String()
        // trim trailing spaces (not leading)
        trimmed := strings.TrimRight(s, " ")
        result[col] = trimmed
    }
    return result
}

