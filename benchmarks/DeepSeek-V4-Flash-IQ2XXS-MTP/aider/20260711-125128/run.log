```python
class Node:
    def __init__(self, value, left=None, right=None):
        self.value = value
        self.left = left
        self.right = right


def node_to_dict(node):
    if node is None:
        return None
    return {"value": node.value,
            "left": node_to_dict(node.left),
            "right": node_to_dict(node.right)}


def dict_to_node(d):
    if d is None:
        return None
    return Node(d["value"],
                dict_to_node(d.get("left")),
                dict_to_node(d.get("right")))


class Zipper:
    def __init__(self, node, crumbs):
        self.node = node
        self.crumbs = crumbs

    @staticmethod
    def from_tree(tree):
        if isinstance(tree, dict):
            tree = dict_to_node(tree)
        return Zipper(tree, [])

    def value(self):
        return self.node.value

    def set_value(self, value):
        new_node = Node(value, self.node.left, self.node.right)
        return Zipper(new_node, self.crumbs)

    def left(self):
        if self.node.left is None:
            return None
        parent_value = self.node.value
        sibling = self.node.right
        new_crumbs = [(parent_value, 'L', sibling)] + self.crumbs
        return Zipper(self.node.left, new_crumbs)

    def set_left(self, node):
        if isinstance(node, dict):
            node = dict_to_node(node)
        new_node = Node(self.node.value, node, self.node.right)
        return Zipper(new_node, self.crumbs)

    def right(self):
        if self.node.right is None:
            return None
        parent_value = self.node.value
        sibling = self.node.left
        new_crumbs = [(parent_value, 'R', sibling)] + self.crumbs
        return Zipper(self.node.right, new_crumbs)

    def set_right(self, node):
        if isinstance(node, dict):
            node = dict_to_node(node)
        new_node = Node(self.node.value, self.node.left, node)
        return Zipper(new_node, self.crumbs)

    def up(self):
        if not self.crumbs:
            return None
        parent_value, direction, sibling = self.crumbs[0]
        rest_crumbs = self.crumbs[1:]
        if direction == 'L':
            parent_node = Node(parent_value, self.node, sibling)
        else:
            parent_node = Node(parent_value, sibling, self.node)
        return Zipper(parent_node, rest_crumbs)

    def to_tree(self):
        node = self.node
        for parent_value, direction, sibling in self.crumbs:
            if direction == 'L':
                node = Node(parent_value, node, sibling)
            else:
                node = Node(parent_value, sibling, node)
        return node_to_dict(node)
```
