Implementation:

```
private FrameState getCurrentState() {
    int i = 0;
    for (int frame = 0; frame < 10; frame++) {
        if (i >= rolls.size()) {
            // no rolls for this frame, so next roll is first of frame
            FrameState s = new FrameState();
            s.frame = frame;
            s.rollInFrame = 0;
            s.isBonus = false;
            return s;
        }
        if (frame == 9) {
            // tenth frame processing
            int first = rolls.get(i);
            i++;
            if (i >= rolls.size()) {
                // only first roll exists
                FrameState s = new FrameState();
                s.frame = frame;
                s.rollInFrame = 1;
                s.isBonus = (first == 10);
                return s;
            }
            if (first == 10) {
                // first roll strike, second roll is first bonus
                // i currently points to second roll
                // consume it
                i++; // consume second roll (first bonus)
                if (i >= rolls.size()) {
                    // we have first two rolls (strike + first bonus)
                    // need third roll (second bonus)
                    FrameState s = new FrameState();
                    s.frame = frame;
                    s.rollInFrame = 2;
                    s.isBonus = true;
                    return s;
                }
                // we have third roll (second bonus)
                i++; // consume third roll
                // after that, tenth frame complete
                // continue to check if more rolls exist
                // break out of loop (but we might have extra rolls)
                break;
            } else {
                // first roll not strike
                int second = rolls.get(i);
                i++; // consume second roll
                if (first + second == 10) {
                    // spare
                    if (i >= rolls.size()) {
                        // need bonus roll
                        FrameState s = new FrameState();
                        s.frame = frame;
                        s.rollInFrame = 2;
                        s.isBonus = true;
                        return s;
                    }
                    // bonus roll exists, consume it
                    i++; // consume bonus roll
                    break;
                } else {
                    // open frame
                    break;
                }
            }
        } else {
            // frames 0-8
            int first = rolls.get(i);
            i++;
            if (first == 10) {
                // strike, frame complete
                // no second roll
            } else {
                if (i >= rolls.size()) {
                    // need second roll
                    FrameState s = new FrameState();
                    s.frame = frame;
                    s.rollInFrame = 1;
                    s.isBonus = false;
                    return s;
                }
                i++; // consume second roll
            }
        }
    }
    // after loop, either game complete or extra rolls exist
    // if i == rolls.size(), game complete
    // if i < rolls.size(), extra rolls exist (game complete)
    return null; // game complete
}
