package transpose

import "strings"

func Transpose(input []string) []string {
	if len(input) == 0 {
		return []string{}
	}

	// convert each row to rune slice for proper Unicode handling
	runeRows := make([][]rune, len(input))
	maxLen := 0
	for i, s := range input {
		runeRows[i] = []rune(s)
		if len(runeRows[i]) > maxLen {
			maxLen = len(runeRows[i])
		}
	}

	if maxLen == 0 {
		return []string{}
	}

	result := make([]string, maxLen)

	for col := 0; col < maxLen; col++ {
		// find first and last row that actually have a character at this column
		first := -1
		last := -1
		for i, row := range runeRows {
			if col < len(row) {
				if first == -1 {
					first = i
				}
				last = i
			}
		}

		// at least one row must have this column because maxLen is the maximum length
		if first == -1 {
			// should not happen, but be safe
			result[col] = ""
			continue
		}

		var b strings.Builder

		// rows before the first row that has a character → pad left with spaces
		for i := 0; i < first; i++ {
			b.WriteRune(' ')
		}

		// rows from first to last (inclusive) – include the character if present, otherwise a space
		for i := first; i <= last; i++ {
			row := runeRows[i]
			if col < len(row) {
				b.WriteRune(row[col])
			} else {
				b.WriteRune(' ')
			}
		}

		// no trailing spaces are added – rows after last are simply omitted
		result[col] = b.String()
	}

	return result
}
