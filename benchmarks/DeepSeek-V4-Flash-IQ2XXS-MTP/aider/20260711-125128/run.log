package zebra

type Solution struct {
        DrinksWater string
        OwnsZebra   string
}

func SolvePuzzle() Solution {
        // define categories
        colors := []string{"red","green","ivory","yellow","blue"}
        nationalities := []string{"Englishman","Spaniard","Ukrainian","Norwegian","Japanese"}
        pets := []string{"dog","snails","fox","horse","zebra"}
        drinks := []string{"coffee","tea","milk","orange juice","water"}
        smokes := []string{"Old Gold","Kools","Chesterfields","Lucky Strike","Parliaments"}
        
        // generate permutations
        colorPerms := generatePermutations(colors)
        natPerms := generatePermutations(nationalities)
        petPerms := generatePermutations(pets)
        drinkPerms := generatePermutations(drinks)
        smokePerms := generatePermutations(smokes)

        // filter colorPerms for constraints
        var validColorPerms [][]string
        for _, cp := range colorPerms {
                // blue at position 2 (index1)
                if cp[1] != "blue" {
                        continue
                }
                // green right of ivory
                found := false
                for i := 0; i < len(cp)-1; i++ {
                        if cp[i] == "ivory" && cp[i+1] == "green" {
                                found = true
                                break
                        }
                }
                if !found {
                        continue
                }
                validColorPerms = append(validColorPerms, cp)
        }

        for _, colorPerm := range validColorPerms {
                for _, natPerm := range natPerms {
                        // Englishman lives in red house
                        engIdx := -1
                        for i, nat := range natPerm {
                                if nat == "Englishman" {
                                        engIdx = i
                                        break
                                }
                        }
                        if colorPerm[engIdx] != "red" {
                                continue
                        }
                        // Norwegian lives in first house
                        if natPerm[0] != "Norwegian" {
                                continue
                        }
                        // Norwegian next to blue house (blue must be at pos2)
                        if colorPerm[1] != "blue" {
                                continue
                        }
                        // (additional check: the Norwegian lives next to blue house is satisfied)
                        for _, petPerm := range petPerms {
                                // Spaniard owns dog
                                spanIdx := -1
                                for i, nat := range natPerm {
                                        if nat == "Spaniard" {
                                                spanIdx = i
                                                break
                                        }
                                }
                                if petPerm[spanIdx] != "dog" {
                                        continue
                                }
                                for _, drinkPerm := range drinkPerms {
                                        // Coffee drunk in green house
                                        coffeeIdx := -1
                                        for i, d := range drinkPerm {
                                                if d == "coffee" {
                                                        coffeeIdx = i
                                                        break
                                                }
                                        }
                                        if colorPerm[coffeeIdx] != "green" {
                                                continue
                                        }
                                        // Ukrainian drinks tea
                                        ukrIdx := -1
                                        for i, nat := range natPerm {
                                                if nat == "Ukrainian" {
                                                        ukrIdx = i
                                                        break
                                                }
                                        }
                                        if drinkPerm[ukrIdx] != "tea" {
                                                continue
                                        }
                                        // Milk in middle house
                                        if drinkPerm[2] != "milk" {
                                                continue
                                        }
                                        for _, smokePerm := range smokePerms {
                                                // Old Gold smoker owns snails
                                                oldGoldIdx := -1
                                                for i, s := range smokePerm {
                                                        if s == "Old Gold" {
                                                                oldGoldIdx = i
                                                                break
                                                        }
                                                }
                                                if petPerm[oldGoldIdx] != "snails" {
                                                        continue
                                                }
                                                // Kools in yellow house
                                                koolsIdx := -1
                                                for i, s := range smokePerm {
                                                        if s == "Kools" {
                                                                koolsIdx = i
                                                                break
                                                        }
                                                }
                                                if colorPerm[koolsIdx] != "yellow" {
                                                        continue
                                                }
                                                // Chesterfields next to fox
                                                chesterIdx := -1
                                                for i, s := range smokePerm {
                                                        if s == "Chesterfields" {
                                                                chesterIdx = i
                                                                break
                                                        }
                                                }
                                                foxIdx := -1
                                                for i, p := range petPerm {
                                                        if p == "fox" {
                                                                foxIdx = i
                                                                break
                                                        }
                                                }
                                                if abs(chesterIdx-foxIdx) != 1 {
                                                        continue
                                                }
                                                // Kools next to horse
                                                horseIdx := -1
                                                for i, p := range petPerm {
                                                        if p == "horse" {
                                                                horseIdx = i
                                                                break
