use std::collections::HashMap;
use std::thread;

pub fn frequency(input: &[&str], worker_count: usize) -> HashMap<char, usize> {
    if input.is_empty() {
        return HashMap::new();
    }
    let n = input.len();
    let worker_count = worker_count.max(1); // ensure at least 1
    let chunk_size = (n + worker_count - 1) / worker_count;
    let mut handles = Vec::with_capacity(worker_count);
    // Use scope to borrow input
    thread::scope(|s| {
        for i in 0..worker_count {
            let start = i * chunk_size;
            if start >= n { break; }
            let end = (start + chunk_size).min(n);
            let chunk = &input[start..end];
            // spawn a thread
            let handle = s.spawn(move || {
                let mut local_counts = HashMap::new();
                for text in chunk {
                    for ch in text.chars() {
                        *local_counts.entry(ch).or_insert(0) += 1;
                    }
                }
                local_counts
            });
            handles.push(handle);
        }
        // Combine results
        let mut final_counts: HashMap<char, usize> = HashMap::new();
        for handle in handles {
            let local = handle.join();
            // merge
            for (k, v) in local {
                *final_counts.entry(k).or_insert(0) += v;
            }
        }
        final_counts
    })
}
```

