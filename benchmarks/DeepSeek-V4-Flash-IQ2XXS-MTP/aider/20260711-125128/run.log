        raise ValueError("Invalid start bucket")

    # initial state
    if start_is_one:
        a = cap1
        b = 0
    else:
        a = 0
        b = cap2
    steps = 1

    from collections import deque
    q = deque()
    q.append((a, b, steps))
    visited = set()
    visited.add((a, b))

    while q:
        a, b, steps = q.popleft()
        # Check if goal is reached
        if a == goal:
            return (steps, "one", b)
        if b == goal:
            return (steps, "two", a)

        # Generate all possible actions
        actions = []

        # Fill bucket one
        actions.append((cap1, b))
        # Fill bucket two
        actions.append((a, cap2))
        # Empty bucket one
        actions.append((0, b))
        # Empty bucket two
        actions.append((a, 0))

        # Pour from bucket one to bucket two
        pour = min(a, cap2 - b)
