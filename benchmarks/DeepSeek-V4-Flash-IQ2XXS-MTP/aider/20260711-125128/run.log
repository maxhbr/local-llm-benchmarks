from json import dumps
from collections import deque


class Tree:
    def __init__(self, label, children=None):
        self.label = label
        self.children = children if children is not None else []

    def __dict__(self):
        return {self.label: [c.__dict__() for c in sorted(self.children)]}

    def __str__(self, indent=None):
        return dumps(self.__dict__(), indent=indent)

    def __lt__(self, other):
        return self.label < other.label

    def __eq__(self, other):
        return self.__dict__() == other.__dict__()

    def from_pov(self, from_node):
        # Build undirected adjacency and collect all labels
        adj = {}
        labels = set()

        def walk(node, parent):
            labels.add(node.label)
            if node.label not in adj:
                adj[node.label] = []
            if parent is not None:
                adj[node.label].append(parent)
                adj[parent].append(node.label)
            for child in node.children:
                walk(child, node.label)

        walk(self, None)

        if from_node not in labels:
            raise ValueError("Tree could not be reoriented")

        # Recursively build new tree rooted at from_node
        def build(label, parent_label):
            children = []
            for neighbor in adj[label]:
                if neighbor != parent_label:
                    child_tree = build(neighbor, label)
                    children.append(child_tree)
            children.sort(key=lambda x: x.label)
            return Tree(label, children)

        return build(from_node, None)

    def path_to(self, from_node, to_node):
        # Build undirected adjacency and collect all labels
        adj = {}
        labels = set()

        def walk(node, parent):
            labels.add(node.label)
            if node.label not in adj:
                adj[node.label] = []
            if parent is not None:
                adj[node.label].append(parent)
                adj[parent].append(node.label)
            for child in node.children:
                walk(child, node.label)

        walk(self, None)

        if from_node not in labels or to_node not in labels:
            raise ValueError("No path found")

        if from_node == to_node:
            return [from_node]

        # BFS to find the unique path
        visited = {from_node}
        predecessor = {from_node: None}
        queue = deque([from_node])

        while queue:
            cur = queue.popleft()
            for neighbor in adj.get(cur, []):
                if neighbor not in visited:
                    visited.add(neighbor)
                    predecessor[neighbor] = cur
                    if neighbor == to_node:
                        # reconstruct path
                        path = []
                        node = to_node
                        while node is not None:
                            path.append(node)
                            node = predecessor[node]
                        path.reverse()
                        return path
                    queue.append(neighbor)

        # Should not happen in a connected tree
        raise ValueError("No path found")
