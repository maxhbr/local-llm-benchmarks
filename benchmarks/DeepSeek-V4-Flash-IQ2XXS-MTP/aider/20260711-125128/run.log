use std::collections::HashMap;

/// Count occurrences of words.
pub fn word_count(words: &str) -> HashMap<String, u32> {
    let lower = words.to_lowercase();
    let mut chars = lower.chars().peekable();
    let mut result = HashMap::new();
    let mut word = String::new();

    loop {
        match chars.next() {
            None => {
                if !word.is_empty() {
                    *result.entry(word.clone()).or_insert(0) += 1;
                }
                break;
            }
            Some(c) => {
                if c.is_alphanumeric() {
                    word.push(c);
                } else if c == '\'' {
                    // apostrophe: include only if it is inside a word (word not empty and next char alphanumeric)
                    if !word.is_empty() && chars.peek().map_or(false, |&n| n.is_alphanumeric()) {
                        word.push(c);
                    } else {
                        // treat as separator
                        if !word.is_empty() {
                            *result.entry(word.clone()).or_insert(0) += 1;
                            word.clear();
                        }
                    }
                } else {
                    // any other character (punctuation or whitespace) acts as separator
                    if !word.is_empty() {
                        *result.entry(word.clone()).or_insert(0) += 1;
                        word.clear();
                    }
                }
            }
        }
    }

    result
}
```
