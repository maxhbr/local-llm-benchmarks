Implementation details:

func generatePermutations(values []string) [][]string {
    result := [][]string{}
    used := make([]bool, len(values))
    current := make([]string, len(values))
    var backtrack func(pos int)
    backtrack = func(pos int) {
        if pos == len(values) {
            perm := make([]string, len(values))
            copy(perm, current)
            result = append(result, perm)
            return
        }
        for i, v := range values {
            if used[i] { continue }
            used[i] = true
            current[pos] = v
            backtrack(pos+1)
            used[i] = false
        }
    }
