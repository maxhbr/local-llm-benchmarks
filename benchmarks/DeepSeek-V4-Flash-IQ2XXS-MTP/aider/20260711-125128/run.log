let flags = {
  lineNumbers: false,
  filesWithMatch: false,
  ignoreCase: false,
  invert: false,
  matchEntireLine: false,
};
let filePaths = [];
for (let i = 1; i < args.length; i++) {
  const arg = args[i];
  if (arg.startsWith('-')) {
    for (let j = 1; j < arg.length; j++) {
      const ch = arg[j];
      switch (ch) {
        case 'n': flags.lineNumbers = true; break;
        case 'l': flags.filesWithMatch = true; break;
        case 'i': flags.ignoreCase = true; break;
        case 'v': flags.invert = true; break;
        case 'x': flags.matchEntireLine = true; break;
        default: // ignore unknown flags
      }
    }
  } else {
    filePaths.push(arg);
  }
}
if (filePaths.length === 0) {
  console.error('Usage: grep pattern [flags] file...');
  process.exit(1);
}

const outputLines = [];
for (let f = 0; f < filePaths.length; f++) {
  const filePath = filePaths[f];
  let lines;
  try {
    lines = readLines(filePath);
  } catch (e) {
    console.error(`grep: ${filePath}: ${e.message}`);
    process.exit(1);
  }
  let fileHasMatch = false;
  for (let lineIdx = 0; lineIdx < lines.length; lineIdx++) {
    const line = lines[lineIdx];
    const compareStr = flags.ignoreCase ? line.toLowerCase() : line;
    const searchStr = flags.ignoreCase ? searchString.toLowerCase() : searchString;
    let match;
    if (flags.matchEntireLine) {
      match = compareStr === searchStr;
    } else {
      match = compareStr.includes(searchStr);
    }
    if (flags.invert) match = !match;
    if (match) fileHasMatch = true;
    if (!flags.filesWithMatch && match) {
      let prefix;
      if (filePaths.length > 1) {
        if (flags.lineNumbers) {
          prefix = `${filePath}:${lineIdx + 1}:`;
        } else {
          prefix = `${filePath}:`;
        }
      } else {
        if (flags.lineNumbers) {
          prefix = `${lineIdx + 1}:`;
        } else {
          prefix = '';
        }
      }
      outputLines.push(prefix + line);
    }
  }
  if (flags.filesWithMatch && fileHasMatch) {
    console.log(filePath);
  }
}
if (!flags.filesWithMatch) {
  for (const line of outputLines) {
    console.log(line);
  }
}
