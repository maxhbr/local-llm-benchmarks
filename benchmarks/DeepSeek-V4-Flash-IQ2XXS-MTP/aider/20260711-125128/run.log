food_chain.go
```
package foodchain

import "strings"

var animals = []string{"fly", "spider", "bird", "cat", "dog", "goat", "cow", "horse"}
var comments = []string{
	"", // fly
	"It wriggled and jiggled and tickled inside her.",
	"How absurd to swallow a bird!",
	"Imagine that, to swallow a cat!",
	"What a hog, to swallow a dog!",
	"Just opened her throat and swallowed a goat!",
	"I don't know how she swallowed a cow!",
	"She's dead, of course!",
}

func Verse(v int) string {
	if v < 1 || v > 8 {
		return ""
	}
	var b strings.Builder
	b.WriteString("I know an old lady who swallowed a ")
	b.WriteString(animals[v-1])
	b.WriteString(".\n")
	if v == 8 {
		b.WriteString("She's dead, of course!")
		return b.String()
	}
	if v > 1 {
		b.WriteString(comments[v-1])
		b.WriteString("\n")
	}
	// Build cumulative chain from the current animal down to the fly
	for i := v; i > 1; i-- {
		b.WriteString("She swallowed the ")
		b.WriteString(animals[i-1])
		b.WriteString(" to catch the ")
		b.WriteString(animals[i-2])
		// Add spider's special phrase when the prey is a spider
		if i-2 == 1 {
			b.WriteString(" that wriggled and jiggled and tickled inside her")
		}
		b.WriteString(".\n")
	}
	b.WriteString("I don't know why she swallowed the fly. Perhaps she'll die.")
	return b.String()
}

func Verses(start, end int) string {
	var b strings.Builder
	for v := start; v <= end; v++ {
		b.WriteString(Verse(v))
		if v < end {
			b.WriteString("\n")
		}
	}
	return b.String()
}

func Song() string {
	return Verses(1, 8)
}
```
