def solve():
    global _solution
    if _solution is not None:
        return _solution

    colors = ['red', 'green', 'ivory', 'yellow', 'blue']
    nationalities = ['Englishman', 'Spaniard', 'Ukrainian', 'Norwegian', 'Japanese']
    pets = ['dog', 'snail', 'fox', 'horse', 'zebra']
    drinks = ['coffee', 'tea', 'milk', 'orange juice', 'water']
    hobbies = ['dancing', 'painter', 'reading', 'football', 'chess']

    for col in itertools.permutations(colors):
        # Constraint 6: green house is immediately to the right of ivory house
        idx_green = col.index('green')
        idx_ivory = col.index('ivory')
        if idx_green != idx_ivory + 1:
            continue
        # Constraint 15: Norwegian lives next to blue house -> house 2 must be blue
        if col[1] != 'blue':
            continue

        # Nationalities with Norwegian fixed at house 1 (index 0)
        nat_list = [n for n in nationalities if n != 'Norwegian']
        for nat_perm in itertools.permutations(nat_list):
            nat = ('Norwegian',) + nat_perm

            # Constraint 2: Englishman lives in red house
            idx_eng = nat.index('Englishman')
            if col[idx_eng] != 'red':
                continue

            # Fixed drink positions
            idx_ukr = nat.index('Ukrainian')
            idx_mid = 2   # house 3 (index 2)
            if len({idx_green, idx_ukr, idx_mid}) != 3:
                continue

            # Build drinks array
            # Remaining houses get water and orange juice
            all_indices = set(range(5))
            fixed_indices = {idx_green, idx_ukr, idx_mid}
            remaining_indices = list(all_indices - fixed_indices)
            rem_drinks = ['water', 'orange juice']
            for d1, d2 in itertools.permutations(rem_drinks, 2):
                drink = [None] * 5
                drink[idx_green] = 'coffee'
                drink[idx_ukr] = 'tea'
                drink[idx_mid] = 'milk'
                drink[remaining_indices[0]] = d1
                drink[remaining_indices[1]] = d2

                # Pets: dog belongs to Spaniard
                idx_spa = nat.index('Spaniard')
                remaining_pet_indices = list(all_indices - {idx_spa})
                pet_list_remaining = [p for p in pets if p != 'dog']
                for pet_perm in itertools.permutations(pet_list_remaining):
                    pet = [None] * 5
                    pet[idx_spa] = 'dog'
                    for i, idx in enumerate(remaining_pet_indices):
                        pet[idx] = pet_perm[i]

                    # Fixed hobby positions
                    idx_snail = pet.index('snail')
                    idx_yellow = col.index('yellow')
                    idx_jap = nat.index('Japanese')
                    idx_orange = drink.index('orange juice')
                    fixed_hobby_indices = {idx_snail, idx_yellow, idx_jap, idx_orange}
                    if len(fixed_hobby_indices) != 4:
                        continue

                    hobby = [None] * 5
                    hobby[idx_snail] = 'dancing'
                    hobby[idx_yellow] = 'painter'
                    hobby[idx_jap] = 'chess'
                    hobby[idx_orange] = 'football'
                    remaining_hobby_index = list(set(range(5)) - fixed_hobby_indices)[0]
                    hobby[remaining_hobby_index] = 'reading'

                    # Constraint 11: reading next to fox
                    idx_reading = hobby.index('reading')
                    idx_fox = pet.index('fox')
                    if abs(idx_reading - idx_fox) != 1:
                        continue

                    # Constraint 12: painter next to horse
                    idx_painter = hobby.index('painter')
                    idx_horse = pet.index('horse')
                    if abs(idx_painter - idx_horse) != 1:
                        continue

                    # All constraints satisfied – found a solution
                    water_idx = drink.index('water')
                    water_drinker = nat[water_idx]
                    zebra_idx = pet.index('zebra')
                    zebra_owner = nat[zebra_idx]
                    _solution = (water_drinker, zebra_owner)
                    return _solution

    # Should never happen for a well‑defined puzzle
    _solution = (None, None)
    return _solution
