package matrix

import (
        "fmt"
        "strconv"
        "strings"
)

type Matrix struct {
        data [][]int
        rows int
        cols int
}

func New(s string) (*Matrix, error) {
        lines := strings.Split(s, "\n")
        var data [][]int
        var width int
        for _, line := range lines {
                trimmed := strings.TrimSpace(line)
                if trimmed == "" {
                        continue
                }
                tokens := strings.Fields(trimmed)
                if len(tokens) == 0 {
                        continue
                }
                row := make([]int, len(tokens))
                for j, tok := range tokens {
                        val, err := strconv.Atoi(tok)
                        if err != nil {
                                return nil, fmt.Errorf("invalid number: %s", tok)
                        }
                        row[j] = val
                }
                if len(data) == 0 {
                        width = len(row)
                } else if len(row) != width {
                        return nil, fmt.Errorf("inconsistent column count")
                }
                data = append(data, row)
        }
        if len(data) == 0 {
                return nil, fmt.Errorf("empty matrix")
        }
        return &Matrix{data: data, rows: len(data), cols: width}, nil
}

func (m *Matrix) Cols() [][]int {
        cols := make([][]int, m.cols)
        for c := 0; c < m.cols; c++ {
                col := make([]int, m.rows)
                for r := 0; r < m.rows; r++ {
                        col[r] = m.data[r][c]
