def proverb(items, qualifier="And"):
    lines = []
    for first, second in zip(items, items[1:]):
        lines.append(f"For want of a {first} the {second} was lost.")
    
    lines.append(f"{qualifier} all for the want of a {items[0]}.")
    
    return "\n".join(lines)
```
