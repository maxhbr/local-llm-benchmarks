import java.util.HashMap;
import java.util.Map;
import java.util.Optional;
import java.util.Set;

class WordSearcher {
    Map<String, Optional<WordLocation>> search(final Set<String> words, final char[][] grid) {
        Map<String, Optional<WordLocation>> results = new HashMap<>();
        if (grid == null || grid.length == 0 || grid[0].length == 0) {
            for (String word : words) {
                results.put(word, Optional.empty());
            }
            return results;
        }

        int rows = grid.length;
        int cols = grid[0].length;

        int[][] directions = {
            {0, 1},   // Right
            {0, -1},  // Left
            {1, 0},   // Down
            {-1, 0},  // Up
            {1, 1},   // Down-Right
            {1, -1},  // Down-Left
            {-1, 1},  // Up-Right
            {-1, -1}  // Up-Left
        };

        for (String word : words) {
            results.put(word, findWord(word, grid, rows, cols, directions));
        }

        return results;
    }

    private Optional<WordLocation> findWord(String word, char[][] grid, int rows, int cols, int[][] directions) {
        if (word == null || word.isEmpty()) {
            return Optional.empty();
        }

        for (int r = 0; r < rows; r++) {
            for (int c = 0; c < cols; c++) {
                if (grid[r][c] == word.charAt(0)) {
                    for (int[] dir : directions) {
                        int dr = dir[0];
                        int dc = dir[1];
                        
                        if (canFindWord(word, grid, r, c, dr, dc, rows, cols)) {
                            int endR = r + (word.length() - 1) * dr;
                            int endC = c + (word.length() - 1) * dc;
                            return Optional.of(new WordLocation(new Pair(r, c), new Pair(endR, endC)));
                        }
                    }
                }
            }
        }
        return Optional.empty();
    }

    private boolean canFindWord(String word, char[][] grid, int r, int c, int dr, int dc, int rows, int cols) {
        for (int i = 1; i < word.length(); i++) {
            int currR = r + i * dr;
            int currC = c + i * dc;

            if (currR < 0 || currR >= rows || currC < 0 || currC >= cols || grid[currR][currC] != word.charAt(i)) {
                return false;
            }
        }
        return true;
    }
}
