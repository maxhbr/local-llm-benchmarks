// The code below is a stub. Just enough to satisfy the compiler.
// In order to pass the tests you can add-to or change any of this code.

#[derive(Debug, PartialEq, Eq)]
pub enum Error {
    InvalidRowCount(usize),
    InvalidColumnCount(usize),
}

pub fn convert(input: &str) -> Result<String, Error> {
    if input.is_empty() {
        return Ok("".to_string());
    }

    let lines: Vec<&str> = input.lines().collect();
    let mut results = Vec::new();
    let mut i = 0;

    while i < lines.len() {
        // A block must be 4 lines high
        if i + 4 > lines.len() {
            return Err(Error::InvalidRowCount(lines.len() - i));
        }

        let block = &lines[i..i + 4];
        
        // Determine the width of the block based on the first 3 lines
        let mut max_width = 0;
        for j in 0..3 {
            if block[j].len() > max_width {
                max_width = block[j].len();
            }
        }

        if max_width % 3 != 0 {
            return Err(Error::InvalidColumnCount(max_width));
        }

        // Convert lines to Vec<char> for efficient indexing
        let char_lines: Vec<Vec<char>> = block.iter().map(|l| l.chars().collect()).collect();
        let mut current_row_string = String::new();

        for col in (0..max_width).step_by(3) {
            let mut chunk = [String::new(), String::new(), String::new()];
            for row in 0..3 {
                let mut part = String::new();
                for char_idx in col..col + 3 {
                    if char_idx < char_lines[row].len() {
                        part.push(char_lines[row][char_idx]);
                    } else {
                        part.push(' ');
                    }
                }
                chunk[row] = part;
            }

            let digit = match (chunk[0].as_str(), chunk[1].as_str(), chunk[2].as_str()) {
                (" _ ", "| |", "|_|") => '0',
                ("   ", "  |", "  |") => '1',
                (" _ ", " _|", "|_ ") => '2',
                (" _ ", " _|", " _|") => '3',
                ("   ", "|_|", "  |") => '4',
                (" _ ", "|_ ", " _|") => '5',
                (" _ ", "|_ ", "|_|") => '6',
                (" _ ", "  |", "  |") => '7',
                (" _ ", "|_|", "|_|") => '8',
                (" _ ", "|_|", " _|") => '9',
                _ => '?',
            };
            current_row_string.push(digit);
        }
        
        results.push(current_row_string);
        i += 4;

        // Skip any blank lines between blocks of numbers
        while i < lines.len() && lines[i].trim().is_empty() {
            i += 1;
        }
    }

    Ok(results.join(","))
}
