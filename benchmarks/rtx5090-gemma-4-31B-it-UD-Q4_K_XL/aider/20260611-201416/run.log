```
import java.text.DecimalFormat;
import java.text.DecimalFormatSymbols;
import java.time.LocalDate;
import java.time.format.DateTimeFormatter;
import java.util.ArrayList;
import java.util.Arrays;
import java.util.List;

public class Ledger {
    public LedgerEntry createLedgerEntry(String d, String desc, int c) {
        LedgerEntry le = new LedgerEntry();
        le.setChange(c);
        le.setDescription(desc);
        le.setLocalDate(LocalDate.parse(d));
        return le;
    }

    public String format(String currency, String locale, LedgerEntry[] entries) {
        FormatterConfig config = getConfig(currency, locale);
        
        StringBuilder sb = new StringBuilder(config.header);

        if (entries.length > 0) {
            List<LedgerEntry> sortedEntries = new ArrayList<>(Arrays.asList(entries));
            sortedEntries.sort((e1, e2) -> {
                boolean e1Neg = e1.getChange() < 0;
                boolean e2Neg = e2.getChange() < 0;
                if (e1Neg != e2Neg) {
                    return e1Neg ? -1 : 1;
                }
                return e1.getLocalDate().compareTo(e2.getLocalDate());
            });

            for (LedgerEntry e : sortedEntries) {
                sb.append("\n").append(formatLine(e, config));
            }
        }

        return sb.toString();
    }

    private String formatLine(LedgerEntry e, FormatterConfig config) {
        String date = e.getLocalDate().format(DateTimeFormatter.ofPattern(config.datePattern));
        
        String desc = e.getDescription();
        if (desc.length() > 25) {
            desc = desc.substring(0, 22) + "...";
        }

        String amount = formatAmount(e.getChange(), config);

        return String.format("%s | %-25s | %13s", date, desc, amount);
    }

    private String formatAmount(double change, FormatterConfig config) {
        double absoluteValue = Math.abs(change / 100.0);
        DecimalFormat df = new DecimalFormat("#,##0.00", config.symbols);
        String formattedValue = df.format(absoluteValue);

        if (config.locale.equals("en-US")) {
            String amount = config.currencySymbol + formattedValue;
            return change < 0 ? "(" + amount + ")" : amount + " ";
        } else { // nl-NL
            if (change < 0) {
                return config.currencySymbol + " -" + formattedValue + " ";
            } else {
                return " " + config.currencySymbol + " " + formattedValue + " ";
            }
        }
    }

    private FormatterConfig getConfig(String currency, String locale) {
        if (!currency.equals("USD") && !currency.equals("EUR")) {
            throw new IllegalArgumentException("Invalid currency");
        }
        if (!locale.equals("en-US") && !locale.equals("nl-NL")) {
            throw new IllegalArgumentException("Invalid locale");
        }

        String symbol = currency.equals("USD") ? "$" : "вӮ¬";
        if (locale.equals("en-US")) {
            return new FormatterConfig(
                locale,
                "Date       | Description               | Change       ",
                "MM/dd/yyyy",
                symbol,
                ',',
                '.'
            );
        } else {
            return new FormatterConfig(
                locale,
                "Datum      | Omschrijving              | Verandering  ",
                "dd/MM/yyyy",
                symbol,
                '.',
                ','
            );
        }
    }

    private static class FormatterConfig {
        final String locale;
        final String header;
        final String datePattern;
        final String currencySymbol;
        final DecimalFormatSymbols symbols;

        FormatterConfig(String locale, String header, String datePattern, String currencySymbol, char thSep, char decSep) {
            this.locale = locale;
            this.header = header;
            this.datePattern = datePattern;
            this.currencySymbol = currencySymbol;
            this.symbols = new DecimalFormatSymbols();
            this.symbols.setGroupingSeparator(thSep);
            this.symbols.setDecimalSeparator(decSep);
        }
    }

    public static class LedgerEntry {
        LocalDate localDate;
        String description;
        double change;

        public LocalDate getLocalDate() {
            return localDate;
        }

        public void setLocalDate(LocalDate localDate) {
            this.localDate = localDate;
        }

        public String getDescription() {
            return description;
        }

        public void setDescription(String description) {
            this.description = description;
        }

        public double getChange() {
            return change;
        }

        public void setChange(double change) {
            this.change = change;
        }
    }
}
