lib.rs
```
use std::time::{SystemTime, UNIX_EPOCH};

pub fn encode(key: &str, s: &str) -> Option<String> {
    if key.is_empty() || !key.chars().all(|c| c.is_ascii_lowercase()) {
        return None;
    }

    let key_bytes = key.as_bytes();
    let mut key_idx = 0;
    let mut result = String::with_capacity(s.len());

    for c in s.chars() {
        if c.is_ascii_lowercase() {
            let shift = key_bytes[key_idx] - b'a';
            let shifted = ((c as u8 - b'a' + shift) % 26) + b'a';
            result.push(shifted as char);
            key_idx = (key_idx + 1) % key_bytes.len();
        } else {
            result.push(c);
        }
    }

    Some(result)
}

pub fn decode(key: &str, s: &str) -> Option<String> {
    if key.is_empty() || !key.chars().all(|c| c.is_ascii_lowercase()) {
        return None;
    }

    let key_bytes = key.as_bytes();
    let mut key_idx = 0;
    let mut result = String::with_capacity(s.len());

    for c in s.chars() {
        if c.is_ascii_lowercase() {
            let shift = key_bytes[key_idx] - b'a';
            let shifted = ((c as u8 - b'a' + 26 - shift) % 26) + b'a';
            result.push(shifted as char);
            key_idx = (key_idx + 1) % key_bytes.len();
        } else {
            result.push(c);
        }
    }

    Some(result)
}

pub fn encode_random(s: &str) -> (String, String) {
    let seed = SystemTime::now()
        .duration_since(UNIX_EPOCH)
        .expect("Time went backwards")
        .as_nanos() as u64;

    let mut state = seed;
    let key: String = (0..100)
        .map(|_| {
            // Simple LCG multiplier and increment
            state = state.wrapping_mul(6364136223846793005).wrapping_add(1);
            ((state % 26) as u8 + b'a') as char
        })
        .collect();

    let encoded = encode(&key, s).expect("Generated key should be valid");
    (key, encoded)
}
```
