// This exercise is deprecated.
// Consider working on protein-translation instead.

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub struct Error;

pub struct CodonsInfo<'a> {
    pairs: Vec<(&'a str, &'a str)>,
}

impl<'a> CodonsInfo<'a> {
    pub fn name_for(&self, codon: &str) -> Result<&'a str, Error> {
        if codon.chars().count() != 3 {
            return Err(Error);
        }

        for (full_codon, name) in &self.pairs {
            if full_codon.len() != 3 {
                continue;
            }

            let mut is_match = true;
            for (s_char, f_char) in codon.chars().zip(full_codon.chars()) {
                if !char_matches(s_char, f_char) {
                    is_match = false;
                    break;
                }
            }

            if is_match {
                return Ok(*name);
            }
        }

        Err(Error)
    }

    pub fn of_rna(&self, rna: &str) -> Result<Vec<&'a str>, Error> {
        let chars: Vec<char> = rna.chars().collect();
        if chars.len() % 3 != 0 {
            return Err(Error);
        }

        let mut proteins = Vec::new();
        for chunk in chars.chunks(3) {
            let codon: String = chunk.iter().collect();
            proteins.push(self.name_for(&codon)?);
        }

        Ok(proteins)
    }
}

pub fn parse<'a>(pairs: Vec<(&'a str, &'a str)>) -> CodonsInfo<'a> {
    CodonsInfo { pairs }
}

fn char_matches(s: char, f: char) -> bool {
    let s_norm = if s == 'U' { 'T' } else { s };
    let f_norm = if f == 'U' { 'T' } else { f };

    if s_norm == f_norm {
        return true;
    }

    let allowed = match s_norm {
        'R' => "AG",
        'Y' => "CT",
        'S' => "GC",
        'W' => "AT",
        'K' => "GT",
        'M' => "AC",
        'B' => "CGT",
        'D' => "AGT",
        'H' => "ACT",
        'V' => "ACG",
        'N' => "ACGT",
        _ => "",
    };

    allowed.chars().any(|c| c == f_norm)
}
```
