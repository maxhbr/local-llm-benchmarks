food_chain.py
```
def recite(start_verse, end_verse):
    animals = ["fly", "spider", "bird", "cat", "dog", "goat", "cow", "horse"]
    comments = {
        "spider": "It wriggled and jiggled and tickled inside her.",
        "bird": "How absurd to swallow a bird!",
        "cat": "Imagine that, to swallow a cat!",
        "dog": "What a hog, to swallow a dog!",
        "goat": "Just opened her throat and swallowed a goat!",
        "cow": "I don't know how she swallowed a cow!",
    }
    spider_modifier = "that wriggled and jiggled and tickled inside her"

    verses = []
    for v in range(start_verse, end_verse + 1):
        lines = []
        animal = animals[v - 1]
        lines.append(f"I know an old lady who swallowed a {animal}.")

        if v == 8:
            lines.append("She's dead, of course!")
        else:
            if v > 1:
                lines.append(comments[animal])
            
            for j in range(v - 1, 0, -1):
                current_animal = animals[j]
                prev_animal = animals[j - 1]
                if prev_animal == "spider":
                    lines.append(f"She swallowed the {current_animal} to catch the spider {spider_modifier}.")
                else:
                    lines.append(f"She swallowed the {current_animal} to catch the {prev_animal}.")
            
            lines.append("I don't know why she swallowed the fly. Perhaps she'll die.")
        
        verses.append("\n".join(lines))

    return "\n\n".join(verses)
```
