clock.cpp
```
#include "clock.h"
#include <iomanip>
#include <sstream>

namespace date_independent {

Clock::Clock(int hours, int minutes) {
    // Use long long to prevent overflow during calculation
    long long total = static_cast<long long>(hours) * 60 + minutes;
    total_minutes_ = static_cast<int>((total % MINUTES_IN_DAY + MINUTES_IN_DAY) % MINUTES_IN_DAY);
}

void Clock::add_minutes(int minutes) {
    // Use long long for intermediate calculation to prevent overflow before modulo
    long long new_total = static_cast<long long>(total_minutes_) + minutes;
    total_minutes_ = static_cast<int>((new_total % MINUTES_IN_DAY + MINUTES_IN_DAY) % MINUTES_IN_DAY);
}

void Clock::subtract_minutes(int minutes) {
    // Subtract directly using long long to avoid overflow when negating INT_MIN
    long long new_total = static_cast<long long>(total_minutes_) - minutes;
    total_minutes_ = static_cast<int>((new_total % MINUTES_IN_DAY + MINUTES_IN_DAY) % MINUTES_IN_DAY);
}

bool Clock::operator==(const Clock& other) const noexcept {
    return total_minutes_ == other.total_minutes_;
}

bool Clock::operator!=(const Clock& other) const noexcept {
    return !(*this == other);
}

std::string Clock::to_string() const {
    int hours = total_minutes_ / 60;
    int minutes = total_minutes_ % 60;
    
    std::ostringstream oss;
    oss << std::setfill('0') << std::setw(2) << hours << ":"
        << std::setfill('0') << std::setw(2) << minutes;
    return oss.str();
}

}  // namespace date_independent
```
