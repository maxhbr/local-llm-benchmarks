response:
To solve the alphametics puzzle, we need to find a unique digit (0-9) for each letter such that the sum of the addends equals the result word, with the constraint that the leading digit of any multi-digit number cannot be zero.

The most efficient way to implement this is to:
1. Parse the input string to identify all unique letters and the words involved.
2. Calculate a "weight" for each letter. For example, in `SEND + MORE = MONEY`, the letter `S` in `SEND` has a weight of $1000$, while the `M` in `MONEY` has a weight of $-10000$.
3. Use a backtracking search to assign digits to letters, pruning the search space by ensuring unique assignments and respecting the leading-zero constraint.
4. Check if the weighted sum of the assigned digits equals zero.

Here is the complete implementation:

lib.rs
```rust
use std::collections::{HashMap, HashSet};

pub fn solve(input: &str) -> Option<HashMap<char, u8>> {
    // Parse the input: "SEND + MORE = MONEY"
    let parts: Vec<&str> = input.split('=').collect();
    if parts.len() != 2 {
        return None;
    }

    let left_side = parts[0].trim();
    let result_word = parts[1].trim();
    let addends: Vec<&str> = left_side.split('+').map(|s| s.trim()).collect();

    // Identify all unique letters
    let mut all_letters_set = HashSet::new();
    for word in addends.iter().chain(std::iter::once(&result_word)) {
        for c in word.chars() {
            all_letters_set.insert(c);
        }
    }

    let letters: Vec<char> = all_letters_set.into_iter().collect();
    if letters.len() > 10 {
        return None; // More than 10 unique letters cannot be mapped to 0-9
    }

    // Calculate weights for each letter
    // Weight is the contribution of the letter to the total sum
    // (Sum of addends) - (Result) = 0
    let mut weights_map = HashMap::new();
    for word in &addends {
        let mut power = 1i64;
        for c in word.chars().rev() {
            *weights_map.entry(c).or_insert(0) += power;
            power *= 10;
        }
    }
    let mut power = 1i64;
    for c in result_word.chars().rev() {
        *weights_map.entry(c).or_insert(0) -= power;
        power *= 10;
    }

    let weights: Vec<i64> = letters.iter().map(|c| *weights_map.get(c).unwrap()).collect();

    // Identify letters that cannot be zero (leading digits of multi-digit numbers)
    let mut leading_letters = HashSet::new();
    for word in addends.iter().chain(std::iter::once(&result_word)) {
        if word.len() > 1 {
            if let Some(first_char) = word.chars().next() {
                leading_letters.insert(first_char);
            }
        }
    }

    let mut mapping = HashMap::new();
    let mut used_digits = [false; 10];

    if backtrack(0, 0, &letters, &weights, &mut mapping, &mut used_digits, &leading_letters) {
        Some(mapping)
    } else {
        None
    }
}

fn backtrack(
    idx: usize,
    current_sum: i64,
    letters: &[char],
    weights: &[i64],
    mapping: &mut HashMap<char, u8>,
    used_digits: &mut [bool; 10],
    leading_letters: &HashSet<char>,
) -> bool {
    if idx == letters.len() {
        return current_sum == 0;
    }

    let c = letters[idx];
    let w = weights[idx];

    for digit in 0..10 {
        if used_digits[digit] {
            continue;
        }

        // Leading digit of a multi-digit number must not be zero
        if digit == 0 && leading_letters.contains(&c) {
            continue;
        }

        used_digits[digit] = true;
        mapping.insert(c, digit as u8);

        if backtrack(
            idx + 1,
            current_sum + (digit as i64 * w),
            letters,
            weights,
            mapping,
            used_digits,
            leading_letters,
        ) {
            return true;
        }

        mapping.remove(&c);
        used_digits[digit] = false;
    }

    false
}
