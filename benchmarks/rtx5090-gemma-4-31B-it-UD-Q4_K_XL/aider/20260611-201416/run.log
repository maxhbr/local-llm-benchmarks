To implement the territory counting logic for a Go board, we need to identify connected components of empty intersections and determine if they are completely surrounded by stones of a single player.

Here is the complete implementation:

GoCounting.java
```
import java.awt.Point;
import java.util.*;

enum Player {
    BLACK, WHITE
}

class GoCounting {
    private final char[][] grid;
    private final int rows;
    private final int cols;

    GoCounting(String board) {
        String[] lines = board.split("\\r?\\n");
        this.rows = lines.length;
        this.cols = (rows > 0) ? lines[0].length() : 0;
        this.grid = new char[rows][cols];
        for (int i = 0; i < rows; i++) {
            char[] rowChars = lines[i].toCharArray();
            for (int j = 0; j < cols; j++) {
                this.grid[i][j] = (j < rowChars.length) ? rowChars[j] : ' ';
            }
        }
    }

    Player getTerritoryOwner(int x, int y) {
        if (isStone(x, y)) {
            return null;
        }
        Set<Point> component = findComponent(x, y);
        return determineOwner(component);
    }

    Set<Point> getTerritory(int x, int y) {
        if (isStone(x, y)) {
            return Collections.emptySet();
        }
        Set<Point> component = findComponent(x, y);
        if (determineOwner(component) != null) {
            return component;
        }
        return Collections.emptySet();
    }

    Map<Player, Set<Point>> getTerritories() {
        Map<Player, Set<Point>> result = new HashMap<>();
        boolean[][] visited = new boolean[rows][cols];
        for (int y = 0; y < rows; y++) {
            for (int x = 0; x < cols; x++) {
                if (!isStone(x, y) && !visited[y][x]) {
                    Set<Point> component = findComponentWithVisited(x, y, visited);
                    Player owner = determineOwner(component);
                    if (owner != null) {
                        result.computeIfAbsent(owner, k -> new HashSet<>()).addAll(component);
                    }
                }
            }
        }
        return result;
    }

    private boolean isStone(int x, int y) {
        if (x < 0 || x >= cols || y < 0 || y >= rows) {
            return false;
        }
        char cell = grid[y][x];
        return cell == 'B' || cell == 'W';
    }

    private Set<Point> findComponent(int x, int y) {
        return findComponentWithVisited(x, y, new boolean[rows][cols]);
    }

    private Set<Point> findComponentWithVisited(int startX, int startY, boolean[][] visited) {
        Set<Point> component = new HashSet<>();
        Queue<Point> queue = new LinkedList<>();
        Point start = new Point(startX, startY);
        
        queue.add(start);
        component.add(start);
        visited[startY][startX] = true;

        int[] dx = {1, -1, 0, 0};
        int[] dy = {0, 0, 1, -1};

        while (!queue.isEmpty()) {
            Point p = queue.poll();
            for (int i = 0; i < 4; i++) {
                int nx = p.x + dx[i];
                int ny = p.y + dy[i];
                if (nx >= 0 && nx < cols && ny >= 0 && ny < rows && !isStone(nx, ny) && !visited[ny][nx]) {
                    visited[ny][nx] = true;
                    Point next = new Point(nx, ny);
                    component.add(next);
                    queue.add(next);
                }
            }
        }
        return component;
    }

    private Player determineOwner(Set<Point> component) {
        Player owner = null;
        int[] dx = {1, -1, 0, 0};
        int[] dy = {0, 0, 1, -1};

        for (Point p : component) {
            for (int i = 0; i < 4; i++) {
                int nx = p.x + dx[i];
                int ny = p.y + dy[i];
                if (nx >= 0 && nx < cols && ny >= 0 && ny < rows) {
                    char cell = grid[ny][nx];
                    if (cell == 'B' || cell == 'W') {
                        Player stonePlayer = (cell == 'B') ? Player.BLACK : Player.WHITE;
                        if (owner == null) {
                            owner = stonePlayer;
                        } else if (owner != stonePlayer) {
                            return null; // Bordered by both players
                        }
                    }
                }
            }
        }
        return owner; // Returns null if no stones surround the component
    }
}
