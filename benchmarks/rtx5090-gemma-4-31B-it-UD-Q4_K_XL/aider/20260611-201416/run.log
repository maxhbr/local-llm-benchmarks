    use std::collections::HashMap;
    use std::thread;

    pub fn frequency(input: &[&str], worker_count: usize) -> HashMap<char, usize> {
        if input.is_empty() {
            return HashMap::new();
        }

        // Adjust worker_count if it's 0 or larger than input length
        let actual_worker_count = if worker_count == 0 {
            1
        } else if worker_count > input.len() {
            input.len()
        } else {
            worker_count
        };

        let chunk_size = (input.len() + actual_worker_count - 1) / actual_worker_count;

        thread::scope(|s| {
            let mut handles = Vec::new();

            for chunk in input.chunks(chunk_size) {
                let handle = s.spawn(move || {
                    let mut map = HashMap::new();
                    for text in chunk {
                        for c in text.chars() {
                            *map.entry(c).or_insert(0) += 1;
                        }
                    }
                    map
                });
                handles.push(handle);
            }

            let mut total_freq = HashMap::new();
            for handle in handles {
                let worker_map = handle.join().unwrap();
                for (c, count) in worker_map {
                    *total_freq.entry(c).or_insert(0) += count;
                }
            }
            total_freq
        })
    }
