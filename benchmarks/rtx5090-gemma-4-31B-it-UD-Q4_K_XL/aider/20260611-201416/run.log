+      for (let r = 0; r < rows; r++) {
+        if (this.board[r][0] === player) {
+          queue.push([r, 0]);
+          visited.add(`${r},0`);
+        }
+      }
+    }
+
+    const neighbors = [
+      [-1, 0],  // Up
+      [-1, 1],  // Up-Right
+      [0, -1],  // Left
+      [0, 1],   // Right
+      [1, -1],  // Down-Left
+      [1, 0],   // Down
+    ];
+
+    while (queue.length > 0) {
+      const [r, c] = queue.shift();
+
