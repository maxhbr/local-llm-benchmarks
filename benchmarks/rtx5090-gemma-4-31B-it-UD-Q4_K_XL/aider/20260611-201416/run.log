KindergartenGarden.java
```
import java.util.ArrayList;
import java.util.Arrays;
import java.util.List;

class KindergartenGarden {
    private final List<String> plantRows;
    private final String[] students = {
        "Alice", "Bob", "Charlie", "David", "Eve", "Fred", 
        "Ginny", "Harriet", "Ileana", "Joseph", "Kincaid", "Larry"
    };

    KindergartenGarden(String garden) {
        // Remove all characters that are not plant encodings (G, C, R, V)
        String plantsOnly = garden.replaceAll("[^GCRV]", "");
        
        // The garden consists of two rows of 24 plants each
        String row1 = plantsOnly.substring(0, 24);
        String row2 = plantsOnly.substring(24, 48);
        
        this.plantRows = Arrays.asList(row1, row2);
    }

    List<Plant> getPlantsOfStudent(String student) {
        int studentIndex = Arrays.asList(students).indexOf(student);
        if (studentIndex == -1) {
            throw new IllegalArgumentException("Student not found in the class list.");
        }

        List<Plant> plants = new ArrayList<>();
        int startIdx = studentIndex * 2;
        
        // Each student has two plants in the first row
        plants.add(charToPlant(plantRows.get(0).charAt(startIdx)));
        plants.add(charToPlant(plantRows.get(0).charAt(startIdx + 1)));
        
        // And two plants in the second row
        plants.add(charToPlant(plantRows.get(1).charAt(startIdx)));
        plants.add(charToPlant(plantRows.get(1).charAt(startIdx + 1)));
        
        return plants;
    }

    private Plant charToPlant(char c) {
        switch (c) {
            case 'G': return Plant.GRASS;
            case 'C': return Plant.CLOVER;
            case 'R': return Plant.RADISH;
            case 'V': return Plant.VIOLET;
            default: throw new IllegalArgumentException("Unknown plant encoding: " + c);
        }
    }
}
```
