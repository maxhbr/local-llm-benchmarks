                return Err(Error::InvalidRowCount(lines.len() - i));
            }

            let block = &lines[i..i + 4];
            let mut max_width = 0;
            for j in 0..3 {
                if block[j].len() > max_width {
                    max_width = block[j].len();
                }
            }

            if max_width % 3 != 0 {
                return Err(Error::InvalidColumnCount(max_width));
            }

            let mut current_row_string = String::new();
            for col in (0..max_width).step_by(3) {
                let mut chunk = [String::new(), String::new(), String::new()];
                for row in 0..3 {
                    let start = col;
                    let end = col + 3;
                    let line = block[row];
                    let mut part = String::new();
                    for char_idx in start..end {
                        if char_idx < line.len() {
                            part.push(line.chars().nth(char_idx).unwrap());
                        } else {
                            part.push(' ');
                        }
                    }
                    chunk[row] = part;
                }

                let digit = match (chunk[0].as_str(), chunk[1].as_str(), chunk[2].as_str()) {
                    (" _ ", "| |", "|_|") => '0',
                    ("   ", "  |", "  |") => '1',
                    (" _ ", " _|", "|_ ") => '2',
                    (" _ ", " _|", " _|") => '3',
                    ("   ", "|_|", "  |") => '4',
                    (" _ ", "|_ ", " _|") => '5',
                    (" _ ", "|_ ", "|_|") => '6',
                    (" _ ", "  |", "  |") => '7',
                    (" _ ", "|_|", "|_|") => '8',
                    (" _ ", "|_|", " _|") => '9',
                    _ => '?',
                };
                current_row_string.push(digit);
            }
            results.push(current_row_string);
            i += 4;
            if i < lines.len() && lines[i].trim().is_empty() {
                i += 1;
            }
        }

        Ok(results.join(","))
    }
