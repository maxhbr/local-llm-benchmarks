        return self._value

    def next(self):
        return self._next


class LinkedList:
    def __init__(self, values=None):
        self._head = None
        self._size = 0
        if values:
            # To maintain the order of values in the linked list,
            # we push them in reverse order so the first value becomes the head.
            for value in reversed(list(values)):
                self.push(value)

    def __iter__(self):
        current = self._head
        while current:
            yield current.value()
            current = current.next()

    def __len__(self):
        return self._size

    def head(self):
        return self._head

    def push(self, value):
        new_node = Node(value)
        new_node._next = self._head
        self._head = new_node
        self._size += 1

    def pop(self):
        if self._head is None:
            raise EmptyListException("The list is empty.")
        
        popped_node = self._head
        self._head = self._head.next()
        self._size -= 1
        return popped_node.value()

    def reversed(self):
        # Create a new list. By iterating through the current list and 
        # pushing each value onto the new list, the order is reversed.
        new_list = LinkedList()
        for value in self:
            new_list.push(value)
        return new_list
