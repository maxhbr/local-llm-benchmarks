```
use std::collections::HashMap;

pub type Value = i32;
pub type Result = std::result::Result<(), Error>;

pub struct Forth {
    stack: Vec<Value>,
    dictionary: HashMap<String, Vec<String>>,
}

#[derive(Debug, PartialEq, Eq)]
pub enum Error {
    DivisionByZero,
    StackUnderflow,
    UnknownWord,
    InvalidWord,
}

impl Forth {
    pub fn new() -> Forth {
        Forth {
            stack: Vec::new(),
            dictionary: HashMap::new(),
        }
    }

    pub fn stack(&self) -> &[Value] {
        &self.stack
    }

    pub fn eval(&mut self, input: &str) -> Result {
        let tokens: Vec<String> = input.split_whitespace().map(|s| s.to_string()).collect();
        self.execute_tokens(&tokens)
    }

    fn pop(&mut self) -> std::result::Result<Value, Error> {
        self.stack.pop().ok_or(Error::StackUnderflow)
    }

    fn execute_tokens(&mut self, tokens: &[String]) -> Result {
        let mut i = 0;
        while i < tokens.len() {
            let token = &tokens[i];

            if token == ":" {
                // Definition mode
                i += 1;
                if i >= tokens.len() {
                    return Err(Error::InvalidWord);
                }
                let name = tokens[i].to_uppercase();
                i += 1;
                let mut definition = Vec::new();
                let mut found_end = false;
                while i < tokens.len() {
                    if tokens[i] == ";" {
                        found_end = true;
                        break;
                    }
                    definition.push(tokens[i].clone());
                    i += 1;
                }
                if !found_end {
                    return Err(Error::InvalidWord);
                }
                self.dictionary.insert(name, definition);
            } else if !token.is_empty() && token.chars().all(|c| c.is_ascii_digit()) {
                // Number parsing
                let val = token.parse::<i32>().map_err(|_| Error::InvalidWord)?;
                self.stack.push(val);
            } else {
                // Word execution
                let word = token.to_uppercase();
                if let Some(def) = self.dictionary.get(&word) {
                    let def_clone = def.clone();
                    self.execute_tokens(&def_clone)?;
                } else {
                    match word.as_str() {
                        "+" => {
                            let a = self.pop()?;
                            let b = self.pop()?;
                            self.stack.push(b + a);
                        }
                        "-" => {
                            let a = self.pop()?;
                            let b = self.pop()?;
                            self.stack.push(b - a);
                        }
                        "*" => {
                            let a = self.pop()?;
                            let b = self.pop()?;
                            self.stack.push(b * a);
                        }
                        "/" => {
                            let a = self.pop()?;
                            let b = self.pop()?;
                            if a == 0 {
                                return Err(Error::DivisionByZero);
                            }
                            self.stack.push(b / a);
                        }
                        "DUP" => {
                            let a = self.pop()?;
                            self.stack.push(a);
                            self.stack.push(a);
                        }
                        "DROP" => {
                            self.pop()?;
                        }
                        "SWAP" => {
                            let a = self.pop()?;
                            let b = self.pop()?;
                            self.stack.push(a);
                            self.stack.push(b);
                        }
                        "OVER" => {
                            let a = self.pop()?;
                            let b = self.pop()?;
                            self.stack.push(b);
                            self.stack.push(a);
                            self.stack.push(b);
                        }
                        _ => return Err(Error::UnknownWord),
                    }
                }
            }
            i += 1;
        }
        Ok(())
    }
}
```
