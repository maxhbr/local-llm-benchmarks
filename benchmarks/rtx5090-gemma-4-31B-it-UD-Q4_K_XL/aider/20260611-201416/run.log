        *   Handle negative minutes in the constructor and addition/subtraction.
        *   Modulo arithmetic: `(minutes % 1440 + 1440) % 1440`.

    *   `Clock(int hours, int minutes)`:
        *   Total minutes = `(hours * 60 + minutes)`.
        *   Normalize to $[0, 1439]$.
    *   `add_minutes(int m)`:
        *   `minutes_ = (minutes_ + m) % 1440`.
        *   If result is negative, add 1440.
    *   `subtract_minutes(int m)`:
        *   `subtract_minutes(m)` is just `add_minutes(-m)`.
    *   `operator==`:
        *   Compare `minutes_`.

    *   `clock.h`:
        ```cpp
        #if !defined(CLOCK_H)
        #define CLOCK_H

        #include <string>

        namespace date_independent {

        class Clock {
        public:
            Clock(int hours, int minutes);
            void add_minutes(int minutes);
            void subtract_minutes(int minutes);
            bool operator==(const Clock& other) const;
            bool operator!=(const Clock& other) const;
            std::string to_string() const;

        private:
            int total_minutes_;
            static constexpr int MINUTES_IN_DAY = 1440;
        };

        }  // namespace date_independent

        #endif // CLOCK_H
        ```

    *   `clock.cpp`:
        ```cpp
        #include "clock.h"
        #include <iomanip>
        #include <sstream>

        namespace date_independent {

        Clock::Clock(int hours, int minutes) {
            int total = hours * 60 + minutes;
            total_minutes_ = (total % MINUTES_IN_DAY + MINUTES_IN_DAY) % MINUTES_IN_DAY;
        }

        void Clock::add_minutes(int minutes) {
            total_minutes_ = (total_minutes_ + minutes) % MINUTES_IN_DAY;
            if (total_minutes_ < 0) {
                total_minutes_ += MINUTES_IN_DAY;
            }
        }

        void Clock::subtract_minutes(int minutes) {
            add_minutes(-minutes);
        }

        bool Clock::operator==(const Clock& other) const {
            return total_minutes_ == other.total_minutes_;
        }

        bool Clock::operator!=(const Clock& other) const {
            return !(*this == other);
        }

