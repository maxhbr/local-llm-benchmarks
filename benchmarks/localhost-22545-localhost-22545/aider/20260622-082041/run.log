#include "phone_number.h"
#include <stdexcept>
#include <cctype>

namespace phone_number {

std::string phone_number(const std::string& number) {
    std::string digits;
    for (char c : number) {
        if (std::isdigit(static_cast<unsigned char>(c))) {
            digits += c;
        }
    }

    if (digits.length() == 11) {
        if (digits[0] == '1') {
            digits = digits.substr(1);
        } else {
            throw std::invalid_argument("Invalid country code");
        }
    }

    if (digits.length() != 10) {
        throw std::invalid_argument("Invalid number length");
    }

    if (digits[0] < '2' || digits[0] > '9') {
        throw std::invalid_argument("Invalid area code");
    }

    if (digits[3] < '2' || digits[3] > '9') {
        throw std::invalid_argument("Invalid exchange code");
    }

    return digits;
}

}  // namespace phone_number
```

