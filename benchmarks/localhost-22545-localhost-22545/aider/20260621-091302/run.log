                value: value.to_string(),
            });
            GraphBuilder {
                nodes: self.nodes,
                edges: self.edges,
                attrs: attrs,
            }
        }

        pub fn build(self) -> Graph {
            Graph {
                nodes: self.nodes,
                edges: self.edges,
                attrs: self.attrs,
            }
        }
    }

