pub mod graph {
    #[derive(Debug, PartialEq, Clone)]
    pub struct Attr {
        pub key: String,
        pub value: String,
    }

    pub mod graph_items {
        pub mod edge {
            use super::super::Attr;
            #[derive(Debug, PartialEq, Clone)]
            pub struct Edge {
                pub from: String,
                pub to: String,
                pub attrs: Vec<Attr>,
            }
            impl Edge {
                pub fn new(from: &str, to: &str) -> Edge {
                    Edge {
                        from: from.to_string(),
                        to: to.to_string(),
                        attrs: vec![],
                    }
                }
                pub fn with_attrs(mut self, attrs: &[(&str, &str)]) -> Edge {
                    self.attrs = attrs.iter().map(|(k, v)| Attr {
                        key: k.to_string(),
                        value: v.to_string(),
                    }).collect();
                    self
                }
            }
        }
        pub mod node {
            use super::super::Attr;
            #[derive(Debug, PartialEq, Clone)]
            pub struct Node {
                pub name: String,
                pub attrs: Vec<Attr>,
            }
            impl Node {
                pub fn new(name: &str) -> Node {
                    Node {
                        name: name.to_string(),
                        attrs: vec![],
                    }
                }
                pub fn with_attrs(mut self, attrs: &[(&str, &str)]) -> Node {
                    self.attrs = attrs.iter().map(|(k, v)| Attr {
                        key: k.to_string(),
                        value: v.to_string(),
                    }).collect();
                    self
                }
            }
        }
    }

    #[derive(Debug, PartialEq, Clone)]
    pub struct Graph {
        pub nodes: Vec<graph_items::node::Node>,
        pub edges: Vec<graph_items::edge::Edge>,
        pub attrs: Vec<Attr>,
    }

    impl Graph {
        pub fn new() -> Graph {
            Graph {
                nodes: vec![],
                edges: vec![],
                attrs: vec![],
            }
        }

        pub fn with_nodes(mut self, nodes: &[graph_items::node::Node]) -> Graph {
            self.nodes = nodes.to_vec();
            self
        }

        pub fn with_edges(mut self, edges: &[graph_items::edge::Edge]) -> Graph {
            self.edges = edges.to_vec();
            self
        }

        pub fn with_attrs(mut self, attrs: &[(&str, &str)]) -> Graph {
            for (key, value) in attrs {
                self.attrs.push(Attr {
                    key: key.to_string(),
                    value: value.to_string(),
                });
            }
            self
        }
    }
}
```

