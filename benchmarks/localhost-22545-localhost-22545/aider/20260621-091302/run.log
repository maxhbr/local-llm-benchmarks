pub struct Graph {
    pub nodes: Vec<graph_items::node::Node>,
    pub edges: Vec<graph_items::edge::Edge>,
    pub attrs: Vec<Attr>,
}
impl Graph {
    pub fn new() -> Graph {
        Graph { nodes: vec![], edges: vec![], attrs: vec![] }
    }
    pub fn with_nodes(mut self, nodes: &[graph_items::node::Node]) -> Graph {
        self.nodes = nodes.to_vec();
        self
    }
    pub fn with_edges(mut self, edges: &[graph_items::edge::Edge]) -> Graph {
        self.edges = edges.to_vec();
        self
    }
    pub fn with_attrs(mut self, attrs: &[(&str, &str)]) -> Graph {
        self.attrs = attrs.iter().map(|(k,v)| Attr { key: k.to_string(), value: v.to_string() }).collect();
        self
    }
}
```

