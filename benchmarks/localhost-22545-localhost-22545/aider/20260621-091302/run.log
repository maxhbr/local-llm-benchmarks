poker.py
```
from collections import Counter

def best_hands(hands):
    def hand_rank(hand):
        cards = hand.split()
        ranks = []
        suits = []
        for card in cards:
            rank_str = card[:-1]
            suit = card[-1]
            suits.append(suit)
            if rank_str.isdigit():
                rank_val = int(rank_str)
            else:
                mapping = {'J': 11, 'Q': 12, 'K': 13, 'A': 14, 'T': 10}
                rank_val = mapping.get(rank_str, 10)  # fallback for unknown
            ranks.append(rank_val)

        # flush?
        flush = all(s == suits[0] for s in suits)

        # straight?
        sorted_ranks = sorted(ranks, reverse=True)
        straight_high = None
        # normal straight
        if len(set(ranks)) == 5 and sorted_ranks[0] - sorted_ranks[4] == 4:
            straight_high = sorted_ranks[0]
        # wheel (A-2-3-4-5)
        if sorted_ranks == [14, 5, 4, 3, 2]:
            straight_high = 5

        # count ranks
        cnt = Counter(ranks)

        # straight flush
        if straight_high is not None and flush:
            return (8, straight_high)

        # straight (non flush)
        if straight_high is not None:
            return (4, straight_high)

        # flush (non straight)
        if flush:
            return (5, tuple(sorted_ranks))

        # four of a kind
        if 4 in cnt.values():
            quad_rank = [r for r, c in cnt.items() if c == 4][0]
            kicker    = [r for r, c in cnt.items() if c == 1][0]
            return (7, (quad_rank, kicker))

        # full house
        if 3 in cnt.values() and 2 in cnt.values():
            trip_rank = [r for r, c in cnt.items() if c == 3][0]
            pair_rank = [r for r, c in cnt.items() if c == 2][0]
            return (6, (trip_rank, pair_rank))

        # three of a kind
        if 3 in cnt.values():
            trip_rank = [r for r, c in cnt.items() if c == 3][0]
            kickers   = sorted([r for r, c in cnt.items() if c != 3], reverse=True)
            return (3, (trip_rank,) + tuple(kickers))

        # count pairs
        pairs = [r for r, c in cnt.items() if c == 2]
        if len(pairs) == 2:
            pairs.sort(reverse=True)
            kicker = [r for r, c in cnt.items() if c == 1][0]
            return (2, (pairs[0], pairs[1], kicker))

        if len(pairs) == 1:
            pair_rank = pairs[0]
            kickers   = sorted([r for r, c in cnt.items() if c != 2], reverse=True)
            return (1, (pair_rank,) + tuple(kickers))

        # high card
        return (0, tuple(sorted_ranks))

    scores = [(hand_rank(h), h) for h in hands]
    best_score = max(scores, key=lambda x: x[0])[0]
    return [h for s, h in scores if s == best_score]
```
