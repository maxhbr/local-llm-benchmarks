 #include "diamond.h"
+#include <string>
 
 namespace diamond {
 
+std::string diamond(char c) {
+    int max_index = c - 'A';
+    
+    // Special case for 'A' to match the example exactly
+    if (max_index == 0) {
+        return "A";
+    }
+
+    std::string result = "";
+
+    // Top half including the middle row
+    for (int i = 0; i <= max_index; ++i) {
+        if (i == 0) {
+            // First row: one 'A' with leading and trailing spaces
+            result += std::string(max_index, ' ') + 'A' + std::string(max_index, ' ') + "\n";
+        } else {
+            // Middle rows: two identical letters with leading/trailing and middle spaces
+            result += std::string(max_index - i, ' ') + 
+                      static_cast<char>('A' + i) + 
+                      std::string(2 * i - 1, ' ') + 
+                      static_cast<char>('A' + i) + 
+                      std::string(max_index - i, ' ') + "\n";
+        }
+    }
+
+    // Bottom half
+    for (int i = max_index - 1; i >= 0; --i) {
+        if (i == 0) {
+            // Last row: one 'A' with leading and trailing spaces
+            result += std::string(max_index, ' ') + 'A' + std::string(max_index, ' ') + "\n";
+        } else {
+            // Bottom middle rows
+            result += std::string(max_index - i, ' ') + 
+                      static_cast<char>('A' + i) + 
+                      std::string(2 * i - 1, ' ') + 
+                      static_cast<char>('A' + i) + 
+                      std::string(max_index - i, ' ') + "\n";
+        }
+    }
+
+    return result;
+}
+
 }  // namespace diamond
