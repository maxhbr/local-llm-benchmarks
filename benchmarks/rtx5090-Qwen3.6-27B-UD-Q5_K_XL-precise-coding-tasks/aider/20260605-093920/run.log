List<String> encoded = new ArrayList<>();
if (n == 0) {
    encoded.add("00");
    return encoded;
}
List<Byte> chunks = new ArrayList<>();
while (n > 0) {
    chunks.add((byte) (n & 0x7F));
    n >>>= 7;
}
// chunks are in reverse order (LSB first)
for (int i = chunks.size() - 1; i >= 0; i--) {
    byte b = chunks.get(i);
    if (i > 0) {
