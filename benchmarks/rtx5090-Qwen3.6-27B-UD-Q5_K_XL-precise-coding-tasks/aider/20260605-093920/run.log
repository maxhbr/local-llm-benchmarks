class EmptyListException(Exception):
    pass


class Node:
    def __init__(self, value, next_node=None):
        self._value = value
        self._next = next_node

    def value(self):
        return self._value

    def next(self):
        return self._next


class LinkedList:
    def __init__(self, values=None):
        self._head = None
        self._count = 0
        if values is not None:
            for value in values:
                self.push(value)

    def __iter__(self):
        current = self._head
        while current:
            yield current.value()
            current = current.next()

    def __len__(self):
        return self._count

    def head(self):
        return self._head

    def push(self, value):
        self._head = Node(value, self._head)
        self._count += 1

    def pop(self):
        if self._head is None:
            raise EmptyListException("list is empty")
        value = self._head.value()
        self._head = self._head.next()
        self._count -= 1
        return value

    def reversed(self):
        new_list = LinkedList()
        current = self._head
        while current:
            new_list.push(current.value())
            current = current.next()
        return new_list
