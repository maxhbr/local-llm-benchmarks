class StackUnderflowError(Exception):
    pass


def evaluate(input_data):
    stack = []
    words = {}
    
    if isinstance(input_data, str):
        tokens = input_data.split()
    else:
        tokens = ' '.join(input_data).split()
        
    i = 0
    while i < len(tokens):
        token = tokens[i]
        lower_token = token.lower()
        
        if lower_token == ':':
            i += 1
            if i >= len(tokens):
                raise ValueError("undefined operation")
            word_name = tokens[i].lower()
            try:
                int(word_name)
                raise ValueError("illegal operation")
            except ValueError:
                pass
            
            i += 1
            definition = []
            while i < len(tokens) and tokens[i].lower() != ';':
                definition.append(tokens[i])
                i += 1
            if i >= len(tokens):
                raise ValueError("undefined operation")
            words[word_name] = definition
            i += 1
            continue
            
        if lower_token in words:
            tokens[i:i+1] = words[lower_token]
            continue
            
        if lower_token == '+':
            if len(stack) < 2: raise StackUnderflowError("Insufficient number of items in stack")
            b, a = stack.pop(), stack.pop()
            stack.append(a + b)
        elif lower_token == '-':
            if len(stack) < 2: raise StackUnderflowError("Insufficient number of items in stack")
            b, a = stack.pop(), stack.pop()
            stack.append(a - b)
        elif lower_token == '*':
            if len(stack) < 2: raise StackUnderflowError("Insufficient number of items in stack")
            b, a = stack.pop(), stack.pop()
            stack.append(a * b)
        elif lower_token == '/':
            if len(stack) < 2: raise StackUnderflowError("Insufficient number of items in stack")
            b, a = stack.pop(), stack.pop()
            if b == 0: raise ZeroDivisionError("divide by zero")
            stack.append(int(a / b))
        elif lower_token == 'dup':
            if len(stack) < 1: raise StackUnderflowError("Insufficient number of items in stack")
            stack.append(stack[-1])
        elif lower_token == 'drop':
            if len(stack) < 1: raise StackUnderflowError("Insufficient number of items in stack")
            stack.pop()
        elif lower_token == 'swap':
            if len(stack) < 2: raise StackUnderflowError("Insufficient number of items in stack")
            stack[-1], stack[-2] = stack[-2], stack[-1]
        elif lower_token == 'over':
            if len(stack) < 2: raise StackUnderflowError("Insufficient number of items in stack")
            stack.append(stack[-2])
        else:
            try:
                stack.append(int(token))
            except ValueError:
                raise ValueError("undefined operation")
                
        i += 1
        
    return stack
```

