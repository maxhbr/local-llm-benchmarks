			g.roll = 0
			return nil
		}
	}

	if g.roll == 1 {
		g.rolls = append(g.rolls, pins)
		if pins == 10 {
			g.frame++
			g.roll = 1
		} else {
			g.roll = 2
		}
		return nil
	}

	if g.roll == 2 {
		if g.rolls[len(g.rolls)-1]+pins > 10 {
			return fmt.Errorf("invalid roll: pins exceed 10 in frame")
		}
		g.rolls = append(g.rolls, pins)
		g.frame++
		g.roll = 1
		return nil
	}

	return fmt.Errorf("unexpected state")
}

func (g *Game) Score() (int, error) {
	if g.roll != 0 {
		return 0, fmt.Errorf("game not complete")
	}

	score := 0
	rollIdx := 0

	for frame := 1; frame <= 10; frame++ {
		if frame < 10 {
			if g.rolls[rollIdx] == 10 { // Strike
				score += 10 + g.rolls[rollIdx+1] + g.rolls[rollIdx+2]
				rollIdx++
			} else if g.rolls[rollIdx]+g.rolls[rollIdx+1] == 10 { // Spare
