Ledger.java
```java
import java.time.LocalDate;
import java.time.format.DateTimeFormatter;
import java.util.ArrayList;
import java.util.Arrays;
import java.util.Comparator;
import java.util.List;
import java.util.Locale;

public class Ledger {
    // Refactoring Log:
    // 1. Replaced deeply nested if-else blocks for locale/currency configuration with direct variable assignment.
    // 2. Introduced java.util.Locale for cleaner date and number formatting.
    // 3. Replaced manual string concatenation with StringBuilder for better performance and readability.
    // 4. Simplified sorting logic using a single List.sort() with a chained Comparator.
    // 5. Extracted entry and amount formatting into dedicated private methods to reduce cyclomatic complexity.
    // 6. Used String.format with Locale for number formatting, removing manual thousands/decimal separator logic.
    // 7. Preserved exact output spacing and formatting to ensure all tests continue to pass.

    public LedgerEntry createLedgerEntry(String d, String desc, int c) {
        LedgerEntry le = new LedgerEntry();
        le.setChange(c);
        le.setDescription(desc);
        le.setLocalDate(LocalDate.parse(d));
        return le;
    }

    public String format(String cur, String loc, LedgerEntry[] entries) {
        if (!cur.equals("USD") && !cur.equals("EUR")) {
            throw new IllegalArgumentException("Invalid currency");
        }
        if (!loc.equals("en-US") && !loc.equals("nl-NL")) {
            throw new IllegalArgumentException("Invalid locale");
        }

        Locale locale = loc.equals("en-US") ? Locale.US : new Locale("nl", "NL");
        String currencySymbol = cur.equals("USD") ? "$" : "€";
        String header = loc.equals("en-US")
                ? "Date       | Description               | Change       "
                : "Datum      | Omschrijving              | Verandering  ";
        DateTimeFormatter dateFormatter = loc.equals("en-US")
                ? DateTimeFormatter.ofPattern("MM/dd/yyyy")
                : DateTimeFormatter.ofPattern("dd/MM/yyyy");

        List<LedgerEntry> sortedEntries = new ArrayList<>(Arrays.asList(entries));
        sortedEntries.sort(Comparator.comparing((LedgerEntry e) -> e.getChange() >= 0)
                .thenComparing(LedgerEntry::getLocalDate));

        StringBuilder sb = new StringBuilder(header);
        for (LedgerEntry entry : sortedEntries) {
            sb.append("\n");
            sb.append(formatEntry(entry, loc, currencySymbol, dateFormatter));
        }

        return sb.toString();
    }

    private String formatEntry(LedgerEntry entry, String loc, String currencySymbol, DateTimeFormatter dateFormatter) {
        String date = entry.getLocalDate().format(dateFormatter);
        String desc = entry.getDescription().length() > 25
                ? entry.getDescription().substring(0, 22) + "..."
                : entry.getDescription();

        String amount = formatAmount(entry.getChange(), loc, currencySymbol);

        return String.format("%s | %-25s | %13s", date, desc, amount);
    }

    private String formatAmount(double changeCents, String loc, String currencySymbol) {
        Locale locale = loc.equals("en-US") ? Locale.US : new Locale("nl", "NL");
        double change = changeCents / 100.0;
        boolean isNegative = change < 0;
        double absChange = Math.abs(change);

        String formattedNumber = String.format(locale, "%,.2f", absChange);

        if (loc.equals("en-US")) {
            return isNegative
                    ? String.format("(%s%s)", currencySymbol, formattedNumber)
                    : String.format("%s%s ", currencySymbol, formattedNumber);
        } else {
            return isNegative
                    ? String.format("%s -%s ", currencySymbol, formattedNumber)
                    : String.format(" %s %s ", currencySymbol, formattedNumber);
        }
    }

    public static class LedgerEntry {
        LocalDate localDate;
        String description;
        double change;

        public LocalDate getLocalDate() {
            return localDate;
        }

        public void setLocalDate(LocalDate localDate) {
            this.localDate = localDate;
        }

        public String getDescription() {
            return description;
        }

        public void setDescription(String description) {
            this.description = description;
        }

        public double getChange() {
            return change;
        }

        public void setChange(double change) {
            this.change = change;
        }
    }

}
