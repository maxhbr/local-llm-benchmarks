int score(std::initializer_list<int> dice, category cat) {
    std::map<int, int> counts;
    int sum = 0;
    for (int d : dice) {
        counts[d]++;
        sum += d;
    }

    switch (cat) {
        case category::ones: return counts[1] * 1;
        case category::twos: return counts[2] * 2;
        case category::threes: return counts[3] * 3;
        case category::fours: return counts[4] * 4;
        case category::fives: return counts[5] * 5;
        case category::sixes: return counts[6] * 6;
        case category::full_house: {
            bool has_three = false;
            bool has_two = false;
            for (auto const& [val, count] : counts) {
                if (count == 3) has_three = true;
                if (count == 2) has_two = true;
            }
            return (has_three && has_two) ? sum : 0;
        }
        case category::four_of_a_kind: {
            for (auto const& [val, count] : counts) {
                if (count >= 4) return val * 4;
            }
            return 0;
        }
        case category::little_straight: {
            // 1-2-3-4-5
            if (counts.size() == 5 && counts.find(6) == counts.end()) return 30;
            return 0;
        }
        case category::big_straight: {
            // 2-3-4-5-6
            if (counts.size() == 5 && counts.find(1) == counts.end()) return 30;
            return 0;
        }
        case category::choice: return sum;
        case category::yacht: {
            for (auto const& [val, count] : counts) {
                if (count == 5) return 50;
            }
            return 0;
        }
    }
    return 0;
}

}  // namespace yacht
