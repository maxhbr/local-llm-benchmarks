```java
class WordProblemSolver {
    int solve(final String wordProblem) {
        if (wordProblem == null || !wordProblem.startsWith("What is ") || !wordProblem.endsWith("?")) {
            throw new IllegalArgumentException("Invalid question format");
        }

        String content = wordProblem.substring(8, wordProblem.length() - 1);
        content = content.replace("multiplied by", "multiplied")
                         .replace("divided by", "divided");
        
        String[] tokens = content.split("\\s+");
        if (tokens.length == 0 || tokens[0].isEmpty()) {
            throw new IllegalArgumentException("Invalid syntax");
        }

        int result;
        try {
            result = Integer.parseInt(tokens[0]);
        } catch (NumberFormatException e) {
            throw new IllegalArgumentException("Invalid syntax");
        }

        for (int i = 1; i < tokens.length; i += 2) {
            if (i + 1 >= tokens.length) {
                throw new IllegalArgumentException("Invalid syntax");
            }
            String op = tokens[i];
            String numStr = tokens[i + 1];
            
            int num;
            try {
                num = Integer.parseInt(numStr);
            } catch (NumberFormatException e) {
                throw new IllegalArgumentException("Invalid syntax");
            }

            switch (op) {
                case "plus":
                    result += num;
                    break;
                case "minus":
                    result -= num;
                    break;
                case "multiplied":
                    result *= num;
                    break;
                case "divided":
                    result /= num;
                    break;
                default:
                    throw new IllegalArgumentException("Unsupported operation");
            }
        }

        return result;
    }
}
