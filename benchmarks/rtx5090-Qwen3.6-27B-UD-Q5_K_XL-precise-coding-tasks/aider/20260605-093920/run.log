```python
from collections import deque

class StackUnderflowError(Exception):
    pass


def evaluate(input_data):
    stack = []
    words = {}
    
    if isinstance(input_data, str):
        tokens = deque(input_data.split())
    else:
        tokens = deque(' '.join(input_data).split())
        
    while tokens:
        token = tokens.popleft().lower()
        
        if token == ':':
            if not tokens:
                raise ValueError("undefined operation")
            word_name = tokens.popleft().lower()
            try:
                int(word_name)
                raise ValueError("illegal operation")
            except ValueError:
                pass
            
            definition = []
            while tokens:
                t = tokens.popleft()
                if t.lower() == ';':
                    break
                definition.append(t)
            else:
                raise ValueError("undefined operation")
            words[word_name] = definition
            continue
            
        if token in words:
            tokens.extendleft(reversed(words[token]))
            continue
            
        if token == '+':
            if len(stack) < 2: raise StackUnderflowError("Insufficient number of items in stack")
            b, a = stack.pop(), stack.pop()
            stack.append(a + b)
        elif token == '-':
            if len(stack) < 2: raise StackUnderflowError("Insufficient number of items in stack")
            b, a = stack.pop(), stack.pop()
            stack.append(a - b)
        elif token == '*':
            if len(stack) < 2: raise StackUnderflowError("Insufficient number of items in stack")
            b, a = stack.pop(), stack.pop()
            stack.append(a * b)
        elif token == '/':
            if len(stack) < 2: raise StackUnderflowError("Insufficient number of items in stack")
            b, a = stack.pop(), stack.pop()
            if b == 0: raise ZeroDivisionError("divide by zero")
            stack.append(int(a / b))
        elif token == 'dup':
            if len(stack) < 1: raise StackUnderflowError("Insufficient number of items in stack")
            stack.append(stack[-1])
        elif token == 'drop':
            if len(stack) < 1: raise StackUnderflowError("Insufficient number of items in stack")
            stack.pop()
        elif token == 'swap':
            if len(stack) < 2: raise StackUnderflowError("Insufficient number of items in stack")
            stack[-1], stack[-2] = stack[-2], stack[-1]
        elif token == 'over':
            if len(stack) < 2: raise StackUnderflowError("Insufficient number of items in stack")
            stack.append(stack[-2])
        else:
            try:
                stack.append(int(token))
            except ValueError:
                raise ValueError("undefined operation")
                
    return stack
```

