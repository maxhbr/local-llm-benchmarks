    from itertools import permutations

    def solve():
        # We'll represent each house as a tuple or dict, but permutations of indices is easier.
        # Let's assign indices 0-4 to each attribute value.
        # nationalities: Englishman, Spaniard, Ukrainian, Norwegian, Japanese
        # We know Norwegian is at 0.
        # So we permute the other 4 nationalities for positions 1,2,3,4.
        # Actually, it's easier to just permute all 5 and check constraints.

        for nat in permutations(['Englishman', 'Spaniard', 'Ukrainian', 'Norwegian', 'Japanese']):
            if nat[0] != 'Norwegian': continue
            # Norwegian next to Blue -> Blue is at 1
            for col in permutations(['Red', 'Green', 'Ivory', 'Yellow', 'Blue']):
                if col[1] != 'Blue': continue
                # Englishman in Red
                if nat.index('Englishman') != col.index('Red'): continue
                # Green right of Ivory
                if col.index('Green') != col.index('Ivory') + 1: continue
                # Yellow is Painter -> we'll check hobbies later
                # Middle drinks Milk
                for dr in permutations(['Coffee', 'Tea', 'Milk', 'Orange Juice', 'Water']):
                    if dr[2] != 'Milk': continue
                    # Green drinks Coffee
                    if dr[col.index('Green')] != 'Coffee': continue
                    # Ukrainian drinks Tea
                    if dr[nat.index('Ukrainian')] != 'Tea': continue
                    # Football drinks OJ
                    for hob in permutations(['Dancing', 'Painter', 'Reading', 'Football', 'Chess']):
                        # Yellow is Painter
                        if hob[col.index('Yellow')] != 'Painter': continue
                        # Football drinks OJ
                        if dr[hob.index('Football')] != 'Orange Juice': continue
                        # Japanese plays Chess
                        if hob[nat.index('Japanese')] != 'Chess': continue
                        # Snail owner likes Dancing
                        for pet in permutations(['Dog', 'Snail', 'Fox', 'Horse', 'Zebra']):
                            # Spaniard owns Dog
                            if pet[nat.index('Spaniard')] != 'Dog': continue
                            # Snail == Dancing
                            if pet.index('Snail') != hob.index('Dancing'): continue
                            # Painter next to Horse
                            if abs(hob.index('Painter') - pet.index('Horse')) != 1: continue
                            # Reading next to Fox
                            if abs(hob.index('Reading') - pet.index('Fox')) != 1: continue

                            # If we reach here, we found the solution
                            # Return the house index for Water and Zebra
                            water_house = dr.index('Water')
                            zebra_house = pet.index('Zebra')
                            return nat[water_house], nat[zebra_house]
