VariableLengthQuantity.java
```java
import java.util.List;
import java.util.ArrayList;

class VariableLengthQuantity {

    List<String> encode(List<Long> numbers) {
        List<String> result = new ArrayList<>();
        for (Long number : numbers) {
            if (number == 0) {
                result.add("00");
                continue;
            }
            List<Byte> chunks = new ArrayList<>();
            long temp = number;
            while (temp > 0) {
                chunks.add((byte) (temp & 0x7F));
                temp >>>= 7;
            }
            for (int i = chunks.size() - 1; i >= 0; i--) {
                byte b = chunks.get(i);
                if (i > 0) {
                    b |= 0x80;
                }
                result.add(String.format("%02X", b & 0xFF));
            }
        }
        return result;
    }

    List<String> decode(List<Long> bytes) {
        List<String> result = new ArrayList<>();
        long current = 0;
        boolean inSequence = false;
        for (Long b : bytes) {
            current = (current << 7) | (b & 0x7F);
            inSequence = true;
            if ((b & 0x80) == 0) {
                result.add(current == 0 ? "00" : Long.toHexString(current).toUpperCase());
                current = 0;
                inSequence = false;
            }
        }
        if (inSequence) {
            throw new IllegalArgumentException("Incomplete sequence");
        }
        return result;
    }
}
