#include "yacht.h"
#include <map>

namespace yacht {

int score(std::vector<int> dice, category cat) {
    std::map<int, int> counts;
    int sum = 0;
    for (int d : dice) {
        counts[d]++;
        sum += d;
    }

    switch (cat) {
        case category::ones: return counts[1] * 1;
        case category::twos: return counts[2] * 2;
        case category::threes: return counts[3] * 3;
        case category::fours: return counts[4] * 4;
        case category::fives: return counts[5] * 5;
        case category::sixes: return counts[6] * 6;
        case category::full_house: {
            bool has_three = false;
            bool has_two = false;
            for (const auto& pair : counts) {
                if (pair.second == 3) has_three = true;
                if (pair.second == 2) has_two = true;
            }
            return (has_three && has_two) ? sum : 0;
        }
        case category::four_of_a_kind: {
            for (const auto& pair : counts) {
                if (pair.second >= 4) return pair.first * 4;
            }
            return 0;
        }
        case category::little_straight:
            return (counts.size() == 5 && counts.find(6) == counts.end()) ? 30 : 0;
        case category::big_straight:
            return (counts.size() == 5 && counts.find(1) == counts.end()) ? 30 : 0;
        case category::choice:
            return sum;
        case category::yacht:
            return (counts.size() == 1) ? 50 : 0;
    }
    return 0;
}

}  // namespace yacht
```

