	}
}

func (g *Game) Roll(pins int) error {
	if pins < 0 || pins > 10 {
		return fmt.Errorf("invalid roll: %d", pins)
	}
	if g.roll == 0 {
		return fmt.Errorf("game already complete")
	}

	if g.frame == 10 {
		if g.roll == 1 {
			g.rolls = append(g.rolls, pins)
			g.roll = 2
			return nil
		}
		if g.roll == 2 {
