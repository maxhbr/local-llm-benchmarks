Alphametics.java
```java
import java.util.*;

class Alphametics {
    private final char[] letters;
    private final long[] coefficients;
    private final boolean[] nonZero;
    private final Map<Character, Integer> solution;

    Alphametics(String userInput) {
        this.solution = new HashMap<>();
        String clean = userInput.replaceAll("\\s+", "");
        String[] parts = clean.split("==");
        if (parts.length != 2) {
            throw new IllegalArgumentException("Invalid equation format");
        }

        String[] leftWords = parts[0].split("\\+");
        String rightWord = parts[1];

        Map<Character, Long> coeffMap = new HashMap<>();
        Set<Character> nonZeroSet = new HashSet<>();

        for (String w : leftWords) {
            if (w.length() > 1) nonZeroSet.add(w.charAt(0));
            long place = 1;
            for (int i = w.length() - 1; i >= 0; i--) {
                char c = w.charAt(i);
                coeffMap.put(c, coeffMap.getOrDefault(c, 0L) + place);
                place *= 10;
            }
        }

        if (rightWord.length() > 1) nonZeroSet.add(rightWord.charAt(0));
        long place = 1;
        for (int i = rightWord.length() - 1; i >= 0; i--) {
            char c = rightWord.charAt(i);
            coeffMap.put(c, coeffMap.getOrDefault(c, 0L) - place);
            place *= 10;
        }

        Set<Character> keySet = coeffMap.keySet();
        this.letters = new char[keySet.size()];
        int idx = 0;
        for (char c : keySet) {
            this.letters[idx++] = c;
        }
        this.coefficients = new long[letters.length];
        this.nonZero = new boolean[letters.length];

        for (int i = 0; i < letters.length; i++) {
            coefficients[i] = coeffMap.get(letters[i]);
            nonZero[i] = nonZeroSet.contains(letters[i]);
        }
    }

    Map<Character, Integer> solve() throws UnsolvablePuzzleException {
        boolean[] used = new boolean[10];
        if (backtrack(0, 0, used)) {
            return Collections.unmodifiableMap(solution);
        }
        throw new UnsolvablePuzzleException();
    }

    private boolean backtrack(int idx, long currentSum, boolean[] used) {
        if (idx == letters.length) {
            return currentSum == 0;
        }

        for (int d = 0; d <= 9; d++) {
            if (!used[d]) {
                if (d == 0 && nonZero[idx]) continue;
                used[d] = true;
                if (backtrack(idx + 1, currentSum + coefficients[idx] * d, used)) {
                    solution.put(letters[idx], d);
                    return true;
                }
                used[d] = false;
            }
        }
        return false;
    }
}
