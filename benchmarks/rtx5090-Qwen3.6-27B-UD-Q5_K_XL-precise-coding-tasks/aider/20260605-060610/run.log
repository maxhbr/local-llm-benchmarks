Zipper.java
```java
class Zipper {
    int value;
    Zipper up;
    Zipper left;
    Zipper right;

    Zipper(int value) {
        this(value, null, null, null);
    }

    Zipper(int value, Zipper up, Zipper left, Zipper right) {
        this.value = value;
        this.up = up;
        this.left = left;
        this.right = right;
    }

    public static Zipper fromTree(BinaryTree tree) {
        return tree.root;
    }

    public Zipper up() {
        return up;
    }

    public Zipper left() {
        return left;
    }

    public Zipper right() {
        return right;
    }

    public BinaryTree toTree() {
        Zipper current = this;
        while (current.up != null) {
            current = current.up;
        }
        return new BinaryTree(current);
    }

    public int getValue() {
        return value;
    }

    public Zipper setValue(int value) {
        return new Zipper(value, up, left, right);
    }

    public Zipper setLeft(Zipper leftChild) {
        return new Zipper(value, up, leftChild, right);
    }

    public Zipper setRight(Zipper rightChild) {
        return new Zipper(value, up, left, rightChild);
    }
}

class BinaryTree {
    final Zipper root;

    BinaryTree(int value) {
        this.root = new Zipper(value);
    }

    BinaryTree(Zipper root) {
        Zipper current = root;
        while (current.up != null) {
            current = current.up;
        }
        this.root = current;
    }

    public Zipper getRoot() {
        return root;
    }

    @Override
    public String toString() {
        return printTree();
    }

    public String printTree() {
        return "value: " + root.value + ", left: " + formatNode(root.left) + ", right: " + formatNode(root.right);
    }

    private String formatNode(Zipper node) {
        if (node == null) return "null";
        return "{ value: " + node.value + ", left: " + formatNode(node.left) + ", right: " + formatNode(node.right) + " }";
    }

    @Override
    public boolean equals(Object o) {
        if (this == o) return true;
        if (!(o instanceof BinaryTree)) return false;
        BinaryTree that = (BinaryTree) o;
        return nodesEqual(this.root, that.root);
    }

    private boolean nodesEqual(Zipper a, Zipper b) {
        if (a == null && b == null) return true;
        if (a == null || b == null) return false;
        return a.value == b.value && nodesEqual(a.left, b.left) && nodesEqual(a.right, b.right);
    }

    @Override
    public int hashCode() {
        return hashNode(root);
    }

    private int hashNode(Zipper node) {
        if (node == null) return 0;
        int result = node.value;
        result = 31 * result + hashNode(node.left);
        result = 31 * result + hashNode(node.right);
        return result;
    }
}
