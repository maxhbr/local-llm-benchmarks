```rust
use std::ops::{Add, Sub, Mul};

/// Type implementing arbitrary-precision decimal arithmetic
#[derive(Debug, Clone, Copy)]
pub struct Decimal {
    mantissa: i128,
    scale: u32,
}

impl Decimal {
    pub fn try_from(input: &str) -> Option<Decimal> {
        let input = input.trim();
        let (mantissa_str, scale) = if let Some(dot_pos) = input.find('.') {
            let int_part = &input[..dot_pos];
            let frac_part = &input[dot_pos + 1..];
            let scale = frac_part.len() as u32;
            let combined = format!("{}{}", int_part, frac_part);
            (combined, scale)
        } else {
            (input.to_string(), 0)
        };

        let mantissa = mantissa_str.parse::<i128>().ok()?;
        Some(Decimal { mantissa, scale }.normalize())
    }

    fn normalize(mut self) -> Self {
        while self.scale > 0 && self.mantissa % 10 == 0 {
            self.mantissa /= 10;
            self.scale -= 1;
        }
        self
    }

    fn align(&self, other: &Self) -> (i128, i128) {
        if self.scale == other.scale {
            (self.mantissa, other.mantissa)
        } else if self.scale > other.scale {
            let diff = self.scale - other.scale;
            (self.mantissa, other.mantissa * 10i128.pow(diff))
        } else {
            let diff = other.scale - self.scale;
            (self.mantissa * 10i128.pow(diff), other.mantissa)
        }
    }
}

impl PartialEq for Decimal {
    fn eq(&self, other: &Self) -> bool {
        let (m1, m2) = self.align(other);
        m1 == m2
    }
}
impl Eq for Decimal {}

impl PartialOrd for Decimal {
    fn partial_cmp(&self, other: &Self) -> Option<std::cmp::Ordering> {
        let (m1, m2) = self.align(other);
        Some(m1.cmp(&m2))
    }
}
impl Ord for Decimal {
    fn cmp(&self, other: &Self) -> std::cmp::Ordering {
        let (m1, m2) = self.align(other);
        m1.cmp(&m2)
    }
}

impl Add for Decimal {
    type Output = Self;
    fn add(self, other: Self) -> Self {
        let (m1, m2) = self.align(&other);
        let scale = self.scale.max(other.scale);
        Decimal { mantissa: m1 + m2, scale }.normalize()
    }
}

impl Sub for Decimal {
    type Output = Self;
    fn sub(self, other: Self) -> Self {
        let (m1, m2) = self.align(&other);
        let scale = self.scale.max(other.scale);
        Decimal { mantissa: m1 - m2, scale }.normalize()
    }
}

impl Mul for Decimal {
    type Output = Self;
    fn mul(self, other: Self) -> Self {
        Decimal {
            mantissa: self.mantissa * other.mantissa,
            scale: self.scale + other.scale,
        }.normalize()
    }
}
```

