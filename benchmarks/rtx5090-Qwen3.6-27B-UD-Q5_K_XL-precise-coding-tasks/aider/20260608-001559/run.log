import math
from collections import deque

def measure(bucket_one, bucket_two, goal, start_bucket):
    if goal > max(bucket_one, bucket_two):
        raise ValueError("goal too large")
    if goal % math.gcd(bucket_one, bucket_two) != 0:
        raise ValueError("goal not reachable")

    # Initial state
    if start_bucket == "one":
        start_state = (bucket_one, 0)
        forbidden = (0, bucket_two)
    else:
        start_state = (0, bucket_two)
        forbidden = (bucket_one, 0)

    if start_state[0] == goal:
        return (1, "one", start_state[1])
    if start_state[1] == goal:
        return (1, "two", start_state[0])

    queue = deque([(start_state[0], start_state[1], 1)])
    visited = {start_state}

    while queue:
        b1, b2, moves = queue.popleft()

        # Generate next states
        next_states = [
            (bucket_one, b2),  # Fill 1
            (b1, bucket_two),  # Fill 2
            (0, b2),           # Empty 1
            (b1, 0),           # Empty 2
            (b1 - min(b1, bucket_two - b2), b2 + min(b1, bucket_two - b2)),  # Pour 1->2
            (b1 + min(b2, bucket_one - b1), b2 - min(b2, bucket_one - b1))   # Pour 2->1
        ]

        for nb1, nb2 in next_states:
            if (nb1, nb2) == forbidden:
                continue
            if (nb1, nb2) in visited:
                continue

            if nb1 == goal:
                return (moves + 1, "one", nb2)
            if nb2 == goal:
                return (moves + 1, "two", nb1)

            visited.add((nb1, nb2))
            queue.append((nb1, nb2, moves + 1))

    raise ValueError("goal not reachable")
