def get_winner(self):
    if not self.board:
        return ""
    
    rows = len(self.board)
    cols = len(self.board[0])
    
    # Check for O
    if self._has_path('O', rows, cols):
        return 'O'
    # Check for X
    if self._has_path('X', rows, cols):
        return 'X'
    return ""

def _has_path(self, player, rows, cols):
    # Determine start and end conditions
    if player == 'O':
        starts = [(0, c) for c in range(cols) if self.board[0][c] == 'O']
        is_end = lambda r, c: r == rows - 1
    else: # 'X'
        starts = [(r, 0) for r in range(rows) if self.board[r][0] == 'X']
        is_end = lambda r, c: c == cols - 1
        
    if not starts:
        return False
        
    visited = set(starts)
    queue = list(starts)
    
    dirs = [(-1, 0), (-1, 1), (0, -1), (0, 1), (1, -1), (1, 0)]
    
    while queue:
        r, c = queue.pop(0)
        if is_end(r, c):
            return True
        for dr, dc in dirs:
            nr, nc = r + dr, c + dc
            if 0 <= nr < rows and 0 <= nc < cols:
                if (nr, nc) not in visited and self.board[nr][nc] == player:
                    visited.add((nr, nc))
                    queue.append((nr, nc))
    return False
```

