```go
package kindergarten

import (
	"errors"
	"sort"
	"strings"
)

// Define the Garden type here.
type Garden struct {
	plants map[string][]string
}

var defaultChildren = []string{
	"Alice", "Bob", "Charlie", "David", "Eve", "Fred",
	"Ginny", "Harriet", "Ileana", "Joseph", "Kincaid", "Larry",
}

var plantNames = map[byte]string{
	'G': "grass",
	'C': "clover",
	'R': "radishes",
	'V': "violets",
}

// The diagram argument starts each row with a '\n'.  This allows Go's
// raw string literals to present diagrams in source code nicely as two
// rows flush left, for example,
//
//     diagram := `
//     VVCCGG
//     VVCCGG`

func NewGarden(diagram string, children []string) (*Garden, error) {
	rows := strings.Split(diagram, "\n")
	var cleanRows []string
	for _, r := range rows {
		if r != "" {
			cleanRows = append(cleanRows, r)
		}
	}
	if len(cleanRows) != 2 {
		return nil, errors.New("invalid diagram")
	}
	row1, row2 := cleanRows[0], cleanRows[1]
	if len(row1) != len(row2) {
		return nil, errors.New("rows have different lengths")
	}

	c := make([]string, len(children))
	copy(c, children)
	if len(c) == 0 {
		c = defaultChildren
	}
	sort.Strings(c)

	seen := make(map[string]bool)
	for _, child := range c {
		if seen[child] {
			return nil, errors.New("duplicate child name")
		}
		seen[child] = true
	}

	if len(row1) != len(c)*2 {
		return nil, errors.New("diagram length does not match number of children")
	}

	g := &Garden{plants: make(map[string][]string)}
	for i, child := range c {
		idx := i * 2
		plants := make([]string, 4)
		for j := 0; j < 2; j++ {
			if name, ok := plantNames[row1[idx+j]]; ok {
				plants[j] = name
			} else {
				return nil, errors.New("invalid plant code")
			}
			if name, ok := plantNames[row2[idx+j]]; ok {
				plants[j+2] = name
			} else {
				return nil, errors.New("invalid plant code")
			}
		}
		g.plants[child] = plants
	}
	return g, nil
}

func (g *Garden) Plants(child string) ([]string, bool) {
	plants, ok := g.plants[child]
	if !ok {
		return nil, false
	}
	res := make([]string, len(plants))
	copy(res, plants)
	return res, true
}
