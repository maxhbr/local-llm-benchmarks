```python
from collections import deque

class ConnectGame:
    def __init__(self, board):
        self.board = [line.replace(" ", "") for line in board.strip().splitlines()]

    def get_winner(self):
        if not self.board:
            return ""
        
        rows = len(self.board)
        cols = len(self.board[0])
        
        if self._has_path('O', rows, cols):
            return 'O'
        if self._has_path('X', rows, cols):
            return 'X'
        return ""

    def _has_path(self, player, rows, cols):
        if player == 'O':
            starts = [(0, c) for c in range(cols) if self.board[0][c] == 'O']
            is_end = lambda r, c: r == rows - 1
        else:
            starts = [(r, 0) for r in range(rows) if self.board[r][0] == 'X']
            is_end = lambda r, c: c == cols - 1
            
        if not starts:
            return False
            
        visited = set(starts)
        queue = deque(starts)
        
        dirs = [(-1, 0), (-1, 1), (0, -1), (0, 1), (1, -1), (1, 0)]
        
        while queue:
            r, c = queue.popleft()
            if is_end(r, c):
                return True
            for dr, dc in dirs:
                nr, nc = r + dr, c + dc
                if 0 <= nr < rows and 0 <= nc < cols:
                    if (nr, nc) not in visited and self.board[nr][nc] == player:
                        visited.add((nr, nc))
                        queue.append((nr, nc))
        return False
```

