use std::collections::HashMap;

pub fn lowest_price(books: &[u32]) -> u32 {
    let mut freqs: HashMap<u32, u32> = HashMap::new();
    for &book in books {
        *freqs.entry(book).or_insert(0) += 1;
    }

    let mut set_sizes = Vec::new();
    while !freqs.is_empty() {
        let distinct_count = freqs.len() as u32;
        set_sizes.push(distinct_count);
        for count in freqs.values_mut() {
            *count -= 1;
        }
        freqs.retain(|_, count| { *count > 0 });
    }

    let mut counts = [0u32; 6];
    for &size in &set_sizes {
        counts[size as usize] += 1;
    }
    
    let replace = counts[5].min(counts[3]);
    counts[5] -= replace;
    counts[3] -= replace;
    counts[4] += 2 * replace;
    
    counts[1] * 800 + 
    counts[2] * 1520 + 
    counts[3] * 2160 + 
    counts[4] * 2560 + 
    counts[5] * 3000
}
