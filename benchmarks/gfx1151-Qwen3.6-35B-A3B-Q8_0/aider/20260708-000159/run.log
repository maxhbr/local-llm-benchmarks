```rust
use std::collections::HashMap;
use std::thread;

pub fn frequency(input: &[&str], worker_count: usize) -> HashMap<char, usize> {
    if input.is_empty() || worker_count == 0 {
        return HashMap::new();
    }

    let chunks = input.chunks((input.len() + worker_count - 1) / worker_count);
    let mut handles = Vec::new();

    for chunk in chunks {
        let chunk = chunk.to_vec(); // or just pass slice, but we need to own it for the thread
        handles.push(thread::spawn(move || {
            let mut counts = HashMap::new();
            for &s in &chunk {
                for c in s.chars() {
                    if c.is_alphabetic() {
                        *counts.entry(c.to_ascii_lowercase()).or_insert(0) += 1;
                    }
                }
            }
            counts
        }));
    }

    let mut total_counts = HashMap::new();
    for handle in handles {
        let counts = handle.join().unwrap();
        for (c, count) in counts {
            *total_counts.entry(c).or_insert(0) += count;
        }
    }

    total_counts
}
```

