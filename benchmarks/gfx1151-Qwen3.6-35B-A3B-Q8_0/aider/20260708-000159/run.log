#include "perfect_numbers.h"

namespace perfect_numbers {
    kind classify(int number) {
        if (number <= 0) {
            throw std::domain_error("Classification is only possible for positive integers.");
        }
        
        if (number == 1) {
            return kind::deficient;
        }
        
        int sum = 1;
        for (int i = 2; i * i <= number; ++i) {
            if (number % i == 0) {
                sum += i;
                if (i * i != number) {
                    sum += number / i;
                }
            }
        }
        
        if (sum == number) {
            return kind::perfect;
        } else if (sum > number) {
            return kind::abundant;
        } else {
            return kind::deficient;
        }
    }
}  // namespace perfect_numbers
```

