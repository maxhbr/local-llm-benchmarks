         teams[team2].l++; teams[team2].mp++;
       } else if (result === 'loss') {
         teams[team1].l++; teams[team1].mp++;
         teams[team2].w++; teams[team2].p += 3; teams[team2].mp++;
       } else if (result === 'draw') {
         teams[team1].d++; teams[team1].p += 1; teams[team1].mp++;
         teams[team2].d++; teams[team2].p += 1; teams[team2].mp++;
