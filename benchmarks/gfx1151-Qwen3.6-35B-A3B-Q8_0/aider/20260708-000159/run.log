export class Board {
  constructor(board) {
    this.grid = board.map(row => row.replace(/\s/g, '').split(''));
  }

  winner() {
    if (this.grid.length === 0) return '';

    if (this.hasPath('O', (r, c) => r === 0, (r, c) => r === this.grid.length - 1)) {
      return 'O';
    }

    if (this.hasPath('X', (r, c) => c === 0, (r, c) => c === this.grid[0].length - 1)) {
      return 'X';
    }

    return '';
  }

  hasPath(player, startCondition, endCondition) {
    const visited = new Set();
    const queue = [];

    for (let r = 0; r < this.grid.length; r++) {
      for (let c = 0; c < this.grid[r].length; c++) {
        if (this.grid[r][c] === player && startCondition(r, c)) {
          queue.push([r, c]);
          visited.add(`${r},${c}`);
        }
      }
    }

    // Corrected directions for hex grid in this skewed representation
    const directions = [[-1, 0], [-1, 1], [0, -1], [0, 1], [1, -1], [1, 0]];

    while (queue.length > 0) {
      const [r, c] = queue.shift();
      if (endCondition(r, c)) return true;

      for (const [dr, dc] of directions) {
        const nr = r + dr;
        const nc = c + dc;
        if (nr >= 0 && nr < this.grid.length && nc >= 0 && nc < this.grid[nr].length) {
          if (this.grid[nr][nc] === player && !visited.has(`${nr},${nc}`)) {
            visited.add(`${nr},${nc}`);
            queue.push([nr, nc]);
          }
        }
      }
    }

    return false;
  }
}
```

