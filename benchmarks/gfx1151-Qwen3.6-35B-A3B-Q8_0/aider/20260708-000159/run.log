#[derive(Debug, PartialEq, Eq)]
pub enum Error {
    NotEnoughPinsLeft,
    GameComplete,
}

pub struct BowlingGame {
    rolls: Vec<u16>,
}

impl BowlingGame {
    pub fn new() -> Self {
        Self { rolls: Vec::new() }
    }

    pub fn roll(&mut self, pins: u16) -> Result<(), Error> {
        if pins > 10 {
            return Err(Error::NotEnoughPinsLeft);
        }
        
        if self.is_game_complete() {
            return Err(Error::GameComplete);
        }

        if !self.is_valid_roll(pins) {
            return Err(Error::NotEnoughPinsLeft);
        }

        self.rolls.push(pins);
        Ok(())
    }

    pub fn score(&self) -> Option<u16> {
        if !self.is_game_complete() {
            return None;
        }
        
        let mut rolls = self.rolls.iter().copied();
        let mut score = 0;
        let mut frame = 1;
        
        while frame <= 10 {
            let r1 = rolls.next()?;
            if frame < 10 {
                let r2 = rolls.next()?;
                if r1 == 10 {
                    let r3 = rolls.next()?;
                    let r4 = rolls.next()?;
                    score += 10 + r3 + r4;
                } else if r1 + r2 == 10 {
                    let r3 = rolls.next()?;
                    score += 10 + r3;
                } else {
                    score += r1 + r2;
                }
            } else {
                let r3 = rolls.next()?;
                score += r1 + r2 + r3;
            }
            frame += 1;
        }
        Some(score)
    }

    fn is_game_complete(&self) -> bool {
        let mut rolls = self.rolls.iter().copied();
        let mut frame = 1;
        while frame <= 10 {
            if frame < 10 {
                let r1 = rolls.next();
                if r1.is_none() { return false; }
                if r1.unwrap() == 10 {
                    // strike, frame ends
                } else {
                    let r2 = rolls.next();
                    if r2.is_none() { return false; }
                }
            } else {
                let r1 = rolls.next();
                let r2 = rolls.next();
                let r3 = rolls.next();
                if r1.is_none() || r2.is_none() { return false; }
                if r1.unwrap() == 10 {
                    return r3.is_some();
                } else if r1.unwrap() + r2.unwrap() == 10 {
                    return r3.is_some();
                } else {
                    return true;
                }
            }
            frame += 1;
        }
        true
    }

    fn is_valid_roll(&self, pins: u16) -> bool {
        let mut rolls = self.rolls.iter().copied();
        let mut frame = 1;
        while frame <= 10 {
            if frame < 10 {
                let r1 = rolls.next();
                if r1.is_none() {
                    return pins <= 10;
                }
                if r1.unwrap() == 10 {
                    frame += 1;
                    continue;
                }
                let r2 = rolls.next();
                if r2.is_none() {
                    return r1.unwrap() + pins <= 10;
                }
                frame += 1;
            } else {
                let r1 = rolls.next();
                let r2 = rolls.next();
                if r1.is_none() {
                    return pins <= 10;
                }
                if r2.is_none() {
                    if r1.unwrap() == 10 {
                        return pins <= 10;
                    }
                    return r1.unwrap() + pins <= 10;
                }
                return pins <= 10;
            }
        }
        false
    }
}
