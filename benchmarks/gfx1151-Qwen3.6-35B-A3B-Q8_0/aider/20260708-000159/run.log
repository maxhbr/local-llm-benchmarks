		tb = append(tb, ranks...)
	} else if isStraight {
		cat = 5
		tb = append(tb, straightHigh)
	} else if len(threes) == 1 {
		cat = 4
		tb = append(tb, threes[0])
		for _, r := range ranks {
			if r != threes[0] {
				tb = append(tb, r)
			}
		}
	} else if len(pairs) == 2 {
		cat = 3
		tb = append(tb, pairs[0], pairs[1])
		for _, r := range ranks {
			if r != pairs[0] && r != pairs[1] {
				tb = append(tb, r)
			}
		}
	} else if len(pairs) == 1 {
		cat = 2
		tb = append(tb, pairs[0])
		for _, r := range ranks {
			if r != pairs[0] {
				tb = append(tb, r)
			}
		}
	} else {
		cat = 1
		tb = append(tb, ranks...)
	}

	return &Hand{original: original, category: cat, tieBreakers: tb}, nil
}
```
