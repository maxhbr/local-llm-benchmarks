#[derive(Debug)]
pub struct Error;

#[derive(Debug)]
pub struct Scale {
    notes: Vec<String>,
}

const SHARPS: [&str; 12] = ["C", "C#", "D", "D#", "E", "F", "F#", "G", "G#", "A", "A#", "B"];
const FLATS: [&str; 12] = ["C", "Db", "D", "Eb", "E", "F", "Gb", "G", "Ab", "A", "Bb", "B"];

impl Scale {
    pub fn new(tonic: &str, intervals: &str) -> Result<Scale, Error> {
        let chromatic = get_chromatic_set(tonic);
        let tonic_idx = chromatic.iter().position(|&n| n.eq_ignore_ascii_case(tonic))
            .ok_or(Error)?;
        
        let mut notes = Vec::new();
        notes.push(chromatic[tonic_idx].to_string());
        
        let mut current_idx = tonic_idx;
        for c in intervals.chars() {
            let step = match c {
                'm' => 1,
                'M' => 2,
                'A' => 3,
                _ => return Err(Error),
            };
            current_idx = (current_idx + step) % 12;
            notes.push(chromatic[current_idx].to_string());
        }
        
        Ok(Scale { notes })
    }

    pub fn chromatic(tonic: &str) -> Result<Scale, Error> {
        let chromatic = get_chromatic_set(tonic);
        let tonic_idx = chromatic.iter().position(|&n| n.eq_ignore_ascii_case(tonic))
            .ok_or(Error)?;
            
        let mut notes = Vec::new();
        notes.push(chromatic[tonic_idx].to_string());
        let mut current_idx = tonic_idx;
        for _ in 0..12 {
            current_idx = (current_idx + 1) % 12;
            notes.push(chromatic[current_idx].to_string());
        }
        Ok(Scale { notes })
    }

    pub fn enumerate(&self) -> Vec<String> {
        self.notes.clone()
    }
}

fn get_chromatic_set(tonic: &str) -> &'static [&'static str] {
    if uses_flats(tonic) {
        &FLATS
    } else {
        &SHARPS
    }
}

fn uses_flats(tonic: &str) -> bool {
    matches!(tonic, "F" | "Bb" | "Eb" | "Ab" | "Db" | "Gb" | "d" | "g" | "c" | "f" | "bb" | "eb")
}
```

