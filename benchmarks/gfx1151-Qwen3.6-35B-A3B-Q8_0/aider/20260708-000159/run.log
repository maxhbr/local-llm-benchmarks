export const encode = (numbers) => {
  let result = [];
  for (const num of numbers) {
    if (num === 0) {
      result.push(0);
      continue;
    }
    let chunks = [];
    let temp = num;
    while (temp > 0) {
      chunks.push(temp & 0x7F);
      temp >>>= 7;
    }
    chunks.reverse();
    for (let i = 0; i < chunks.length; i++) {
      if (i < chunks.length - 1) {
        result.push(chunks[i] | 0x80);
      } else {
        result.push(chunks[i]);
      }
    }
  }
  return result;
};

export const decode = (bytes) => {
  let result = [];
  let value = 0;
  for (const byte of bytes) {
    value = (value << 7) | (byte & 0x7F);
    if ((byte & 0x80) === 0) {
      result.push(value);
      value = 0;
    }
  }
  if (bytes.length > 0 && (bytes[bytes.length - 1] & 0x80)) {
    throw new Error('Incomplete sequence');
  }
  return result;
};
```

