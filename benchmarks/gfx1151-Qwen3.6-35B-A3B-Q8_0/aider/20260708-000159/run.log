#include "bank_account.h"
#include <stdexcept>

namespace Bankaccount {

void Bankaccount::open() {
    std::lock_guard<std::mutex> lock(mtx_);
    if (is_open_) {
        throw std::logic_error("Account already open");
    }
    is_open_ = true;
    balance_ = 0;
}

void Bankaccount::close() {
    std::lock_guard<std::mutex> lock(mtx_);
    if (!is_open_) {
        throw std::logic_error("Account not open");
    }
    is_open_ = false;
}

void Bankaccount::deposit(long amount) {
    std::lock_guard<std::mutex> lock(mtx_);
    if (!is_open_) {
        throw std::logic_error("Account not open");
    }
    if (amount <= 0) {
        throw std::logic_error("Amount must be positive");
    }
    balance_ += amount;
}

void Bankaccount::withdraw(long amount) {
    std::lock_guard<std::mutex> lock(mtx_);
    if (!is_open_) {
        throw std::logic_error("Account not open");
    }
    if (amount <= 0) {
        throw std::logic_error("Amount must be positive");
    }
    if (balance_ < amount) {
        throw std::logic_error("Insufficient funds");
    }
    balance_ -= amount;
}

long Bankaccount::balance() const {
    std::lock_guard<std::mutex> lock(mtx_);
    if (!is_open_) {
        throw std::logic_error("Account not open");
    }
    return balance_;
}

}  // namespace Bankaccount
```
