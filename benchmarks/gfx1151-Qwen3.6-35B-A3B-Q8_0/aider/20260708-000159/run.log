package tree

import (
        "errors"
        "sort"
)

type Record struct {
        ID     int
        Parent int
}

type Node struct {
        ID       int
        Children []*Node
}

func (n *Node) String() string {
        return "" // not needed
}

func Build(records []Record) (*Node, error) {
        if len(records) == 0 {
                return nil, nil
        }

        nodes := make([]*Node, len(records))
        parentMap := make(map[int]int)

        for _, r := range records {
                if r.ID < 0 || r.ID >= len(records) {
                        return nil, errors.New("ID out of range")
                }
                if nodes[r.ID] != nil {
                        return nil, errors.New("duplicate ID")
                }
                if r.ID == 0 {
                        if r.Parent != 0 {
                                return nil, errors.New("root parent must be 0")
                        }
                } else {
                        if r.Parent >= r.ID {
                                return nil, errors.New("parent ID must be less than child ID")
                        }
                }
                nodes[r.ID] = &Node{ID: r.ID}
                parentMap[r.ID] = r.Parent
        }

        // Check for missing IDs (though bounds + no duplicates + length check implies continuity if length 
matches, but let's be safe)
        // Actually, if len(records) == N, and all IDs are in [0, N-1] and unique, then they must be 0..N-1. So 
no need to check missing.

        for i := 1; i < len(records); i++ {
                parentID := parentMap[i]
                nodes[parentID].Children = append(nodes[parentID].Children, nodes[i])
        }

        // Sort children by ID
        for _, n := range nodes {
                sort.Slice(n.Children, func(i, j int) bool {
                        return n.Children[i].ID < n.Children[j].ID
                })
        }

        return nodes[0], nil
}
