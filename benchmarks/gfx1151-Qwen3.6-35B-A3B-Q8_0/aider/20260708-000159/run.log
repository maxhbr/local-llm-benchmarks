        "-":  func(s []int) ([]int, error) { return applyBinary(s, func(a, b int) int { return a - b }) },
        "*":  func(s []int) ([]int, error) { return applyBinary(s, func(a, b int) int { return a * b }) },
        "/":  func(s []int) ([]int, error) { return applyBinary(s, func(a, b int) int { return a / b }) },
        "dup": func(s []int) ([]int, error) {
                if len(s) < 1 { return nil, errors.New("dup requires 1 argument") }
                return append(s, s[len(s)-1]), nil
        },
        "drop": func(s []int) ([]int, error) {
                if len(s) < 1 { return nil, errors.New("drop requires 1 argument") }
                return s[:len(s)-1], nil
        },
        "swap": func(s []int) ([]int, error) {
                if len(s) < 2 { return nil, errors.New("swap requires 2 arguments") }
                s[len(s)-1], s[len(s)-2] = s[len(s)-2], s[len(s)-1]
                return s, nil
        },
        "over": func(s []int) ([]int, error) {
                if len(s) < 2 { return nil, errors.New("over requires 2 arguments") }
                return append(s, s[len(s)-2]), nil
        },
}

func applyBinary(stack []int, op func(int, int) int) ([]int, error) {
        if len(stack) < 2 {
                return nil, errors.New("operator requires 2 arguments")
        }
        a := stack[len(stack)-1]
        b := stack[len(stack)-2]
        stack = stack[:len(stack)-2]
        return append(stack, op(b, a)), nil
}
