export class Forth {
  constructor() {
    this.stack = [];
    this.definitions = {};
  }

  evaluate(input) {
    const tokens = input.toLowerCase().split(/\s+/);
    let i = 0;
    while (i < tokens.length) {
      const token = tokens[i];
      
      if (token === ':') {
        i++;
        const wordName = tokens[i];
        if (/^-?\d+$/.test(wordName)) {
          throw new Error('Invalid definition');
        }
        i++;
        const definition = [];
        while (i < tokens.length && tokens[i] !== ';') {
          definition.push(tokens[i]);
          i++;
        }
        if (i >= tokens.length) {
          throw new Error('Unterminated definition');
        }
        this.definitions[wordName] = definition;
        i++; // skip ';'
      } else if (/^-?\d+$/.test(token)) {
        this.stack.push(parseInt(token, 10));
        i++;
      } else if (this.definitions[token]) {
        // Expand definition
        const def = this.definitions[token];
        // Insert definition tokens at current position
        // We can just push them to the front of the remaining tokens, or splice
        // Splicing is easier for index tracking
        tokens.splice(i, 1, ...def);
        // Don't increment i, process the first token of the definition
      } else if (this.isOperator(token)) {
        this.executeOperator(token);
        i++;
      } else {
        throw new Error('Unknown command');
      }
    }
  }

  isOperator(token) {
    return ['+', '-', '*', '/', 'dup', 'drop', 'swap', 'over'].includes(token);
  }

  executeOperator(token) {
    const pop = () => {
      if (this.stack.length === 0) throw new Error('Stack empty');
      return this.stack.pop();
    };
    const pop2 = () => {
      if (this.stack.length < 2) throw new Error('Stack empty');
      return [pop(), pop()];
    };

    switch (token) {
      case '+': {
        const [b, a] = pop2();
        this.stack.push(a + b);
        break;
      }
      case '-': {
        const [b, a] = pop2();
        this.stack.push(a - b);
        break;
      }
      case '*': {
        const [b, a] = pop2();
        this.stack.push(a * b);
        break;
      }
      case '/': {
        const [b, a] = pop2();
        if (b === 0) throw new Error('Division by zero');
        this.stack.push(Math.trunc(a / b)); // Forth usually truncates towards zero
        break;
      }
      case 'dup': {
        const a = pop();
        this.stack.push(a, a);
        break;
      }
      case 'drop': {
        pop();
        break;
      }
      case 'swap': {
        const [b, a] = pop2();
        this.stack.push(b, a);
        break;
      }
      case 'over': {
        const [b, a] = pop2();
        this.stack.push(a, b, a);
        break;
      }
    }
  }

  get stack() {
    return this.stack;
  }
}
```

