        [currB1, 0],              // Empty two
        [currB1 - Math.min(currB1, this.bucketTwo - currB2), currB2 + Math.min(currB1, this.bucketTwo - currB2)], // Pour one to two
        [currB1 + Math.min(currB2, this.bucketOne - currB1), currB2 - Math.min(currB2, this.bucketOne - currB1)]  // Pour two to one
      ];
      
