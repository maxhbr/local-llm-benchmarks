```javascript
//
// This is only a SKELETON file for the 'Zebra Puzzle' exercise. It's been provided as a
// convenience to get you started writing code faster.
//

const VALUES = {
  color: ['Red', 'Green', 'Ivory', 'Yellow', 'Blue'],
  nationality: ['Englishman', 'Spaniard', 'Ukrainian', 'Norwegian', 'Japanese'],
  pet: ['Dog', 'Snail', 'Fox', 'Horse', 'Zebra'],
  drink: ['Coffee', 'Tea', 'Milk', 'Orange Juice', 'Water'],
  hobby: ['Dancing', 'Painter', 'Reading', 'Football', 'Chess']
};

export class ZebraPuzzle {
  constructor() {
    this.solution = this.solve();
  }

  solve() {
    const houses = Array(5).fill(null).map(() => ({}));
    const used = {
      color: new Set(),
      nationality: new Set(),
      pet: new Set(),
      drink: new Set(),
      hobby: new Set()
    };

    const check = (idx) => {
      const h = houses[idx];
      
      if (idx === 0 && h.nationality !== 'Norwegian') return false;
      if (idx === 2 && h.drink !== 'Milk') return false;
      if (idx === 1 && h.color !== 'Blue') return false;
      
      if (h.color === 'Green' && (idx === 0 || houses[idx-1].color !== 'Ivory')) return false;
      if (h.color === 'Ivory' && idx === 4) return false;
      
      if (h.nationality === 'Englishman' && h.color !== 'Red') return false;
      if (h.color === 'Red' && h.nationality !== 'Englishman') return false;
      
      if (h.nationality === 'Spaniard' && h.pet !== 'Dog') return false;
      if (h.pet === 'Dog' && h.nationality !== 'Spaniard') return false;
      
      if (h.color === 'Green' && h.drink !== 'Coffee') return false;
      if (h.drink === 'Coffee' && h.color !== 'Green') return false;
      
      if (h.nationality === 'Ukrainian' && h.drink !== 'Tea') return false;
      if (h.drink === 'Tea' && h.nationality !== 'Ukrainian') return false;
      
      if (h.pet === 'Snail' && h.hobby !== 'Dancing') return false;
      if (h.hobby === 'Dancing' && h.pet !== 'Snail') return false;
      
      if (h.color === 'Yellow' && h.hobby !== 'Painter') return false;
      if (h.hobby === 'Painter' && h.color !== 'Yellow') return false;
      
      if (h.hobby === 'Football' && h.drink !== 'Orange Juice') return false;
      if (h.drink === 'Orange Juice' && h.hobby !== 'Football') return false;
      
      if (h.nationality === 'Japanese' && h.hobby !== 'Chess') return false;
      if (h.hobby === 'Chess' && h.nationality !== 'Japanese') return false;

      if (h.hobby === 'Reading') {
        let hasFox = false;
        if (idx > 0 && houses[idx-1].pet === 'Fox') hasFox = true;
        if (idx < 4 && houses[idx+1].pet === 'Fox') hasFox = true;
        if (!hasFox && idx > 0 && idx < 4 && houses[idx-1].pet && houses[idx+1].pet) return false;
        if (!hasFox && idx === 0 && houses[1].pet && houses[1].pet !== 'Fox') return false;
        if (!hasFox && idx === 4 && houses[3].pet && houses[3].pet !== 'Fox') return false;
      }
      
      if (h.hobby === 'Painter') {
        let hasHorse = false;
        if (idx > 0 && houses[idx-1].pet === 'Horse') hasHorse = true;
        if (idx < 4 && houses[idx+1].pet === 'Horse') hasHorse = true;
        if (!hasHorse && idx > 0 && idx < 4 && houses[idx-1].pet && houses[idx+1].pet) return false;
        if (!hasHorse && idx === 0 && houses[1].pet && houses[1].pet !== 'Horse') return false;
        if (!hasHorse && idx === 4 && houses[3].pet && houses[3].pet !== 'Horse') return false;
      }

      return true;
    };

    const backtrack = (idx) => {
      if (idx === 5) return true;

      for (const color of VALUES.color) {
        if (used.color.has(color)) continue;
        houses[idx].color = color;
        used.color.add(color);

        for (const nationality of VALUES.nationality) {
          if (used.nationality.has(nationality)) continue;
          houses[idx].nationality = nationality;
          used.nationality.add(nationality);

          for (const pet of VALUES.pet) {
            if (used.pet.has(pet)) continue;
            houses[idx].pet = pet;
            used.pet.add(pet);

            for (const drink of VALUES.drink) {
              if (used.drink.has(drink)) continue;
              houses[idx].drink = drink;
              used.drink.add(drink);

              for (const hobby of VALUES.hobby) {
                if (used.hobby.has(hobby)) continue;
                houses[idx].hobby = hobby;
                used.hobby.add(hobby);

                if (check(idx)) {
                  if (backtrack(idx + 1)) return true;
                }

                used.hobby.delete(hobby);
              }
              used.drink.delete(drink);
            }
            used.pet.delete(pet);
          }
          used.nationality.delete(nationality);
        }
        used.color.delete(color);
      }
      return false;
    };

    backtrack(0);
    return houses;
  }

  waterDrinker() {
    const waterHouse = this.solution.find(h => h.drink === 'Water');
    return waterHouse.nationality;
  }

  zebraOwner() {
    const zebraHouse = this.solution.find(h => h.pet === 'Zebra');
    return zebraHouse.nationality;
  }
}
