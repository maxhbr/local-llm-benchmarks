```javascript
//
// This is only a SKELETON file for the 'Forth' exercise. It's been provided as a
// convenience to get you started writing code faster.
//

export class Forth {
  constructor() {
    this._stack = [];
    this.definitions = {};
  }

  evaluate(input) {
    const tokens = input.toLowerCase().split(/\s+/);
    let i = 0;
    while (i < tokens.length) {
      const token = tokens[i];

      if (token === ':') {
        i++;
        if (i >= tokens.length) throw new Error('Invalid definition');
        const wordName = tokens[i];
        if (/^-?\d+$/.test(wordName)) {
          throw new Error('Invalid definition');
        }
        i++;
        const definition = [];
        while (i < tokens.length && tokens[i] !== ';') {
          definition.push(tokens[i]);
          i++;
        }
        if (i >= tokens.length) {
          throw new Error('Unterminated definition');
        }
        this.definitions[wordName] = definition;
        i++; // skip ';'
      } else if (/^-?\d+$/.test(token)) {
        this._stack.push(parseInt(token, 10));
        i++;
      } else if (this.definitions[token]) {
        const def = this.definitions[token];
        tokens.splice(i, 1, ...def);
      } else if (this.isOperator(token)) {
        this.executeOperator(token);
        i++;
      } else {
        throw new Error('Unknown command');
      }
    }
  }

  isOperator(token) {
    return ['+', '-', '*', '/', 'dup', 'drop', 'swap', 'over'].includes(token);
  }

  executeOperator(token) {
    const pop = () => {
      if (this._stack.length === 0) throw new Error('Stack empty');
      return this._stack.pop();
    };
    const pop2 = () => {
      if (this._stack.length < 2) throw new Error('Stack empty');
      return [pop(), pop()];
    };

    switch (token) {
      case '+': {
        const [b, a] = pop2();
        this._stack.push(a + b);
        break;
      }
      case '-': {
        const [b, a] = pop2();
        this._stack.push(a - b);
        break;
      }
      case '*': {
        const [b, a] = pop2();
        this._stack.push(a * b);
        break;
      }
      case '/': {
        const [b, a] = pop2();
        if (b === 0) throw new Error('Division by zero');
        this._stack.push(Math.trunc(a / b));
        break;
      }
      case 'dup': {
        const a = pop();
        this._stack.push(a, a);
        break;
      }
      case 'drop': {
        pop();
        break;
      }
      case 'swap': {
        const [b, a] = pop2();
        this._stack.push(b, a);
        break;
      }
      case 'over': {
        const [b, a] = pop2();
        this._stack.push(a, b, a);
        break;
      }
    }
  }

  get stack() {
    return this._stack;
  }
}
