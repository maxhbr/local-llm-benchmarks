```python
import math

def encode(plain_text, a, b):
    if math.gcd(a, 26) != 1:
        raise ValueError("a and m must be coprime.")
    
    # Clean input: keep only alphanumeric, convert to lowercase
    cleaned = [c.lower() for c in plain_text if c.isalnum()]
    
    encrypted_chars = []
    for c in cleaned:
        if c.isdigit():
            encrypted_chars.append(c)
        else:
            i = ord(c) - ord('a')
            e = (a * i + b) % 26
            encrypted_chars.append(chr(e + ord('a')))
            
    # Group into chunks of 5
    result = []
    for i in range(0, len(encrypted_chars), 5):
        result.append("".join(encrypted_chars[i:i+5]))
        
    return " ".join(result)

def decode(ciphered_text, a, b):
    if math.gcd(a, 26) != 1:
        raise ValueError("a and m must be coprime.")
        
    # Find MMI of a mod 26
    mmi = None
    for x in range(1, 26):
        if (a * x) % 26 == 1:
            mmi = x
            break
            
    # Clean input: keep only alphanumeric (ciphered text might have spaces)
    cleaned = [c.lower() for c in ciphered_text if c.isalnum()]
    
    decrypted_chars = []
    for c in cleaned:
        if c.isdigit():
            decrypted_chars.append(c)
        else:
            y = ord(c) - ord('a')
            d = (mmi * (y - b)) % 26
            decrypted_chars.append(chr(d + ord('a')))
            
    return "".join(decrypted_chars)
```

