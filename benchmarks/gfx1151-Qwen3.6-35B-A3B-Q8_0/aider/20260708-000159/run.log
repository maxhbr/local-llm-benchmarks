```javascript
//
// This is only a SKELETON file for the 'Tournament' exercise. It's been provided as a
// convenience to get you started writing code faster.
//

export const tournamentTally = (input) => {
  const teams = {};
  const lines = (input || '').split('\n');

  for (const line of lines) {
    const trimmed = line.trim();
    if (!trimmed) continue;
    const parts = trimmed.split(';');
    if (parts.length !== 3) continue;

    const [team1, team2, result] = parts;
    if (!teams[team1]) teams[team1] = { mp: 0, w: 0, d: 0, l: 0, p: 0 };
    if (!teams[team2]) teams[team2] = { mp: 0, w: 0, d: 0, l: 0, p: 0 };

    if (result === 'win') {
      teams[team1].w++; teams[team1].p += 3; teams[team1].mp++;
      teams[team2].l++; teams[team2].mp++;
    } else if (result === 'loss') {
      teams[team1].l++; teams[team1].mp++;
      teams[team2].w++; teams[team2].p += 3; teams[team2].mp++;
    } else if (result === 'draw') {
      teams[team1].d++; teams[team1].p += 1; teams[team1].mp++;
      teams[team2].d++; teams[team2].p += 1; teams[team2].mp++;
    }
  }

  const sortedTeams = Object.keys(teams).sort((a, b) => {
    if (teams[b].p !== teams[a].p) return teams[b].p - teams[a].p;
    return a.localeCompare(b);
  });

  let output = 'Team                           | MP |  W |  D |  L |  P\n';
  for (const team of sortedTeams) {
    const t = teams[team];
    output += `${team.padEnd(31)}| ${String(t.mp).padStart(2)} | ${String(t.w).padStart(2)} | ${String(t.d).padStart(2)} | ${String(t.l).padStart(2)} | ${String(t.p).padStart(2)}\n`;
  }

  return output;
};
