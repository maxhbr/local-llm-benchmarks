package wordsearch

import "errors"

func Solve(words []string, puzzle []string) (map[string][2][2]int, error) {
        result := make(map[string][2][2]int)
        rows := len(puzzle)
        if rows == 0 {
                return result, nil
        }
        cols := len(puzzle[0])

        directions := [][2]int{
                {0, 1},   // right
                {0, -1},  // left
                {1, 0},   // down
                {-1, 0},  // up
                {1, 1},   // down-right
                {1, -1},  // down-left
                {-1, 1},  // up-right
                {-1, -1}, // up-left
        }

        for _, word := range words {
                found := false
                for r := 0; r < rows && !found; r++ {
                        for c := 0; c < cols && !found; c++ {
                                for _, dr := range directions {
                                        if match(word, puzzle, r, c, dr[0], dr[1]) {
                                                result[word] = [2][2]int{{r, c}, {r + dr[0]*(len(word)-1), c + 
dr[1]*(len(word)-1)}}
                                                found = true
                                        }
                                }
                        }
                }
                if !found {
                        return nil, errors.New("word not found")
                }
        }
        return result, nil
}

func match(word string, puzzle []string, startR, startC, dr, dc int) bool {
        rows := len(puzzle)
        cols := len(puzzle[0])
        for i := 0; i < len(word); i++ {
                r := startR + dr*i
                c := startC + dc*i
                if r < 0 || r >= rows || c < 0 || c >= cols || puzzle[r][c] != word[i] {
                        return false
                }
        }
        return true
}
