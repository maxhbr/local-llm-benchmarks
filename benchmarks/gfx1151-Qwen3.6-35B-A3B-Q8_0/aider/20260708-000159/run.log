```python
class Zipper:
    def __init__(self, focus, path=None):
        self.focus = focus
        self.path = path if path is not None else []

    @staticmethod
    def from_tree(tree):
        return Zipper(tree)

    def value(self):
        return self.focus['value']

    def set_value(self, value):
        new_focus = dict(self.focus)
        new_focus['value'] = value
        return Zipper(new_focus, self.path)

    def left(self):
        if self.focus.get('left') is None:
            return None
        new_path = self.path + [('left', self.focus)]
        return Zipper(self.focus['left'], new_path)

    def set_left(self, node):
        new_focus = dict(self.focus)
        new_focus['left'] = node
        return Zipper(new_focus, self.path)

    def right(self):
        if self.focus.get('right') is None:
            return None
        new_path = self.path + [('right', self.focus)]
        return Zipper(self.focus['right'], new_path)

    def set_right(self, node):
        new_focus = dict(self.focus)
        new_focus['right'] = node
        return Zipper(new_focus, self.path)

    def up(self):
        if not self.path:
            return None
        direction, parent = self.path[-1]
        new_path = self.path[:-1]
        return Zipper(parent, new_path)

    def to_tree(self):
        # Reconstruct tree from focus up to root
        tree = self.focus
        for direction, parent in reversed(self.path):
            new_parent = dict(parent)
            new_parent[direction] = tree
            tree = new_parent
        return tree
```

