package bookstore

func Cost(books []int) int {
	counts := make(map[int]int)
	for _, b := range books {
		counts[b]++
	}

	var groups []int
	for len(counts) > 0 {
		k := len(counts)
		groups = append(groups, k)
		for book := range counts {
			counts[book]--
			if counts[book] == 0 {
				delete(counts, book)
			}
		}
	}

	prices := []int{0, 800, 1520, 2160, 2560, 3000}
	total := 0
	fives := 0
	threes := 0
	for _, g := range groups {
		total += prices[g]
		if g == 5 {
			fives++
		} else if g == 3 {
			threes++
		}
	}

	replacements := fives
	if threes < replacements {
		replacements = threes
	}
	total -= replacements * 40

	return total
}
