package react

// Define reactor, cell and canceler types here.
// These types will implement the Reactor, Cell and Canceler interfaces, respectively.

type reactor struct {
        cells []*cell
}

type cell struct {
        value      int
        deps       []*cell
        dependents []*cell
        callbacks  []*canceler
        compute1   func(int) int
        compute2   func(int, int) int
        isInput    bool
}

type canceler struct {
        cell     *cell
        callback func(int)
        canceled bool
}

func (c *canceler) Cancel() {
        c.canceled = true
}

func (c *cell) Value() int {
        return c.value
}

func (c *cell) SetValue(value int) {
        if c.value == value {
                return
        }
        c.value = value

        changed := make(map[*cell]bool)
        queue := []*cell{}

        for _, dep := range c.dependents {
                queue = append(queue, dep)
        }

        for len(queue) > 0 {
                curr := queue[0]
                queue = queue[1:]

                var newVal int
                if curr.compute1 != nil {
                        newVal = curr.compute1(curr.deps[0].Value())
                } else {
                        newVal = curr.compute2(curr.deps[0].Value(), curr.deps[1].Value())
                }

                if newVal != curr.value {
                        curr.value = newVal
                        changed[curr] = true
                        for _, dep := range curr.dependents {
                                queue = append(queue, dep)
                        }
                }
        }

        for cell := range changed {
                for _, c := range cell.callbacks {
                        if !c.canceled {
                                c.callback(cell.value)
                        }
                }
        }
}

func (c *cell) AddCallback(callback func(int)) Canceler {
        cancel := &canceler{
                cell:     c,
                callback: callback,
        }
        c.callbacks = append(c.callbacks, cancel)
        return cancel
}

func New() Reactor {
        return &reactor{}
}

func (r *reactor) CreateInput(initial int) InputCell {
        c := &cell{
                value:   initial,
                isInput: true,
        }
        r.cells = append(r.cells, c)
        return c
}

func (r *reactor) CreateCompute1(dep Cell, compute func(int) int) ComputeCell {
        dc := dep.(*cell)
        c := &cell{
                deps:     []*cell{dc},
                compute1: compute,
                isInput:  false,
        }
        dc.dependents = append(dc.dependents, c)
        c.value = compute(dep.Value())
        r.cells = append(r.cells, c)
        return c
}

func (r *reactor) CreateCompute2(dep1, dep2 Cell, compute func(int, int) int) ComputeCell {
        d1 := dep1.(*cell)
        d2 := dep2.(*cell)
        c := &cell{
                deps:     []*cell{d1, d2},
                compute2: compute,
                isInput:  false,
        }
        d1.dependents = append(d1.dependents, c)
        d2.dependents = append(d2.dependents, c)
        c.value = compute(dep1.Value(), dep2.Value())
        r.cells = append(r.cells, c)
        return c
}
```

