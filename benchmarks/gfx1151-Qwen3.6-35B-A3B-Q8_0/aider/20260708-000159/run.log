def can_chain(dominoes):
    if not dominoes:
        return []
    
    n = len(dominoes)
    used = [False] * n
    
    def backtrack(chain):
        if len(chain) == n:
            if chain[0][0] == chain[-1][1]:
                return chain
            return None
            
        last_val = chain[-1][1]
        for i in range(n):
            if not used[i]:
                a, b = dominoes[i]
                if a == last_val:
                    used[i] = True
                    res = backtrack(chain + [(a, b)])
                    if res:
                        return res
                    used[i] = False
                if b == last_val and a != b: # avoid duplicate work for doubles
                    used[i] = True
                    res = backtrack(chain + [(b, a)])
                    if res:
                        return res
                    used[i] = False
        return None

    # Start with the first domino in both orientations
    a, b = dominoes[0]
    used[0] = True
    
    res = backtrack([(a, b)])
    if res:
        return res
        
    if a != b:
        res = backtrack([(b, a)])
        if res:
            return res
            
    return None
