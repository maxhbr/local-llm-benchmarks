                        } else if "aeiou".contains(c) {
                            split_idx = i;
                            break;
                        } else if c == 'y' && i > 0 {
                            split_idx = i;
                            break;
                        }
                    }
                }
            }
            
            let (prefix, suffix) = word.split_at(split_idx);
            format!("{}{}ay", suffix, prefix)
        })
        .collect::<Vec<_>>()
        .join(" ")
}
