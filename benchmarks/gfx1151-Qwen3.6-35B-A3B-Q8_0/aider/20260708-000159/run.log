    if math.gcd(a, 26) != 1:
        raise ValueError("a and m must be coprime.")
        
    cleaned = [c.lower() for c in plain_text if c.isalnum()]
    encrypted = []
    for char in cleaned:
        if char.isdigit():
            encrypted.append(char)
        else:
            i = ord(char) - ord('a')
            e = (a * i + b) % 26
            encrypted.append(chr(e + ord('a')))
            
    return " ".join("".join(encrypted[i:i+5]) for i in range(0, len(encrypted), 5))

def decode(ciphered_text, a, b):
    if math.gcd(a, 26) != 1:
        raise ValueError("a and m must be coprime.")
        
    mmi = next(x for x in range(1, 26) if (a * x) % 26 == 1)
        
    cleaned = [c.lower() for c in ciphered_text if c.isalnum()]
    decrypted = []
    for char in cleaned:
        if char.isdigit():
            decrypted.append(char)
        else:
            y = ord(char) - ord('a')
            d = (mmi * (y - b)) % 26
            decrypted.append(chr(d + ord('a')))
            
    return "".join(decrypted)
