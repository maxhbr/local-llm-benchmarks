    score = [3, rank1, rank2, rank3];
  } else if (count1 === 2) {
    score = [2, rank1, rank2, rank3, rank4];
  } else {
    score = [1, ...ranks];
  }
  
  return score;
}

function compareScores(a, b) {
  for (let i = 0; i < Math.max(a.length, b.length); i++) {
    const va = a[i] || 0;
    const vb = b[i] || 0;
    if (va > vb) return 1;
    if (va < vb) return -1;
  }
  return 0;
}

export const bestHands = (hands) => {
  const evaluated = hands.map((h, i) => ({ hand: h, score: evaluateHand(h), index: i }));
  const maxScore = evaluated.reduce((max, curr) => {
    if (compareScores(curr.score, max.score) > 0) return curr.score;
    return max.score;
  }, [0]);
  
  return evaluated
    .filter(e => compareScores(e.score, maxScore) === 0)
    .map(e => e.index);
};
