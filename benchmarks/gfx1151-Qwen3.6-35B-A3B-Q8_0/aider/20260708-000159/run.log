  counts.sort((a, b) => b.count - a.count || b.rank - a.rank);

  const [count1, rank1] = [counts[0].count, counts[0].rank];
  const [count2, rank2] = counts.length > 1 ? [counts[1].count, counts[1].rank] : [0, 0];
  const [count3, rank3] = counts.length > 2 ? [counts[2].count, counts[2].rank] : [0, 0];
  const [count4, rank4] = counts.length > 3 ? [counts[3].count, counts[3].rank] : [0, 0];

  let score = [];

  if (isStraight && isFlush) {
    score = [9, straightHigh];
  } else if (count1 === 4) {
    score = [8, rank1, rank2];
  } else if (count1 === 3 && count2 === 2) {
