            }
            used[d] = true;
            assignment[*c as usize] = Some(d as u8);
            if let Some(res) = solve_recursive(chars, coeffs, used, assignment, idx + 1, leading_chars) {
                return Some(res);
            }
            used[d] = false;
            assignment[*c as usize] = None;
        }
    }
    None
}
```

