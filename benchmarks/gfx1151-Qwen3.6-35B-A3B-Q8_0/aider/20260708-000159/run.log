from collections import deque

class InputCell:
    def __init__(self, initial_value):
        self._value = initial_value
        self.dependents = []

    @property
    def value(self):
        return self._value

    @value.setter
    def value(self, new_value):
        if self._value == new_value:
            return
        self._value = new_value
        self._propagate()

    def _propagate(self):
        changed_cells = set()
        queue = deque([self])
        visited = {self}
        
        while queue:
            cell = queue.popleft()
            if isinstance(cell, ComputeCell):
                old_value = cell._value
                new_value = cell.compute()
                if new_value != old_value:
                    cell._value = new_value
                    changed_cells.add(cell)
                
                for dep in cell.dependents:
                    if dep not in visited:
                        visited.add(dep)
                        queue.append(dep)
                        
        for cell in changed_cells:
            for cb in cell.callbacks:
                cb(cell)


class ComputeCell:
    def __init__(self, inputs, compute_function):
        self.inputs = inputs
        self._compute_function = compute_function
        self._value = self._compute_function([inp.value for inp in inputs])
        self.dependents = []
        self.callbacks = []
        
        for inp in inputs:
            inp.dependents.append(self)

    @property
    def value(self):
        return self._value

    def compute(self):
        return self._compute_function([inp.value for inp in self.inputs])

    def add_callback(self, callback):
        self.callbacks.append(callback)

    def remove_callback(self, callback):
        self.callbacks.remove(callback)
