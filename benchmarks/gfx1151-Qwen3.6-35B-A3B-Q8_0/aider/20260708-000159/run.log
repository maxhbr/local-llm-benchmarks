fn solve_recursive(
    chars: &[char],
    coeffs: &HashMap<char, i64>,
    used: &mut [bool; 10],
    assignment: &mut [Option<u8>; 256],
    idx: usize,
    leading_chars: &std::collections::HashSet<char>,
) -> Option<HashMap<char, u8>> {
