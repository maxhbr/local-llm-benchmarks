export const meetup = (year, month, week, dayOfWeek) => {
  const dayNames = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
  const targetDay = dayNames.indexOf(dayOfWeek);
  
  const candidates = [];
  for (let d = 1; d <= 31; d++) {
    const date = new Date(year, month - 1, d);
    if (date.getMonth() === month - 1 && date.getDay() === targetDay) {
      candidates.push(date);
    }
  }
  
  if (week === 'first') return candidates[0];
  if (week === 'second') return candidates[1];
  if (week === 'third') return candidates[2];
  if (week === 'fourth') return candidates[3];
  if (week === 'last') return candidates[candidates.length - 1];
  if (week === 'teenth') return candidates.find(d => d.getDate() >= 13 && d.getDate() <= 19);
};
```

