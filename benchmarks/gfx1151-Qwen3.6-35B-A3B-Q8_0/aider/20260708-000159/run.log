  export const transpose = (input) => {
    if (!input) return '';
    const lines = input.split('\n');
    const maxLen = Math.max(...lines.map(l => l.length), 0);
    const result = [];

    for (let j = 0; j < maxLen; j++) {
      let lastRow = -1;
      for (let i = lines.length - 1; i >= 0; i--) {
        if (j < lines[i].length) {
          lastRow = i;
          break;
        }
      }
      
      if (lastRow === -1) continue; // Should not happen if maxLen is correct

      let transposedRow = '';
      for (let i = 0; i <= lastRow; i++) {
        if (j < lines[i].length) {
          transposedRow += lines[i][j];
        } else {
          transposedRow += ' ';
        }
      }
      result.push(transposedRow);
    }

    return result.join('\n');
  };
  ```

