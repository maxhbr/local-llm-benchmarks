```python
from collections import Counter

def total(basket):
    if not basket:
        return 0.0
        
    counts = sorted(Counter(basket).values(), reverse=True)
    
    groups = []
    while any(c > 0 for c in counts):
        # Find how many distinct books are available
        group_size = sum(1 for c in counts if c > 0)
        groups.append(group_size)
