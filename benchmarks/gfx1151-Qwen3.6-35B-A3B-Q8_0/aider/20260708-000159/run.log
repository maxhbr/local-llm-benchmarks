                                html.WriteString("</ul>")
                                inList = false
                        }
                        level := 0
                        for i := 0; i < len(line) && line[i] == '#'; i++ {
                                level++
                        }
                        content := line[level+1:]
                        html.WriteString(fmt.Sprintf("<h%d>%s</h%d>", level, content, level))
                } else if strings.HasPrefix(line, "* ") {
                        // Handle list items
                        content := line[2:]
                        if !inList {
                                html.WriteString("<ul>")
                                inList = true
                        }
                        html.WriteString(fmt.Sprintf("<li>%s</li>", content))
                } else {
                        // Close list if open, then render as paragraph
                        if inList {
                                html.WriteString("</ul>")
                                inList = false
                        }
                        html.WriteString(fmt.Sprintf("<p>%s</p>", line))
                }
        }

        // Close any remaining open list
        if inList {
                html.WriteString("</ul>")
        }

        return html.String()
}

// formatInline replaces markdown inline syntax with HTML tags
func formatInline(text string) string {
        text = strings.ReplaceAll(text, "__", "<strong>")
        text = strings.ReplaceAll(text, "__", "</strong>")
        text = strings.ReplaceAll(text, "_", "<em>")
        text = strings.ReplaceAll(text, "_", "</em>")
