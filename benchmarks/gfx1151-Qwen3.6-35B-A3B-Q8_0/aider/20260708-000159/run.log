```javascript
export class TwoBucket {
  constructor(bucketOne, bucketTwo, goal, startBucket) {
    this.bucketOne = bucketOne;
    this.bucketTwo = bucketTwo;
    this.goal = goal;
    this.startBucket = startBucket;
  }

  solve() {
    const q = [];
    const visited = new Set();
    
    let b1, b2, moves;
    if (this.startBucket === 'one') {
      b1 = this.bucketOne;
      b2 = 0;
    } else {
      b1 = 0;
      b2 = this.bucketTwo;
    }
    moves = 1;
    
    if (b1 === this.goal) {
      return { moves, goalBucket: 'one', otherBucket: b2 };
    }
    if (b2 === this.goal) {
      return { moves, goalBucket: 'two', otherBucket: b1 };
    }
    
    q.push([b1, b2, moves]);
    visited.add(`${b1},${b2}`);
    
    const forbidden = this.startBucket === 'one' 
      ? `${0},${this.bucketTwo}` 
      : `${this.bucketOne},0`;

    while (q.length > 0) {
      const [currB1, currB2, currMoves] = q.shift();
      
      const nextStates = [];
      // Fill one
      nextStates.push([this.bucketOne, currB2]);
      // Fill two
      nextStates.push([currB1, this.bucketTwo]);
      // Empty one
      nextStates.push([0, currB2]);
      // Empty two
      nextStates.push([currB1, 0]);
      // Pour one to two
      const pour1to2 = Math.min(currB1, this.bucketTwo - currB2);
      nextStates.push([currB1 - pour1to2, currB2 + pour1to2]);
      // Pour two to one
      const pour2to1 = Math.min(currB2, this.bucketOne - currB1);
      nextStates.push([currB1 + pour2to1, currB2 - pour2to1]);
      
      for (const [nb1, nb2] of nextStates) {
        const stateKey = `${nb1},${nb2}`;
        if (stateKey === forbidden || visited.has(stateKey)) continue;
        
        if (nb1 === this.goal) {
          return { moves: currMoves + 1, goalBucket: 'one', otherBucket: nb2 };
        }
        if (nb2 === this.goal) {
          return { moves: currMoves + 1, goalBucket: 'two', otherBucket: nb1 };
        }
        
        visited.add(stateKey);
        q.push([nb1, nb2, currMoves + 1]);
      }
    }
    
    throw new Error('No solution possible');
  }
}
```

