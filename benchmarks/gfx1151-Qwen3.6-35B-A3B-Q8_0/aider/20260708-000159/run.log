package tree

import (
        "errors"
        "sort"
)

type Record struct {
        ID     int
        Parent int
        // feel free to add fields as you see fit
}

type Node struct {
        ID       int
        Children []*Node
        // feel free to add fields as you see fit
}

func Build(records []Record) (*Node, error) {
        if len(records) == 0 {
                return nil, nil
        }

        nodes := make([]*Node, len(records))

        for _, r := range records {
                if r.ID < 0 || r.ID >= len(records) {
                        return nil, errors.New("ID out of range")
                }
                if nodes[r.ID] != nil {
                        return nil, errors.New("duplicate ID")
                }
                if r.ID == 0 {
                        if r.Parent != 0 {
                                return nil, errors.New("root parent must be 0")
                        }
                } else {
                        if r.Parent >= r.ID {
                                return nil, errors.New("parent ID must be less than child ID")
                        }
                }
                nodes[r.ID] = &Node{ID: r.ID}
        }

        for _, r := range records {
                if r.ID == 0 {
                        continue
                }
                nodes[r.Parent].Children = append(nodes[r.Parent].Children, nodes[r.ID])
        }

        for _, n := range nodes {
                sort.Slice(n.Children, func(i, j int) bool {
                        return n.Children[i].ID < n.Children[j].ID
                })
        }

        return nodes[0], nil
}
