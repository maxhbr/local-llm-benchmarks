            straight_high = sorted_ranks[0]
        elif sorted_ranks == [14, 5, 4, 3, 2]:
            is_straight = True
            straight_high = 5
            
    if is_flush and is_straight:
        return (8, straight_high)
    elif groups[0][1] == 4:
        return (7, groups[0][0], groups[1][0])
    elif groups[0][1] == 3 and groups[1][1] == 2:
        return (6, groups[0][0], groups[1][0])
    elif is_flush:
        return (5, *sorted_ranks)
    elif is_straight:
        return (4, straight_high)
    elif groups[0][1] == 3:
        return (3, groups[0][0], groups[1][0], groups[2][0])
    elif groups[0][1] == 2 and groups[1][1] == 2:
        return (2, groups[0][0], groups[1][0], groups[2][0])
    elif groups[0][1] == 2:
        return (1, groups[0][0], groups[1][0], groups[2][0], groups[3][0])
    else:
        return (0, *sorted_ranks)
```

