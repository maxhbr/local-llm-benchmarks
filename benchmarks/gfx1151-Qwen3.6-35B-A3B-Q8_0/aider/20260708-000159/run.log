import "errors"

func HandleErrors(input string) (int64, error) {
	var result int64
	for _, c := range input {
		var val int64
		switch {
		case c >= '0' && c <= '9':
			val = int64(c - '0')
		case c >= 'a' && c <= 'f':
			val = int64(c - 'a' + 10)
		case c >= 'A' && c <= 'F':
			val = int64(c - 'A' + 10)
		default:
			return 0, errors.New("invalid hexadecimal string")
		}
		result = result*16 + val
	}
	return result, nil
}
```
