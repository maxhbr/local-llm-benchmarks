#[derive(Debug, PartialEq, Eq)]
pub enum Error {
    InvalidRowCount(usize),
    InvalidColumnCount(usize),
}

pub fn convert(input: &str) -> Result<String, Error> {
    let lines: Vec<&str> = input.lines().collect();
    
    if lines.is_empty() {
        return Ok(String::new());
    }

    if lines.len() % 4 != 0 {
        return Err(Error::InvalidRowCount(lines.len()));
    }

    let width = lines[0].len();
    if width % 3 != 0 {
        return Err(Error::InvalidColumnCount(width));
    }

    for line in &lines {
        if line.len() != width {
            return Err(Error::InvalidColumnCount(line.len()));
        }
    }

    let mut result_rows = Vec::new();
    
    for chunk in lines.chunks(4) {
        let mut row_str = String::new();
        for i in (0..width).step_by(3) {
            let p1 = &chunk[0][i..i+3];
            let p2 = &chunk[1][i..i+3];
            let p3 = &chunk[2][i..i+3];
            let pattern = format!("{}{}{}", p1, p2, p3);
            
            let digit = match pattern.as_str() {
                " _ | ||_|" => "0",
                "     |  |" => "1",
                " _  _||_ " => "2",
                " _  _| _|" => "3",
                "   |_|  |" => "4",
                " _ |_  _|" => "5",
                " _ |_ |_|" => "6",
                " _   |  |" => "7",
                " _ |_||_|" => "8",
                " _ |_| _|" => "9",
                _ => "?",
            };
            row_str.push_str(digit);
        }
        result_rows.push(row_str);
    }

    Ok(result_rows.join(","))
}
