        let mut sum = 0i64;
        for &c in chars {
            sum += coeffs[&c] * assignment[*c as usize] as i64;
        }
        if sum == 0 {
            let mut map = HashMap::new();
            for &c in chars {
                map.insert(c, assignment[*c as usize].unwrap());
            }
            return Some(map);
        }
        return None;
    }

    let c = chars[idx];
    for d in 0..10 {
        if !used[d] {
            if d == 0 && leading_chars.contains(&c) {
