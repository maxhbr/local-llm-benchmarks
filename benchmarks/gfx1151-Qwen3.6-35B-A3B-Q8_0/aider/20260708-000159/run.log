          sb.Grow(lastRow + 1)
          for i := 0; i <= lastRow; i++ {
              if len(input[i]) > j {
                  sb.WriteByte(input[i][j])
              } else {
                  sb.WriteByte(' ')
              }
          }
          result[j] = sb.String()
      }
      return result
  }
