```go
package counter

import (
        "strings"
        "unicode"
)

// Counter keeps track of lines, letters, and characters.
type Counter struct {
        lines      int
        letters    int
        characters int
}

// New creates a new Counter.
func New() *Counter {
        return &Counter{}
}

// Add increments the counters based on the provided string.
func (c *Counter) Add(s string) {
        c.characters += len(s)
        c.letters += countLetters(s)
        c.lines += countLines(s)
}

// Lines returns the total number of lines.
func (c *Counter) Lines() int {
        return c.lines
}

// Letters returns the total number of letters.
func (c *Counter) Letters() int {
        return c.letters
}

// Characters returns the total number of characters.
func (c *Counter) Characters() int {
        return c.characters
}

func countLetters(s string) int {
        count := 0
        for _, r := range s {
                if unicode.IsLetter(r) {
                        count++
                }
        }
        return count
}

func countLines(s string) int {
        if s == "" {
                return 0
        }
        n := strings.Count(s, "\n")
        if s[len(s)-1] != '\n' {
                n++
        }
        return n
}
```

