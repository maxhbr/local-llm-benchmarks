package markdown

import (
        "bufio"
        "fmt"
        "strings"
)

func Render(markdown string) string {
        scanner := bufio.NewScanner(strings.NewReader(markdown))
        var html strings.Builder
        inList := false

        for scanner.Scan() {
                line := scanner.Text()
                
                // Check for header
                if strings.HasPrefix(line, "# ") {
                        if inList {
                                html.WriteString("</ul>")
                                inList = false
                        }
                        level := 0
                        for i, char := range line {
                                if char == '#' {
                                        level++
                                } else {
                                        break
                                }
                        }
                        content := line[level+1:]
                        content = formatInline(content)
                        html.WriteString(fmt.Sprintf("<h%d>%s</h%d>\n", level, content, level))
                        continue
                }

                // Check for list item
                if strings.HasPrefix(line, "* ") {
                        content := line[2:]
                        content = formatInline(content)
                        if !inList {
                                html.WriteString("<ul>")
                                inList = true
                        }
                        html.WriteString(fmt.Sprintf("<li>%s</li>\n", content))
                        continue
                }

                // Close list if open
                if inList {
                        html.WriteString("</ul>")
                        inList = false
                }

                // Paragraph
                content := formatInline(line)
                html.WriteString(fmt.Sprintf("<p>%s</p>\n", content))
        }

        if inList {
                html.WriteString("</ul>")
        }

        return html.String()
}

func formatInline(text string) string {
        text = strings.ReplaceAll(text, "__", "<strong>")
        text = strings.ReplaceAll(text, "__", "</strong>")
        text = strings.ReplaceAll(text, "_", "<em>")
        text = strings.ReplaceAll(text, "_", "</em>")
        return text
}
