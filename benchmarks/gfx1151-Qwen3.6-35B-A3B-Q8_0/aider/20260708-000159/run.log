  } else if (count1 === 3) {
    score = [4, rank1, rank2, rank3];
  } else if (count1 === 2 && count2 === 2) {
    score = [3, rank1, rank2, rank3];
  } else if (count1 === 2) {
    score = [2, rank1, rank2, rank3, rank4];
  } else {
    score = [1, ...ranks];
  }
  
  return score;
}

function compareScores(a, b) {
  for (let i = 0; i < Math.max(a.length, b.length); i++) {
    const va = a[i] || 0;
    const vb = b[i] || 0;
    if (va > vb) return 1;
    if (va < vb) return -1;
