```go
package forth

import (
        "errors"
        "strconv"
        "strings"
)

func Forth(input []string) ([]int, error) {
        stack := []int{}
        customs := make(map[string][]string)

        for _, line := range input {
                tokens := strings.Fields(line)
                var err error
                stack, err = evaluate(tokens, stack, customs)
                if err != nil {
                        return nil, err
                }
        }
        return stack, nil
}

func expand(tokens []string, customs map[string][]string) []string {
        var res []string
        for _, t := range tokens {
                if def, ok := customs[t]; ok {
                        res = append(res, def...)
                } else {
                        res = append(res, t)
                }
        }
        return res
}

func evaluate(tokens []string, stack []int, customs map[string][]string) ([]int, error) {
        for i := 0; i < len(tokens); i++ {
                tok := strings.ToLower(tokens[i])

                if tok == ":" {
                        if i+1 >= len(tokens) {
                                return nil, errors.New("invalid definition")
                        }
                        name := strings.ToLower(tokens[i+1])
                        if _, err := strconv.Atoi(name); err == nil {
                                return nil, errors.New("cannot redefine numbers")
                        }
                        if _, ok := builtins[name]; ok {
                                return nil, errors.New("cannot redefine built-in")
                        }

                        def := []string{}
                        j := i + 2
                        for j < len(tokens) {
                                if tokens[j] == ";" {
                                        customs[name] = expand(def, customs)
                                        i = j
                                        break
                                }
                                def = append(def, strings.ToLower(tokens[j]))
                                j++
                        }
                        if j >= len(tokens) {
                                return nil, errors.New("invalid definition, missing ;")
                        }
                        continue
                }

                if tok == ";" {
                        return nil, errors.New("unexpected ;")
                }

                if val, err := strconv.Atoi(tok); err == nil {
                        stack = append(stack, val)
                } else if fn, ok := builtins[tok]; ok {
                        var err error
                        stack, err = fn(stack)
                        if err != nil {
                                return nil, err
                        }
                } else if def, ok := customs[tok]; ok {
                        var err error
                        stack, err = evaluate(def, stack, customs)
                        if err != nil {
                                return nil, err
                        }
                } else {
                        return nil, errors.New("unknown word")
                }
        }
        return stack, nil
}

var builtins = map[string]func([]int) ([]int, error){
        "+": func(s []int) ([]int, error) {
                if len(s) < 2 {
                        return nil, errors.New("operator requires 2 arguments")
                }
                a, b := s[len(s)-1], s[len(s)-2]
                return append(s[:len(s)-2], a+b), nil
        },
        "-": func(s []int) ([]int, error) {
                if len(s) < 2 {
                        return nil, errors.New("operator requires 2 arguments")
                }
                a, b := s[len(s)-1], s[len(s)-2]
                return append(s[:len(s)-2], b-a), nil
        },
        "*": func(s []int) ([]int, error) {
                if len(s) < 2 {
                        return nil, errors.New("operator requires 2 arguments")
                }
                a, b := s[len(s)-1], s[len(s)-2]
                return append(s[:len(s)-2], a*b), nil
        },
        "/": func(s []int) ([]int, error) {
                if len(s) < 2 {
                        return nil, errors.New("operator requires 2 arguments")
                }
                a, b := s[len(s)-1], s[len(s)-2]
                if a == 0 {
                        return nil, errors.New("division by zero")
                }
                return append(s[:len(s)-2], b/a), nil
        },
        "dup": func(s []int) ([]int, error) {
                if len(s) < 1 {
                        return nil, errors.New("stack empty")
                }
                return append(s, s[len(s)-1]), nil
        },
        "drop": func(s []int) ([]int, error) {
                if len(s) < 1 {
                        return nil, errors.New("stack empty")
                }
                return s[:len(s)-1], nil
        },
        "swap": func(s []int) ([]int, error) {
                if len(s) < 2 {
                        return nil, errors.New("stack empty")
                }
                s[len(s)-1], s[len(s)-2] = s[len(s)-2], s[len(s)-1]
                return s, nil
        },
        "over": func(s []int) ([]int, error) {
                if len(s) < 2 {
                        return nil, errors.New("stack empty")
                }
                return append(s, s[len(s)-2]), nil
        },
}
