```python
from collections import Counter
from functools import lru_cache

def total(basket):
    if not basket:
        return 0
        
    counts = tuple(sorted(Counter(basket).values(), reverse=True))
    
    prices = {1: 800, 2: 1520, 3: 2160, 4: 2560, 5: 3000}
    
    @lru_cache(maxsize=None)
    def min_price(c):
        if not any(c):
            return 0
            
        best = float('inf')
        # Try forming groups of size 1 to 5
        for k in range(1, 6):
            # Check if we can form a group of size k
            if c[k-1] > 0:
                # Form group: subtract 1 from the first k counts
                new_c = list(c)
                for i in range(k):
                    new_c[i] -= 1
                new_c = tuple(sorted(new_c, reverse=True))
                cost = prices[k] + min_price(new_c)
                if cost < best:
                    best = cost
        return best
        
    return min_price(counts)
```

