        "-": func(s []int) ([]int, error) {
                if len(s) < 2 { return nil, errors.New("operator requires 2 arguments") }
                a, b := s[len(s)-1], s[len(s)-2]
                return append(s[:len(s)-2], b-a), nil
        },
        "*": func(s []int) ([]int, error) {
                if len(s) < 2 { return nil, errors.New("operator requires 2 arguments") }
                a, b := s[len(s)-1], s[len(s)-2]
                return append(s[:len(s)-2], a*b), nil
        },
        "/": func(s []int) ([]int, error) {
                if len(s) < 2 { return nil, errors.New("operator requires 2 arguments") }
                a, b := s[len(s)-1], s[len(s)-2]
                if a == 0 { return nil, errors.New("division by zero") }
                return append(s[:len(s)-2], b/a), nil
        },
        "dup": func(s []int) ([]int, error) {
                if len(s) < 1 { return nil, errors.New("dup requires 1 argument") }
                return append(s, s[len(s)-1]), nil
        },
        "drop": func(s []int) ([]int, error) {
                if len(s) < 1 { return nil, errors.New("drop requires 1 argument") }
                return s[:len(s)-1], nil
        },
        "swap": func(s []int) ([]int, error) {
                if len(s) < 2 { return nil, errors.New("swap requires 2 arguments") }
                s[len(s)-1], s[len(s)-2] = s[len(s)-2], s[len(s)-1]
