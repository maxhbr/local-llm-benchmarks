```python
def recite(start_verse, end_verse):
    animals = ["fly", "spider", "bird", "cat", "dog", "goat", "cow", "horse"]
    reactions = [
        "",
        "It wriggled and jiggled and tickled inside her.",
        "How absurd to swallow a bird!",
        "Imagine that, to swallow a cat!",
        "What a hog, to swallow a dog!",
        "Just opened her throat and swallowed a goat!",
        "I don't know how she swallowed a cow!",
        "She's dead, of course!"
    ]
    
    all_lyrics = []
    for n in range(start_verse, end_verse + 1):
        verse_lines = []
        verse_lines.append(f"I know an old lady who swallowed a {animals[n-1]}.")
        
        if n == 8:
            verse_lines.append(reactions[7])
            all_lyrics.append(verse_lines)
            continue
            
        if n > 1:
            verse_lines.append(reactions[n-1])
            
        for i in range(n-1, 0, -1):
            curr = animals[i]
            prev = animals[i-1]
            line = f"She swallowed the {curr} to catch the {prev}."
            if prev == "spider":
                line = f"She swallowed the {curr} to catch the spider that wriggled and jiggled and tickled 
inside her."
            verse_lines.append(line)
            
        if n < 8:
            verse_lines.append("I don't know why she swallowed the fly. Perhaps she'll die.")
            
        all_lyrics.append(verse_lines)
        
    return all_lyrics
```

