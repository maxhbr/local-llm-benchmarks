BuildTree.java
```java
import java.util.ArrayList;
import java.util.Comparator;

class BuildTree {

    TreeNode buildTree(ArrayList<Record> records) throws InvalidRecordsException {
        int n = records.size();
        if (n == 0) {
            return null;
        }

        records.sort(Comparator.comparingInt(Record::getRecordId));

        TreeNode[] nodes = new TreeNode[n];
        
        for (Record record : records) {
            int id = record.getRecordId();
            int parentId = record.getParentId();

            if (id < 0 || id >= n) {
                throw new InvalidRecordsException("Invalid Records");
            }
            if (nodes[id] != null) {
                throw new InvalidRecordsException("Invalid Records");
            }
            if (id == 0 && parentId != 0) {
                throw new InvalidRecordsException("Invalid Records");
            }
            if (id != 0 && parentId >= id) {
                throw new InvalidRecordsException("Invalid Records");
            }
            
            nodes[id] = new TreeNode(id);
        }

        for (Record record : records) {
            int id = record.getRecordId();
            int parentId = record.getParentId();
            if (id != 0) {
                nodes[parentId].getChildren().add(nodes[id]);
            }
        }

        return nodes[0];
    }

}
```
