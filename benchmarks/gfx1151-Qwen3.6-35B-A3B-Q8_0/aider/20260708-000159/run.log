        new_focus['value'] = value
        return Zipper(new_focus, self.path)

    def left(self):
        if self.focus.get('left') is None:
            return None
        return Zipper(self.focus['left'], self.path + [('left', self.focus)])

    def set_left(self, node):
        new_focus = dict(self.focus)
        new_focus['left'] = node
        return Zipper(new_focus, self.path)

    def right(self):
        if self.focus.get('right') is None:
            return None
        return Zipper(self.focus['right'], self.path + [('right', self.focus)])

    def set_right(self, node):
        new_focus = dict(self.focus)
        new_focus['right'] = node
        return Zipper(new_focus, self.path)

    def up(self):
        if not self.path:
            return None
        direction, parent = self.path[-1]
        return Zipper(parent, self.path[:-1])

    def to_tree(self):
        tree = self.focus
        for direction, parent in reversed(self.path):
            new_parent = dict(parent)
            new_parent[direction] = tree
            tree = new_parent
        return tree

    def __eq__(self, other):
        if not isinstance(other, Zipper):
            return False
        return self.to_tree() == other.to_tree()
