Let's rewrite `get_chromatic_set` properly.
Actually, it's easier to just have two static arrays and pick one.
```rust
const SHARPS: [&str; 12] = ["C", "C#", "D", "D#", "E", "F", "F#", "G", "G#", "A", "A#", "B"];
const FLATS: [&str; 12] = ["C", "Db", "D", "Eb", "E", "F", "Gb", "G", "Ab", "A", "Bb", "B"];

fn get_chromatic_set(tonic: &str) -> &'static [&'static str] {
    if uses_flats(tonic) {
        &FLATS
    } else {
        &SHARPS
    }
}

fn uses_flats(tonic: &str) -> bool {
    matches!(tonic, "F" | "Bb" | "Eb" | "Ab" | "Db" | "Gb" | "d" | "g" | "c" | "f" | "bb" | "eb")
}
```
