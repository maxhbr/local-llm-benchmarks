```java
import java.util.ArrayList;
import java.util.List;

public class Transpose {
    public String transpose(String toTranspose) {
        if (toTranspose == null || toTranspose.isEmpty()) {
            return "";
        }
        
        String[] lines = toTranspose.split("\n", -1);
        int maxLen = 0;
        for (String line : lines) {
            if (line.length() > maxLen) {
                maxLen = line.length();
            }
        }
        
        List<String> result = new ArrayList<>();
        for (int j = 0; j < maxLen; j++) {
            int lastRow = -1;
            for (int i = lines.length - 1; i >= 0; i--) {
                if (j < lines[i].length()) {
                    lastRow = i;
                    break;
                }
            }
            
            if (lastRow == -1) continue; // Should not happen if maxLen is correct
            
            StringBuilder sb = new StringBuilder();
            for (int i = 0; i <= lastRow; i++) {
                if (j < lines[i].length()) {
                    sb.append(lines[i].charAt(j));
                } else {
                    sb.append(' ');
                }
            }
            result.add(sb.toString());
        }
        
        return String.join("\n", result);
    }
}
```

