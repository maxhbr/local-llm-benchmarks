use std::collections::{HashMap, HashSet};

pub fn solve(input: &str) -> Option<HashMap<char, u8>> {
    let parts: Vec<&str> = input.split("==").collect();
    if parts.len() != 2 {
        return None;
    }

    let mut coeffs = HashMap::new();
    let mut leading_chars = HashSet::new();
    let mut unique_chars = HashSet::new();

    let add_words: Vec<&str> = parts[0].split('+').map(|s| s.trim()).filter(|s| !s.is_empty()).collect();
    let sub_words: Vec<&str> = vec![parts[1].trim()];

    for word in add_words.iter() {
        let chars: Vec<char> = word.chars().collect();
        if chars.len() > 1 {
            leading_chars.insert(chars[0]);
        }
        unique_chars.extend(chars.iter());
        let mut power = 1i64;
        for &c in chars.iter().rev() {
            *coeffs.entry(c).or_insert(0) += power;
            power *= 10;
        }
    }

    for word in sub_words.iter() {
        let chars: Vec<char> = word.chars().collect();
        if chars.len() > 1 {
            leading_chars.insert(chars[0]);
        }
        unique_chars.extend(chars.iter());
        let mut power = 1i64;
        for &c in chars.iter().rev() {
            *coeffs.entry(c).or_insert(0) -= power;
            power *= 10;
        }
    }

    let chars: Vec<char> = unique_chars.into_iter().collect();
    if chars.len() > 10 {
        return None;
    }

    let mut used = [false; 10];
    let mut assignment = [None; 256]; // maps char to digit

    solve_recursive(&chars, &coeffs, &mut used, &mut assignment, 0, &leading_chars)
}

fn solve_recursive(
    chars: &[char],
    coeffs: &HashMap<char, i64>,
    used: &mut [bool; 10],
    assignment: &mut [Option<u8>; 256],
    idx: usize,
    leading_chars: &HashSet<char>,
) -> Option<HashMap<char, u8>> {
