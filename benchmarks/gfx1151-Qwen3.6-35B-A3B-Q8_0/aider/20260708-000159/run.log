        }
        if (nb2 === this.goal) {
          return { moves: moves + 1, goalBucket: 'two', otherBucket: nb1 };
        }
        
        visited.add(stateKey);
        queue.push([nb1, nb2, moves + 1]);
      }
    }
    
    throw new Error('impossible');
  }
}
