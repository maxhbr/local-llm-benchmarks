import java.util.Map;
import java.util.Optional;
import java.util.Set;
import java.util.HashMap;

class WordSearcher {
    Map<String, Optional<WordLocation>> search(final Set<String> words, final char[][] grid) {
        Map<String, Optional<WordLocation>> result = new HashMap<>();
        int rows = grid.length;
        if (rows == 0) {
            for (String word : words) {
                result.put(word, Optional.empty());
            }
            return result;
        }
        int cols = grid[0].length;
        
        int[] dRow = {-1, -1, -1, 0, 0, 1, 1, 1};
        int[] dCol = {-1, 0, 1, -1, 1, -1, 0, 1};
        
        for (String word : words) {
            Optional<WordLocation> found = Optional.empty();
            outer:
            for (int r = 0; r < rows; r++) {
                for (int c = 0; c < cols; c++) {
                    for (int i = 0; i < 8; i++) {
                        int endR = r + dRow[i] * (word.length() - 1);
                        int endC = c + dCol[i] * (word.length() - 1);
                        
                        if (endR < 0 || endR >= rows || endC < 0 || endC >= cols) {
                            continue;
                        }
                        
                        boolean matches = true;
                        for (int k = 0; k < word.length(); k++) {
                            if (grid[r + dRow[i] * k][c + dCol[i] * k] != word.charAt(k)) {
                                matches = false;
                                break;
                            }
                        }
                        
                        if (matches) {
                            found = Optional.of(new WordLocation(
                                new Coordinate(r + 1, c + 1),
                                new Coordinate(endR + 1, endC + 1)
                            ));
                            break outer;
                        }
                    }
                }
            }
            result.put(word, found);
        }
        return result;
    }
}

class Coordinate {
    private final int row;
    private final int column;

    Coordinate(int row, int column) {
        this.row = row;
        this.column = column;
    }

    int getRow() { return row; }
    int getColumn() { return column; }
    
    @Override
    public boolean equals(Object o) {
        if (this == o) return true;
        if (!(o instanceof Coordinate)) return false;
        Coordinate that = (Coordinate) o;
        return row == that.row && column == that.column;
    }
    
    @Override
    public int hashCode() {
        return 31 * row + column;
    }
}

class WordLocation {
    private final Coordinate start;
    private final Coordinate end;

    WordLocation(Coordinate start, Coordinate end) {
        this.start = start;
        this.end = end;
    }

    Coordinate getStart() { return start; }
    Coordinate getEnd() { return end; }
}
