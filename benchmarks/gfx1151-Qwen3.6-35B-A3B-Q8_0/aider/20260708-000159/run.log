```go
func parseHand(s string) (*Hand, error) {
    cards := strings.Fields(s)
    if len(cards) != 5 {
        return nil, errors.New("invalid hand length")
    }
    ranks := make([]int, 5)
    suits := make([]byte, 5)
    for i, c := range cards {
        if len(c) < 2 {
            return nil, errors.New("invalid card")
        }
        suit := c[len(c)-1]
        rankStr := c[:len(c)-1]
        r, ok := rankMap[rankStr]
        if !ok {
            return nil, errors.New("invalid rank")
        }
        ranks[i] = r
        suits[i] = suit
    }
    // evaluate
    return evaluate(ranks, suits, s)
}
```

