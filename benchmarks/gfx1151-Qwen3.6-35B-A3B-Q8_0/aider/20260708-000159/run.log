      if (h.pet === 'Dog' && h.nationality !== 'Spaniard') return false;
      
      if (h.color === 'Green' && h.drink !== 'Coffee') return false;
      if (h.drink === 'Coffee' && h.color !== 'Green') return false;
      
      if (h.nationality === 'Ukrainian' && h.drink !== 'Tea') return false;
      if (h.drink === 'Tea' && h.nationality !== 'Ukrainian') return false;
      
      if (h.pet === 'Snail' && h.hobby !== 'Dancing') return false;
      if (h.hobby === 'Dancing' && h.pet !== 'Snail') return false;
      
      if (h.color === 'Yellow' && h.hobby !== 'Painter') return false;
      if (h.hobby === 'Painter' && h.color !== 'Yellow') return false;
      
      if (h.hobby === 'Football' && h.drink !== 'Orange Juice') return false;
      if (h.drink === 'Orange Juice' && h.hobby !== 'Football') return false;
      
      if (h.nationality === 'Japanese' && h.hobby !== 'Chess') return false;
      if (h.hobby === 'Chess' && h.nationality !== 'Japanese') return false;

      if (h.hobby === 'Reading') {
        let hasFox = false;
        if (idx > 0 && houses[idx-1].pet === 'Fox') hasFox = true;
        if (idx < 4 && houses[idx+1].pet === 'Fox') hasFox = true;
        if (!hasFox && idx > 0 && idx < 4 && houses[idx-1].pet && houses[idx+1].pet) return false;
        if (!hasFox && idx === 0 && houses[1].pet && houses[1].pet !== 'Fox') return false;
        if (!hasFox && idx === 4 && houses[3].pet && houses[3].pet !== 'Fox') return false;
      }
      
      if (h.hobby === 'Painter') {
        let hasHorse = false;
        if (idx > 0 && houses[idx-1].pet === 'Horse') hasHorse = true;
        if (idx < 4 && houses[idx+1].pet === 'Horse') hasHorse = true;
        if (!hasHorse && idx > 0 && idx < 4 && houses[idx-1].pet && houses[idx+1].pet) return false;
        if (!hasHorse && idx === 0 && houses[1].pet && houses[1].pet !== 'Horse') return false;
        if (!hasHorse && idx === 4 && houses[3].pet && houses[3].pet !== 'Horse') return false;
