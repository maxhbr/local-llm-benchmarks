```go
package markdown

import (
        "fmt"
        "strings"
)

// Render translates markdown to HTML
// Refactored to use a clear line-by-line parsing approach.
// Fixed header detection to handle multiple '#' characters.
// Fixed inline formatting to correctly replace opening and closing tags.
func Render(markdown string) string {
        lines := strings.Split(markdown, "\n")
        var html strings.Builder
        inList := false

        for _, line := range lines {
                // Skip empty lines
                if line == "" {
                        continue
                }

                // Apply inline formatting before block processing
                line = formatInline(line)

                // Check for headers
                if len(line) > 0 && line[0] == '#' {
                        level := 0
                        for i := 0; i < len(line) && line[i] == '#'; i++ {
                                level++
                        }
                        // Valid headers are 1-6 '#' followed by a space
                        if level < 7 && len(line) > level && line[level] == ' ' {
                                if inList {
                                        html.WriteString("</ul>")
                                        inList = false
                                }
                                content := line[level+1:]
                                html.WriteString(fmt.Sprintf("<h%d>%s</h%d>", level, content, level))
                                continue
                        }
                }

                // Check for list items
                if strings.HasPrefix(line, "* ") {
                        content := line[2:]
                        if !inList {
                                html.WriteString("<ul>")
                                inList = true
                        }
                        html.WriteString(fmt.Sprintf("<li>%s</li>", content))
                } else {
                        // Paragraphs close any open list
                        if inList {
                                html.WriteString("</ul>")
                                inList = false
                        }
                        html.WriteString(fmt.Sprintf("<p>%s</p>", line))
                }
        }

        // Close any list that remains open at the end of the document
        if inList {
                html.WriteString("</ul>")
        }

        return html.String()
}

// formatInline converts markdown inline syntax to HTML tags.
// It processes bold (__) before italic (_) to prevent overlapping replacements.
// Uses strings.Index to correctly replace the first occurrence with the opening tag
// and the second with the closing tag.
func formatInline(text string) string {
        // Handle bold
        idx := strings.Index(text, "__")
        if idx != -1 {
                text = text[:idx] + "<strong>" + text[idx+2:]
                idx2 := strings.Index(text, "__")
                if idx2 != -1 {
                        text = text[:idx2] + "</strong>" + text[idx2+2:]
                }
        }

        // Handle italic
        idx = strings.Index(text, "_")
        if idx != -1 {
                text = text[:idx] + "<em>" + text[idx+1:]
                idx2 := strings.Index(text, "_")
                if idx2 != -1 {
                        text = text[:idx2] + "</em>" + text[idx2+1:]
                }
        }
        return text
}
```

