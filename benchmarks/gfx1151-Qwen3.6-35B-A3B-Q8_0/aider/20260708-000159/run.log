```java
import java.util.ArrayList;
import java.util.Deque;
import java.util.ArrayDeque;
import java.util.List;
import java.util.Random;

public class MazeGenerator {

    private final Random random;

    public char[][] generatePerfectMaze(int rows, int columns) {
        return generatePerfectMaze(rows, columns, -1);
    }

    public char[][] generatePerfectMaze(int rows, int columns, int seed) {
        if (seed != -1) {
            this.random = new Random(seed);
        } else {
            this.random = new Random();
        }
        
        int H = 2 * rows + 1;
        int W = 2 * columns + 1;
        boolean[][] isWall = new boolean[H][W];
        for (boolean[] row : isWall) {
            java.util.Arrays.fill(row, true);
        }
        
        // Mark cells as not walls
        for (int r = 0; r < rows; r++) {
            for (int c = 0; c < columns; c++) {
                isWall[2 * r + 1][2 * c + 1] = false;
            }
        }
        
        boolean[][] visited = new boolean[rows][columns];
        Deque<int[]> stack = new ArrayDeque<>();
        stack.push(new int[]{0, 0});
        visited[0][0] = true;
        
        int[][] dirs = {{0, 1}, {1, 0}, {0, -1}, {-1, 0}};
        
        while (!stack.isEmpty()) {
            int[] curr = stack.peek();
            int r = curr[0];
            int c = curr[1];
            
            List<int[]> neighbors = new ArrayList<>();
            for (int[] d : dirs) {
                int nr = r + d[0];
                int nc = c + d[1];
                if (nr >= 0 && nr < rows && nc >= 0 && nc < columns && !visited[nr][nc]) {
                    neighbors.add(new int[]{nr, nc});
                }
            }
            
            if (!neighbors.isEmpty()) {
                int[] next = neighbors.get(random.nextInt(neighbors.size()));
                int wallR = r + next[0] + 1;
                int wallC = c + next[1] + 1;
                isWall[wallR][wallC] = false;
                
                visited[next[0]][next[1]] = true;
                stack.push(next);
            } else {
                stack.pop();
            }
        }
        
        char[][] maze = new char[H][W];
        for (int r = 0; r < H; r++) {
            for (int c = 0; c < W; c++) {
                if (!isWall[r][c]) {
                    maze[r][c] = ' ';
                } else {
                    maze[r][c] = getWallChar(isWall, r, c);
                }
            }
        }
        
        maze[rows][0] = '⇨';
        maze[rows][W - 1] = '⇨';
        
        return maze;
    }
    
    private char getWallChar(boolean[][] isWall, int r, int c) {
        int bits = 0;
        if (r > 0 && isWall[r - 1][c]) bits |= 1; // U
        if (c < isWall[0].length - 1 && isWall[r][c + 1]) bits |= 2; // R
        if (r < isWall.length - 1 && isWall[r + 1][c]) bits |= 4; // D
        if (c > 0 && isWall[r][c - 1]) bits |= 8; // L
        
        switch (bits) {
            case 0: return ' ';
            case 1: return '│';
            case 2: return '─';
            case 3: return '┬';
            case 4: return '│';
            case 5: return '│';
            case 6: return '┘';
            case 7: return '├';
            case 8: return '─';
            case 9: return '┴';
            case 10: return '─';
            case 11: return '┴';
            case 12: return '┌';
            case 13: return '┤';
            case 14: return '┬';
            case 15: return '┼';
            default: return ' ';
        }
    }
}
```

