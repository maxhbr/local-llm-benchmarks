        let tonic_idx = chromatic.iter().position(|&n| n.eq_ignore_ascii_case(tonic))
            .ok_or(Error)?;
            
        let mut notes = Vec::new();
        notes.push(chromatic[tonic_idx].to_string());
        let mut current_idx = tonic_idx;
        for _ in 0..11 {
            current_idx = (current_idx + 1) % 12;
            notes.push(chromatic[current_idx].to_string());
        }
        Ok(Scale { notes })
    }
```
