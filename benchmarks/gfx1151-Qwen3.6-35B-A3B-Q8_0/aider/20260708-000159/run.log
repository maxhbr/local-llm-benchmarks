package markdown

import (
	"fmt"
	"strings"
)

// Render translates markdown to HTML
// Refactored from a confusing character-by-character state machine to a clean
// line-by-line parser. This improves readability, maintainability, and correctly
// handles inline formatting and list/paragraph boundaries.
func Render(markdown string) string {
	lines := strings.Split(markdown, "\n")
	var html strings.Builder
	inList := false

	for _, line := range lines {
		// Skip empty lines to avoid generating empty paragraphs
		if line == "" {
			continue
		}

		// Apply inline formatting (bold/italic) to the line before block processing
		line = formatInline(line)

		if strings.HasPrefix(line, "# ") {
			// Headers close any open list
			if inList {
				html.WriteString("</ul>")
				inList = false
			}
			level := 0
			for i := 0; i < len(line) && line[i] == '#'; i++ {
				level++
			}
			content := line[level+1:]
			html.WriteString(fmt.Sprintf("<h%d>%s</h%d>", level, content, level))
		} else if strings.HasPrefix(line, "* ") {
			// List items
			content := line[2:]
			if !inList {
				html.WriteString("<ul>")
				inList = true
			}
			html.WriteString(fmt.Sprintf("<li>%s</li>", content))
		} else {
			// Paragraphs close any open list
			if inList {
				html.WriteString("</ul>")
				inList = false
			}
			html.WriteString(fmt.Sprintf("<p>%s</p>", line))
		}
	}

	// Close any list that remains open at the end of the document
	if inList {
		html.WriteString("</ul>")
	}

	return html.String()
}

// formatInline converts markdown inline syntax to HTML tags.
// It processes bold (__) before italic (_) to prevent overlapping replacements.
func formatInline(text string) string {
	text = strings.ReplaceAll(text, "__", "<strong>")
	text = strings.ReplaceAll(text, "__", "</strong>")
	text = strings.ReplaceAll(text, "_", "<em>")
	text = strings.ReplaceAll(text, "_", "</em>")
	return text
}
```
