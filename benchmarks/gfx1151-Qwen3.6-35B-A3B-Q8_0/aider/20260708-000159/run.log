//
// This is only a SKELETON file for the 'Two Bucket' exercise. It's been provided as a
// convenience to get you started writing code faster.
//

export class TwoBucket {
  constructor(bucketOne, bucketTwo, goal, startBucket) {
    this.bucketOne = bucketOne;
    this.bucketTwo = bucketTwo;
    this.goal = goal;
    this.startBucket = startBucket;

    if (goal > bucketOne && goal > bucketTwo) {
      throw new Error('impossible');
    }
    
    const gcd = (a, b) => b === 0 ? a : gcd(b, a % b);
    if (goal % gcd(bucketOne, bucketTwo) !== 0) {
      throw new Error('impossible');
    }
  }

  solve() {
    const queue = [];
    const visited = new Set();
    
    let b1, b2;
    if (this.startBucket === 'one') {
      b1 = this.bucketOne;
      b2 = 0;
    } else {
      b1 = 0;
      b2 = this.bucketTwo;
    }
    
    if (b1 === this.goal) {
      return { moves: 1, goalBucket: 'one', otherBucket: b2 };
    }
    if (b2 === this.goal) {
      return { moves: 1, goalBucket: 'two', otherBucket: b1 };
    }
    
    queue.push([b1, b2, 1]);
    visited.add(`${b1},${b2}`);
    
    const forbidden = this.startBucket === 'one' 
      ? `${0},${this.bucketTwo}` 
      : `${this.bucketOne},0`;

    while (queue.length > 0) {
      const [currB1, currB2, moves] = queue.shift();
      
      const nextStates = [
        [this.bucketOne, currB2], // Fill one
        [currB1, this.bucketTwo], // Fill two
        [0, currB2],              // Empty one
        [currB1, 0],              // Empty two
        [currB1 - Math.min(currB1, this.bucketTwo - currB2), currB2 + Math.min(currB1, this.bucketTwo - currB2)], // Pour one to two
        [currB1 + Math.min(currB2, this.bucketOne - currB1), currB2 - Math.min(currB2, this.bucketOne - currB1)]  // Pour two to one
      ];
      
      for (const [nb1, nb2] of nextStates) {
        const stateKey = `${nb1},${nb2}`;
        if (stateKey === forbidden || visited.has(stateKey)) continue;
        
        if (nb1 === this.goal) {
          return { moves: moves + 1, goalBucket: 'one', otherBucket: nb2 };
        }
        if (nb2 === this.goal) {
          return { moves: moves + 1, goalBucket: 'two', otherBucket: nb1 };
        }
        
        visited.add(stateKey);
        queue.push([nb1, nb2, moves + 1]);
      }
    }
    
    throw new Error('impossible');
  }
}
