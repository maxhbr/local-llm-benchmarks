    for item in list:
        accumulator = function(accumulator, item)
    return accumulator


def foldr(function, list, initial):
    accumulator = initial
    for item in reverse(list):
        accumulator = function(accumulator, item)
    return accumulator


def reverse(list):
    result = []
    for i in range(length(list) - 1, -1, -1):
        result.append(list[i])
    return result
