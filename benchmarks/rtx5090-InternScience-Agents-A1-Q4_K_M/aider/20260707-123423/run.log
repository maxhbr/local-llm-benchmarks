package variablelengthquantity

import "errors"

func EncodeVarint(input []uint32) []byte {
    var result []byte
    for _, n := range input {
        if n == 0 {
            result = append(result, 0)
            continue
        }
        var bytes []byte
        for n > 0 {
            bytes = append(bytes, byte(n&0x7F))
            n >>= 7
        }
        // Reverse to get MSB first
        for i, j := 0, len(bytes)-1; i < j; i, j 
= i+1, j-1 {
            bytes[i], bytes[j] = bytes[j], 
bytes[i]
        }
        // Set continuation bit on all but last
        for i := 0; i < len(bytes)-1; i++ {
            bytes[i] |= 0x80
        }
        result = append(result, bytes...)
    }
    return result
}

func DecodeVarint(input []byte) ([]uint32, error)
{
    var numbers []uint32
    var current uint32
    var hasMore bool
    
    for _, b := range input {
        hasMore = (b & 0x80) != 0
        data := b & 0x7F
        
        // Check for overflow before shifting
        if current > (0xFFFFFFFF >> 7) {
            return nil, errors.New("overflow")
        }
        
        current = (current << 7) | uint32(data)
        
        if !hasMore {
            numbers = append(numbers, current)
            current = 0
        }
    }
    
    if hasMore {
        return nil, errors.New("incomplete 
sequence")
    }
    
    return numbers, nil
}
```

