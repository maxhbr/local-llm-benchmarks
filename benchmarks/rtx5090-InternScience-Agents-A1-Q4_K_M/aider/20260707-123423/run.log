class ResistorColorTrio {
    String label(String[] colors) {
        // Map colors to digits
        java.util.Map<String, Integer> colorMap = new java.util.HashMap<>();
        colorMap.put("black", 0);
        colorMap.put("brown", 1);
        colorMap.put("red", 2);
        colorMap.put("orange", 3);
        colorMap.put("yellow", 4);
        colorMap.put("green", 5);
        colorMap.put("blue", 6);
        colorMap.put("violet", 7);
        colorMap.put("grey", 8);
        colorMap.put("white", 9);
        
        // Get the first two digits
        int firstDigit = colorMap.get(colors[0]);
        int secondDigit = colorMap.get(colors[1]);
        int baseValue = firstDigit * 10 + secondDigit;
        
        // Get the multiplier (number of zeros)
        int multiplier = colorMap.get(colors[2]);
        
        // Calculate total value
        long value = baseValue;
        for (int i = 0; i < multiplier; i++) {
            value *= 10;
        }
        
        // Determine appropriate unit
        if (value >= 1_000_000_000) {
            return (value / 1_000_000_000) + " gigaohms";
        } else if (value >= 1_000_000) {
            return (value / 1_000_000) + " megaohms";
        } else if (value >= 1_000) {
            return (value / 1_000) + " kiloohms";
        } else {
            return value + " ohms";
        }
    }
}
