use std::collections::HashSet;
use std::sync::{Mutex, Once};
use std::time::{SystemTime, UNIX_EPOCH};
use std::cell::RefCell;

static INIT: Once = Once::new();
static mut NAMES: Option<Mutex<HashSet<String>>> = None;

fn get_names() -> &'static Mutex<HashSet<String>> {
    unsafe {
        INIT.call_once(|| {
            NAMES = Some(Mutex::new(HashSet::new()));
        });
        &*NAMES.unwrap()
    }
}

pub struct Robot {
    name: RefCell<Option<String>>,
}

impl Robot {
    pub fn new() -> Self {
        Robot { 
            name: RefCell::new(None) 
        }
    }

    pub fn name(&self) -> &str {
        let mut n = self.name.borrow_mut();
        if n.is_none() {
            drop(n); // Release the borrow
            let new_name = generate_unique_name();
            *self.name.borrow_mut() = Some(new_name);
        }
        // Need to re-borrow after dropping
        let n = self.name.borrow();
        n.as_ref().unwrap().as_str()
    }

    pub fn reset_name(&mut self) {
        let new_name = generate_unique_name();
        *self.name.borrow_mut() = Some(new_name);
    }
}

fn generate_unique_name() -> String {
    loop {
        let name = generate_random_name();
        let mut names = get_names();
        let mut used_names = names.lock().unwrap();
        
        if !used_names.contains(&name) {
            used_names.insert(name.clone());
            return name;
        }
        // If name exists, try again
    }
}

fn generate_random_name() -> String {
