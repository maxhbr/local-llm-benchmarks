scale_generator.go
```
package scale

import (
	"strings"
)

// Chromatic scales - sharp and flat versions
var sharpScale = []string{"A", "A#", "B", "C", "C#", "D", "D#", "E", "F", "F#", "G", "G#"}
var flatScale = []string{"A", "Bb", "B", "C", "Db", "D", "Eb", "E", "F", "Gb", "G", "Ab"}

// isSharpTonic determines if the tonic should use sharps
func isSharpTonic(tonic string) bool {
	// Natural notes C and a follow sharps when ascending
	if strings.EqualFold(tonic, "C") || strings.EqualFold(tonic, "a") {
		return true
	}
	
	// Major scales with sharp: G, D, A, E, B, F#
	// Minor scales with sharp: e, b, f#, c#, g#, d#
	sharpTonics := []string{"G", "D", "A", "E", "B", "F#", "e", "b", "f#", "c#", "g#", "d#"}
	for _, t := range sharpTonics {
		if strings.EqualFold(tonic, t) {
			return true
		}
	}
	return false
}

// getChromaticScale returns the appropriate chromatic scale based on tonic
func getChromaticScale(tonic string) []string {
	if isSharpTonic(tonic) {
		return sharpScale
	}
	return flatScale
}

// findIndex finds the index of a note in a scale
func findIndex(scale []string, note string) int {
	for i, n := range scale {
		if strings.EqualFold(n, note) {
			return i
		}
	}
	return -1
}

func Scale(tonic, interval string) []string {
	// Normalize tonic: first letter uppercase, rest as-is (preserving # or b)
	normalizedTonic := strings.ToUpper(string(tonic[0])) + tonic[1:]
	
	// Get the appropriate chromatic scale (sharp or flat)
	scale := getChromaticScale(normalizedTonic)
	
	// Find the starting index based on normalized tonic
	startIndex := findIndex(scale, normalizedTonic)
	if startIndex == -1 {
		return []string{}
	}
	
	// If interval is empty, return chromatic scale starting from tonic
	if interval == "" {
		result := make([]string, 12)
		for i := 0; i < 12; i++ {
			result[i] = scale[(startIndex+i)%12]
		}
		return result
	}
	
	// Build diatonic scale based on intervals
	result := []string{normalizedTonic}
	currentIndex := startIndex
	
	for _, r := range interval {
		step := 0
		if r == 'm' {
			step = 1 // half step
		} else if r == 'M' {
			step = 2 // whole step
		} else if r == 'A' {
			step = 3 // augmented second
		}
		
		currentIndex = (currentIndex + step) % 12
		result = append(result, scale[currentIndex])
	}
	
	return result
}
```
