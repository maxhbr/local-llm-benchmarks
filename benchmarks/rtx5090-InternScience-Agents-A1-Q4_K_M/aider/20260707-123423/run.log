"T".to_string()],
            'S' => vec!["G".to_string(), 
"C".to_string()],
            'W' => vec!["A".to_string(), 
"T".to_string()],
            'K' => vec!["G".to_string(), 
"T".to_string()],
            'M' => vec!["A".to_string(), 
"C".to_string()],
            'B' => vec!["C".to_string(), 
"G".to_string(), "T".to_string()],
            'D' => vec!["A".to_string(), 
"G".to_string(), "T".to_string()],
            'H' => vec!["A".to_string(), 
"C".to_string(), "T".to_string()],
            'V' => vec!["A".to_string(), 
"C".to_string(), "G".to_string()],
            'N' => vec!["A".to_string(), 
"C".to_string(), "G".to_string(), 
"T".to_string()],
            _ => return Vec::new(), // invalid 
character
        };
        let mut new_results = Vec::new();
        for prefix in &results {
            for expansion in &expansions {
                new_results.push(format!("{}{}", 
prefix, expansion));
            }
        }
        results = new_results;
    }
    results
}
```

