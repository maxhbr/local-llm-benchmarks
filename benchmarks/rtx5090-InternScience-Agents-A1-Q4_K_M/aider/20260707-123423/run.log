use std::collections::HashMap; // Not needed if 
we use Vec

pub struct CodonsInfo<'a> {
    pairs: Vec<(&'a str, &'a str)>,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub struct Error;

impl<'a> CodonsInfo<'a> {
    pub fn name_for(&self, codon: &str) -> 
Result<&'a str, Error> {
        // Check length
        if codon.len() != 3 {
            return Err(Error);
        }
        let expanded = expand_codon(codon);
        let mut names = Vec::new();
        for full_codon in expanded {
            for (c, name) in &self.pairs {
                if c == &full_codon.as_str() {
                    names.push(*name);
                }
            }
        }
        if names.is_empty() {
            return Err(Error);
        }
        // Check all names are the same
        let first = names[0];
        for name in &names {
            if *name != first {
                return Err(Error);
            }
        }
        Ok(first)
    }

    pub fn of_rna(&self, rna: &str) -> 
Result<Vec<&'a str>, Error> {
        // Convert U to T
        let dna: String = rna.chars().map(|c| if 
c == 'U' { 'T' } else { c }).collect();
        if dna.len() % 3 != 0 {
            return Err(Error);
        }
        let mut result = Vec::new();
        for i in (0..dna.len()).step_by(3) {
            let codon = &dna[i..i+3];
            let name = self.name_for(codon)?;
            result.push(name);
        }
        Ok(result)
    }
}

pub fn parse<'a>(pairs: Vec<(&'a str, &'a str)>) 
-> CodonsInfo<'a> {
    CodonsInfo { pairs }
}

