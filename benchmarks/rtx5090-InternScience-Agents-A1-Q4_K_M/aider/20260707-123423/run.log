Let me understand the requirements:

1. Implement a `grep` function that searches files for lines matching a pattern
2. The function takes three arguments:
   - `pattern`: string to search for
   - `flags`: list of flags (like `-n`, `-l`, `-i`, `-v`, `-x`)
   - `files`: list of files to search in

3. Flags:
   - `-n`: Prepend line number and colon to each line (after filename if present)
   - `-l`: Output only filenames that contain at least one match
   - `-i`: Case-insensitive matching
   - `-v`: Invert match - collect lines that fail to match
   - `-x`: Match entire line only

4. When searching multiple files, prepend filename and colon to each matching line.

Let me implement this step by step:

```python
def grep(pattern, flags, files):
    # Parse flags
    show_line_numbers = '-n' in flags
    show_filenames_only = '-l' in flags
    case_insensitive = '-i' in flags
    invert_match = '-v' in flags
    match_entire_line = '-x' in flags
    
    results = []
    
    for file in files:
        # Read file
        with open(file, 'r') as f:
            lines = f.readlines()
        
        file_has_match = False
        
        for line_num, line in enumerate(lines, 1):
            # Strip newline for comparison but keep original for output
            line_content = line.rstrip('\n')
            
            # Apply case-insensitive if needed
            search_pattern = pattern
            compare_line = line_content
            
            if case_insensitive:
                search_pattern = pattern.lower()
                compare_line = line_content.lower()
            
            # Check match
            if match_entire_line:
                matches = (compare_line == search_pattern)
            else:
                matches = (search_pattern in compare_line)
            
            # Invert if needed
            if invert_match:
                matches = not matches
            
            if matches:
                file_has_match = True
                
                if show_filenames_only:
                    continue  # We'll handle this later
                
                # Build output line
                output_line = line_content
                
                if len(files) > 1:
                    output_line = f"{file}:{output_line}"
                
                if show_line_numbers:
                    if len(files) > 1:
                        output_line = f"{file}:{line_num}:{output_line}"
                    else:
                        output_line = f"{line_num}:{output_line}"
                
                results.append(output_line)
    
    # Handle -l flag
    if show_filenames_only:
        for file in files:
            with open(file, 'r') as f:
                lines = f.readlines()
            
            file_has_match = False
            for line in lines:
                line_content = line.rstrip('\n')
                
                if case_insensitive:
                    search_pattern = pattern.lower()
                    compare_line = line_content.lower()
                else:
                    search_pattern = pattern
                    compare_line = line_content
                
                if match_entire_line:
                    matches = (compare_line == search_pattern)
                else:
                    matches = (search_pattern in compare_line)
                
                if invert_match:
                    matches = not matches
                
                if matches:
                    file_has_match = True
                    break
            
            if file_has_match:
                results.append(file)
    
    return results
```

