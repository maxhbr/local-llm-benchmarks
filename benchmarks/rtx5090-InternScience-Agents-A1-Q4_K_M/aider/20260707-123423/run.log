```



spiral_matrix.cpp

```diff
@@ -1,5 +1,51 @@
 #include "spiral_matrix.h"
 
 namespace spiral_matrix {
 
+std::vector<std::vector<int>> spiral_matrix(int size) {
+    if (size <= 0) {
+        return {};
+    }
+    
+    std::vector<std::vector<int>> matrix(size, std::vector<int>(size, 0));
+    
+    int top = 0;
+    int bottom = size - 1;
+    int left = 0;
+    int right = size - 1;
+    int value = 1;
+    
+    while (value <= size * size) {
+        // Traverse from left to right along top row
+        for (int col = left; col <= right && value <= size * size; ++col) {
+            matrix[top][col] = value++;
+        }
+        top++;
+        
+        // Traverse from top to bottom along right column
+        for (int row = top; row <= bottom && value <= size * size; ++row) {
+            matrix[row][right] = value++;
+        }
+        right--;
+        
+        // Traverse from right to left along bottom row
+        if (top <= bottom) {
+            for (int col = right; col >= left && value <= size * size; --col) {
+                matrix[bottom][col] = value++;
+            }
+            bottom--;
+        }
+        
+        // Traverse from bottom to top along left column
+        if (left <= right) {
+            for (int row = bottom; row >= top && value <= size * size; --row) {
+                matrix[row][left] = value++;
+            }
+            left++;
+        }
+    }
+    
+    return matrix;
+}
+
 }  // namespace spiral_matrix
```


