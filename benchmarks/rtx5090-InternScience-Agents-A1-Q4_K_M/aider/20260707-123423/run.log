binary_search_tree.h
```
#if !defined(BINARY_SEARCH_TREE_H)
#define BINARY_SEARCH_TREE_H

#include <memory>
#include <vector>
#include <algorithm>

namespace binary_search_tree {

template <typename T>
class binary_tree {
public:
    explicit binary_tree(T value) : data_(value), left_(nullptr), right_(nullptr) {}
    
    T data() const { return data_; }
    
    std::unique_ptr<binary_tree<T>> const& left() const { return left_; }
    std::unique_ptr<binary_tree<T>> const& right() const { return right_; }
    
    void insert(T value) {
        if (value <= data_) {
            if (left_) {
                left_->insert(value);
            } else {
                left_ = std::make_unique<binary_tree<T>>(value);
            }
        } else {
            if (right_) {
                right_->insert(value);
            } else {
                right_ = std::make_unique<binary_tree<T>>(value);
            }
        }
    }

private:
    T data_;
    std::unique_ptr<binary_tree<T>> left_;
    std::unique_ptr<binary_tree<T>> right_;
};

template <typename T>
std::unique_ptr<binary_tree<T>> make_tree(std::vector<T> values) {
    if (values.empty()) {
        return nullptr;
    }
    
    auto tree = std::make_unique<binary_tree<T>>(values[0]);
    for (size_t i = 1; i < values.size(); ++i) {
        tree->insert(values[i]);
    }
    return tree;
}

}  // namespace binary_search_tree

#endif // BINARY_SEARCH_TREE_H
