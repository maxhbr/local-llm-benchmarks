```java
enum Winner {
    NONE,
    O,
    X
}

class Connect {
    private char[][] board;
    private int rows;
    private int cols;

    public Connect(String[] board) {
        if (board == null || board.length == 0) {
            this.board = new char[0][0];
            this.rows = 0;
            this.cols = 0;
            return;
        }

        this.rows = board.length;
        int maxCols = 0;
        for (String line : board) {
            String trimmed = line.trim();
            if (trimmed.isEmpty()) {
                maxCols = Math.max(maxCols, 0);
            } else {
                String[] cells = trimmed.split("\\s+");
                maxCols = Math.max(maxCols, cells.length);
            }
        }
        this.cols = maxCols;

        this.board = new char[rows][cols];
        for (int r = 0; r < rows; r++) {
            String trimmed = board[r].trim();
            if (trimmed.isEmpty()) {
                for (int c = 0; c < cols; c++) {
                    this.board[r][c] = '.';
                }
            } else {
                String[] cells = trimmed.split("\\s+");
                for (int c = 0; c < cols; c++) {
                    if (c < cells.length) {
                        this.board[r][c] = cells[c].charAt(0);
                    } else {
                        this.board[r][c] = '.';
                    }
                }
            }
        }
    }

    public Winner computeWinner() {
        if (hasPath('O', true)) {
            return Winner.O;
        }
        if (hasPath('X', false)) {
            return Winner.X;
        }
        return Winner.NONE;
    }

    private boolean hasPath(char player, boolean topToBottom) {
        if (rows == 0 || cols == 0) {
            return false;
        }

        boolean[][] visited = new boolean[rows][cols];
        Queue<int[]> queue = new java.util.LinkedList<>();

        // Add all starting positions
        for (int r = 0; r < rows; r++) {
            for (int c = 0; c < cols; c++) {
                if (board[r][c] == player) {
                    if (topToBottom && r == 0) {
                        visited[r][c] = true;
                        queue.offer(new int[]{r, c});
                    } else if (!topToBottom && c == 0) {
                        visited[r][c] = true;
                        queue.offer(new int[]{r, c});
                    }
                }
            }
        }

        while (!queue.isEmpty()) {
            int[] current = queue.poll();
            int r = current[0];
            int c = current[1];

            // Check if we reached the target
            if (topToBottom && r == rows - 1) {
                return true;
            }
            if (!topToBottom && c == cols - 1) {
                return true;
            }

            // Get neighbors based on row parity
            int[][] neighbors = getNeighbors(r, c);
            for (int[] neighbor : neighbors) {
                int nr = neighbor[0];
                int nc = neighbor[1];

