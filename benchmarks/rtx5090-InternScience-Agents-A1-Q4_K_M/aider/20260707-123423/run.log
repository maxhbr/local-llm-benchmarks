```
func encodeSingle(n uint32) []byte {
    if n == 0 {
        return []byte{0}
    }
    var bytes []byte
    for n > 0 {
        byte := n & 0x7F
        n >>= 7
        bytes = append(bytes, byte)
    }
    // Now reverse bytes and set continuation 
bits
    for i := len(bytes)/2 - 1; i >= 0; i-- {
        bytes[i], bytes[len(bytes)-1-i] = 
bytes[len(bytes)-1-i], bytes[i]
    }
    // Set continuation bit on all but last
    for i := 0; i < len(bytes)-1; i++ {
        bytes[i] |= 0x80
    }
    return bytes
}
```

