// This is only a SKELETON file for the 'State of Tic Tac Toe' exercise. It's been provided as a
// convenience to get you started writing code faster.
//

export const gamestate = (board) => {
  // Count X's and O's - board is array of strings
  let xCount = 0;
  let oCount = 0;
  
  for (let row of board) {
    for (let cell of row) {
      if (cell === 'X') xCount++;
      if (cell === 'O') oCount++;
    }
  }
  
  // Validate turn order: X starts, so X count should be equal to O count or X count = O count + 1
  if (xCount > oCount + 1) {
    throw new Error('Wrong turn order: X went twice');
  }
  if (oCount > xCount) {
    throw new Error('Wrong turn order: O started');
  }
  
  // Check for winners - need to parse the board properly
  const winningLines = [
    // Rows
    [[0,0], [0,1], [0,2]],
    [[1,0], [1,1], [1,2]],
    [[2,0], [2,1], [2,2]],
    // Columns
    [[0,0], [1,0], [2,0]],
    [[0,1], [1,1], [2,1]],
    [[0,2], [1,2], [2,2]],
    // Diagonals
    [[0,0], [1,1], [2,2]],
    [[0,2], [1,1], [2,0]]
  ];
  
  let xWon = false;
  let oWon = false;
  
  for (let line of winningLines) {
    const [a, b, c] = line;
    const cellA = board[a[0]][a[1]];
    const cellB = board[b[0]][b[1]];
    const cellC = board[c[0]][c[1]];
    
    if (cellA === 'X' && cellB === 'X' && cellC === 'X') {
      xWon = true;
    }
    if (cellA === 'O' && cellB === 'O' && cellC === 'O') {
      oWon = true;
    }
  }
  
  // Both players can't win
  if (xWon && oWon) {
    throw new Error('Impossible board: both players have won');
  }
  
  // If X won, X count should be O count + 1 (since X made the last move)
  if (xWon && xCount !== oCount + 1) {
    throw new Error('Impossible board: game should have ended after the game was won');
  }
  
  // If O won, X count should equal O count (since O made the last move)
  if (oWon && xCount !== oCount) {
    throw new Error('Impossible board: game should have ended after the game was won');
  }
  
  // Determine state
  if (xWon || oWon) {
    return 'win';
  }
  
  // Check if board is full - need to handle string board properly
  const isFull = board.every(row => row.length === 3 && row.split('').every(cell => cell !== ''));
  if (isFull) {
    return 'draw';
  }
  
  return 'ongoing';
};
