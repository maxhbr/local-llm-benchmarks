class StateOfTicTacToe {
    public GameState determineState(String[] board) {
        // Validate board dimensions
        if (board.length != 3) {
            throw new IllegalArgumentException("Board must have 3 rows");
        }
        
        for (String row : board) {
            if (row.length() != 3) {
                throw new IllegalArgumentException("Each row must have 3 columns");
            }
        }
        
        // Count X's and O's
        int xCount = 0;
        int oCount = 0;
        for (String row : board) {
            for (int i = 0; i < row.length(); i++) {
                char c = row.charAt(i);
                if (c == 'X') xCount++;
                else if (c == 'O') oCount++;
            }
        }
        
        // Validate turn order: X starts, so xCount should be equal to or one more than oCount
        if (oCount > xCount || xCount > oCount + 1) {
            throw new IllegalArgumentException("Invalid turn order");
        }
        
        // Check for wins
        boolean xWins = checkWin(board, 'X');
        boolean oWins = checkWin(board, 'O');
        
        // Both players can't win simultaneously
        if (xWins && oWins) {
            throw new IllegalArgumentException("Impossible board: both players won");
        }
        
        // If X wins, X count should be one more than O count (since X goes last)
        if (xWins) {
            if (xCount != oCount + 1) {
                throw new IllegalArgumentException("X won but turn order is invalid");
            }
        }
        
        // If O wins, counts should be equal (since O goes last)
        if (oWins) {
            if (xCount != oCount) {
                throw new IllegalArgumentException("O won but turn order is invalid");
            }
        }
        
        // Determine game state
        if (xWins || oWins) {
            return GameState.WIN;
        }
        
        if (xCount + oCount == 9) {
            return GameState.DRAW;
        }
        
        return GameState.ONGOING;
    }
    
    private boolean checkWin(String[] board, char player) {
        // Check rows
        for (int i = 0; i < 3; i++) {
            if (board[i].charAt(0) == player && board[i].charAt(1) == player && board[i].charAt(2) == player) {
                return true;
            }
        }
        
        // Check columns
        for (int j = 0; j < 3; j++) {
            if (board[0].charAt(j) == player && board[1].charAt(j) == player && board[2].charAt(j) == player) {
                return true;
            }
        }
        
        // Check diagonals
        if (board[0].charAt(0) == player && board[1].charAt(1) == player && board[2].charAt(2) == player) {
            return true;
        }
        if (board[0].charAt(2) == player && board[1].charAt(1) == player && board[2].charAt(0) == player) {
            return true;
        }
        
        return false;
    }
}
