package twobucket

import (
	"errors"
)

type state struct {
	b1, b2 int
	steps  int
}

func Solve(sizeBucketOne, sizeBucketTwo, goalAmount int, startBucket string) (string, int, int, error) {
	// Validate inputs
	if sizeBucketOne <= 0 || sizeBucketTwo <= 0 || goalAmount < 0 {
		return "", 0, 0, errors.New("invalid parameters")
	}
	if startBucket != "one" && startBucket != "two" {
		return "", 0, 0, errors.New("invalid start bucket")
	}

	// Initial state based on startBucket (first action is to fill the starting bucket)
	var initialState [2]int
	if startBucket == "one" {
		initialState = [2]int{sizeBucketOne, 0}
	} else {
		initialState = [2]int{0, sizeBucketTwo}
	}

	// Check if initial state already meets goal
	if initialState[0] == goalAmount {
		return "one", 1, initialState[1], nil
	}
	if initialState[1] == goalAmount {
		return "two", 1, initialState[0], nil
	}

	// BFS queue: states to explore
	queue := []state{{b1: initialState[0], b2: initialState[1], steps: 1}}
	visited := make(map[[2]int]bool)
	visited[[2]int{initialState[0], initialState[1]}] = true

	for len(queue) > 0 {
		current := queue[0]
		queue = queue[1:]

		// Generate all possible next states
		nextStates := generateNextStates(current.b1, current.b2, sizeBucketOne, sizeBucketTwo, startBucket)

		for _, ns := range nextStates {
			// Check if this state meets the goal
			if ns.b1 == goalAmount {
				return "one", current.steps + 1, ns.b2, nil
			}
			if ns.b2 == goalAmount {
				return "two", current.steps + 1, ns.b1, nil
			}

			stateKey := [2]int{ns.b1, ns.b2}
			if !visited[stateKey] {
				visited[stateKey] = true
				queue = append(queue, ns)
			}
		}
	}

	return "", 0, 0, errors.New("no solution found")
}

func generateNextStates(b1, b2, size1, size2 int, startBucket string) []state {
	var states []state

	// Pour from bucket 1 to bucket 2
	pourAmount := min(b1, size2-b2)
	states = append(states, state{b1: b1 - pourAmount, b2: b2 + pourAmount, steps: 0})

	// Pour from bucket 2 to bucket 1
	pourAmount = min(b2, size1-b1)
	states = append(states, state{b1: b1 + pourAmount, b2: b2 - pourAmount, steps: 0})

	// Empty bucket 1
	states = append(states, state{b1: 0, b2: b2, steps: 0})

	// Empty bucket 2
	states = append(states, state{b1: b1, b2: 0, steps: 0})

	// Fill bucket 1
	states = append(states, state{b1: size1, b2: b2, steps: 0})

	// Fill bucket 2
	states = append(states, state{b1: b1, b2: size2, steps: 0})

	// Filter out states that violate the rule:
	// After an action, you may not arrive at a state where the starting bucket is empty and the other bucket is full.
	var validStates []state
	for _, s := range states {
		if !(startBucket == "one" && s.b1 == 0 && s.b2 == size2) &&
			!(startBucket == "two" && s.b2 == 0 && s.b1 == size1) {
			validStates = append(validStates, s)
		}
	}

	return validStates
}

func min(a, b int) int {
	if a < b {
		return a
	}
	return b
}
