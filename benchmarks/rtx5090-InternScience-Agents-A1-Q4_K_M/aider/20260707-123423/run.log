pub struct CodonsInfo<'a> {
    pairs: Vec<(&'a str, &'a str)>,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub struct Error;

impl<'a> CodonsInfo<'a> {
    pub fn name_for(&self, codon: &str) -> Result<&'a str, Error> {
        // Codons should be exactly 3 nucleotides long
        if codon.len() != 3 {
            return Err(Error);
        }

        // Expand shorthand codon to all possible full codons
        let expanded = expand_codon(codon);
        
        // Look up each expanded codon in the pairs
        let mut names = Vec::new();
        for (c, name) in &self.pairs {
            if *c == expanded.as_str() {
                names.push(*name);
            }
        }

        if names.is_empty() {
            return Err(Error);
        }

        // Ensure all found names are the same (consistency check)
        let first = names[0];
        for name in &names {
            if *name != first {
                return Err(Error);
            }
        }

        Ok(first)
    }

    pub fn of_rna(&self, rna: &str) -> Result<Vec<&'a str>, Error> {
        // Convert RNA to DNA (U -> T)
        let dna: String = rna.chars().map(|c| if c == 'U' { 'T' } else { c }).collect();
        
        // Check length is divisible by 3
        if dna.len() % 3 != 0 {
            return Err(Error);
        }

        let mut result = Vec::new();
        for i in (0..dna.len()).step_by(3) {
            let codon = &dna[i..i+3];
            let name = self.name_for(codon)?;
            result.push(name);
        }

        Ok(result)
    }
}

pub fn parse<'a>(pairs: Vec<(&'a str, &'a str)>) -> CodonsInfo<'a> {
    CodonsInfo { pairs }
}

// Helper function to expand a codon with shorthand notation
fn expand_codon(codon: &str) -> Vec<String> {
    let mut results = vec![String::new()];
    
    for ch in codon.chars() {
        let expansions = match ch {
            'A' => vec!["A".to_string()],
            'C' => vec!["C".to_string()],
            'G' => vec!["G".to_string()],
            'T' => vec!["T".to_string()],
            'R' => vec!["A".to_string(), "G".to_string()], // purine
            'Y' => vec!["C".to_string(), "T".to_string()], // pyrimidine
            'S' => vec!["G".to_string(), "C".to_string()], // strong
            'W' => vec!["A".to_string(), "T".to_string()], // weak
            'K' => vec!["G".to_string(), "T".to_string()], // keto
            'M' => vec!["A".to_string(), "C".to_string()], // amino
            'B' => vec!["C".to_string(), "G".to_string(), "T".to_string()], // not A
            'D' => vec!["A".to_string(), "G".to_string(), "T".to_string()], // not C
            'H' => vec!["A".to_string(), "C".to_string(), "T".to_string()], // not G
            'V' => vec!["A".to_string(), "C".to_string(), "G".to_string()], // not T
            'N' => vec!["A".to_string(), "C".to_string(), "G".to_string(), "T".to_string()], // any
            _ => return Vec::new(), // invalid character
        };

        let mut new_results = Vec::new();
