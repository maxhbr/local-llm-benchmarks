        int oCount = 0;
        for (String row : board) {
            for (int i = 0; i < row.length(); i++) {
                char c = row.charAt(i);
                if (c == 'X') xCount++;
                else if (c == 'O') oCount++;
            }
        }
        
        // Validate turn order: X starts, so xCount should be equal to or one more than oCount
        if (oCount > xCount || xCount > oCount + 1) {
            throw new IllegalArgumentException("Invalid turn order");
        }
        
        // Check for wins
        boolean xWins = checkWin(board, 'X');
        boolean oWins = checkWin(board, 'O');
        
        // Both players can't win simultaneously
        if (xWins && oWins) {
            throw new IllegalArgumentException("Impossible board: both players won");
        }
        
        // If X wins, X count should be one more than O count (since X goes last)
        if (xWins) {
            if (xCount != oCount + 1) {
                throw new IllegalArgumentException("X won but turn order is invalid");
            }
        }
        
        // If O wins, counts should be equal (since O goes last)
        if (oWins) {
            if (xCount != oCount) {
                throw new IllegalArgumentException("O won but turn order is invalid");
            }
        }
        
        // Determine game state
        if (xWins || oWins) {
            return GameState.WIN;
        }
        
        if (xCount + oCount == 9) {
            return GameState.DRAW;
        }
        
        return GameState.ONGOING;
    }
    
    private boolean checkWin(String[] board, char player) {
