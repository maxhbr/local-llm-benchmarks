food_chain.py
```
def recite(start_verse, end_verse):
    animals = ['fly', 'spider', 'bird', 'cat', 'dog', 'goat', 'cow', 'horse']
    reactions = {
        'fly': None,
        'spider': 'It wriggled and jiggled and tickled inside her.',
        'bird': 'How absurd to swallow a bird!',
        'cat': 'Imagine that, to swallow a cat!',
        'dog': 'What a hog, to swallow a dog!',
        'goat': 'Just opened her throat and swallowed a goat!',
        'cow': 'I don\'t know how she swallowed a cow!',
        'horse': "She's dead, of course!"
    }
    
    verses = []
    
    for verse_num in range(start_verse, end_verse + 1):
        idx = verse_num - 1
        animal = animals[idx]
        
        verse_lines = [f"I know an old lady who swallowed a {animal}."]
        
        if verse_num == 8:  # horse verse
            verse_lines.append(reactions[animal])
        else:
            if reactions[animal]:
                verse_lines.append(reactions[animal])
            
            # Build cumulative chain from current animal down to fly
            for i in range(idx, 0, -1):
                current = animals[i]
                previous = animals[i - 1]
                line = f"She swallowed the {current} to catch the {previous}"
                if previous == 'spider':
                    line += " that wriggled and jiggled and tickled inside her"
                line += "."
                verse_lines.append(line)
            
            verse_lines.append("I don't know why she swallowed the fly. Perhaps she'll die.")
        
        verses.append(verse_lines)
    
    # Join verses with empty string between them
    result = []
    for i, verse in enumerate(verses):
        if i > 0:
            result.append("")
        result.extend(verse)
    
    return result
```
