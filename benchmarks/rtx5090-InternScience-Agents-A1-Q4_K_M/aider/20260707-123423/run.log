```go
package wordsearch

import "errors"

func Solve(words []string, puzzle []string) (map[string][2][2]int, error) {
    result := make(map[string][2][2]int)
    
    if len(puzzle) == 0 || len(puzzle[0]) == 0 {
        // Return error for empty puzzle
        return nil, errors.New("empty puzzle")
    }
    
    rows := len(puzzle)
    cols := len(puzzle[0])
    
    // Directions: [row_delta, col_delta]
    directions := [][2]int{
        {0, 1},   // right
        {0, -1},  // left
        {1, 0},   // down
        {-1, 0},  // up
        {1, 1},   // down-right
        {1, -1},  // down-left
        {-1, 1},  // up-right
        {-1, -1}, // up-left
    }
    
    for _, word := range words {
        if len(word) == 0 {
            continue
        }
        
        found := false
        for r := 0; r < rows && !found; r++ {
            for c := 0; c < cols && !found; c++ {
                if puzzle[r][c] == word[0] {
                    // Check all directions
                    for _, dir := range directions {
                        dr, dc := dir[0], dir[1]
                        
                        // Calculate end position
                        endR := r + (len(word)-1)*dr
                        endC := c + (len(word)-1)*dc
                        
                        // Check bounds
                        if endR < 0 || endR >= rows || endC < 0 || endC >= cols {
                            continue
                        }
                        
                        // Verify the word matches in this direction
                        match := true
                        for i := 0; i < len(word); i++ {
                            currR := r + i*dr
                            currC := c + i*dc
                            if puzzle[currR][currC] != word[i] {
                                match = false
                                break
                            }
                        }
                        
                        if match {
                            // Return coordinates as [col, row] format
                            result[word] = [2][2]int{{c, r}, {endC, endR}}
                            found = true
                        }
                    }
                }
            }
        }
        
        if !found {
            return nil, errors.New("word not found")
        }
    }
    
    return result, nil
}
```
