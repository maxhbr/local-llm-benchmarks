import java.util.ArrayList;
import java.util.List;

class VariableLengthQuantity {

    List<String> encode(List<Long> numbers) {
        List<String> result = new ArrayList<>();
        
        for (Long number : numbers) {
            if (number == null || number < 0 || number > 0xFFFFFFFFL) {
                throw new IllegalArgumentException("Number out of range");
            }
            
            List<String> bytes = encodeNumber(number);
            result.addAll(bytes);
        }
        
        return result;
    }

    private List<String> encodeNumber(Long number) {
        List<String> bytes = new ArrayList<>();
        
        if (number == 0) {
            bytes.add("0x0");
            return bytes;
        }
        
        // Extract 7-bit chunks from LSB to MSB
        List<Integer> chunks = new ArrayList<>();
        long n = number;
        
        while (n > 0) {
            chunks.add((int)(n & 0x7F));
            n >>= 7;
        }
        
        // Reverse to get MSB first, and set continuation bit on all but last
        for (int i = chunks.size() - 1; i >= 0; i--) {
            int chunk = chunks.get(i);
            if (i > 0) {
                chunk |= 0x80; // Set continuation bit
            }
            bytes.add(String.format("0x%02x", chunk));
        }
        
        return bytes;
    }

    List<String> decode(List<Long> bytes) {
        List<String> result = new ArrayList<>();
        long currentNumber = 0;
        boolean hasContinuation = false;
        
        for (Long byteVal : bytes) {
            if (byteVal == null || byteVal < 0 || byteVal > 0xFFL) {
                throw new IllegalArgumentException("Byte out of range");
            }
            
            int b = byteVal.intValue();
            int value = b & 0x7F;
            
            // Check for overflow before shifting
            if ((currentNumber & 0xFE000000L) != 0) {
                throw new IllegalArgumentException("Overflow");
            }
            
            currentNumber = (currentNumber << 7) | value;
            
            if ((b & 0x80) == 0) {
                // Last byte of sequence
                result.add(String.format("0x%x", currentNumber));
                currentNumber = 0;
                hasContinuation = false;
            } else {
                hasContinuation = true;
            }
        }
        
        if (hasContinuation) {
            throw new IllegalArgumentException("Invalid variable-length quantity encoding");
        }
        
        return result;
    }
}
```

