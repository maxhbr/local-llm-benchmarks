```rust
pub type Value = i32;
pub type Result = std::result::Result<(), Error>;

pub struct Forth {
    stack: Vec<Value>,
    words: std::collections::HashMap<String, Vec<String>>,
    in_definition: bool,
    current_word: Option<String>,
    definition_body: Vec<String>,
}

#[derive(Debug, PartialEq, Eq)]
pub enum Error {
    DivisionByZero,
    StackUnderflow,
    UnknownWord,
    InvalidWord,
}

impl Forth {
    pub fn new() -> Forth {
        Forth {
            stack: Vec::new(),
            words: std::collections::HashMap::new(),
            in_definition: false,
            current_word: None,
            definition_body: Vec::new(),
        }
    }

    pub fn stack(&self) -> &[Value] {
        &self.stack
    }

    pub fn eval(&mut self, input: &str) -> Result {
        let tokens: Vec<String> = input
            .split_whitespace()
            .map(|s| s.to_uppercase())
            .collect();

        for token in tokens {
            self.process_token(&token)?;
        }

        Ok(())
    }

    fn process_token(&mut self, token: &str) -> Result {
        if self.in_definition {
            return self.process_definition_token(token);
        }

        if token == ":" {
            self.in_definition = true;
            self.current_word = None;
            self.definition_body.clear();
            return Ok(());
        }

        if token == ";" {
            return Err(Error::InvalidWord);
        }

        // Check if it's a number
        if let Ok(num) = token.parse::<Value>() {
            self.stack.push(num);
            return Ok(());
        }

        // Check if it's a defined word
        if let Some(definition) = self.words.get(token) {
            for def_token in definition {
                self.process_token(def_token)?;
            }
            return Ok(());
        }

        // Handle built-in operations
        match token {
            "+" => {
                let b = self.stack.pop().ok_or(Error::StackUnderflow)?;
                let a = self.stack.pop().ok_or(Error::StackUnderflow)?;
                self.stack.push(a + b);
                Ok(())
            }
            "-" => {
                let b = self.stack.pop().ok_or(Error::StackUnderflow)?;
                let a = self.stack.pop().ok_or(Error::StackUnderflow)?;
                self.stack.push(a - b);
                Ok(())
            }
            "*" => {
                let b = self.stack.pop().ok_or(Error::StackUnderflow)?;
                let a = self.stack.pop().ok_or(Error::StackUnderflow)?;
                self.stack.push(a * b);
                Ok(())
            }
            "/" => {
                let b = self.stack.pop().ok_or(Error::StackUnderflow)?;
                let a = self.stack.pop().ok_or(Error::StackUnderflow)?;
                if b == 0 {
                    return Err(Error::DivisionByZero);
                }
                self.stack.push(a / b);
                Ok(())
            }
            "DUP" => {
                let val = *self.stack.last().ok_or(Error::StackUnderflow)?;
                self.stack.push(val);
                Ok(())
            }
            "DROP" => {
                self.stack.pop().ok_or(Error::StackUnderflow)?;
                Ok(())
            }
            "SWAP" => {
                let b = self.stack.pop().ok_or(Error::StackUnderflow)?;
                let a = self.stack.pop().ok_or(Error::StackUnderflow)?;
                self.stack.push(b);
                self.stack.push(a);
                Ok(())
            }
            "OVER" => {
                if self.stack.len() < 2 {
                    return Err(Error::StackUnderflow);
                }
                let len = self.stack.len();
                self.stack.push(self.stack[len - 2]);
                Ok(())
            }
            _ => Err(Error::UnknownWord),
        }
    }

    fn process_definition_token(&mut self, token: &str) -> Result {
        if let Some(ref word) = self.current_word {
            // We're collecting the definition body
            if token == ";" {
                // End of definition
                self.words.insert(word.clone(), self.definition_body.clone());
                self.in_definition = false;
                self.current_word = None;
                self.definition_body.clear();
                Ok(())
            } else {
                self.definition_body.push(token.to_string());
                Ok(())
            }
        } else {
            // Just saw ':', next token is the word name
            if token.parse::<Value>().is_ok() {
                Err(Error::InvalidWord)
            } else {
                self.current_word = Some(token.to_string());
                Ok(())
            }
        }
    }
}
