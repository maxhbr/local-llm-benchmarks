"G".to_string()],
            'Y' => vec!["C".to_string(), 
"T".to_string()],
            'S' => vec!["G".to_string(), 
"C".to_string()],
            'W' => vec!["A".to_string(), 
"T".to_string()],
            'K' => vec!["G".to_string(), 
"T".to_string()],
            'M' => vec!["A".to_string(), 
"C".to_string()],
            'B' => vec!["C".to_string(), 
"G".to_string(), "T".to_string()],
            'D' => vec!["A".to_string(), 
"G".to_string(), "T".to_string()],
            'H' => vec!["A".to_string(), 
"C".to_string(), "T".to_string()],
            'V' => vec!["A".to_string(), 
"C".to_string(), "G".to_string()],
            'N' => vec!["A".to_string(), 
"C".to_string(), "G".to_string(), 
"T".to_string()],
            _ => return Vec::new(), // invalid 
