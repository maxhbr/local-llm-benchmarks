Looking at the instructions, I need to implement a `Scale` class that can:
1. Generate a 12-note chromatic scale starting with a given tonic (using sharps or flats based on the tonic)
2. Generate diatonic scales based on interval patterns

Let me analyze the requirements:
- For chromatic scales, I need to determine whether to use sharps or flats based on the tonic
- The chromatic scale should start with the given tonic and include all 12 notes
- For intervals, I need to navigate through the chromatic scale using half steps (m), whole steps (M), and augmented seconds (A)

Here's my implementation:

scale_generator.py
```
class Scale:
    # Chromatic scales - one with sharps, one with flats
    SHARP_SCALE = ['A', 'A#', 'B', 'C', 'C#', 'D', 'D#', 'E', 'F', 'F#', 'G', 'G#']
    FLAT_SCALE = ['A', 'Bb', 'B', 'C', 'Db', 'D', 'Eb', 'E', 'F', 'Gb', 'G', 'Ab']
    
    # Keys that use sharps (ascending)
    SHARP_KEYS = {'C', 'G', 'D', 'A', 'E', 'B', 'F#', 'a', 'e', 'b', 'f#', 'c#', 'g#', 'd#'}
    
    # Keys that use flats (descending or specific cases)
    FLAT_KEYS = {'F', 'Bb', 'Eb', 'Ab', 'Db', 'Gb', 'd', 'g', 'c', 'f', 'bb', 'eb'}
    
    # Mapping from sharp notes to flat notes (enharmonic equivalents)
    SHARP_TO_FLAT = {
        'A#': 'Bb', 'C#': 'Db', 'D#': 'Eb', 'F#': 'Gb', 'G#': 'Ab',
        'Bb': 'A#', 'Db': 'C#', 'Eb': 'D#', 'Gb': 'F#', 'Ab': 'G#'
    }
    
    def __init__(self, tonic):
        self.tonic = tonic.capitalize()
        # Determine if we should use sharps or flats
        # For C and a (natural), use sharps when ascending
        # For sharp keys, use sharps
        # For flat keys, use flats
        if self.tonic in self.SHARP_KEYS:
            self.use_sharps = True
        elif self.tonic in self.FLAT_KEYS:
            self.use_sharps = False
        else:
            # Default to sharps for unknown tonics
            self.use_sharps = True
    
    def chromatic(self):
        # Select the appropriate scale based on tonic
        scale = self.SHARP_SCALE if self.use_sharps else self.FLAT_SCALE
        
        # Find the index of the tonic in the scale
        try:
            start_index = scale.index(self.tonic)
        except ValueError:
            # If tonic not found, try to find enharmonic equivalent
            if self.use_sharps:
                flat_tonic = self.SHARP_TO_FLAT.get(self.tonic)
                if flat_tonic:
                    start_index = scale.index(flat_tonic)
                else:
                    start_index = 0
            else:
                sharp_tonic = self.SHARP_TO_FLAT.get(self.tonic)
                if sharp_tonic:
                    start_index = scale.index(sharp_tonic)
                else:
                    start_index = 0
        
        # Rotate the scale to start with the tonic
        return scale[start_index:] + scale[:start_index]
    
    def interval(self, intervals):
        # Get the chromatic scale starting with the tonic
        chromatic = self.chromatic()
        
        # Build the scale based on intervals
        scale = [self.tonic]
        current_note = self.tonic
        
        for interval in intervals:
            # Find current note index in chromatic scale
            try:
                current_index = chromatic.index(current_note)
            except ValueError:
                # Try enharmonic equivalent
                if self.use_sharps and current_note in self.SHARP_TO_FLAT:
                    current_note_flat = self.SHARP_TO_FLAT[current_note]
                    if current_note_flat in chromatic:
                        current_index = chromatic.index(current_note_flat)
                        current_note = current_note_flat
                    else:
                        current_index = 0
                elif not self.use_sharps and current_note in self.SHARP_TO_FLAT:
                    current_note_sharp = self.SHARP_TO_FLAT[current_note]
                    if current_note_sharp in chromatic:
                        current_index = chromatic.index(current_note_sharp)
                        current_note = current_note_sharp
                    else:
                        current_index = 0
                else:
                    current_index = 0
            
            # Calculate the step size based on interval
            if interval == 'm':
                step = 1
            elif interval == 'M':
                step = 2
            elif interval == 'A':
                step = 3
            else:
                step = 1
            
            # Find the next note
            next_index = (current_index + step) % 12
            next_note = chromatic[next_index]
            
            # If we're using sharps but got a flat note, convert it
            if self.use_sharps and next_note in self.SHARP_TO_FLAT:
                # Find the sharp equivalent
                for sharp, flat in self.SHARP_TO_FLAT.items():
                    if flat == next_note:
                        next_note = sharp
                        break
            
            # If we're using flats but got a sharp note, convert it
            elif not self.use_sharps and next_note in self.SHARP_TO_FLAT:
                # Find the flat equivalent
                for flat, sharp in self.SHARP_TO_FLAT.items():
                    if sharp == next_note:
                        next_note = flat
                        break
            
            scale.append(next_note)
            current_note = next_note
        
        return scale
```
