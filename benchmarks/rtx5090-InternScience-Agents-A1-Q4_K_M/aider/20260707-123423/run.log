Here's the complete implementation:

bowling.go
```go
package bowling

import "errors"

// Game represents a bowling game
type Game struct {
    rolls []int
}

func NewGame() *Game {
    return &Game{
        rolls: make([]int, 0),
    }
}

func (g *Game) Roll(pins int) error {
    // Validate pins
    if pins < 0 || pins > 10 {
        return errors.New("pin count must be between 0 and 10")
    }
    
    // Check if game is already complete
    if g.isComplete() {
        return errors.New("game is already complete")
    }
    
    // Validate the roll in context of current game state
    if err := g.validateRoll(pins); err != nil {
        return err
    }
    
    g.rolls = append(g.rolls, pins)
    return nil
}

func (g *Game) Score() (int, error) {
    if !g.isComplete() {
        return 0, errors.New("game is not complete")
    }
    
    score := 0
    rollIndex := 0
    
    for frame := 1; frame <= 10; frame++ {
        if frame < 10 {
            // Regular frames (1-9)
            if g.rolls[rollIndex] == 10 {
                // Strike
                score += 10 + g.rolls[rollIndex+1] + g.rolls[rollIndex+2]
                rollIndex++
            } else if g.rolls[rollIndex]+g.rolls[rollIndex+1] == 10 {
                // Spare
                score += 10 + g.rolls[rollIndex+2]
                rollIndex += 2
            } else {
                // Open frame
                score += g.rolls[rollIndex] + g.rolls[rollIndex+1]
                rollIndex += 2
            }
        } else {
            // 10th frame - special rules
            // The 10th frame can have 2 or 3 rolls depending on strikes/spares
            score += g.rolls[rollIndex] + g.rolls[rollIndex+1]
            if rollIndex+2 < len(g.rolls) {
                score += g.rolls[rollIndex+2]
            }
        }
    }
    
    return score, nil
}

// isComplete checks if the game has been played completely
func (g *Game) isComplete() bool {
    if len(g.rolls) == 0 {
        return false
    }
    
    // Check if all 10 frames are complete
    rollIndex := 0
    for frame := 1; frame <= 10; frame++ {
        if rollIndex >= len(g.rolls) {
            return false
        }
        
        if frame < 10 {
            // Regular frames: either 1 roll (strike) or 2 rolls
            if g.rolls[rollIndex] == 10 {
                rollIndex++
            } else {
                if rollIndex+1 >= len(g.rolls) {
                    return false
                }
                rollIndex += 2
            }
        } else {
            // 10th frame: can have 2 or 3 rolls
            // If first two sum to less than 10, it's 2 rolls (open)
            // Otherwise, it's 3 rolls (strike or spare)
            if rollIndex+1 >= len(g.rolls) {
                return false
            }
            firstTwoSum := g.rolls[rollIndex] + g.rolls[rollIndex+1]
            if firstTwoSum < 10 {
                // Open frame, only 2 rolls needed
                rollIndex += 2
            } else {
                // Strike or spare, need 3rd roll
                if rollIndex+2 >= len(g.rolls) {
                    return false
                }
                rollIndex += 3
            }
        }
    }
    
    return rollIndex == len(g.rolls)
}

// validateRoll checks if adding this roll would create an invalid game state
func (g *Game) validateRoll(pins int) error {
    // Simulate the game state to check validity
    tempRolls := append([]int{}, g.rolls...)
    tempRolls = append(tempRolls, pins)
    
    // Check if this creates an invalid frame
    rollIndex := 0
    for frame := 1; frame <= 10; frame++ {
        if rollIndex >= len(tempRolls) {
            break
        }
        
        if frame < 10 {
            // Regular frames
            if g.rolls[rollIndex] == 10 {
                // Strike - only 1 roll in this frame
                rollIndex++
            } else {
                // Need second roll
                if rollIndex+1 >= len(tempRolls) {
                    return nil // Incomplete, but not invalid
                }
                frameSum := tempRolls[rollIndex] + tempRolls[rollIndex+1]
                if frameSum > 10 {
                    return errors.New("pin count exceeds 10 in a frame")
                }
                rollIndex += 2
            }
        } else {
            // 10th frame special rules
            if rollIndex+1 >= len(tempRolls) {
                return nil // Incomplete, but not invalid
            }
            firstTwoSum := tempRolls[rollIndex] + tempRolls[rollIndex+1]
            if firstTwoSum < 10 {
                // Open frame - only 2 rolls allowed
                if len(tempRolls) > rollIndex+2 {
                    return errors.New("too many rolls in 10th frame")
                }
            } else {
                // Strike or spare - need exactly 3 rolls
                if len(tempRolls) < rollIndex+3 {
                    return nil // Incomplete, but not invalid
                }
                if len(tempRolls) > rollIndex+3 {
                    return errors.New("too many rolls in 10th frame")
                }
            }
            break
        }
    }
    
    return nil
}
```
