Looking at the instructions, I need to implement a REST API for tracking IOUs between roommates. The API needs to handle:

1. GET /users - list users (all or specific)
2. POST /add - create a new user
3. POST /iou - record a loan between users

Let me implement the complete solution:

rest_api.py
```
import json

class RestAPI:
    def __init__(self, database=None):
        self.users = {}
        if database is not None and 'users' in database:
            for user_data in database['users']:
                self.users[user_data['name']] = User(user_data)

    def get(self, url, payload=None):
        if url == '/users':
            if payload:
                payload_dict = json.loads(payload)
                user_names = payload_dict.get('users', [])
                result = [self.users[name] for name in user_names if name in self.users]
            else:
                result = list(self.users.values())
            return {"users": sorted(result, key=lambda u: u.name)}
        return None

    def post(self, url, payload=None):
        if url == '/add':
            if payload:
                payload_dict = json.loads(payload)
                user_name = payload_dict.get('user')
                if user_name and user_name not in self.users:
                    new_user = User(user_name)
                    self.users[user_name] = new_user
                    return new_user
        elif url == '/iou':
            if payload:
                payload_dict = json.loads(payload)
                lender_name = payload_dict.get('lender')
                borrower_name = payload_dict.get('borrower')
                amount = payload_dict.get('amount')
                
                if lender_name and borrower_name and amount is not None:
                    # Ensure both users exist
                    if lender_name not in self.users:
                        self.users[lender_name] = User(lender_name)
                    if borrower_name not in self.users:
                        self.users[borrower_name] = User(borrower_name)
                    
                    lender = self.users[lender_name]
                    borrower = self.users[borrower_name]
                    
                    # Update debts
                    if borrower_name in lender.owed_by:
                        lender.owed_by[borrower_name] += amount
                    else:
                        lender.owed_by[borrower_name] = amount
                    
                    if lender_name in borrower.owes:
                        borrower.owes[lender_name] += amount
                    else:
                        borrower.owes[lender_name] = amount
                    
                    # Clean up zero entries
                    lender._cleanup()
                    borrower._cleanup()
                    
                    return {"users": sorted([lender, borrower], key=lambda u: u.name)}
        return None


class User:
    def __init__(self, name, owes=None, owed_by=None):
        self.name = name
        self.owes = owes.copy() if owes else {}
        self.owed_by = owed_by.copy() if owed_by else {}
    
    @property
    def balance(self):
        total_owed_by = sum(self.owed_by.values())
        total_owed_to = sum(self.owes.values())
        return total_owed_by - total_owed_to
    
    def _cleanup(self):
        # Remove zero entries
        self.owes = {k: v for k, v in self.owes.items() if v != 0}
        self.owed_by = {k: v for k, v in self.owed_by.items() if v != 0}
    
    def to_dict(self):
        return {
            "name": self.name,
            "owes": self.owes,
            "owed_by": self.owed_by,
            "balance": self.balance
        }
    
    def __repr__(self):
        return self.to_dict()
```
