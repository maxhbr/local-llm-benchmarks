use std::collections::{HashMap, HashSet};

pub fn solve(input: &str) -> Option<HashMap<char, u8>> {
    // Handle empty input
    if input.trim().is_empty() {
        return None;
    }
    
    // Normalize the input by removing spaces and converting to uppercase
    let normalized: String = input.chars().filter(|c| !c.is_whitespace()).collect();
    
    // Split by == or =
    let parts: Vec<&str> = if normalized.contains("==") {
        normalized.split("==").collect()
    } else {
        normalized.split('=').collect()
    };
    
    if parts.len() != 2 {
        return None;
    }
    
    let left_str = parts[0];
    let right_str = parts[1];
    
    // Extract words from left side (split by +)
    let mut left_words: Vec<String> = Vec::new();
    for word in left_str.split('+') {
        if !word.is_empty() {
            left_words.push(word.to_string());
        }
    }
    
    // Extract words from right side
    let mut right_words: Vec<String> = Vec::new();
    for word in right_str.split('+') {
        if !word.is_empty() {
            right_words.push(word.to_string());
        }
    }
    
    // Get all unique letters
    let mut letters: HashSet<char> = HashSet::new();
    for word in left_words.iter().chain(right_words.iter()) {
        for c in word.chars() {
            letters.insert(c);
        }
    }
    
    if letters.len() > 10 {
        return None; // More than 10 unique letters, impossible with digits 0-9
    }
    
    let letter_vec: Vec<char> = letters.into_iter().collect();
    
    // Determine leading letters (cannot be zero)
    let mut leading_letters: HashSet<char> = HashSet::new();
    for word in left_words.iter().chain(right_words.iter()) {
        if word.len() > 1 {
            leading_letters.insert(word.chars().next().unwrap());
        }
    }
    
    // Backtracking function
    fn backtrack(
        letter_vec: &[char],
        leading_letters: &HashSet<char>,
        left_words: &[String],
        right_words: &[String],
        assignment: &mut HashMap<char, u8>,
        used_digits: &mut Vec<bool>,
        index: usize,
    ) -> Option<HashMap<char, u8>> {
        if index == letter_vec.len() {
            // Check if this assignment satisfies the equation
            let left_sum: u64 = left_words.iter().map(|word| word_to_number(word, assignment)).sum();
            let right_sum: u64 = right_words.iter().map(|word| word_to_number(word, assignment)).sum();
            
            if left_sum == right_sum {
                return Some(assignment.clone());
            }
            return None;
        }
        
        let letter = letter_vec[index];
        
        for digit in 0..=9 {
            if used_digits[digit] {
                continue;
            }
            
            if digit == 0 && leading_letters.contains(&letter) {
                continue;
            }
            
            assignment.insert(letter, digit);
            used_digits[digit] = true;
            
            if let Some(solution) = backtrack(letter_vec, leading_letters, left_words, right_words, assignment, used_digits, index + 1) {
                return Some(solution);
            }
            
            assignment.remove(&letter);
            used_digits[digit] = false;
        }
        
        None
    }
    
    fn word_to_number(word: &str, assignment: &HashMap<char, u8>) -> u64 {
        let mut num = 0u64;
        for c in word.chars() {
            if let Some(&digit) = assignment.get(&c) {
                num = num * 10 + digit as u64;
            } else {
                return 0; // Should not happen
            }
        }
        num
    }
    
    let mut assignment = HashMap::new();
    let mut used_digits = vec![false; 10];
    
    backtrack(&letter_vec, &leading_letters, &left_words, &right_words, &mut assignment, &mut used_digits, 0)
}
