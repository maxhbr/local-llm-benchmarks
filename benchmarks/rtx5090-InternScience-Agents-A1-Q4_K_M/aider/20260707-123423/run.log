```python
class Board:
    """Count territories of each player in a Go game

    Args:
        board (list[str]): A two-dimensional Go board
    """

    def __init__(self, board):
        self.board = board
        self.rows = len(board)
        self.cols = len(board[0]) if self.rows > 0 else 0

    def territory(self, x, y):
        """Find the owner and the territories given a coordinate on
           the board

        Args:
            x (int): Column on the board
            y (int): Row on the board

        Returns:
            (str, set): A tuple, the first element being the owner
                        of that area.  One of "W", "B", "".  The
                        second being a set of coordinates, representing
                        the owner's territories.
        """
        # Validate coordinates
        if not (0 <= x < self.cols and 0 <= y < self.rows):
            raise ValueError('Invalid coordinate')
        
        # If it's a stone, no territory
        if self.board[y][x] in ('B', 'W'):
            return ("", set())
        
        # Find the connected empty region
        return self._find_region(x, y)

    def _find_region(self, x, y):
        """Helper to find a connected region of empty spaces and determine owner."""
        if self.board[y][x] != ' ':
            return ("", set())
        
        visited = set()
        region = set()
        borders = set()
        
        # BFS to find all connected empty spaces
        queue = [(x, y)]
        visited.add((x, y))
        region.add((x, y))
        
        while queue:
            cx, cy = queue.pop(0)
            
            # Check all 4 neighbors
            for dx, dy in [(0, 1), (0, -1), (1, 0), (-1, 0)]:
                nx, ny = cx + dx, cy + dy
                
                if 0 <= nx < self.cols and 0 <= ny < self.rows:
                    cell = self.board[ny][nx]
                    
                    if cell == ' ':
                        if (nx, ny) not in visited:
                            visited.add((nx, ny))
                            region.add((nx, ny))
                            queue.append((nx, ny))
                    elif cell in ('B', 'W'):
                        borders.add(cell)
        
        # Determine owner based on borders
        if len(borders) == 1:
            owner = list(borders)[0]
        else:
            owner = ""
        
        return (owner, region)

    def territories(self):
        """Find the owners and the territories of the whole board

        Args:
            none

        Returns:
            dict(str, set): A dictionary whose key being the owner
                        , i.e. "W", "B", "".  The value being a set
                        of coordinates owned by the owner.
        """
        result = {"W": set(), "B": set(), "": set()}
        visited = set()
        
        for y in range(self.rows):
            for x in range(self.cols):
                if self.board[y][x] == ' ' and (x, y) not in visited:
                    owner, region = self._find_region(x, y)
                    visited.update(region)
                    result[owner].update(region)
        
        return result
```

