namespace phone_number {

phone_number::phone_number(const std::string& number) {
    std::string digits;
    for (char c : number) {
        if (std::isdigit(static_cast<unsigned char>(c))) {
            digits += c;
        } else if (std::isalpha(static_cast<unsigned char>(c))) {
            throw std::invalid_argument("letters not permitted");
        } else if (c != ' ' && c != '(' && c != ')' && c != '+' && c != '-' && c != '.') {
            throw std::invalid_argument("punctuations not permitted");
        }
    }

    if (digits.length() == 11) {
        if (digits[0] == '1') {
            digits = digits.substr(1);
        } else {
            throw std::invalid_argument("11 digits must start with 1");
        }
    }

    if (digits.length() != 10) {
        throw std::invalid_argument("incorrect number of digits");
    }

    if (digits[0] < '2' || digits[3] < '2') {
        throw std::invalid_argument("area code and exchange code must start with 2-9");
    }

    cleaned_number_ = digits;
}

std::string phone_number::number() const {
    return cleaned_number_;
}

}  // namespace phone_number
