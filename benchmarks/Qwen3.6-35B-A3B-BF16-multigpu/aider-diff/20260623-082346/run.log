```go
package variablelengthquantity

import "errors"

func EncodeVarint(input []uint32) []byte {
        var result []byte
        for _, n := range input {
                if n == 0 {
                        result = append(result, 0x00)
                        continue
                }
                var chunks []byte
                for n > 0 {
                        chunks = append(chunks, byte(n&0x7F))
                        n >>= 7
                }
                for i := len(chunks) - 1; i >= 0; i-- {
                        b := chunks[i]
                        if i > 0 {
                                b |= 0x80
                        }
                        result = append(result, b)
                }
        }
        return result
}

func DecodeVarint(input []byte) ([]uint32, error) {
        var result []uint32
        var current uint32
        var hasContinuation bool

        for _, b := range input {
                hasContinuation = (b & 0x80) != 0
                current = (current << 7) | uint32(b&0x7F)
                
                if !hasContinuation {
                        result = append(result, current)
                        current = 0
                }
        }

        if hasContinuation {
                return nil, errors.New("incomplete sequence")
        }
        return result, nil
}
```

