            String desc = e.getDescription();
            if (desc.length() > 25) {
                desc = desc.substring(0, 22) + "...";
            }

            int change = e.getChange();
            int absChange = Math.abs(change);
            int dollars = absChange / 100;
            int cents = absChange % 100;

