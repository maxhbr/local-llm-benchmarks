        # We can just check if there are any characters that are not digits or allowed punctuation
        allowed_chars = set("+-(). ")
        if any(c in number and not c.isdigit() and c not in allowed_chars for c in number):
            raise ValueError("punctuations not permitted")
            
        # Extract digits
        digits = "".join(c for c in number if c.isdigit())
        
        # Length checks
        if len(digits) < 10:
            raise ValueError("must not be fewer than 10 digits")
        if len(digits) > 11:
            raise ValueError("must not be greater than 11 digits")
            
        # Handle 11 digits
        if len(digits) == 11:
            if digits[0] != '1':
                raise ValueError("11 digits must start with 1")
            digits = digits[1:]
            
        # Now digits should be exactly 10
        area_code = digits[0]
        exchange_code = digits[3]
        
