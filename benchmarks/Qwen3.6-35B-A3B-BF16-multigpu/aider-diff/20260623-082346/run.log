func parseHand(s string) ([]Card, error) {
    parts := strings.Split(s, " ")
    if len(parts) != 5 {
        return nil, errors.New("invalid hand")
    }
    cards := make([]Card, 5)
    for i, p := range parts {
        r, suit, err := parseCard(p)
        if err != nil {
            return nil, err
        }
        cards[i] = Card{Rank: r, Suit: suit}
    }
    return cards, nil
}
```

`parseCard`:
```go
func parseCard(s string) (int, rune, error) {
    suit := rune(s[len(s)-1])
    rankStr := s[:len(s)-1]
    switch rankStr {
    case "2": return 2, suit, nil
    case "3": return 3, suit, nil
    case "4": return 4, suit, nil
    case "5": return 5, suit, nil
    case "6": return 6, suit, nil
    case "7": return 7, suit, nil
    case "8": return 8, suit, nil
    case "9": return 9, suit, nil
    case "10": return 10, suit, nil
    case "J": return 11, suit, nil
    case "Q": return 12, suit, nil
    case "K": return 13, suit, nil
    case "A": return 14, suit, nil
    default: return 0, 0, errors.New("invalid card")
    }
}
```

