// this module adds some functionality based on the required 
implementations
// here like: `LinkedList::pop_back` or `Clone for LinkedList<T>`
// You are free to use anything in it, but it's mainly for the test 
framework.
mod pre_implemented;

struct Node<T> {
    data: T,
    next: *mut Node<T>,
    prev: *mut Node<T>,
}

pub struct LinkedList<T> {
    head: *mut Node<T>,
    tail: *mut Node<T>,
    len: usize,
}

pub struct Cursor<'a, T> {
    list: *mut LinkedList<T>,
    node: *mut Node<T>,
    _marker: std::marker::PhantomData<&'a mut T>,
}

pub struct Iter<'a, T> {
    head: *mut Node<T>,
    _marker: std::marker::PhantomData<&'a T>,
}

impl<T> LinkedList<T> {
    pub fn new() -> Self {
        Self {
            head: std::ptr::null_mut(),
            tail: std::ptr::null_mut(),
            len: 0,
        }
    }

    pub fn is_empty(&self) -> bool {
        self.len == 0
    }

    pub fn len(&self) -> usize {
        self.len
    }

    pub fn push_front(&mut self, element: T) {
        let new_node = Box::into_raw(Box::new(Node {
            data: element,
            next: self.head,
            prev: std::ptr::null_mut(),
        }));
        if self.head.is_null() {
            self.tail = new_node;
        } else {
            unsafe { (*self.head).prev = new_node; }
        }
        self.head = new_node;
        self.len += 1;
    }

    pub fn push_back(&mut self, element: T) {
        let new_node = Box::into_raw(Box::new(Node {
            data: element,
            next: std::ptr::null_mut(),
            prev: self.tail,
        }));
        if self.tail.is_null() {
            self.head = new_node;
        } else {
            unsafe { (*self.tail).next = new_node; }
        }
        self.tail = new_node;
        self.len += 1;
    }

    pub fn pop_front(&mut self) -> Option<T> {
        if self.head.is_null() {
            return None;
        }
        let old_head = self.head;
        self.head = unsafe { (*old_head).next };
        if self.head.is_null() {
            self.tail = std::ptr::null_mut();
        } else {
            unsafe { (*self.head).prev = std::ptr::null_mut(); }
        }
        let data = unsafe { ptr::read(&(*old_head).data) };
        drop(unsafe { Box::from_raw(old_head) });
        self.len -= 1;
        Some(data)
    }

    pub fn pop_back(&mut self) -> Option<T> {
        if self.tail.is_null() {
            return None;
        }
        let old_tail = self.tail;
        self.tail = unsafe { (*old_tail).prev };
        if self.tail.is_null() {
            self.head = std::ptr::null_mut();
        } else {
            unsafe { (*self.tail).next = std::ptr::null_mut(); }
        }
        let data = unsafe { ptr::read(&(*old_tail).data) };
        drop(unsafe { Box::from_raw(old_tail) });
        self.len -= 1;
        Some(data)
    }

    /// Return a cursor positioned on the front element
    pub fn cursor_front(&mut self) -> Cursor<'_, T> {
        Cursor {
            list: self as *mut Self,
            node: self.head,
            _marker: std::marker::PhantomData,
        }
    }

    /// Return a cursor positioned on the back element
    pub fn cursor_back(&mut self) -> Cursor<'_, T> {
        Cursor {
            list: self as *mut Self,
            node: self.tail,
            _marker: std::marker::PhantomData,
        }
    }

    /// Return an iterator that moves from front to back
    pub fn iter(&self) -> Iter<'_, T> {
        Iter {
            head: self.head,
            _marker: std::marker::PhantomData,
        }
    }
}

// Safety: The cursor holds a raw pointer to the list and a node.
// It is safe to use as long as the list outlives the cursor and 
invariants are maintained.
impl<T> Cursor<'_, T> {
    /// Take a mutable reference to the current element
    pub fn peek_mut(&mut self) -> Option<&mut T> {
        if self.node.is_null() {
            None
        } else {
            Some(unsafe { &mut (*self.node).data })
        }
    }

    /// Move one position forward (towards the back) and
    /// return a reference to the new position
    #[allow(clippy::should_implement_trait)]
    pub fn next(&mut self) -> Option<&mut T> {
        if self.node.is_null() {
            return None;
        }
        self.node = unsafe { (*self.node).next };
        self.peek_mut()
    }

    /// Move one position backward (towards the front) and
    /// return a reference to the new position
    pub fn prev(&mut self) -> Option<&mut T> {
        if self.node.is_null() {
            return None;
        }
        self.node = unsafe { (*self.node).prev };
        self.peek_mut()
    }

    /// Remove and return the element at the current position and move 
the cursor
    /// to the neighboring element that's closest to the back. This can 
be
    /// either the next or previous position.
    pub fn take(&mut self) -> Option<T> {
        if self.node.is_null() {
            return None;
        }
        let list = unsafe { &mut *self.list };
        let node = self.node;
        
        let prev_node = unsafe { (*node).prev };
        let next_node = unsafe { (*node).next };

        // Unlink the node
        if let Some(prev) = prev_node.as_mut() {
            prev.next = next_node;
        } else {
            list.head = next_node;
        }

        if let Some(next) = next_node.as_mut() {
            next.prev = prev_node;
        } else {
            list.tail = prev_node;
        }

        // Clear pointers to prevent double-free or dangling references
        unsafe {
            (*node).next = std::ptr::null_mut();
            (*node).prev = std::ptr::null_mut();
        }

        let data = unsafe { ptr::read(&(*node).data) };
        drop(unsafe { Box::from_raw(node) });
        
        list.len -= 1;
        self.node = next_node;
        
        Some(data)
    }

    pub fn insert_after(&mut self, element: T) {
        self.insert(element, true)
    }

    pub fn insert_before(&mut self, element: T) {
        self.insert(element, false)
    }
}

impl<T> Cursor<'_, T> {
    fn insert(&mut self, element: T, after: bool) {
        let new_node = Box::into_raw(Box::new(Node {
            data: element,
            next: std::ptr::null_mut(),
            prev: std::ptr::null_mut(),
        }));
        let list = unsafe { &mut *self.list };

        if self.node.is_null() {
            if after {
                list.head = new_node;
                list.tail = new_node;
                self.node = new_node;
            }
            // If !after and null, we do nothing (cursor is at the 
beginning)
            return;
        }

        let current = self.node;
        if after {
            let next_node = unsafe { (*current).next };
            unsafe {
                (*new_node).next = next_node;
                (*new_node).prev = current;
                (*current).next = new_node;
                if let Some(next) = next_node.as_mut() {
                    next.prev = new_node;
                } else {
                    list.tail = new_node;
                }
            }
            self.node = new_node;
        } else {
            let prev_node = unsafe { (*current).prev };
            unsafe {
                (*new_node).prev = prev_node;
                (*new_node).next = current;
                (*current).prev = new_node;
                if let Some(prev) = prev_node.as_mut() {
                    prev.next = new_node;
                } else {
                    list.head = new_node;
                }
            }
            self.node = new_node;
        }
        list.len += 1;
    }
}

impl<'a, T> Iterator for Iter<'a, T> {
    type Item = &'a T;

    fn next(&mut self) -> Option<&'a T> {
        if self.head.is_null() {
            return None;
        }
        let data = unsafe { &(*self.head).data };
        self.head = unsafe { (*self.head).next };
        Some(data)
    }
}

impl<T> Drop for LinkedList<T> {
    fn drop(&mut self) {
        while self.pop_front().is_some() {}
    }
}

// Advanced: Send and Sync implementations
// Safety: LinkedList only contains raw pointers to heap-allocated data.
// As long as T is Send, the data inside nodes can be safely transferred 
between threads.
// The list manages its own memory and pointers, so concurrent access is 
not supported,
// but sending the list itself to another thread is safe.
unsafe impl<T: Send> Send for LinkedList<T> {}
unsafe impl<T: Sync> Sync for LinkedList<T> {}
