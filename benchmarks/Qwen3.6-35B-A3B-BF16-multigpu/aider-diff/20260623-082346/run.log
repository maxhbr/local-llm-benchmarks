const M = 26;

function gcd(a, b) {
  return b === 0 ? a : gcd(b, a % b);
}

function mod(a, n) {
  return ((a % n) + n) % n;
}

function mmi(a, m) {
  for (let x = 1; x < m; x++) {
    if ((a * x) % m === 1) return x;
  }
  throw new Error('a and m must be coprime.');
}

export const encode = (phrase, key) => {
  const { a, b } = key;
  if (gcd(a, M) !== 1) {
    throw new Error('a and m must be coprime.');
  }

  const cleaned = phrase.toLowerCase().replace(/[^a-z0-9]/g, '');
  let encrypted = '';
  for (let i = 0; i < cleaned.length; i++) {
    const char = cleaned[i];
    if (/\d/.test(char)) {
      encrypted += char;
    } else {
      const x = char.charCodeAt(0) - 97;
      const y = mod(a * x + b, M);
      encrypted += String.fromCharCode(y + 97);
    }
  }

  const chunks = encrypted.match(/.{1,5}/g) || [];
  return chunks.join(' ');
};

export const decode = (phrase, key) => {
  const { a, b } = key;
  if (gcd(a, M) !== 1) {
    throw new Error('a and m must be coprime.');
  }

  const cleaned = phrase.toLowerCase().replace(/[^a-z0-9]/g, '');
  const aInv = mmi(a, M);
  let decrypted = '';
  for (let i = 0; i < cleaned.length; i++) {
    const char = cleaned[i];
    if (/\d/.test(char)) {
      decrypted += char;
    } else {
      const y = char.charCodeAt(0) - 97;
      const x = mod(aInv * (y - b), M);
      decrypted += String.fromCharCode(x + 97);
    }
  }
  return decrypted;
};
