            } else { // nl-NL
                if (change < 0) {
                    amount = curSymb + " -" + formattedAmount;
                } else {
                    amount = curSymb + " " + formattedAmount;
                }
            }

            sb.append("\n");
            sb.append(String.format("%s | %-25s | %13s", date, desc, amount));
        }

        return sb.toString();
    }
