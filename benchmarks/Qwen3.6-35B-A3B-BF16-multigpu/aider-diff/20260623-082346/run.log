export class List {
  constructor(items = []) {
    this._items = items;
  }

  append(list2) {
    for (let i = 0; i < list2._items.length; i++) {
      this._items[this._items.length] = list2._items[i];
    }
    return this;
  }

  concat(listOfLists) {
    for (let i = 0; i < listOfLists._items.length; i++) {
      const innerList = listOfLists._items[i];
      for (let j = 0; j < innerList._items.length; j++) {
        this._items[this._items.length] = innerList._items[j];
      }
    }
    return this;
  }

  filter(predicate) {
    const result = new List();
    for (let i = 0; i < this._items.length; i++) {
      if (predicate(this._items[i])) {
        result._items[result._items.length] = this._items[i];
      }
    }
    return result;
  }

  map(fn) {
    const result = new List();
    for (let i = 0; i < this._items.length; i++) {
      result._items[result._items.length] = fn(this._items[i]);
    }
    return result;
  }

  length() {
    return this._items.length;
  }

  foldl(fn, initial) {
    let acc = initial;
    for (let i = 0; i < this._items.length; i++) {
      acc = fn(acc, this._items[i]);
    }
    return acc;
  }

  foldr(fn, initial) {
    let acc = initial;
    for (let i = this._items.length - 1; i >= 0; i--) {
      acc = fn(acc, this._items[i]);
    }
    return acc;
  }

  reverse() {
    const result = new List();
    for (let i = this._items.length - 1; i >= 0; i--) {
      result._items[result._items.length] = this._items[i];
    }
    return result;
  }
}
