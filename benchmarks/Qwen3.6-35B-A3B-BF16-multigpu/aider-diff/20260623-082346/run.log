from collections import deque

class StackUnderflowError(Exception):
    def __init__(self, message="Insufficient number of items in stack"):
        self.message = message
        super().__init__(self.message)


def evaluate(input_data):
    stack = []
    definitions = {}
    
    tokens = deque()
    for line in input_data:
        tokens.extend(line.lower().split())
        
    while tokens:
        token = tokens.popleft()
        
        if token == ':':
            if not tokens:
                raise ValueError("undefined operation")
            word_name = tokens.popleft()
            def_tokens = []
            while tokens and tokens[0] != ';':
                def_tokens.append(tokens.popleft())
            if not tokens:
                raise ValueError("undefined operation")
            tokens.popleft() # skip ;
            definitions[word_name] = def_tokens
            
        elif token in definitions:
            for t in reversed(definitions[token]):
                tokens.appendleft(t)
                
        elif token.lstrip('-').isdigit():
            stack.append(int(token))
            
        elif token == '+':
            if len(stack) < 2: raise StackUnderflowError("Insufficient 
number of items in stack")
            stack.append(stack.pop() + stack.pop())
        elif token == '-':
            if len(stack) < 2: raise StackUnderflowError("Insufficient 
number of items in stack")
            b, a = stack.pop(), stack.pop()
            stack.append(a - b)
        elif token == '*':
            if len(stack) < 2: raise StackUnderflowError("Insufficient 
number of items in stack")
            stack.append(stack.pop() * stack.pop())
        elif token == '/':
            if len(stack) < 2: raise StackUnderflowError("Insufficient 
number of items in stack")
            b, a = stack.pop(), stack.pop()
            if b == 0: raise ZeroDivisionError("divide by zero")
            stack.append(int(a / b))
        elif token == 'dup':
            if len(stack) < 1: raise StackUnderflowError("Insufficient 
number of items in stack")
            stack.append(stack[-1])
        elif token == 'drop':
            if len(stack) < 1: raise StackUnderflowError("Insufficient 
number of items in stack")
            stack.pop()
        elif token == 'swap':
            if len(stack) < 2: raise StackUnderflowError("Insufficient 
number of items in stack")
            stack[-1], stack[-2] = stack[-2], stack[-1]
        elif token == 'over':
            if len(stack) < 2: raise StackUnderflowError("Insufficient 
number of items in stack")
            stack.append(stack[-2])
        else:
            raise ValueError("undefined operation")
            
    return stack
```

