      prefix = 'megaohms';
      displayValue = value / 1_000_000;
    } else if (value >= 1_000) {
      prefix = 'kiloohms';
      displayValue = value / 1_000;
    }

    return `Resistor value: ${displayValue} ${prefix}`;
