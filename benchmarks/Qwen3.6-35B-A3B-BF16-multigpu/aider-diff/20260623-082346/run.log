            for (int i = 0; i < dollarsStr.length(); i++) {
                if (i > 0 && (dollarsStr.length() - i) % 3 == 0) {
                    dollarsSb.append(thSep);
                }
                dollarsSb.append(dollarsStr.charAt(i));
            }
            String formattedAmount = dollarsSb.toString() + decSep + String.format("%02d", cents);

            String amount;
