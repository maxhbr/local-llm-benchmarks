```java
import java.util.Random;
import java.util.Stack;

public class MazeGenerator {

    public char[][] generatePerfectMaze(int rows, int columns) {
        return generatePerfectMaze(rows, columns, -1);
    }

    public char[][] generatePerfectMaze(int rows, int columns, int seed) {
        Random rand = (seed == -1) ? new Random() : new Random(seed);
        int height = 2 * rows + 1;
        int width = 2 * columns + 1;
        char[][] maze = new char[height][width];

        // Initialize with spaces
        for (int r = 0; r < height; r++) {
            for (int c = 0; c < width; c++) {
                maze[r][c] = ' ';
            }
        }

        // Draw outer walls
        for (int c = 1; c < width - 1; c++) {
            maze[0][c] = 'ŌöĆ';
            maze[height - 1][c] = 'ŌöĆ';
        }
        for (int r = 1; r < height - 1; r++) {
            maze[r][0] = 'Ōöé';
            maze[r][width - 1] = 'Ōöé';
        }
        maze[0][0] = 'Ōöī'; maze[0][width - 1] = 'ŌöÉ';
        maze[height - 1][0] = 'Ōöö'; maze[height - 1][width - 1] = 'Ōöś';

        // Internal walls
        for (int r = 0; r < rows; r++) {
            for (int c = 1; c < columns; c++) {
                maze[2 * r + 1][2 * c] = 'Ōöé';
            }
        }
        for (int r = 1; r < rows; r++) {
            for (int c = 0; c < columns; c++) {
                maze[2 * r][2 * c + 1] = 'ŌöĆ';
            }
        }

        // Carve maze using iterative DFS
        boolean[][] visited = new boolean[rows][columns];
        Stack<int[]> stack = new Stack<>();
        stack.push(new int[]{0, 0});
        visited[0][0] = true;

        int[] dr = {-1, 1, 0, 0};
        int[] dc = {0, 0, -1, 1};

        while (!stack.isEmpty()) {
            int[] current = stack.peek();
            int r = current[0];
            int c = current[1];

            // Find unvisited neighbors
            int[] neighbors = new int[4];
            int count = 0;
            for (int i = 0; i < 4; i++) {
                int nr = r + dr[i];
                int nc = c + dc[i];
                if (nr >= 0 && nr < rows && nc >= 0 && nc < columns && !visited[nr][nc]) {
                    neighbors[count++] = i;
                }
            }

            if (count > 0) {
                int dir = neighbors[rand.nextInt(count)];
                int nr = r + dr[dir];
                int nc = c + dc[dir];

                // Remove wall
                if (dir == 0) { // up
                    maze[2 * r][2 * c + 1] = ' ';
                } else if (dir == 1) { // down
                    maze[2 * r + 2][2 * c + 1] = ' ';
                } else if (dir == 2) { // left
                    maze[2 * r + 1][2 * c] = ' ';
                } else { // right
                    maze[2 * r + 1][2 * c + 2] = ' ';
                }

                visited[nr][nc] = true;
                stack.push(new int[]{nr, nc});
            } else {
                stack.pop();
            }
        }

        // Place entrance and exit
        maze[rows][0] = 'Ōć©';
        maze[rows][width - 1] = 'Ōć©';

        return maze;
    }
}
```

