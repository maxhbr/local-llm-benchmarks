```rust
pub fn encode(n: u64) -> String {
    if n == 0 {
        return "zero".to_string();
    }

    let scales = ["", "thousand", "million", "billion", "trillion", "quadrillion", "quintillion"];
    let mut chunks = Vec::new();
    let mut temp = n;
    let mut scale_idx = 0;

    while temp > 0 {
        let chunk = temp % 1000;
        if chunk > 0 {
            let mut chunk_str = encode_chunk(chunk);
            if !scales[scale_idx].is_empty() {
                chunk_str.push_str(" ");
                chunk_str.push_str(scales[scale_idx]);
            }
            chunks.push(chunk_str);
        }
        temp /= 1000;
        scale_idx += 1;
    }

    chunks.reverse();
    chunks.join(" ")
}

fn encode_chunk(n: u64) -> String {
    // n is 1..999
    let mut parts = Vec::new();
    if n >= 100 {
        parts.push(encode_small(n / 100));
        parts.push("hundred");
        n %= 100;
    }
    if n > 0 {
        parts.push(encode_small(n));
    }
    parts.join(" ")
}

fn encode_small(n: u64) -> String {
    if n < 20 {
        let ones = ["", "one", "two", "three", "four", "five", "six", "seven", "eight", "nine",
                    "ten", "eleven", "twelve", "thirteen", "fourteen", "fifteen", "sixteen", 
"seventeen", "eighteen", "nineteen"];
        ones[n as usize].to_string()
    } else {
        let tens = ["", "", "twenty", "thirty", "forty", "fifty", "sixty", "seventy", "eighty", 
"ninety"];
        let t = n / 10;
        let o = n % 10;
        if o == 0 {
            tens[t as usize].to_string()
        } else {
            format!("{}-{}", tens[t as usize], encode_small(o))
        }
    }
}
```

