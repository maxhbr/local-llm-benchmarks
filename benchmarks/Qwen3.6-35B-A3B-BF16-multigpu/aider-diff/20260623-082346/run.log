Let's draft the implementation:
```cpp
#include "crypto_square.h"
#include <string>
#include <vector>
#include <cmath>
#include <cctype>
#include <algorithm>

namespace crypto_square {

std::string ciphertext(const std::string& plaintext) {
    std::string normalized;
    for (char c : plaintext) {
        if (std::isalnum(static_cast<unsigned char>(c))) {
            normalized += std::tolower(static_cast<unsigned char>(c));
        }
    }

    if (normalized.empty()) {
        return "";
    }

    size_t len = normalized.length();
    size_t c = std::ceil(std::sqrt(len));
    size_t r = std::ceil(static_cast<double>(len) / c);

    std::string padded = normalized;
    padded.resize(r * c, ' ');

    std::vector<std::string> chunks(c, std::string(r, ' '));
    for (size_t i = 0; i < len; ++i) {
        chunks[i % c][i / c] = padded[i];
    }

    std::string result;
    for (size_t i = 0; i < c; ++i) {
        if (i > 0) result += ' ';
        result += chunks[i];
    }

    return result;
}

}  // namespace crypto_square
```

Wait, `chunks[i % c][i / c]` works because `i` goes from `0` to `len-1`.
`i % c` is the column index.
`i / c` is the row index.
So `chunks[col][row] = padded[i]`.
This correctly fills column by column? Wait, we are reading down columns.
The rectangle is filled row by row from `padded`.
`padded` indices: `0..c-1` is row 0, `c..2c-1` is row 1, etc.
So `padded[row * c + col]` corresponds to `row = i / c`, `col = i % c`.
When we read down columns, we want `chunks[col][row]`.
So `chunks[i % c][i / c] = padded[i]` is correct.

