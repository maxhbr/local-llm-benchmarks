```rust
pub fn answer(command: &str) -> Option<i32> {
    let command = command.trim();
    let body = command.strip_prefix("What is ").and_then(|s| s.strip_suffix('?'))?;
    
    let body = body
        .replace("multiplied by", "multiplied_by")
        .replace("divided by", "divided_by")
        .replace("raised to the", "raised_to_the")
        .replace(" power", "");
        
    let mut tokens = body.split_whitespace().collect::<Vec<&str>>();
    if tokens.is_empty() {
        return None;
    }
    
    let mut result: i32 = parse_num(tokens.remove(0))?;
    
    while !tokens.is_empty() {
        let op = tokens.remove(0);
        let num: i32 = parse_num(tokens.remove(0))?;
        
        match op {
            "plus" => result = result.checked_add(num)?,
            "minus" => result = result.checked_sub(num)?,
            "multiplied_by" => result = result.checked_mul(num)?,
            "divided_by" => result = result.checked_div(num)?,
            #[cfg(feature = "exponentials")]
            "raised_to_the" => result = result.checked_pow(num as u32)?,
            _ => return None,
        }
    }
    
    Some(result)
}

fn parse_num(s: &str) -> Option<i32> {
    s.trim_end_matches(|c: char| c.is_ascii_alphabetic()).parse().ok()
}
```

