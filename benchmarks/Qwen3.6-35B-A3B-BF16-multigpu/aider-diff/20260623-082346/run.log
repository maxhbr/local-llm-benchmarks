Wait, the instructions say:
`"balance": "<(total owed by other users) - (total owed to other users)>"`
So `balance` = `Object.values(owed_by).reduce((a,b)=>a+b, 0) - Object.values(owes).reduce((a,b)=>a+b, 0)`

Let's implement helper functions or methods inside the class.

```javascript
export class RestAPI {
  constructor(db = {}) {
    this.db = db;
  }

  getUser(name) {
    if (!this.db[name]) {
      this.db[name] = { name, owes: {}, owed_by: {}, balance: 0 };
    }
    return this.db[name];
  }

  calculateBalance(user) {
    const owedByTotal = Object.values(user.owed_by).reduce((sum, val) => sum + val, 0);
    const owesTotal = Object.values(user.owes).reduce((sum, val) => sum + val, 0);
    user.balance = owedByTotal - owesTotal;
    return user;
  }

  get(url) {
    const [path, queryString] = url.split('?');
    let users = Object.values(this.db);
    
    if (path === '/users') {
      if (queryString) {
        const params = new URLSearchParams(queryString);
        const requestedUsers = params.get('users')?.split(',') || [];
        users = users.filter(u => requestedUsers.includes(u.name));
      }
      users.sort((a, b) => a.name.localeCompare(b.name));
      return JSON.stringify({ users });
    }
    return JSON.stringify({});
  }

  post(url, payload) {
    const data = JSON.parse(payload);
    const [path] = url.split('?');

    if (path === '/add') {
      const user = this.getUser(data.user);
      return JSON.stringify(user);
    }

    if (path === '/iou') {
      const { lender, borrower, amount } = data;
      const lenderUser = this.getUser(lender);
      const borrowerUser = this.getUser(borrower);

      // Update owed_by for lender
      lenderUser.owed_by[borrower] = (lenderUser.owed_by[borrower] || 0) + amount;
      // Update owes for borrower
      borrowerUser.owes[lender] = (borrowerUser.owes[lender] || 0) + amount;

      // Net out
      const lenderOwesBorrower = lenderUser.owed_by[borrower] || 0;
      const borrowerOwesLender = borrowerUser.owes[lender] || 0;

      if (lenderOwesBorrower > borrowerOwesLender) {
        lenderUser.owed_by[borrower] = lenderOwesBorrower - borrowerOwesLender;
        delete borrowerUser.owes[lender];
      } else if (borrowerOwesLender > lenderOwesBorrower) {
        borrowerUser.owes[lender] = borrowerOwesLender - lenderOwesBorrower;
        delete lenderUser.owed_by[borrower];
      } else {
        delete lenderUser.owed_by[borrower];
        delete borrowerUser.owes[lender];
      }

      this.calculateBalance(lenderUser);
      this.calculateBalance(borrowerUser);

      const updatedUsers = [lenderUser, borrowerUser].sort((a, b) => a.name.localeCompare(b.name));
      return JSON.stringify({ users: updatedUsers });
    }

    return JSON.stringify({});
  }
}
```

