```java
public class AffineCipher {
    private static final int M = 26;

    public String encode(String text, int coefficient1, int coefficient2)
{
        if (!isCoprime(coefficient1, M)) {
            throw new IllegalArgumentException("Error: a and m must be 
coprime.");
        }
        StringBuilder cleaned = new StringBuilder();
        for (char c : text.toLowerCase().toCharArray()) {
            if (Character.isLetterOrDigit(c)) {
                cleaned.append(c);
            }
        }

        StringBuilder result = new StringBuilder();
        for (int i = 0; i < cleaned.length(); i++) {
            char c = cleaned.charAt(i);
            if (Character.isDigit(c)) {
                result.append(c);
            } else {
                int x = c - 'a';
                int encrypted = (coefficient1 * x + coefficient2) % M;
                // Handle negative modulo just in case, though 
coefficients are usually positive
                encrypted = (encrypted + M) % M;
                result.append((char) (encrypted + 'a'));
            }
            // Add space every 5 characters
            if ((i + 1) % 5 == 0 && i + 1 < cleaned.length()) {
                result.append(' ');
            }
        }
        return result.toString();
    }

    public String decode(String text, int coefficient1, int coefficient2)
{
        if (!isCoprime(coefficient1, M)) {
            throw new IllegalArgumentException("Error: a and m must be 
coprime.");
        }
        int aInv = modInverse(coefficient1, M);
        StringBuilder cleaned = new StringBuilder();
        for (char c : text.toLowerCase().toCharArray()) {
            if (Character.isLetterOrDigit(c)) {
                cleaned.append(c);
            }
        }

        StringBuilder result = new StringBuilder();
        for (int i = 0; i < cleaned.length(); i++) {
            char c = cleaned.charAt(i);
            if (Character.isDigit(c)) {
                result.append(c);
            } else {
                int y = c - 'a';
                int decrypted = (aInv * (y - coefficient2)) % M;
                decrypted = (decrypted + M) % M;
                result.append((char) (decrypted + 'a'));
            }
        }
        return result.toString();
    }

    private boolean isCoprime(int a, int m) {
        return gcd(a, m) == 1;
    }

    private int gcd(int a, int b) {
        while (b != 0) {
            int temp = b;
            b = a % b;
            a = temp;
        }
        return a;
    }

    private int modInverse(int a, int m) {
        a = (a % m + m) % m;
        for (int x = 1; x < m; x++) {
            if ((a * x) % m == 1) {
                return x;
            }
        }
        throw new IllegalArgumentException("Modular inverse does not 
exist.");
    }
}
```

