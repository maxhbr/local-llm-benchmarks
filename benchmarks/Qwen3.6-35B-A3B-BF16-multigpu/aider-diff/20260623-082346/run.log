#include "allergies.h"

namespace allergies {

static const std::string ALLERGENS[] = {
    "eggs", "peanuts", "shellfish", "strawberries",
    "tomatoes", "chocolate", "pollen", "cats"
};

allergies::allergies(unsigned int score) : score_(score) {
    for (int i = 0; i < 8; ++i) {
        if (score_ & (1u << i)) {
            allergies_list_.emplace(ALLERGENS[i]);
        }
    }
}

bool allergies::is_allergic_to(const std::string& item) const {
    return allergies_list_.find(item) != allergies_list_.end();
}

std::unordered_set<std::string> allergies::get_allergies() const {
    return allergies_list_;
}

}  // namespace allergies
