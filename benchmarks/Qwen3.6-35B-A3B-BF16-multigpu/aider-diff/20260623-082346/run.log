export function count(diagram) {
  if (!diagram || diagram.length === 0) return 0;
  
  const rows = diagram.length;
  const cols = diagram[0].length;
  let rectangleCount = 0;
  
  for (let r1 = 0; r1 < rows; r1++) {
    for (let c1 = 0; c1 < cols; c1++) {
      if (diagram[r1][c1] === '+') {
        for (let r2 = r1 + 1; r2 < rows; r2++) {
          for (let c2 = c1 + 1; c2 < cols; c2++) {
            if (diagram[r2][c2] === '+' && 
                diagram[r1][c2] === '+' && 
                diagram[r2][c1] === '+') {
              
              // Check horizontal edges
              let valid = true;
              for (let k = c1 + 1; k < c2; k++) {
                if (diagram[r1][k] !== '-' && diagram[r1][k] !== '+') {
                  valid = false;
                  break;
                }
                if (diagram[r2][k] !== '-' && diagram[r2][k] !== '+') {
                  valid = false;
                  break;
                }
              }
              if (!valid) continue;
              
              // Check vertical edges
              for (let k = r1 + 1; k < r2; k++) {
                if (diagram[k][c1] !== '|' && diagram[k][c1] !== '+') {
                  valid = false;
                  break;
                }
                if (diagram[k][c2] !== '|' && diagram[k][c2] !== '+') {
                  valid = false;
                  break;
                }
              }
              
              if (valid) {
                rectangleCount++;
              }
            }
          }
        }
      }
    }
  }
  
  return rectangleCount;
}
