package poker

import (
        "errors"
        "sort"
        "strings"
)

type Card struct {
        Rank int
        Suit rune
}

func BestHand(hands []string) ([]string, error) {
        if len(hands) == 0 {
                return nil, errors.New("hands cannot be empty")
        }

        type Hand struct {
                Original string
                Score    []int
        }

        var evaluated []Hand
        for _, h := range hands {
                score, err := evaluateHand(h)
                if err != nil {
                        return nil, err
                }
                evaluated = append(evaluated, Hand{Original: h, Score: score})
        }

        // Find max score
        maxIdx := 0
        for i := 1; i < len(evaluated); i++ {
                if compareScores(evaluated[i].Score, evaluated[maxIdx].Score) > 0 {
                        maxIdx = i
                }
        }

        var best []string
        for _, h := range evaluated {
                if compareScores(h.Score, evaluated[maxIdx].Score) == 0 {
                        best = append(best, h.Original)
                }
        }
        return best, nil
}

func compareScores(a, b []int) int {
        for i := 0; i < len(a); i++ {
                if a[i] > b[i] {
                        return 1
                }
                if a[i] < b[i] {
                        return -1
                }
        }
        return 0
}

func evaluateHand(s string) ([]int, error) {
        parts := strings.Split(s, " ")
        if len(parts) != 5 {
                return nil, errors.New("invalid hand")
        }

        cards := make([]Card, 5)
        for i, p := range parts {
                r, suit, err := parseCard(p)
                if err != nil {
                        return nil, err
                }
                cards[i] = Card{Rank: r, Suit: suit}
        }

        // Sort cards by rank descending
        sort.Slice(cards, func(i, j int) bool {
                return cards[i].Rank > cards[j].Rank
        })

        isFlush := cards[0].Suit == cards[1].Suit && cards[1].Suit == cards[2].Suit && cards[2].Suit == cards[3].Suit && cards[3].Suit 
== cards[4].Suit

        isStraight := true
        for i := 1; i < 5; i++ {
                if cards[i].Rank != cards[i-1].Rank-1 {
                        isStraight = false
                        break
                }
        }
        wheelStraight := false
        if !isStraight && cards[0].Rank == 14 && cards[1].Rank == 5 && cards[2].Rank == 4 && cards[3].Rank == 3 && cards[4].Rank == 2 {
                isStraight = true
                wheelStraight = true
        }

        counts := make(map[int]int)
        for _, c := range cards {
                counts[c.Rank]++
        }

        type rankCount struct {
                rank  int
                count int
        }
        var rc []rankCount
        for r, c := range counts {
                rc = append(rc, rankCount{r, c})
        }
        sort.Slice(rc, func(i, j int) bool {
                if rc[i].count != rc[j].count {
                        return rc[i].count > rc[j].count
                }
                return rc[i].rank > rc[j].rank
        })

        score := make([]int, 6)
        switch {
        case isStraight && isFlush:
                score[0] = 8
                score[1] = cards[0].Rank
                if wheelStraight {
                        score[1] = 5
                }
        case rc[0].count == 4:
                score[0] = 7
                score[1] = rc[0].rank
                score[2] = rc[1].rank
        case rc[0].count == 3 && rc[1].count == 2:
                score[0] = 6
                score[1] = rc[0].rank
                score[2] = rc[1].rank
        case isFlush:
                score[0] = 5
                for i := 0; i < 5; i++ {
                        score[i+1] = cards[i].Rank
                }
        case isStraight:
                score[0] = 4
                score[1] = cards[0].Rank
                if wheelStraight {
                        score[1] = 5
                }
        case rc[0].count == 3:
                score[0] = 3
                score[1] = rc[0].rank
                score[2] = rc[1].rank
                score[3] = rc[2].rank
        case rc[0].count == 2 && rc[1].count == 2:
                score[0] = 2
                score[1] = rc[0].rank
                score[2] = rc[1].rank
                score[3] = rc[2].rank
        case rc[0].count == 2:
                score[0] = 1
                score[1] = rc[0].rank
                score[2] = rc[1].rank
                score[3] = rc[2].rank
                score[4] = rc[3].rank
        default:
                score[0] = 0
                for i := 0; i < 5; i++ {
                        score[i+1] = cards[i].Rank
                }
        }

        return score, nil
}

func parseCard(s string) (int, rune, error) {
        suit := rune(s[len(s)-1])
        rankStr := s[:len(s)-1]
        switch rankStr {
        case "2":
                return 2, suit, nil
        case "3":
                return 3, suit, nil
        case "4":
                return 4, suit, nil
        case "5":
                return 5, suit, nil
        case "6":
                return 6, suit, nil
        case "7":
                return 7, suit, nil
        case "8":
                return 8, suit, nil
        case "9":
                return 9, suit, nil
        case "10":
                return 10, suit, nil
        case "J":
                return 11, suit, nil
        case "Q":
                return 12, suit, nil
        case "K":
                return 13, suit, nil
        case "A":
                return 14, suit, nil
        default:
                return 0, 0, errors.New("invalid card")
        }
}
