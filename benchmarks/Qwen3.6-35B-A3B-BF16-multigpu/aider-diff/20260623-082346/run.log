```rust
const SHARPS: &[&str] = &["A", "A#", "B", "C", "C#", "D", "D#", "E", "F", "F#", "G", "G#"];
const FLATS: &[&str] = &["A", "Bb", "B", "C", "Db", "D", "Eb", "E", "F", "Gb", "G", "Ab"];

#[derive(Debug)]
pub struct Error;

pub struct Scale {
    notes: Vec<String>,
}

impl Scale {
    pub fn new(tonic: &str, intervals: &str) -> Result<Scale, Error> {
        let use_flats = tonic.contains('b') || tonic == "F";
        let chromatic = if use_flats { FLATS } else { SHARPS };
        
        let tonic_idx = chromatic.iter().position(|&n| n == tonic);
        let tonic_idx = tonic_idx.ok_or(Error)?;
        
        let mut notes = Vec::new();
        let mut current_idx = tonic_idx;
        notes.push(chromatic[current_idx].to_string());
        
        for interval in intervals.chars() {
            let steps = match interval {
                'm' => 1,
                'M' => 2,
                'A' => 3,
                _ => return Err(Error),
            };
            current_idx = (current_idx + steps) % 12;
            notes.push(chromatic[current_idx].to_string());
        }
        
        Ok(Scale { notes })
    }

    pub fn chromatic(tonic: &str) -> Result<Scale, Error> {
        Self::new(tonic, "mmmmmmmmmmm")
    }

    pub fn enumerate(&self) -> Vec<String> {
        self.notes.clone()
    }
}
```

