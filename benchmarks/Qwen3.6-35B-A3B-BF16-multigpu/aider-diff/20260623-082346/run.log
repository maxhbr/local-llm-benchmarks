    pub fn new(tonic: &str, intervals: &str) -> Result<Scale, Error> {
        let tonic_lower = tonic.to_lowercase();
        let use_flats = tonic_lower.contains('b') || tonic_lower == "f";
        let chromatic = if use_flats { FLATS } else { SHARPS };
        
        let tonic_idx = chromatic.iter().position(|&n| n.eq_ignore_ascii_case(tonic));
