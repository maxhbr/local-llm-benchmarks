import java.util.Map;
import java.util.Optional;
import java.util.Set;
import java.util.HashMap;

class WordSearcher {
    Map<String, Optional<WordLocation>> search(final Set<String> words, final char[][] grid) {
        Map<String, Optional<WordLocation>> results = new HashMap<>();
        
        for (String word : words) {
            Optional<WordLocation> location = findWord(word, grid);
            results.put(word, location);
        }
        
        return results;
    }
    
    private Optional<WordLocation> findWord(String word, char[][] grid) {
        if (word.isEmpty() || grid == null || grid.length == 0 || grid[0].length == 0) {
            return Optional.empty();
        }
        
        int rows = grid.length;
        int cols = grid[0].length;
        
        // All 8 directions: right, left, down, up, diagonal down-right, diagonal down-left, diagonal up-right, diagonal up-left
        int[][] directions = {
            {0, 1},   // right
            {0, -1},  // left
            {1, 0},   // down
            {-1, 0},  // up
            {1, 1},   // diagonal down-right
            {1, -1},  // diagonal down-left
            {-1, 1},  // diagonal up-right
            {-1, -1}  // diagonal up-left
        };
        
        for (int row = 0; row < rows; row++) {
            for (int col = 0; col < cols; col++) {
                for (int[] dir : directions) {
                    if (matchesWord(word, grid, row, col, dir[0], dir[1])) {
                        int endRow = row + (word.length() - 1) * dir[0];
                        int endCol = col + (word.length() - 1) * dir[1];
                        // Return 1-based coordinates
                        return Optional.of(new WordLocation(row + 1, col + 1, endRow + 1, endCol + 1));
                    }
                }
            }
        }
        
        return Optional.empty();
    }
    
    private boolean matchesWord(String word, char[][] grid, int startRow, int startCol, int dRow, int dCol) {
        int rows = grid.length;
        int cols = grid[0].length;
        
        for (int i = 0; i < word.length(); i++) {
            int row = startRow + i * dRow;
            int col = startCol + i * dCol;
            
            // Check bounds
            if (row < 0 || row >= rows || col < 0 || col >= cols) {
                return false;
            }
            
            if (grid[row][col] != word.charAt(i)) {
                return false;
            }
        }
        
        return true;
    }
    
    static class WordLocation {
        private final int startRow;
        private final int startCol;
        private final int endRow;
        private final int endCol;
        
        public WordLocation(int startRow, int startCol, int endRow, int endCol) {
            this.startRow = startRow;
            this.startCol = startCol;
            this.endRow = endRow;
            this.endCol = endCol;
        }
        
        public int getStartRow() { return startRow; }
        public int getStartCol() { return startCol; }
        public int getEndRow() { return endRow; }
        public int getEndCol() { return endCol; }
    }
}
