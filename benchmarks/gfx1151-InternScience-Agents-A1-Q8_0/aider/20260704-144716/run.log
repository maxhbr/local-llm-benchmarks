Looking at the instructions, I need to implement the affine cipher with:

1. **Encryption**: E(x) = (ai + b) mod m
2. **Decryption**: D(y) = (a^-1)(y - b) mod m
3. **Validation**: a and m (26) must be coprime, otherwise throw an error
4. **Processing**: Letters are encrypted/decrypted, digits pass through unchanged, spaces/punctuation are removed
5. **Output format**: Encrypted text is grouped in chunks of 5 letters separated by spaces

Here's the complete implementation:

affine-cipher.js
```
export const encode = (phrase, key) => {
  const m = 26;
  const a = key.a;
  const b = key.b;
  
  // Check if a and m are coprime
  if (!areCoprime(a, m)) {
    throw new Error('a and m must be coprime');
  }
  
  // Process the phrase
  let result = '';
  for (const char of phrase.toLowerCase()) {
    if (char >= 'a' && char <= 'z') {
      const i = char.charCodeAt(0) - 'a'.charCodeAt(0);
      const encryptedIndex = (a * i + b) % m;
      result += String.fromCharCode(encryptedIndex + 'a'.charCodeAt(0));
    } else if (char >= '0' && char <= '9') {
      result += char;
    }
    // Ignore spaces and punctuation
  }
  
  // Group into chunks of 5
  const grouped = [];
  for (let i = 0; i < result.length; i += 5) {
    grouped.push(result.slice(i, i + 5));
  }
  
  return grouped.join(' ');
};

export const decode = (phrase, key) => {
  const m = 26;
  const a = key.a;
  const b = key.b;
  
  // Check if a and m are coprime
  if (!areCoprime(a, m)) {
    throw new Error('a and m must be coprime');
  }
  
  // Find modular multiplicative inverse of a
  const aInv = findMMI(a, m);
  
  // Process the phrase
  let result = '';
  for (const char of phrase.toLowerCase()) {
    if (char >= 'a' && char <= 'z') {
      const y = char.charCodeAt(0) - 'a'.charCodeAt(0);
      const decryptedIndex = (aInv * (y - b)) % m;
      // Handle negative modulo
      const finalIndex = (decryptedIndex + m) % m;
      result += String.fromCharCode(finalIndex + 'a'.charCodeAt(0));
    } else if (char >= '0' && char <= '9') {
      result += char;
    }
    // Ignore spaces and punctuation
  }
  
  return result;
};

function areCoprime(a, b) {
  // Euclidean algorithm to find GCD
  while (b !== 0) {
    const temp = b;
    b = a % b;
    a = temp;
  }
  return a === 1;
}

function findMMI(a, m) {
  // Find x such that (a * x) % m = 1
  for (let x = 1; x < m; x++) {
    if ((a * x) % m === 1) {
      return x;
    }
  }
  throw new Error('No modular multiplicative inverse found');
}
