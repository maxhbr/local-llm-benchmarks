              return None
          new_path = [{'dir': 'left', 'sibling': self.focus['right'], 'value': self.focus['value']}] + self.path
          return Zipper(self.focus['left'], new_path)

      def set_left(self, node):
          new_focus = {**self.focus, 'left': node}
          return Zipper(new_focus, self.path)

      def right(self):
          if self.focus.get('right') is None:
              return None
          new_path = [{'dir': 'right', 'sibling': self.focus['left'], 'value': self.focus['value']}] + self.path
          return Zipper(self.focus['right'], new_path)

      def set_right(self, node):
          new_focus = {**self.focus, 'right': node}
          return Zipper(new_focus, self.path)

      def up(self):
          if not self.path:
              return None
          step = self.path[0]
          rest_path = self.path[1:]
          if step['dir'] == 'left':
              new_focus = {'value': step['value'], 'left': self.focus, 'right': step['sibling']}
          else:
              new_focus = {'value': step['value'], 'left': step['sibling'], 'right': self.focus}
          return Zipper(new_focus, rest_path)

      def to_tree(self):
          z = self
          while z.path:
              z = z.up()
          return z.focus
