      } else {
        line += '.';
      }
      lines.push(line);
    }

    lines.push("I don't know why she swallowed the fly. Perhaps she'll die.");
    return lines.join('\n') + '\n';
  }

  verses(start, end) {
    let result = '';
    for (let i = start; i <= end; i++) {
      result += this.verse(i) + '\n';
    }
    return result;
  }
}
