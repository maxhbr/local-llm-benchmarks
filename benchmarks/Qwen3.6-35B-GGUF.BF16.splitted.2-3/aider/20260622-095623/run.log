```python
def can_chain(dominoes):
    if not dominoes:
        return []
    
    # We can fix the first domino to reduce search space, 
    # but we must try both orientations.
    # Actually, just starting DFS with the first domino is fine.
    
    def dfs(chain, remaining):
        if not remaining:
            if chain[0][0] == chain[-1][1]:
                return chain
            return None
            
        last_val = chain[-1][1]
        for i, (a, b) in enumerate(remaining):
            # Try orientation (a, b)
            if a == last_val:
                res = dfs(chain + [(a, b)], remaining[:i] + remaining[i+1:])
                if res:
                    return res
            # Try orientation (b, a)
            if b == last_val:
                res = dfs(chain + [(b, a)], remaining[:i] + remaining[i+1:])
                if res:
                    return res
        return None

    # Start with the first domino in both orientations
    first = dominoes[0]
    # Try first as is
    res = dfs([first], dominoes[1:])
    if res:
        return res
    # Try first flipped
    if first[0] != first[1]:
        res = dfs([(first[1], first[0])], dominoes[1:])
        if res:
            return res
            
    return None
```

