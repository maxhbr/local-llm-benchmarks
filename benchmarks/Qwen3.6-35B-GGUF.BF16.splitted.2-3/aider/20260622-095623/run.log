Let's rewrite `grep.py` carefully.

```python
def grep(pattern, flags, files):
    flag_list = flags.split() if flags else []
    flag_n = '-n' in flag_list
    flag_l = '-l' in flag_list
    flag_i = '-i' in flag_list
    flag_v = '-v' in flag_list
    flag_x = '-x' in flag_list
    
    multiple_files = len(files) > 1
    results = []
    
    for filepath in files:
        with open(filepath, 'r') as f:
            for line_num, line in enumerate(f, 1):
                line_content = line.rstrip('\r\n')
                
                search_line = line_content.lower() if flag_i else line_content
                search_pattern = pattern.lower() if flag_i else pattern
                
                if flag_x:
                    match = (search_line == search_pattern)
                else:
                    match = (search_pattern in search_line)
                    
                if flag_v:
                    match = not match
                    
                if match:
                    if flag_l:
                        results.append(filepath + "\n")
                        break
                    else:
                        parts = []
                        if multiple_files:
                            parts.append(filepath)
                        if flag_n:
                            parts.append(str(line_num))
                        parts.append(line_content)
                        results.append(":".join(parts) + "\n")
                        
