```javascript
export class Scale {
  constructor(tonic) {
    this.tonic = tonic;
    this.useFlats = ['F', 'Bb', 'Eb', 'Ab', 'Db', 'Gb', 'd', 'g', 'c', 'f', 'bb', 'eb'].includes(tonic);
    this.sharps = ['A', 'A#', 'B', 'C', 'C#', 'D', 'D#', 'E', 'F', 'F#', 'G', 'G#'];
    this.flats = ['A', 'Bb', 'B', 'C', 'Db', 'D', 'Eb', 'E', 'F', 'Gb', 'G', 'Ab'];
  }

  chromatic() {
    const scale = this.useFlats ? this.flats : this.sharps;
    const idx = scale.findIndex(note => note.toLowerCase() === this.tonic.toLowerCase());
    return [...scale.slice(idx), ...scale.slice(0, idx)];
  }

  interval(intervals) {
    const chromatic = this.chromatic();
    const notes = [chromatic[0]];
    let idx = 0;
    for (const step of intervals) {
      if (step === 'm') idx = (idx + 1) % 12;
      else if (step === 'M') idx = (idx + 2) % 12;
      else if (step === 'A') idx = (idx + 3) % 12;
      notes.push(chromatic[idx]);
    }
    return notes;
  }
}
```

