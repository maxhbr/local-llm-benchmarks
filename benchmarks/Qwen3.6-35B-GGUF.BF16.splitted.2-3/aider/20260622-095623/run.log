const pattern = args[0];
const files = [];
const flags = {
  n: false,
  l: false,
  i: false,
  v: false,
  x: false,
};

for (let i = 1; i < args.length; i++) {
  if (args[i].startsWith('-')) {
    const flagStr = args[i].slice(1);
    for (let j = 0; j < flagStr.length; j++) {
      if (VALID_OPTIONS.includes(flagStr[j])) {
        flags[flagStr[j]] = true;
      }
    }
  } else {
    files.push(args[i]);
  }
}

const multipleFiles = files.length > 1;

for (const file of files) {
  const lines = readLines(file);
  let found = false;

  for (let i = 0; i < lines.length; i++) {
    const line = lines[i];
    const lineNum = i + 1;

    let searchLine = line;
    let searchPattern = pattern;

    if (flags.i) {
      searchLine = searchLine.toLowerCase();
      searchPattern = searchPattern.toLowerCase();
    }

    let isMatch = false;
    if (flags.x) {
      isMatch = searchLine === searchPattern;
    } else {
      isMatch = searchLine.includes(searchPattern);
    }

    if (flags.v) {
      isMatch = !isMatch;
    }

    if (isMatch) {
      found = true;
      if (flags.l) {
        console.log(file);
        break;
      }

      let output = '';
      if (multipleFiles) {
        output += file + ':';
      }
      if (flags.n) {
        output += lineNum + ':';
      }
      output += line;
      console.log(output);
    }
  }
}
```

