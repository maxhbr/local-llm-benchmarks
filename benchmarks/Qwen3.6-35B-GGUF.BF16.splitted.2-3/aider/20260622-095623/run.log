//
// This is only a SKELETON file for the 'Forth' exercise. It's been provided as a
// convenience to get you started writing code faster.
//

export class Forth {
  constructor() {
    this._stack = [];
    this.definitions = {};
  }

  evaluate(input) {
    const tokens = input.trim().split(/\s+/).filter(t => t !== '');
    let i = 0;
    while (i < tokens.length) {
      const token = tokens[i];
      const lower = token.toLowerCase();

      if (lower === ':') {
        i++;
        if (i >= tokens.length) throw Error('Invalid definition');
        const name = tokens[i].toLowerCase();
        if (/^-?\d+$/.test(name)) throw Error('Invalid definition');
        i++;
        const def = [];
        while (i < tokens.length && tokens[i] !== ';') {
          def.push(tokens[i].toLowerCase());
          i++;
        }
        if (i >= tokens.length) throw Error('Unterminated definition');
        i++; // skip ';'
        this.definitions[name] = def;
      } else {
        this.executeToken(lower);
        i++;
      }
    }
  }

  executeToken(token) {
    if (/^-?\d+$/.test(token)) {
      this._stack.push(parseInt(token, 10));
    } else if (this.definitions[token]) {
      for (const defToken of this.definitions[token]) {
        this.executeToken(defToken);
      }
    } else if (BUILTINS[token]) {
      BUILTINS[token](this._stack);
    } else {
      throw Error(`Unknown word: ${token}`);
    }
  }

  get stack() {
    return this._stack;
  }
}

const BUILTINS = {
  '+': (s) => {
    if (s.length < 2) throw Error('Stack empty');
    const b = s.pop();
    const a = s.pop();
    s.push(a + b);
  },
  '-': (s) => {
    if (s.length < 2) throw Error('Stack empty');
