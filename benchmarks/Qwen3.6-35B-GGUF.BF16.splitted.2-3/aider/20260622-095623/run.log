    const b = s.pop();
    const a = s.pop();
    s.push(a * b);
  },
  '/': (s) => {
    if (s.length < 2) throw Error('Stack empty');
    const b = s.pop();
    const a = s.pop();
    if (b === 0) throw Error('Division by zero');
    s.push(Math.trunc(a / b));
  },
  'dup': (s) => {
    if (s.length < 1) throw Error('Stack empty');
    s.push(s[s.length - 1]);
