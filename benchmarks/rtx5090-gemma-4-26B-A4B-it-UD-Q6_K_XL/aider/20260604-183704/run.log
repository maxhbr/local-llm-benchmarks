lib.rs
```rust
pub mod graph {
    use std::collections::HashMap;

    pub struct Graph {
        pub attributes: HashMap<String, String>,
        pub nodes: HashMap<String, Node>,
        pub edges: Vec<Edge>,
    }

    pub struct Node {
        pub id: String,
        pub attributes: HashMap<String, String>,
    }

    pub struct Edge {
        pub from: String,
        pub to: String,
        pub attributes: HashMap<String, String>,
    }

    pub struct NodeBuilder {
        id: String,
        attributes: HashMap<String, String>,
    }

    impl NodeBuilder {
        pub fn new(id: &str) -> Self {
            NodeBuilder {
                id: id.to_string(),
                attributes: HashMap::new(),
            }
        }

        pub fn with_attribute(mut self, key: &str, value: &str) -> Self {
            self.attributes.insert(key.to_string(), value.to_string());
            self
        }

        pub fn build(self) -> Node {
            Node {
                id: self.id,
                attributes: self.attributes,
            }
        }
    }

    pub struct EdgeBuilder {
        from: String,
        to: String,
        attributes: HashMap<String, String>,
    }

    impl EdgeBuilder {
        pub fn new(from: &str, to: &str) -> Self {
            EdgeBuilder {
                from: from.to_string(),
                to: to.to_string(),
                attributes: HashMap::new(),
            }
        }

        pub fn with_attribute(mut self, key: &str, value: &str) -> Self {
            self.attributes.insert(key.to_string(), value.to_string());
            self
        }

        pub fn build(self) -> Edge {
            Edge {
                from: self.from,
                to: self.to,
                attributes: self.attributes,
            }
        }
    }

    impl Graph {
        pub fn new() -> Self {
            Graph {
                attributes: HashMap::new(),
                nodes: HashMap::new(),
                edges: Vec::new(),
            }
        }

        pub fn with_attribute(mut self, key: &str, value: &str) -> Self {
            self.attributes.insert(key.to_string(), value.to_string());
            self
        }

        pub fn add_node(mut self, id: &str, f: impl FnOnce(NodeBuilder) -> NodeBuilder) -> Self {
            let node = f(NodeBuilder::new(id)).build();
            self.nodes.insert(id.to_string(), node);
            self
        }

        pub fn add_edge(mut self, from: &str, to: &str, f: impl FnOnce(EdgeBuilder) -> EdgeBuilder) -> Self {
            let edge = f(EdgeBuilder::new(from, to)).build();
            self.edges.push(edge);
            self
        }
    }
}
```
