    use std::collections::HashMap;

    pub fn lowest_price(books: &[u32]) -> f64 {
        let mut counts_map = HashMap::new();
        for &book in books {
            *counts_map.entry(book).or_insert(0) += 1;
        }

        let mut counts: Vec<u32> = counts_map.values().cloned().collect();
        counts.sort_by(|a, b| b.cmp(a));

        let mut memo = HashMap::new();
        solve(counts, &mut memo)
    }

    fn solve(counts: Vec<u32>, memo: &mut HashMap<Vec<u32>, f64>) -> f64 {
        // Normalize: remove zeros and sort descending
        let mut normalized_counts: Vec<u32> = counts.into_iter().filter(|&c| c > 0).collect();
        normalized_counts.sort_by(|a, b| b.cmp(a));

        if normalized_counts.is_empty() {
            return 0.0;
        }

        if let Some(&res) = memo.get(&normalized_counts) {
            return res;
        }

        let mut min_price = f64::MAX;
        let num_different = normalized_counts.len();

        for k in 1..=num_different {
            let discount = match k {
                5 => 0.75,
                4 => 0.80,
                3 => 0.90,
                2 => 0.95,
                _ => 1.00,
            };

            let current_group_price = (k as f64) * 8.0 * discount;

            let mut next_counts = normalized_counts.clone();
            for i in 0..k {
                next_counts[i] -= 1;
            }

            let price = current_group_price + solve(next_counts, memo);
            if price < min_price {
                min_price = price;
            }
        }

        memo.insert(normalized_counts, min_price);
        min_price
    }
