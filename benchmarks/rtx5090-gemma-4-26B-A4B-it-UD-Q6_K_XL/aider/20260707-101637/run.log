    use std::collections::HashMap;

    pub fn lowest_price(books: &[u32]) -> u32 {
        let mut counts_map = HashMap::new();
        for &book in books {
            *counts_map.entry(book).or_insert(0) += 1;
        }

        let mut counts_vec: Vec<u32> = counts_map.values().cloned().collect();
        counts_vec.sort_by(|a, b| b.cmp(a));
        
        let mut counts_arr = [0u32; 5];
        for i in 0..counts_vec.len().min(5) {
            counts_arr[i] = counts_vec[i];
        }

        let mut memo = HashMap::new();
        solve(counts_arr, &mut memo)
    }

    fn group_cost(k: u32) -> u32 {
        match k {
            1 => 800,
            2 => 1520,
            3 => 2160,
            4 => 2560,
            5 => 3000,
            _ => 0,
        }
    }

    fn solve(counts: [u32; 5], memo: &mut HashMap<[u32; 5], u32>) -> u32 {
        if counts.iter().all(|&c| c == 0) {
            return 0;
        }
        if let Some(&res) = memo.get(&counts) {
            return res;
        }

        let mut min_cost = u32::MAX;
        let non_zero_count = counts.iter().filter(|&&c| c > 0).count() as u32;

        // Try all possible group sizes k from 1 to non_zero_count
        // But we only need to try k up to 5.
        let max_k = non_zero_count.min(5);

        for k in 1..=max_k {
            let mut next_counts = counts;
            // Pick the k largest counts and decrement them
            // Since counts is sorted descending, we pick the first k
            for i in 0..k as usize {
                next_counts[i] -= 1;
            }
            next_counts.sort_by(|a, b| b.cmp(a));

            let cost = group_cost(k) + solve(next_counts, memo);
            if cost < min_cost {
                min_cost = cost;
            }
        }

        memo.insert(counts, min_cost);
        min_cost
    }
