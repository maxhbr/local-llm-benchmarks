    pub fn lowest_price(books: &[u32]) -> f64 {
        let mut counts_map = HashMap::new();
        for &book in books {
            *counts_map.entry(book).or_insert(0) += 1;
        }

        let mut counts: Vec<u32> = counts_map.values().cloned().collect();
        counts.sort_by(|a, b| b.cmp(a)); // Sort descending

        let mut memo = HashMap::new();
        solve(&mut counts, &mut memo)
    }

    fn solve(counts: &mut Vec<u32>, memo: &mut HashMap<Vec<u32>, f64>) -> f64 {
        // Remove zeros and sort to normalize state
        counts.retain(|&c| c > 0);
        counts.sort_by(|a, b| b.cmp(a));

        if counts.is_empty() {
            return 0.0;
        }

        if let Some(&res) = memo.get(counts) {
            return res;
        }

        let mut min_price = f64::MAX;

        // Try all possible group sizes from 5 down to 1
        // But we can only pick a group of size k if we have at least k different books
        let num_different = counts.len();
        
        for k in (1..=num_different).rev() {
