            return Classification::Deficient;
        }
        if (number == 1) {
            return Classification::Deficient;
        }

        long long aliquot_sum = 1;
        for (int i = 2; i <= number / i; ++i) {
            if (number % i == 0) {
                aliquot_sum += i;
                int other = number / i;
                if (other != i) {
                    aliquot_sum += other;
                }
            }
        }

        if (aliquot_sum == static_cast<long long>(number)) {
            return Classification::Perfect;
        } else if (aliquot_sum > static_cast<long long>(number)) {
            return Classification::Abundant;
        } else {
            return Classification::Deficient;
        }
    }

    bool is_perfect(int number) {
        return classify(number) == Classification::Perfect;
    }

    bool is_abundant(int number) {
        return classify(number) == Classification::Abundant;
    }

    bool is_deficient(int number) {
        return classify(number) == Classification::Deficient;
    }

    }  // namespace perfect_numbers
