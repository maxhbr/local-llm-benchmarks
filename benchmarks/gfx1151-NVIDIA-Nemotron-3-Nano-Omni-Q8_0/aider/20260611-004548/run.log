package markdown

// implementation to refactor

import (
	"fmt"
	"strings"
)

// Render translates markdown to HTML
func Render(markdown string) string {
	// Apply the original bold and italic replacements (as in the original code)
	markdown = strings.Replace(markdown, "__", "<strong>", 1)
	markdown = strings.Replace(markdown, "__", "</strong>", 1)
	markdown = strings.Replace(markdown, "_", "<em>", 1)
	markdown = strings.Replace(markdown, "_", "</em>", 1)

	var output string
	headerLevel := 0
	listCount := 0
	listOpen := false
	insideHeader := false

	i := 0
	for {
		ch := markdown[i]

		if ch == '#' {
			// count consecutive '#' characters
			for ch == '#' {
				headerLevel++
				i++
				ch = markdown[i]
			}
			if headerLevel == 7 {
				output += fmt.Sprintf("<p>%s ", strings.Repeat("#", headerLevel))
			} else if insideHeader {
				output += "# "
				headerLevel--
			} else {
				output += fmt.Sprintf("<h%d>", headerLevel)
			}
			insideHeader = true
			i++
			continue
		}

		insideHeader = true // any other character starts normal text

		if ch == '*' && headerLevel == 0 && strings.Contains(markdown, "\n") {
			if listCount == 0 {
				output += "<ul>"
			}
			listCount++
			if !listOpen {
				output += "<li>"
				listOpen = true
			} else {
				output += string(ch) + " "
			}
			i += 2 // skip '*' and the following character
			continue
		}

		if ch == '\n' {
			// check for end of list item (original condition)
			if listOpen && strings.LastIndex(markdown, "\n") == i && strings.LastIndex(markdown, "\n") > strings.LastIndex(markdown, "*") {
				output += "</li></ul><p>"
				listOpen = false
				listCount = 0
			}
			// close any open list item
			if listOpen {
				output += "</li>"
				listOpen = false
				listCount = 0
			}
			// close any open header
			if headerLevel > 0 {
				output += fmt.Sprintf("</h%d>", headerLevel)
				headerLevel = 0
			}
			i++
			continue
		}

		output += string(ch)
		i++
		if i >= len(markdown) {
			break
		}
	}

	switch {
	case headerLevel == 7:
		return output + "</p>"
	case headerLevel > 0:
		return output + fmt.Sprintf("</h%d>", headerLevel)
	}
	if listCount > 0 {
		return output + "</li></ul>"
	}
	if strings.Contains(output, "<p>") {
		return output + "</p>"
	}
	return "<p>" + output + "</p>"
}
