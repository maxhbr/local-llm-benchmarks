space_age.cpp
```
package space_age

import "fmt"

func Age(seconds int, planet string) float64 {
    const secondsPerYear = 31557600
    const earthYear = 1.0
    const periods = map[string]float64{
        "Mercury": 0.2408467,
        "Venus":   0.61519726,
        "Earth":   1.0,
        "Mars":    1.8808158,
        "Jupiter": 11.862615,
        "Saturn":  29.447498,
        "Uranus":  84.016846,
        "Neptune": 164.79132,
    }

    years := float64(seconds) / float64(secondsPerYear)
    period := periods[planet]
    return years * period / earthYear
}
```

