BottleSong.java
```
class BottleSong {

    String recite(int startBottles, int takeDown) {
        StringBuilder sb = new StringBuilder();
        // Iterate from startBottles down to 1 (the last verse ends with "no green bottles")
        for (int i = startBottles; i >= 1; i--) {
            // First two lines are identical
            String word = numberToWord(i);
            sb.append(word).append(" green");
            if (i == 1) {
                sb.append(" bottle");
            } else {
                sb.append(" bottles");
            }
            sb.append(" hanging on the wall,\n");
            sb.append(word).append(" green");
            if (i == 1) {
                sb.append(" bottle");
            } else {
                sb.append(" bottles");
            }
            sb.append(" hanging on the wall,\n");

            // Next lines describe the fall
            sb.append("And if one green bottle should accidentally fall,\n");
            int next = i - 1;
            if (next == 0) {
                sb.append("There'll be no green bottles hanging on the wall.\n");
            } else {
                String nextWord = numberToWord(next);
                sb.append("There'll be ").append(nextWord).append(" green");
                if (next == 1) {
                    sb.append(" bottle");
                } else {
                    sb.append(" bottles");
                }
                sb.append(" hanging on the wall.\n");
            }

            // Blank line between verses
            sb.append("\n");
        }
        return sb.toString();
    }

    private String numberToWord(int n) {
        switch (n) {
            case 1: return "One";
            case 2: return "Two";
            case 3: return "Three";
            case 4: return "Four";
            case 5: return "Five";
            case 6: return "Six";
            case 7: return "Seven";
            case 8: return "Eight";
            case 9: return "Nine";
            case 10: return "Ten";
            default: return ""; // not used for this song
        }
    }

}
```
