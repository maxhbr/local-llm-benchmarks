BottleSong.java
```
class BottleSong {

    String recite(int startBottles, int takeDown) {
        StringBuilder sb = new StringBuilder();
        // Iterate from startBottles down to 1 (the last verse ends with "no green bottles")
        for (int i = startBottles; i >= 1; i--) {
            // First two lines are identical
            sb.append(i).append(" green");
            if (i == 1) {
                sb.append(" bottle");
            } else {
                sb.append(" bottles");
            }
            sb.append(" hanging on the wall,\n");
            sb.append(i).append(" green");
            if (i == 1) {
                sb.append(" bottle");
            } else {
                sb.append(" bottles");
            }
            sb.append(" hanging on the wall,\n");

            // Next lines describe the fall
            sb.append("And if one green bottle should accidentally fall,\n");
            int next = i - 1;
            sb.append("There'll be ");
            if (next == 0) {
                sb.append("no");
            } else {
                sb.append(next).append(" green");
                if (next == 1) {
                    sb.append(" bottle");
                } else {
                    sb.append(" bottles");
                }
            }
            sb.append(" hanging on the wall.\n");
        }
        // If the requested range includes 0 (i.e., takeDown == 0), add the final verse for 0 bottles
        if (takeDown == 0) {
            sb.append("No green bottles hanging on the wall.\n");
        }
        return sb.toString();
    }

}
