package scale

import "strings"

func Scale(tonic, interval string) []string {
	// Mapping from note spellings (case‑insensitive) to pitch‑class index 0‑11
	noteToIndex := map[string]int{
		"c": 0, "C": 0,
		"c#": 1, "C#": 1,
		"db": 1, "Db": 1,
		"d": 2, "D": 2,
		"d#": 3, "D#": 3,
		"eb": 3, "Eb": 3,
		"e": 4, "E": 4,
		"fb": 4, "Fb": 4,
		"f": 5, "F": 5,
		"f#": 6, "F#": 6,
		"gb": 6, "Gb": 6,
		"g": 7, "G": 7,
		"g#": 8, "G#": 8,
		"ab": 8, "Ab": 8,
		"a": 9, "A": 9,
		"a#": 10, "A#": 10,
		"bb": 10, "Bb": 10,
		"b": 11, "B": 11,
		"cb": 11, "Cb": 11,
	}

	// Parse tonic to its pitch‑class index
	tonicKey := strings.ToLower(tonic)
	idx, ok := noteToIndex[tonicKey]
	if !ok {
		panic("invalid tonic")
	}

	// Determine naming mode: use flats if tonic is a natural note (C or a) → sharps,
	// otherwise use flats if tonic contains a flat accidental or is a flat‑note name.
	useFlats := false
	if tonicKey == "c" || tonicKey == "a" {
		useFlats = false // sharps
	} else if strings.Contains(tonicKey, "b") {
		useFlats = true
	} else {
		// check if tonic matches a flat‑note name (e.g., F, G, etc.)
		for _, n := range flatNotes {
			if strings.ToUpper(n) == tonicKey {
				useFlats = true
				break
			}
		}
	}

	// Note slices for sharp and flat naming
	sharpNotes := []string{
		"C", "C#", "D", "D#", "E", "F", "F#", "G", "G#", "A", "A#", "B",
	}
	flatNotes := []string{
		"C", "Db", "D", "Eb", "E", "F", "Gb", "G", "Ab", "A", "Bb", "B",
	}

	// Helper to get note name from index according to mode
	getNote := func(i int) string {
		if useFlats {
			return flatNotes[i]
		}
		return sharpNotes[i]
	}

	// Parse interval string into step counts (M = whole step = 2, m = half step = 1)
	steps := []int{}
	// ignore any whitespace in the interval
	interval = strings.TrimSpace(interval)
	for i := 0; i < len(interval); i++ {
		switch interval[i] {
		case 'M':
			steps = append(steps, 2)
		case 'm':
			steps = append(steps, 1)
		default:
			panic("invalid interval character")
		}
	}

	// Handle empty interval → full chromatic scale (12 notes)
	if len(steps) == 0 {
		result := []string{getNote(idx)}
		current := idx
		for i := 0; i < 11; i++ {
			current = (current + 1) % 12
			result = append(result, getNote(current))
		}
		return result
	}

	// Build the resulting scale
	result := []string{getNote(idx)}
	current := idx
	for _, s := range steps {
		current = (current + s) % 12
		result = append(result, getNote(current))
	}

	return result
}
