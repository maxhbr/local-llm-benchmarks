from collections import deque

def measure(bucket_one, bucket_two, goal, start_bucket):
    # Validate inputs
    if bucket_one <= 0 or bucket_two <= 0:
        raise ValueError("Bucket sizes must be positive integers.")
    if goal < 0:
        raise ValueError("Goal must be a non‑negative integer.")
    if start_bucket not in ("bucket one", "bucket two", "one", "two"):
        raise ValueError("start_bucket must be either 'bucket one', 'bucket two', 'one', or 'two'.")

    # Determine canonical start bucket and short name for return values
    if start_bucket in ("bucket one", "one"):
        start_is_one = True
        start_short = "one"
    else:  # "bucket two" or "two"
        start_is_one = False
        start_short = "two"

    cap_one, cap_two = bucket_one, bucket_two

    # Helper to check if a state is forbidden after an action
    def is_forbidden(a1, a2):
        if start_is_one:
            return a1 == 0 and a2 == cap_two   # starting bucket empty, other full
        else:
            return a1 == cap_one and a2 == 0    # starting bucket full, other empty

    # BFS initialization: first action is filling the starting bucket
    if start_is_one:
        # first fill bucket_one
        initial = (cap_one, 0)
    else:
        # first fill bucket_two
        initial = (0, cap_two)

    # If the goal is already met after the first fill
    if initial[0] == goal:
        return (1, start_short, 0)
    if initial[1] == goal:
        return (1, start_short, 0)

    # BFS queue holds tuples: (a1, a2, steps)
    queue = deque()
    queue.append((initial[0], initial[1], 1))
    visited = set()
    visited.add((initial[0], initial[1]))

    while queue:
        a1, a2, steps = queue.popleft()

        # Generate all possible next states (one action each)
        next_states = []

        # 1. Fill bucket_one
        if a1 < cap_one:
            new_a1, new_a2 = cap_one, a2
            if not is_forbidden(new_a1, new_a2):
                next_states.append((new_a1, new_a2))

        # 2. Fill bucket_two
        if a2 < cap_two:
            new_a1, new_a2 = a1, cap_two
            if not is_forbidden(new_a1, new_a2):
                next_states.append((new_a1, new_a2))

        # 3. Empty bucket_one
        if a1 > 0:
            new_a1, new_a2 = 0, a2
            if not is_forbidden(new_a1, new_a2):
                next_states.append((new_a1, new_a2))

        # 4. Empty bucket_two
        if a2 > 0:
            new_a1, new_a2 = a1, 0
            if not is_forbidden(new_a1, new_a2):
                next_states.append((new_a1, new_a2))

        # 5. Pour bucket_one -> bucket_two
        if a1 > 0 and a2 < cap_two:
            amount = min(a1, cap_two - a2)
            new_a1, new_a2 = a1 - amount, a2 + amount
            if not is_forbidden(new_a1, new_a2):
                next_states.append((new_a1, new_a2))

        # 6. Pour bucket_two -> bucket_one
        if a2 > 0 and a1 < cap_one:
            amount = min(a2, cap_one - a1)
            new_a1, new_a2 = a1 + amount, a2 - amount
            if not is_forbidden(new_a1, new_a2):
                next_states.append((new_a1, new_a2))

        # Check each successor
        for ns in next_states:
            new_a1, new_a2 = ns
            # Goal reached?
            if new_a1 == goal:
                return (steps + 1, "one" if new_a1 == goal else "two", new_a2 if new_a1 == goal else new_a1)
            if new_a2 == goal:
                return (steps + 1, "two" if new_a2 == goal else "one", new_a1 if new_a2 == goal else new_a2)

            # Enqueue if not visited
            if (new_a1, new_a2) not in visited:
                visited.add((new_a1, new_a2))
                queue.append((new_a1, new_a2, steps + 1))

    # If BFS completes without finding goal
    raise ValueError(f"Cannot measure {goal} liters with buckets of {bucket_one} and {bucket_two} liters starting with {start_bucket}.")
```
