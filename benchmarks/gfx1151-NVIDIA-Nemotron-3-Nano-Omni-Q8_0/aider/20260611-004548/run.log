export class ResistorColorTrio {
  constructor(color1, color2, color3) {
    const colorMap = {
      black: 0,
      brown: 1,
      red: 2,
      orange: 3,
      yellow: 4,
      green: 5,
      blue: 6,
      violet: 7,
      grey: 8,
      white: 9
    };
    this._colors = [color1, color2, color3];
    // Validate colors
    for (const c of this._colors) {
      if (!(c in colorMap)) {
        throw new Error('invalid color');
      }
    }
  }

  get label() {
    const colorMap = {
      black: 0,
      brown: 1,
      red: 2,
      orange: 3,
      yellow: 4,
      green: 5,
      blue: 6,
      violet: 7,
      grey: 8,
      white: 9
    };
    const [c1, c2, c3] = this._colors;
    const v1 = colorMap[c1];
    const v2 = colorMap[c2];
    const zeros = colorMap[c3];

    const mainValue = v1 * 10 + v2;
    const totalOhms = mainValue * Math.pow(10, zeros);

    let valueStr, unit;
    if (totalOhms >= 1000) {
      valueStr = (totalOhms / 1000).toFixed(0);
      unit = 'kiloohms';
    } else {
      valueStr = totalOhms.toString();
      unit = 'ohms';
    }
    return `Resistor value: ${valueStr} ${unit}`;
  }
}

