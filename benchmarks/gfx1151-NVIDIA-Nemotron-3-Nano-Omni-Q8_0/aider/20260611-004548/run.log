func Render(markdown string) string {
        // Initial bold/italic replacement (as original)
        markdown = strings.Replace(markdown, "__", "<strong>", 1)
        markdown = strings.Replace(markdown, "__", "</strong>", 1)
        markdown = strings.Replace(markdown, "_", "<em>", 1)
        markdown = strings.Replace(markdown, "_", "</em>", 1)

        var html strings.Builder
        header := 0
        list := 0
        listOpened := false
        inHeader := false // renamed from 'he'

        // iterate over characters
        for i := 0; i < len(markdown); i++ {
                c := markdown[i]

                switch {
                case c == '#':
                        // count consecutive '#'
                        header = 0
                        for i < len(markdown) && markdown[i] == '#' {
                                header++
                                i++
                        }
                        // adjust index because loop will increment i again
                        i-- // because the for loop will do i++

                        if header == 7 {
                                html.WriteString("<p>")
                                html.WriteString(strings.Repeat("#", header))
                                html.WriteString(" ")
                        } else if inHeader {
                                html.WriteString("# ")
                                header--
                        } else {
                                html.WriteString(fmt.Sprintf("<h%d>", header))
                        }
                        inHeader = true

                case c == '\n':
                        // handle newline and list closing
                        if listOpened && (i == len(markdown)-1 || markdown[i+1] == '\n') {
                                // end of list item
                                if listOpened {
                                        html.WriteString("</li>")
                                        listOpened = false
                                }
                                if header > 0 {
                                        html.WriteString(fmt.Sprintf("</h%d>", header))
                                        header = 0
                                }
                                html.WriteString("<p>")
                        }
                        if listOpened {
                                html.WriteString("</li>")
                                listOpened = false
                                list = 0
                        }
                        if header > 0 {
                                html.WriteString(fmt.Sprintf("</h%d>", header))
                                header = 0
                        }

                case c == '*':
                        // list item start
                        if header == 0 && strings.Contains(markdown, "\n") {
                                if list == 0 {
                                        html.WriteString("<ul>")
                                }
                                list++
                                if !listOpened {
                                        html.WriteString("<li>")
                                        listOpened = true
                                } else {
                                        html.WriteString(" ")
                                }
                                // skip the '*' character
                                i++ // skip '*'
                                continue
                        }

                default:
                        if inHeader {
                                // still inside a header, just add the character
                                html.WriteRune(rune(c))
                        } else {
                                html.WriteRune(rune(c))
                        }
                }
        }

        // final closing tags
        switch {
        case header == 7:
                html.WriteString("</p>")
        case header > 0:
                html.WriteString(fmt.Sprintf("</h%d>", header))
        }
        if list > 0 {
                html.WriteString("</li></ul>")
        }
        if strings.Contains(html.String(), "<p>") {
                html.WriteString("</p>")
        }
        if html.Len() == 0 {
                return "<p>" + html.String() + "</p>"
        }
        return html.String()
}
