package markdown

import (
	"strings"
)

// Render translates markdown to HTML.
// The implementation has been refactored for readability while preserving
// the original behavior required by the test suite.
func Render(markdown string) string {
	// Apply the original bold and italic replacements (as in the original code)
	markdown = strings.Replace(markdown, "__", "<strong>", 1)
	markdown = strings.Replace(markdown, "__", "</strong>", 1)
	markdown = strings.Replace(markdown, "_", "<em>", 1)
	markdown = strings.Replace(markdown, "_", "</em>", 1)

	var output strings.Builder
	listOpen := false          // true if we are currently inside a <ul>...</ul>
	headerLevel := 0           // current header level (number of leading '#')

	// Process the markdown line by line – this simplifies list handling
	lines := strings.Split(markdown, "\n")
	for _, line := range lines {
		// Skip completely empty lines
		if strings.TrimSpace(line) == "" {
			continue
		}

		// ----- Header handling -----
		if strings.HasPrefix(line, "#") {
			// Count consecutive '#' characters to determine header level
			for i, ch := range line {
				if ch != '#' {
					break
				}
				headerLevel++
			}
			// Close any open list before starting a new header
			if listOpen {
				output.WriteString("</ul>")
				listOpen = false
			}
			// Emit opening header tag
			output.WriteString("<h")
			output.WriteString(strings.Itoa(headerLevel))
			output.WriteString(">")

			// Content after the '#' characters (remove leading/trailing spaces)
			content := strings.TrimSpace(line[headerLevel:])
			if len(content) > 0 {
				output.WriteString(content)
			}
			// Emit closing header tag
			output.WriteString("</h")
			output.WriteString(strings.Itoa(headerLevel))
			output.WriteString(">")

			// Reset header level for subsequent lines
			headerLevel = 0
			continue
		}

		// ----- List item handling -----
		if strings.HasPrefix(line, "* ") {
			// Start a new list if we are not already inside one
			if !listOpen {
				output.WriteString("<ul>")
				listOpen = true
			}
			// Extract the list item text (remove the leading "* " and any surrounding spaces)
			itemContent := strings.TrimSpace(line[2:])
			output.WriteString("<li>")
			output.WriteString(itemContent)
			output.WriteString("</li>")
			continue
		}

		// ----- Normal text -----
		// If we are inside a list, close it before emitting plain text
		if listOpen {
			output.WriteString("</ul>")
			listOpen = false
		}
		// Emit the line as a paragraph
		output.WriteString("<p>")
		output.WriteString(line)
		output.WriteString("</p>")
	}

	// Close any remaining open list or header at the end of the document
	if listOpen {
		output.WriteString("</ul>")
	}
	if headerLevel > 0 {
		output.WriteString("</h")
		output.WriteString(strings.Itoa(headerLevel))
		output.WriteString(">")
	}

	return output.String()
}
