package scale

import "strings"

func Scale(tonic, interval string) []string {
    // mapping tonic to index
    noteToIndex := map[string]int{
        "c":0, "c#":1, "d":2, "d#":3, "e":4, "f":5, "f#":6, "g":7, "g#":8, "a":9, "a#":10, "b":11,
        "cb":11, "db":0, "eb":2, "fb":4, "gb":5, "ab":7, "bb":9,
    }
    // normalize tonic to lower case for key lookup
    tonicKey := strings.ToLower(tonic)
    idx, ok := noteToIndex[tonicKey]
    if !ok {
        panic("invalid tonic")
    }

    // determine naming mode
    flatTonicSet := map[string]bool{
        "f":"true","fb":"true","eb":"true","ab":"true","db":"true","gb":"true",
    }
    // use lower case tonic for set check
    useFlats := flatTonicSet[tonicKey]

    // note slices
    sharpNotes := []string{"C","C#","D","D#","E","F","F#","G","G#","A","A#","B"}
    flatNotes := []string{"C","Db","D","Eb","E","F","Gb","F","G","Ab","A","Bb"}

    // helper to get note name from index
    getNote := func(i int) string {
        if useFlats {
            return flatNotes[i]
        }
        return sharpNotes[i]
    }

    // parse intervals
    steps := []int{}
    for i := 0; i < len(interval); i++ {
        ch := interval[i]
        switch ch {
        case 'M':
            steps = append(steps, 2)
        case 'm':
            steps = append(steps, 1)
        default:
            panic("invalid interval character")
        }
    }

    // build result
    result := []string{}
    // first note
    result = append(result, getNote(idx))

    current := idx
    for _, s := range steps {
        current = (current + s) % 12
        result = append(result, getNote(current))
    }

    return result
}

