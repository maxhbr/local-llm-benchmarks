package palindrome

import "fmt"

// Product represents a palindrome product and its factor pairs.
type Product struct {
    Value int
    Pairs []struct{ A, B int }
}

// IsPalindrome checks whether n is a palindrome in base 10.
func IsPalindrome(n int) bool {
    s := fmt.Sprintf("%d", n)
    for i, j := 0, len(s)-1; i < j; i, j = i+1, j-1 {
        if s[i] != s[j] {
            return false
        }
    }
    return true
}

// Products returns the smallest and largest palindrome products
// that can be expressed as a product of two numbers in the range [fmin, fmax].
// If no palindrome exists, it returns an error.
func Products(fmin, fmax int) (Product, Product, error) {
    if fmin > fmax {
        return Product{}, Product{}, fmt.Errorf("invalid range")
    }

    // maps from palindrome value to its factor pairs
    smallestMap := make(map[int][]struct{ A, B int })
    largestMap := make(map[int][]struct{ A, B int })

    smallestVal := 0
    largestVal := 0

    for i := fmin; i <= fmax; i++ {
        for j := i; j <= fmax; j++ { // i <= j to avoid duplicate unordered pairs
            prod := i * j
            if IsPalindrome(prod) {
                // store pair
                if _, ok := smallestMap[prod]; !ok {
                    smallestMap[prod] = []struct{ A, B int }{}
                }
                smallestMap[prod] = append(smallestMap[prod], struct{ A, B int }{A: i, B: j})

                if _, ok := largestMap[prod]; !ok {
                    largestMap[prod] = []struct{ A, B int }{}
                }
                largestMap[prod] = append(largestMap[prod], struct{ A, B int }{A: i, B: j})

                // update smallest/largest values
                if smallestVal == 0 || prod < smallestVal {
                    smallestVal = prod
                }
                if largestVal == 0 || prod > largestVal {
                    largestVal = prod
                }
            }
        }
    }

    if smallestVal == 0 { // no palindrome found
        return Product{}, Product{}, fmt.Errorf("no palindrome products in range")
    }

    // Build Product results
    smallestProd := Product{
        Value: smallestVal,
        Pairs: smallestMap[smallestVal],
    }
    largestProd := Product{
        Value: largestVal,
        Pairs: largestMap[largestVal],
    }

    return smallestProd, largestProd, nil
}
```

