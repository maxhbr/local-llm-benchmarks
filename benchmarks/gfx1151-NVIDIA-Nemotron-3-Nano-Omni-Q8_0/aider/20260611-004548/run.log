//
 // This is only a SKELETON file for the 'Rational Numbers' exercise. It's been provided as a
 // convenience to get you started writing code faster.
 //
 export class Rational {
   constructor(numerator = 0, denominator = 1) {
     if (denominator === 0 && numerator === 0) {
       throw new Error('Both numerator and denominator cannot be zero');
     }
     this.numerator = numerator;
     this.denominator = denominator;
     this.reduce();
   }

   // Helper: greatest common divisor using Euclidean algorithm
   static gcd(a, b) {
     a = Math.abs(a);
     b = Math.abs(b);
     while (b !== 0) {
       [a, b] = [b, a % b];
     }
     return a;
   }

   // Reduce the fraction to lowest terms and ensure positive denominator
   reduce() {
     const g = Rational.gcd(this.numerator, this.denominator);
     this.numerator /= g;
     this.denominator /= g;
     if (this.denominator < 0) {
       this.numerator = -this.numerator;
       this.denominator = -this.denominator;
     }
     return this;
   }

   add(other) {
     const num = this.numerator * other.denominator + other.numerator * this.denominator;
     const den = this.denominator * other.denominator;
     return new Rational(num, den);
   }

   sub(other) {
     const num = this.numerator * other.denominator - other.numerator * this.denominator;
     const den = this.denominator * other.denominator;
     return new Rational(num, den);
   }

   mul(other) {
     const num = this.numerator * other.numerator;
     const den = this.denominator * other.denominator;
     return new Rational(num, den);
   }

   div(other) {
     if (other.numerator === 0) {
       throw new Error('Division by zero rational number');
     }
     const num = this.numerator * other.denominator;
     const den = other.numerator * this.denominator;
     return new Rational(num, den);
   }

   abs() {
     const num = Math.abs(this.numerator);
     const den = Math.abs(this.denominator);
     return new Rational(num, den);
   }

   // Exponentiation
   exprational(n) {
     if (n >= 0) {
       const num = Math.pow(this.numerator, n);
       const den = Math.pow(this.denominator, n);
       return new Rational(num, den);
     } else {
       const m = -n; // make exponent positive
       const num = Math.pow(this.denominator, m);
       const den = Math.pow(this.numerator, m);
       return new Rational(num, den);
     }
   }

   expreal(x) {
     // Determine if x is a Rational (rational exponent) or a number (real exponent)
     if (x instanceof Rational) {
       // exponent is rational: base is real number x, exponent = this.numerator / this.denominator
       const base = x; // real number
       const exponent = this.numerator / this.denominator;
       return Math.pow(base, exponent);
     } else {
       // x is a number: treat as real exponent
       const base = this.numerator / this.denominator;
       return Math.pow(base, x);
     }
   }
 }
