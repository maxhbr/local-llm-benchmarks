#include "diamond.h"
#include <vector>
#include <string>

namespace diamond {

std::vector<std::string> rows(char c) {
    int n = c - 'A';
    int size = 2 * n + 1;
    std::vector<std::string> result(size, std::string(size, ' '));
    
    for (int i = 0; i <= n; ++i) {
        char current_char = 'A' + i;
        int outer_spaces = n - i;
        
        result[i][outer_spaces] = current_char;
        result[i][size - 1 - outer_spaces] = current_char;
        
        result[size - 1 - i] = result[i];
    }
    
    return result;
}

}  // namespace diamond
