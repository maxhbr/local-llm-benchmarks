export class ResistorColorTrio {
  constructor(colors) {
    this.colors = colors;
  }

  label() {
    const colorCodes = {
      black: 0,
      brown: 1,
      red: 2,
      orange: 3,
      yellow: 4,
      green: 5,
      blue: 6,
      violet: 7,
      grey: 8,
      white: 9,
    };

    const value =
      (colorCodes[this.colors[0]] * 10 + colorCodes[this.colors[1]]) *
      Math.pow(10, colorCodes[this.colors[2]]);

    let unit = 'ohms';
    let result = value;

    if (value >= 1_000_000_000 && value % 1_000_000_000 === 0) {
      result = value / 1_000_000_000;
      unit = 'gigaohms';
    } else if (value >= 1_000_000 && value % 1_000_000 === 0) {
      result = value / 1_000_000;
      unit = 'megaohms';
    } else if (value >= 1_000 && value % 1_000 === 0) {
      result = value / 1_000;
      unit = 'kiloohms';
    }

    return `${result} ${unit}`;
  }
}
```

