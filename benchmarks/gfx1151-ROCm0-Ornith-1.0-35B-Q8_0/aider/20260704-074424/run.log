```javascript
//
// This is only a SKELETON file for the 'Rest API' exercise. It's been provided as a
// convenience to get you started writing code faster.
//

export class RestAPI {
  constructor(db = {}) {
    this.db = db;
  }

  get(url) {
    const parsedUrl = new URL(url, 'http://localhost');
    if (parsedUrl.pathname === '/users') {
      const usersParam = parsedUrl.searchParams.get('users');
      let users = Object.values(this.db);
      if (usersParam) {
        const names = usersParam.split(',');
        users = users.filter(u => names.includes(u.name));
      }
      users.sort((a, b) => a.name.localeCompare(b.name));
      return JSON.stringify({ users });
    }
    return null;
  }

  post(url, payload) {
    const parsedUrl = new URL(url, 'http://localhost');
    const data = typeof payload === 'string' ? JSON.parse(payload) : payload;

    if (parsedUrl.pathname === '/add') {
      const name = data.user;
      if (!this.db[name]) {
        this.db[name] = { name, owes: {}, owed_by: {}, balance: 0 };
        return JSON.stringify(this.db[name]);
      }
      return null;
    } else if (parsedUrl.pathname === '/iou') {
      const { lender, borrower, amount } = data;
      this._handleIou(lender, borrower, amount);
      const users = [this.db[lender], this.db[borrower]]
        .sort((a, b) => a.name.localeCompare(b.name));
      return JSON.stringify({ users });
    }
    return null;
  }

  _handleIou(lender, borrower, amount) {
    const l = this.db[lender];
    const b = this.db[borrower];

    const existing = b.owes[lender] || 0;
    if (existing >= amount) {
      b.owes[lender] = existing - amount;
      if (b.owes[lender] === 0) delete b.owes[lender];
      l.owed_by[borrower] -= amount;
      if (l.owed_by[borrower] === 0) delete l.owed_by[borrower];
    } else {
      const diff = amount - existing;
      delete b.owes[lender];
      l.owes[borrower] = (l.owes[borrower] || 0) + diff;
      b.owed_by[lender] = (b.owed_by[lender] || 0) + diff;
    }

    l.balance = this._calcBalance(l);
    b.balance = this._calcBalance(b);
  }

  _calcBalance(user) {
    const owedByTotal = Object.values(user.owed_by).reduce((a, b) => a + b, 0);
    const owesTotal = Object.values(user.owes).reduce((a, b) => a + b, 0);
    return owedByTotal - owesTotal;
  }
}
