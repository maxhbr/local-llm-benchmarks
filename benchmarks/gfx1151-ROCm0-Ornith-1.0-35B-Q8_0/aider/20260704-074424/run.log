class ConnectGame:
    def __init__(self, board):
        self.grid = [row.split() for row in board]
        self.rows = len(self.grid)
        self.cols = len(self.grid[0]) if self.rows > 0 else 0

    def get_winner(self):
        if self._has_path('X'):
            return 'X'
        if self._has_path('O'):
            return 'O'
        return ''

    def _has_path(self, player):
        grid = self.grid
        rows = self.rows
        cols = self.cols
        
        if player == 'O':
            starts = [(0, c) for c in range(cols) if grid[0][c] == 'O']
            is_target = lambda r, c: r == rows - 1
        else:
            starts = [(r, 0) for r in range(rows) if grid[r][0] == 'X']
            is_target = lambda r, c: c == cols - 1
            
        if not starts:
            return False
            
        visited = set(starts)
        queue = list(starts)
        idx = 0
        
        while idx < len(queue):
            r, c = queue[idx]
            idx += 1
            
            if is_target(r, c):
                return True
                
            for dr, dc in ((-1, 0), (-1, 1), (0, -1), (0, 1), (1, -1), (1, 0)):
                nr, nc = r + dr, c + dc
                if 0 <= nr < rows and 0 <= nc < cols and (nr, nc) not in visited and grid[nr][nc] == player:
                    visited.add((nr, nc))
                    queue.append((nr, nc))
        return False
