```python
class ConnectGame:
    def __init__(self, board):
        self.grid = [row.split() for row in board]
        self.rows = len(self.grid)
        self.cols = len(self.grid[0]) if self.rows > 0 else 0

    def get_winner(self):
        if self._check_winner('X'):
            return 'X'
        if self._check_winner('O'):
            return 'O'
        return ''

    def _check_winner(self, player):
        grid = self.grid
        rows = self.rows
        cols = self.cols
        
        if player == 'O':
            # Top to bottom
            start_nodes = [(0, c) for c in range(cols) if grid[0][c] == 'O']
            target_r = rows - 1
        else:
            # Left to right
            start_nodes = [(r, 0) for r in range(rows) if grid[r][0] == 'X']
            target_c = cols - 1
            
        if not start_nodes:
            return False
            
        visited = set(start_nodes)
        queue = list(start_nodes)
        idx = 0
        
        while idx < len(queue):
            r, c = queue[idx]
            idx += 1
            
            if player == 'O' and r == target_r:
                return True
            if player == 'X' and c == target_c:
                return True
                
            for dr, dc in [(-1, 0), (-1, 1), (0, -1), (0, 1), (1, -1), (1, 0)]:
                nr, nc = r + dr, c + dc
                if 0 <= nr < rows and 0 <= nc < cols and (nr, nc) not in visited:
                    if grid[nr][nc] == player:
                        visited.add((nr, nc))
                        queue.append((nr, nc))
        return False
```

