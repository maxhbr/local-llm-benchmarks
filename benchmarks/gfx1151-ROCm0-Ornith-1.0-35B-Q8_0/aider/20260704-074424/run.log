dnd_character.cpp
```
#include "dnd_character.h"
#include <random>

namespace dnd_character {

int modifier(int score) {
    int diff = score - 10;
    if (diff >= 0) {
        return diff / 2;
    } else {
        return (diff - 1) / 2;
    }
}

int ability() {
    static std::mt19937 rng(std::random_device{}());
    std::uniform_int_distribution<int> dist(1, 6);
    int min_val = 7;
    int sum = 0;
    for (int i = 0; i < 4; ++i) {
        int roll = dist(rng);
        if (roll < min_val) min_val = roll;
        sum += roll;
    }
    return sum - min_val;
}

Character::Character()
    : strength(ability())
    , dexterity(ability())
    , constitution(ability())
    , intelligence(ability())
    , wisdom(ability())
    , charisma(ability())
    , hitpoints(10 + modifier(constitution)) {}

}  // namespace dnd_character
```
