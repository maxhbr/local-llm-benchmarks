```java
private String formatAmount(String currencySymbol, String decimalSep, String groupSep, double change, String 
locale) {
    boolean negative = change < 0;
    double absChange = Math.abs(change);
    
    // change is in cents, convert to main unit
    double amount = absChange / 100.0;
    
    String formatted = String.format("%.02f", amount);
    String[] parts = formatted.split("\\.");
    String intPart = parts[0];
    String decPart = parts[1];
    
    // Add grouping separators to integer part
    StringBuilder grouped = new StringBuilder();
    int count = 1;
    for (int i = intPart.length() - 1; i >= 0; i--) {
        if (count % 3 == 0 && i > 0) {
            grouped.insert(0, groupSep + intPart.charAt(i));
        } else {
            grouped.insert(0, intPart.charAt(i));
        }
        count++;
    }
    
    String amountStr;
    if ("nl-NL".equals(locale)) {
        amountStr = currencySymbol + " " + grouped + decimalSep + decPart;
    } else {
        amountStr = currencySymbol + grouped + decimalSep + decPart;
    }
    
    if (negative) {
        if ("en-US".equals(locale)) {
            amountStr = "(" + amountStr + ")";
        } else {
            amountStr = currencySymbol + " -" + grouped + decimalSep + decPart + " ";
        }
    } else {
        if ("nl-NL".equals(locale)) {
            amountStr = " " + amountStr + " ";
        } else {
            amountStr = amountStr + " ";
        }
    }
    
    return amountStr;
}
```

