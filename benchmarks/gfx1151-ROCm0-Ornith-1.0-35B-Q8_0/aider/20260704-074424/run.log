```go
package cryptosquare

import (
        "math"
        "strings"
        "unicode"
)

func Encode(pt string) string {
        var sb strings.Builder
        for _, r := range pt {
                if unicode.IsLetter(r) || unicode.IsDigit(r) {
                        sb.WriteRune(unicode.ToLower(r))
                }
        }
        normalized := sb.String()
        
        if len(normalized) == 0 {
                return ""
        }
        
        l := len(normalized)
        c := int(math.Ceil(math.Sqrt(float64(l))))
        r := int(math.Ceil(float64(l) / float64(c)))
        
        // Build the rectangle virtually or just read columns directly
        // The rectangle is r rows, c columns.
        // normalized[i] goes to row i/c, col i%c
        // We read down columns: for col j from 0 to c-1, for row i from 0 to r-1:
        // index = i*c + j
        // if index < l, char = normalized[index], else char = ' '
        
        var result []string
        for j := 0; j < c; j++ {
                var col strings.Builder
                for i := 0; i < r; i++ {
                        idx := i*c + j
                        if idx < l {
                                col.WriteByte(normalized[idx])
                        } else {
                                col.WriteByte(' ')
                        }
                }
                result = append(result, col.String())
        }
        
        return strings.Join(result, " ")
}
```

