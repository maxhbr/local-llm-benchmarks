                } else {
                        line += "."
                }
                b.WriteString(line)
                b.WriteString("\n")
        }

        b.WriteString("I don't know why she swallowed the fly. Perhaps she'll die.\n")
        return b.String()
}

func Verses(start, end int) string {
        var b strings.Builder
        for i := start; i <= end; i++ {
                b.WriteString(Verse(i))
                b.WriteString("\n")
        }
        return b.String()
}

