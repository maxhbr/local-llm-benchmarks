pub fn answer(command: &str) -> Option<i32> {
    let command = command.trim();
    if !command.starts_with("What is ") || !command.ends_with('?') {
        return None;
    }
    
    let mut tokens = command[8..command.len()-1]
        .replace("multiplied by", "multiplied_by")
        .replace("divided by", "divided_by")
        .replace("raised to the power of", "raised_to_the_power_of")
        .split_whitespace()
        .collect::<Vec<&str>>();
        
    if tokens.is_empty() {
        return None;
    }
    
    let mut result: i32 = tokens.remove(0).parse().ok()?;
    
    while let Some(op) = tokens.first() {
        tokens.remove(0);
        let rhs = tokens.first()?.parse::<i32>().ok()?;
        tokens.remove(0);
        
        result = match op {
            "plus" => result + rhs,
            "minus" => result - rhs,
            "multiplied_by" => result * rhs,
            "divided_by" => result / rhs,
            #[cfg(feature = "exponentials")]
            "raised_to_the_power_of" => result.pow(rhs as u32),
            _ => return None,
        };
    }
    
    Some(result)
}
```

