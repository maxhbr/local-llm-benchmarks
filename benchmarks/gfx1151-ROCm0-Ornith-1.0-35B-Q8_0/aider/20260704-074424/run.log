package palindrome

import "errors"

// Define Product type here.
type Product struct {
	Value          int
	Factorizations [][2]int
}

func Products(fmin, fmax int) (Product, Product, error) {
	if fmin > fmax {
		return Product{}, Product{}, errors.New("fmin > fmax")
	}

	var minProd, maxProd Product
	found := false

	for i := fmin; i <= fmax; i++ {
		for j := i; j <= fmax; j++ {
			p := i * j
			if isPalindrome(p) {
				if !found || p < minProd.Value {
					minProd.Value = p
					minProd.Factorizations = [][2]int{{i, j}}
				} else if p == minProd.Value {
					minProd.Factorizations = append(minProd.Factorizations, [2]int{i, j})
				}
				if !found || p > maxProd.Value {
					maxProd.Value = p
					maxProd.Factorizations = [][2]int{{i, j}}
				} else if p == maxProd.Value {
					maxProd.Factorizations = append(maxProd.Factorizations, [2]int{i, j})
				}
				found = true
			}
		}
	}

	if !found {
		return Product{}, Product{}, errors.New("no palindromes in range")
	}
	return minProd, maxProd, nil
}

func isPalindrome(n int) bool {
	if n < 0 {
		return false
	}
	rev := 0
	for rev < n {
		rev = rev*10 + n%10
		n /= 10
	}
	return n == rev || n == rev/10
}
```
