```java
// Refactoring Log:
// 1. Extracted validation logic for currency and locale into dedicated private methods.
// 2. Replaced deeply nested if/else blocks for locale/currency configuration with flat assignments.
// 3. Replaced manual list splitting and dual-sorting with Arrays.sort and a single Comparator.
// 4. Extracted header generation and description truncation into focused helper methods.
// 5. Replaced repeated String concatenation with a StringBuilder for the output.
// 6. Cleaned up createLedgerEntry to initialize fields in a logical, readable order.
// 7. Preserved exact output formatting behavior for all locale/currency/positive/negative combinations.

import java.time.LocalDate;
import java.time.format.DateTimeFormatter;
import java.util.Arrays;
import java.util.Comparator;

public class Ledger {

    public LedgerEntry createLedgerEntry(String date, String description, int change) {
        LedgerEntry entry = new LedgerEntry();
        entry.setLocalDate(LocalDate.parse(date));
        entry.setDescription(description);
        entry.setChange(change);
        return entry;
    }

    public String format(String currency, String locale, LedgerEntry[] entries) {
        validateCurrency(currency);
        validateLocale(locale);

        String header = formatHeader(locale);
        String dateFormat = "MM/dd/yyyy".equals(locale) ? "MM/dd/yyyy" : "dd/MM/yyyy";
        String decimalSeparator = "MM/dd/yyyy".equals(locale) ? "." : ",";
        String groupSeparator = "MM/dd/yyyy".equals(locale) ? "," : ".";
        String currencySymbol = "USD".equals(currency) ? "$" : "Ōé¼";

        StringBuilder result = new StringBuilder();
        result.append(header);

        LedgerEntry[] sortedEntries = Arrays.copyOf(entries, entries.length);
        Arrays.sort(sortedEntries, Comparator.comparing(LedgerEntry::getLocalDate));

        for (LedgerEntry entry : sortedEntries) {
            String dateStr = entry.getLocalDate().format(DateTimeFormatter.ofPattern(dateFormat));
            String desc = truncateDescription(entry.getDescription());
            String amountStr = formatAmount(currencySymbol, decimalSeparator, groupSeparator, entry.getChange(), locale);

            result.append(String.format("\n%s | %-25s | %13s", dateStr, desc, amountStr));
        }

        return result.toString();
    }

    private void validateCurrency(String currency) {
        if (!"USD".equals(currency) && !"EUR".equals(currency)) {
            throw new IllegalArgumentException("Invalid currency");
        }
    }

    private void validateLocale(String locale) {
        if (!"en-US".equals(locale) && !"nl-NL".equals(locale)) {
            throw new IllegalArgumentException("Invalid locale");
        }
    }

    private String formatHeader(String locale) {
        if ("en-US".equals(locale)) {
            return "Date       | Description               | Change       ";
        }
        return "Datum      | Omschrijving              | Verandering  ";
    }

    private String truncateDescription(String description) {
        if (description.length() > 25) {
            return description.substring(0, 22) + "...";
        }
        return description;
    }

    private String formatAmount(String currencySymbol, String decimalSep, String groupSep, double change, String locale) {
        boolean negative = change < 0;
        double absChange = negative ? -change : change;
        String[] parts = String.format("%.02f", absChange).split("\\.");
        String intPart = parts[0];
        String decPart = parts[1];

        StringBuilder amount = new StringBuilder();
        int count = 1;
        for (int i = intPart.length() - 1; i >= 0; i--) {
            if (count % 3 == 0 && i > 0) {
                amount.insert(0, groupSep + intPart.charAt(i));
            } else {
                amount.insert(0, intPart.charAt(i));
            }
            count++;
        }

        String formatted;
        if ("nl-NL".equals(locale)) {
            formatted = currencySymbol + " " + amount + decimalSep + decPart;
        } else {
            formatted = currencySymbol + amount + decimalSep + decPart;
        }

        if (negative) {
            if ("en-US".equals(locale)) {
                formatted = "(" + formatted + ")";
            } else {
                String withoutSymbol = formatted.replace(currencySymbol, "").trim();
                formatted = currencySymbol + " -" + withoutSymbol + " ";
            }
        } else {
            if ("nl-NL".equals(locale)) {
                formatted = " " + formatted + " ";
            } else {
                formatted = formatted + " ";
            }
        }
        return formatted;
    }

    public static class LedgerEntry {
        LocalDate localDate;
        String description;
        double change;

        public LocalDate getLocalDate() {
            return localDate;
        }

        public void setLocalDate(LocalDate localDate) {
            this.localDate = localDate;
        }

        public String getDescription() {
            return description;
        }

        public void setDescription(String description) {
            this.description = description;
        }

        public double getChange() {
            return change;
        }

        public void setChange(double change) {
            this.change = change;
        }
    }

}
