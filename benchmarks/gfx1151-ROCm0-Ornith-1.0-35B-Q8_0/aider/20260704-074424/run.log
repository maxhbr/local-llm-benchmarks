                prev := animals[i-2]
                curr := animals[i-1]
                line := fmt.Sprintf("She swallowed the %s to catch the %s", curr, prev)
                if prev == "spider" {
                        line += " that wriggled and jiggled and tickled inside her."
                } else {
                        line += "."
                }
                b.WriteString(line)
                b.WriteString("\n")
        }

        b.WriteString("I don't know why she swallowed the fly. Perhaps she'll die.")
        return b.String()
}

func Verses(start, end int) string {
        var b strings.Builder
        for i := start; i <= end; i++ {
                if i > start {
                        b.WriteString("\n")
                }
                b.WriteString(Verse(i))
        }
        return b.String()
}

func Song() string {
        return Verses(1, 8)
}
```

