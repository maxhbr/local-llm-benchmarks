					minProd.Value = p
					minProd.Factorizations = [][2]int{{i, j}}
				} else if p == minProd.Value {
					minProd.Factorizations = append(minProd.Factorizations, [2]int{i, j})
				}
				if !found || p > maxProd.Value {
					maxProd.Value = p
					maxProd.Factorizations = [][2]int{{i, j}}
				} else if p == maxProd.Value {
					maxProd.Factorizations = append(maxProd.Factorizations, [2]int{i, j})
				}
				found = true
			}
		}
	}

	if !found {
		return Product{}, Product{}, errors.New("no palindromes in range")
	}
	return minProd, maxProd, nil
}

func isPalindrome(n int) bool {
	if n < 0 {
		return false
	}
	orig := n
	rev := 0
	for n > 0 {
		rev = rev*10 + n%10
		n /= 10
	}
	return orig == rev
}
```
