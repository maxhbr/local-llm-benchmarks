		}
	}
	norm := normalized.String()

	if len(norm) == 0 {
		return ""
	}

	l := len(norm)
	c := int(math.Ceil(math.Sqrt(float64(l))))
	r := int(math.Ceil(float64(l) / float64(c)))

	var result []string
	for j := 0; j < c; j++ {
		var col strings.Builder
		for i := 0; i < r; i++ {
			idx := i*c + j
			if idx < l {
				col.WriteByte(norm[idx])
			} else {
				col.WriteByte(' ')
			}
		}
		result = append(result, col.String())
	}

	return strings.Join(result, " ")
}
```
