				if d[1] == lastVal && d[0] != d[1] {
					used[i] = true
					chain = append(chain, Domino{d[1], d[0]})
					if solve() {
						return true
					}
					chain = chain[:len(chain)-1]
					used[i] = false
				}
			}
		}
		return false
	}

	used[0] = true
	chain = append(chain, input[0])
	if solve() {
		return chain, true
	}
	chain = chain[:0]
	used[0] = false

	if input[0][0] != input[0][1] {
		used[0] = true
		chain = append(chain, Domino{input[0][1], input[0][0]})
		if solve() {
