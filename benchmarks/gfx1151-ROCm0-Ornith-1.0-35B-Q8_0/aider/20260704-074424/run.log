class InputCell:
    def __init__(self, initial_value):
        self._value = initial_value
        self._dependents = []

    @property
    def value(self):
        return self._value

    @value.setter
    def value(self, new_value):
        if self._value == new_value:
            return
        self._value = new_value
        changed = set()
        for dep in self._dependents:
            self._propagate(dep, changed)
        for cell in changed:
            for cb in cell._callbacks:
                cb(cell.value)

    @staticmethod
    def _propagate(cell, changed):
        new_value = cell._compute_function(*[inp.value for inp in cell._inputs])
        if new_value != cell._value:
            cell._value = new_value
            changed.add(cell)
            for dep in cell._dependents:
                InputCell._propagate(dep, changed)


class ComputeCell:
    def __init__(self, inputs, compute_function):
        self._inputs = inputs
        self._compute_function = compute_function
        self._value = None
        self._dependents = []
        self._callbacks = []
        self._calculate()
        for inp in inputs:
            inp._dependents.append(self)

    def _calculate(self):
        self._value = self._compute_function(*[inp.value for inp in self._inputs])

    def add_callback(self, callback):
        self._callbacks.append(callback)

    def remove_callback(self, callback):
        if callback in self._callbacks:
            self._callbacks.remove(callback)
