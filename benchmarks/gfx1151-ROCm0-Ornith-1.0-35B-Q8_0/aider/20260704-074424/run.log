pub struct Decimal {
    sign: bool,
    digits: Vec<u32>,
    scale: usize,
}

const BASE: u32 = 1_000_000_000;

impl Decimal {
    pub fn try_from(input: &str) -> Option<Decimal> {
        let input = input.trim();
        if input.is_empty() {
            return None;
        }
        
        let (sign, rest) = if input.starts_with('-') {
            (true, &input[1..])
        } else if input.starts_with('+') {
            (false, &input[1..])
        } else {
            (false, input)
        };
        
        if rest.is_empty() {
            return None;
        }
        
        let (int_part, frac_part) = match rest.find('.') {
            Some(pos) => (&rest[..pos], &rest[pos+1..]),
            None => (rest, ""),
        };
        
        if int_part.is_empty() && frac_part.is_empty() {
            return None;
        }
        
        // Combine digits
        let mut all_digits = String::new();
        all_digits.push_str(int_part);
        all_digits.push_str(frac_part);
        
        // Remove leading zeros
        let all_digits = all_digits.trim_start_matches('0');
        let scale = if frac_part.is_empty() {
            0
        } else {
            frac_part.len()
        };
        
        // If all digits are zero
        if all_digits.is_empty() {
            return Some(Decimal {
                sign: false,
                digits: vec![0],
                scale: 0,
            });
        }
        
        // Convert digits string to Vec<u32> in base 10^9
        let digits = digits_from_str(all_digits);
        
        Some(Decimal {
            sign,
            digits,
            scale,
        })
    }
}
```

