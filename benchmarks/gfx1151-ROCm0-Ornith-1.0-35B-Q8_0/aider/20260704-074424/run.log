```rust
pub fn answer(command: &str) -> Option<i32> {
    let body = command.trim().strip_prefix("What is ").and_then(|s| s.strip_suffix('?'))?;
    let mut tokens = body.split_whitespace().peekable();
    
    let mut result: i32 = tokens.next()?.parse().ok()?;
    
    while let Some(&op) = tokens.peek() {
        match op {
            "plus" | "minus" => {
                tokens.next();
                let rhs = tokens.next()?.parse::<i32>().ok()?;
                result = match op {
                    "plus" => result.checked_add(rhs)?,
                    "minus" => result.checked_sub(rhs)?,
                    _ => unreachable!()
                };
            }
            "multiplied" | "divided" => {
                tokens.next(); // consume operator
                tokens.next()?; // consume "by"
                let rhs = tokens.next()?.parse::<i32>().ok()?;
                result = match op {
                    "multiplied" => result.checked_mul(rhs)?,
                    "divided" => result.checked_div(rhs)?,
                    _ => unreachable!()
                };
            }
            #[cfg(feature = "exponentials")]
            "raised" => {
                tokens.next(); // "raised"
                tokens.next()?; // "to"
                tokens.next()?; // "the"
                tokens.next()?; // "power"
                let num_str = tokens.next()?;
                let num_str = num_str.trim_end_matches(|c: char| c.is_alphabetic());
                let rhs = num_str.parse::<i32>().ok()?;
                result = result.checked_pow(rhs as u32)?;
            }
            _ => return None,
        }
    }
    
    Some(result)
}
```

