use std::collections::{BTreeMap, HashSet};

pub struct School {
    roster: BTreeMap<u32, Vec<String>>,
    all_students: HashSet<String>,
}

impl School {
    pub fn new() -> School {
        School {
            roster: BTreeMap::new(),
            all_students: HashSet::new(),
        }
    }

    pub fn add(&mut self, grade: u32, student: &str) {
        if self.all_students.contains(student) {
            return; // or return Err(...)
        }
        self.roster.entry(grade).or_insert_with(Vec::new).push(student.to_string());
        self.all_students.insert(student.to_string());
    }

    pub fn grades(&self) -> Vec<u32> {
        self.roster.keys().copied().collect()
    }

    pub fn grade(&self, grade: u32) -> Vec<String> {
        let mut students = self.roster.get(&grade).cloned().unwrap_or_default();
        students.sort();
        students
    }
}
```

