```rust
/// Type implementing arbitrary-precision decimal arithmetic
pub struct Decimal {
    sign: bool,
    digits: Vec<u32>,
    scale: usize,
}

const BASE: u32 = 1_000_000_000;

impl Decimal {
    pub fn try_from(input: &str) -> Option<Decimal> {
        let input = input.trim();
        if input.is_empty() {
            return None;
        }
        
        let (sign, rest) = if input.starts_with('-') {
            (true, &input[1..])
        } else if input.starts_with('+') {
            (false, &input[1..])
        } else {
            (false, input)
        };
        
        if rest.is_empty() {
            return None;
        }
        
        // Validate characters
        let bytes = rest.as_bytes();
        let mut has_digit = false;
        let mut dot_count = 0;
        for &b in bytes {
            if b == b'.' {
                dot_count += 1;
                if dot_count > 1 {
                    return None;
                }
            } else if b >= b'0' && b <= b'9' {
                has_digit = true;
            } else {
                return None;
            }
        }
        if !has_digit {
            return None;
        }
        
        let (int_part, frac_part) = if let Some(pos) = rest.find('.') {
            (&rest[..pos], &rest[pos+1..])
        } else {
            (rest, "")
        };
        
        if int_part.is_empty() && frac_part.is_empty() {
            return None;
        }
        
        // Combine digits
        let mut all_digits = String::with_capacity(int_part.len() + frac_part.len());
        all_digits.push_str(int_part);
        all_digits.push_str(frac_part);
        
        // Remove leading zeros
        let start = all_digits.find(|c: char| c != '0').unwrap_or(all_digits.len());
        all_digits = all_digits[start..].to_string();
        
        let scale = frac_part.len();
        
        // If all digits are zero
        if all_digits.is_empty() {
            return Some(Decimal {
                sign: false,
                digits: vec![0],
                scale: 0,
            });
        }
        
        // Normalize: remove trailing zeros from the fractional part
        let mut new_scale = scale;
        while new_scale > 0 && all_digits.ends_with('0') {
            all_digits.pop();
            new_scale -= 1;
        }
        
        let digits = digits_from_str(&all_digits);
        
        Some(Decimal {
            sign,
            digits,
            scale: new_scale,
        })
    }
    
    fn is_zero(&self) -> bool {
        self.digits.len() == 1 && self.digits[0] == 0
    }
    
    fn abs_cmp(&self, other: &Decimal) -> std::cmp::Ordering {
        if self.is_zero() && other.is_zero() {
            return std::cmp::Ordering::Equal;
        }
        if self.is_zero() {
            return std::cmp::Ordering::Less;
        }
        if other.is_zero() {
            return std::cmp::Ordering::Greater;
        }
        
        // Align scales
        let max_scale = self.scale.max(other.scale);
        let a_shifted = mul_pow10(&self.digits, max_scale - self.scale);
        let b_shifted = mul_pow10(&other.digits, max_scale - other.scale);
        
        cmp_big(&a_shifted, &b_shifted)
    }
}

fn digits_from_str(s: &str) -> Vec<u32> {
    let mut result = Vec::new();
    let bytes = s.as_bytes();
    let mut pos = bytes.len();
    while pos > 0 {
        let start = pos.saturating_sub(9);
        let chunk: String = bytes[start..pos].iter().map(|&b| b as char).collect();
        result.push(chunk.parse::<u32>().unwrap());
        pos = start;
    }
    result
}

fn mul_pow10(digits: &[u32], k: usize) -> Vec<u32> {
    if k == 0 {
        return digits.to_vec();
    }
    let mut result = digits.to_vec();
    for _ in 0..k {
        let mut carry = 0u64;
        for digit in result.iter_mut() {
            let prod = *digit as u64 * 10 + carry;
            *digit = (prod % BASE as u64) as u32;
            carry = prod / BASE as u64;
        }
        if carry > 0 {
            result.push(carry as u32);
        }
    }
    result
}

fn cmp_big(a: &[u32], b: &[u32]) -> std::cmp::Ordering {
    if a.len() != b.len() {
        return a.len().cmp(&b.len());
    }
    for i in (0..a.len()).rev() {
        if a[i] != b[i] {
            return a[i].cmp(&b[i]);
        }
    }
    std::cmp::Ordering::Equal
}

fn add_big(a: &[u32], b: &[u32]) -> Vec<u32> {
    let max_len = a.len().max(b.len());
    let mut result = Vec::with_capacity(max_len + 1);
    let mut carry = 0u64;
    for i in 0..max_len {
        let ai = if i < a.len() { a[i] as u64 } else { 0 };
        let bi = if i < b.len() { b[i] as u64 } else { 0 };
        let sum = ai + bi + carry;
        result.push((sum % BASE as u64) as u32);
        carry = sum / BASE as u64;
    }
    if carry > 0 {
        result.push(carry as u32);
    }
    normalize_big(&result)
}

fn sub_big(a: &[u32], b: &[u32]) -> Vec<u32> {
    let mut result = Vec::with_capacity(a.len());
    let mut borrow = 0i64;
    for i in 0..a.len() {
        let ai = a[i] as i64 - borrow;
        let bi = if i < b.len() { b[i] as i64 } else { 0 };
        let diff = ai - bi;
        if diff < 0 {
            result.push((diff + BASE as i64) as u32);
            borrow = 1;
        } else {
            result.push(diff as u32);
            borrow = 0;
        }
    }
    normalize_big(&result)
}

fn mul_big(a: &[u32], b: &[u32]) -> Vec<u32> {
    if (a.len() == 1 && a[0] == 0) || (b.len() == 1 && b[0] == 0) {
        return vec![0];
    }
    let mut result = vec![0u32; a.len() + b.len()];
    for (i, &ai) in a.iter().enumerate() {
        let mut carry = 0u64;
        for (j, &bi) in b.iter().enumerate() {
            let prod = ai as u64 * bi as u64 + result[i + j] as u64 + carry;
            result[i + j] = (prod % BASE as u64) as u32;
            carry = prod / BASE as u64;
        }
        if carry > 0 {
            result[i + b.len()] += carry as u32;
        }
    }
    normalize_big(&result)
}

fn normalize_big(digits: &[u32]) -> Vec<u32> {
    let mut result = digits.to_vec();
    while result.len() > 1 && *result.last().unwrap() == 0 {
        result.pop();
    }
    result
}

impl PartialEq for Decimal {
    fn eq(&self, other: &Decimal) -> bool {
        if self.sign != other.sign {
            return false;
        }
        if self.is_zero() && other.is_zero() {
            return true;
        }
        let max_scale = self.scale.max(other.scale);
        let a_shifted = mul_pow10(&self.digits, max_scale - self.scale);
        let b_shifted = mul_pow10(&other.digits, max_scale - other.scale);
        a_shifted == b_shifted
    }
}

impl PartialOrd for Decimal {
    fn partial_cmp(&self, other: &Decimal) -> Option<std::cmp::Ordering> {
        Some(self.cmp(other))
    }
}

impl Ord for Decimal {
    fn cmp(&self, other: &Self) -> std::cmp::Ordering {
        if self.is_zero() && other.is_zero() {
            return std::cmp::Ordering::Equal;
        }
        if self.is_zero() {
            return if other.sign { std::cmp::Ordering::Greater } else { std::cmp::Ordering::Less };
        }
        if other.is_zero() {
            return if self.sign { std::cmp::Ordering::Less } else { std::cmp::Ordering::Greater };
        }
        if self.sign != other.sign {
            return if self.sign { std::cmp::Ordering::Less } else { std::cmp::Ordering::Greater };
        }
        match self.abs_cmp(other) {
            std::cmp::Ordering::Equal => std::cmp::Ordering::Equal,
            ord if self.sign => ord.reverse(),
            ord => ord,
        }
    }
}

impl Add for Decimal {
    type Output = Decimal;
    
    fn add(self, rhs: Self) -> Self::Output {
        if self.sign == rhs.sign {
            let max_scale = self.scale.max(rhs.scale);
            let a_shifted = mul_pow10(&self.digits, max_scale - self.scale);
            let b_shifted = mul_pow10(&rhs.digits, max_scale - rhs.scale);
            let sum = add_big(&a_shifted, &b_shifted);
            Decimal {
                sign: self.sign,
                digits: sum,
                scale: max_scale,
            }
        } else {
            match self.abs_cmp(&rhs) {
                std::cmp::Ordering::Equal => Decimal {
                    sign: false,
                    digits: vec![0],
                    scale: 0,
                },
                std::cmp::Ordering::Greater => {
                    let max_scale = self.scale.max(rhs.scale);
                    let a_shifted = mul_pow10(&self.digits, max_scale - self.scale);
                    let b_shifted = mul_pow10(&rhs.digits, max_scale - rhs.scale);
                    let diff = sub_big(&a_shifted, &b_shifted);
                    Decimal {
                        sign: self.sign,
                        digits: diff,
                        scale: max_scale,
                    }
                },
                std::cmp::Ordering::Less => {
                    let max_scale = self.scale.max(rhs.scale);
                    let a_shifted = mul_pow10(&rhs.digits, max_scale - rhs.scale);
                    let b_shifted = mul_pow10(&self.digits, max_scale - self.scale);
                    let diff = sub_big(&a_shifted, &b_shifted);
                    Decimal {
                        sign: rhs.sign,
                        digits: diff,
                        scale: max_scale,
                    }
                },
            }
        }
    }
}

impl Sub for Decimal {
    type Output = Decimal;
    
    fn sub(self, rhs: Self) -> Self::Output {
        self + Decimal {
            sign: !rhs.sign,
            digits: rhs.digits,
            scale: rhs.scale,
        }
    }
}

impl Mul for Decimal {
    type Output = Decimal;
    
    fn mul(self, rhs: Self) -> Self::Output {
        let product = mul_big(&self.digits, &rhs.digits);
        let scale = self.scale + rhs.scale;
        Decimal {
            sign: self.sign != rhs.sign,
            digits: product,
            scale,
        }
    }
}

impl Clone for Decimal {
    fn clone(&self) -> Self {
        Decimal {
            sign: self.sign,
            digits: self.digits.clone(),
            scale: self.scale,
        }
    }
}

impl Copy for Decimal {}

impl std::fmt::Debug for Decimal {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        write!(f, "{}", self)
    }
}

impl std::fmt::Display for Decimal {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        if self.is_zero() {
            return write!(f, "0");
        }
        if self.sign {
            write!(f, "-")?;
        }
        let mut digits_str = big_digits_to_str(&self.digits);
        let mut scale = self.scale;
        
        // Normalize trailing zeros
        while scale > 0 && digits_str.ends_with('0') {
            digits_str.pop();
            scale -= 1;
        }
        
        if scale == 0 {
            write!(f, "{}", digits_str)
        } else if digits_str.len() <= scale {
            write!(f, "0.{}{}", "0".repeat(scale - digits_str.len()), digits_str)
        } else {
            let pos = digits_str.len() - scale;
            write!(f, "{}.{}", &digits_str[..pos], &digits_str[pos..])
        }
    }
}

fn big_digits_to_str(digits: &[u32]) -> String {
    if digits.is_empty() || (digits.len() == 1 && digits[0] == 0) {
        return "0".to_string();
    }
    let mut result = format!("{}", digits.last().unwrap());
    for i in (0..digits.len() - 1).rev() {
        result.push_str(&format!("{:09}", digits[i]));
    }
    result
}

impl std::str::FromStr for Decimal {
    type Err = ();
    fn from_str(s: &str) -> Result<Decimal, ()> {
        Decimal::try_from(s).ok_or(())
    }
}
