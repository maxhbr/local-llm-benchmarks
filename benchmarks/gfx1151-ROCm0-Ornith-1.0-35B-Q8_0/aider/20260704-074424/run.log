    if int_part.is_empty() && frac_part.is_empty() {
        return None;
    }
    
    // Combine digits
    let mut all_digits = String::new();
    all_digits.push_str(int_part);
    all_digits.push_str(frac_part);
    
    // Remove leading zeros
    let all_digits = all_digits.trim_start_matches('0');
    
    // Determine scale
    let raw_scale = frac_part.len();
    let trailing_zeros = all_digits.chars().rev().take_while(|&c| c == '0').count();
    let scale = raw_scale.saturating_sub(trailing_zeros);
    
    // If all digits are zero
    if all_digits.is_empty() {
        return Some(Decimal {
            sign: false,
            digits: vec![0],
            scale: 0,
        });
    }
    
    let digits = digits_from_str(all_digits);
    
    Some(Decimal {
        sign,
        digits,
        scale,
    })
}
