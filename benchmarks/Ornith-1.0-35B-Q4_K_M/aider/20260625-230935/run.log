public Tree fromPov(String fromNode) {
    List<Tree> path = findPath(this, fromNode);
    if (path == null) throw new UnsupportedOperationException("Tree could not be reoriented");
    
    // We will rebuild the tree.
    // For each node on the path, its children are:
    //   - parent (if exists)
    //   - original children except the next one on path
    //   - plus recursively process off-path children
    
    return buildNewTree(this, path, null);
}

private Tree buildNewTree(Tree node, List<Tree> path, Tree parent) {
    int idx = path.indexOf(node);
    List<Tree> newChildren = new ArrayList<>();
    if (parent != null) {
        newChildren.add(parent);
    }
    for (Tree child : node.children) {
        if (idx < path.size() - 1 && child.equals(path.get(idx + 1))) {
            continue; // skip the child that is on the path to fromNode
        }
        // Recursively build off-path children
        // Wait, off-path children don't change structure, just labels and their own children.
        // But we need to clone them to avoid mutation.
        newChildren.add(cloneTree(child));
    }
    return new Tree(node.label, newChildren);
}

private Tree cloneTree(Tree node) {
    List<Tree> newChildren = new ArrayList<>();
    for (Tree child : node.children) {
        newChildren.add(cloneTree(child));
    }
    return new Tree(node.label, newChildren);
}
```
