        plants.add(charToPlant(rows[1].charAt(colStart)));
        plants.add(charToPlant(rows[1].charAt(colStart + 1)));
        return plants;
    }

    private Plant charToPlant(char c) {
        switch (c) {
            case 'G': return Plant.GRASS;
            case 'C': return Plant.CLOVER;
            case 'R': return Plant.RADISHES;
            case 'V': return Plant.VIOLETS;
            default: throw new IllegalArgumentException("Unknown plant: " + c);
        }
    }
}
