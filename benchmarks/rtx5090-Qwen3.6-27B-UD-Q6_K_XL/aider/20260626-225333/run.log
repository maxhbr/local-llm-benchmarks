```rust
pub fn answer(command: &str) -> Option<i32> {
    let expr = command.strip_prefix("What is ")?.strip_suffix('?')?;
    
    let mut tokens: Vec<&str> = expr.split_whitespace().collect();
    
    let mut cleaned = Vec::new();
    let mut i = 0;
    while i < tokens.len() {
        if (tokens[i] == "multiplied" || tokens[i] == "divided") && i + 1 < tokens.len() && tokens[i+1] == "by" {
            cleaned.push(tokens[i]);
            i += 2;
        } else {
            cleaned.push(tokens[i]);
            i += 1;
        }
    }
    
    let mut iter = cleaned.into_iter();
    
    let mut current: i32 = match iter.next()?.parse() {
        Ok(n) => n,
        Err(_) => return None,
    };
    
    loop {
        match iter.next() {
            Some(op) => {
                let next_num_str = match iter.next() {
                    Some(s) => s,
                    None => return None,
                };
                
                let next_num: i32 = match next_num_str.parse() {
                    Ok(n) => n,
                    Err(_) => return None,
                };
                
                current = match op {
                    "plus" => current.checked_add(next_num)?,
                    "minus" => current.checked_sub(next_num)?,
                    "multiplied" => current.checked_mul(next_num)?,
                    "divided" => current.checked_div(next_num)?,
                    _ => return None,
                };
            }
            None => break,
        }
    }
    
    Some(current)
}
```

