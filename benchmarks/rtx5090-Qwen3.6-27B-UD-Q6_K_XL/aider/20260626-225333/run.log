        Node(T val) : data(val), prev(nullptr), next(nullptr) {}
    };

    Node* head_;
    Node* tail_;
    size_t size_;

public:
    List() : head_(nullptr), tail_(nullptr), size_(0) {}

    ~List() {
        Node* current = head_;
        while (current) {
            Node* next_node = current->next;
            delete current;
            current = next_node;
        }
    }

    void push(T value) {
        Node* newNode = new Node(value);
        if (!tail_) {
            head_ = tail_ = newNode;
        } else {
            tail_->next = newNode;
            newNode->prev = tail_;
            tail_ = newNode;
        }
        size_++;
    }

    T pop() {
        if (!tail_) {
            throw std::runtime_error("Cannot pop from an empty list");
        }
        T value = tail_->data;
        Node* toDelete = tail_;
        if (head_ == tail_) {
            head_ = tail_ = nullptr;
        } else {
            tail_ = tail_->prev;
            tail_->next = nullptr;
        }
        delete toDelete;
        size_--;
        return value;
