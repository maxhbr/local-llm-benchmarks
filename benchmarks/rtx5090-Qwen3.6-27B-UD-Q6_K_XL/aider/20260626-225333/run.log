```javascript
//
// This is only a SKELETON file for the 'State of Tic Tac Toe' exercise. It's been provided as a
// convenience to get you started writing code faster.
//

export const gamestate = (board) => {
  const flat = board.join('');
  const countX = (flat.match(/X/g) || []).length;
  const countO = (flat.match(/O/g) || []).length;

  if (countO > countX || countX > countO + 1) {
    throw new Error('Invalid board');
  }

  const hasWon = (player) => {
    const lines = [
      [0, 1, 2], [3, 4, 5], [6, 7, 8],
      [0, 3, 6], [1, 4, 7], [2, 5, 8],
      [0, 4, 8], [2, 4, 6]
    ];
    return lines.some(line => line.every(idx => flat[idx] === player));
  };

  const xWins = hasWon('X');
  const oWins = hasWon('O');

  if (xWins && oWins) {
    throw new Error('Invalid board');
  }

  if (xWins && countX !== countO + 1) {
    throw new Error('Invalid board');
  }

  if (oWins && countX !== countO) {
    throw new Error('Invalid board');
  }

  if (xWins || oWins) {
    return 'win';
  }

  if (countX + countO === 9) {
    return 'draw';
  }

  return 'ongoing';
};
```

