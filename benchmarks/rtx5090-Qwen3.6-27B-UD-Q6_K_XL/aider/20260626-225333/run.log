import java.util.HashSet;
import java.util.LinkedList;
import java.util.Queue;
import java.util.Set;

class TwoBucket {
    private int totalMoves;
    private String finalBucket;
    private int otherBucket;

    TwoBucket(int bucketOneCap, int bucketTwoCap, int desiredLiters, String startBucket) {
        Queue<int[]> queue = new LinkedList<>();
        Set<String> visited = new HashSet<>();

        int startB1 = startBucket.equals("one") ? bucketOneCap : 0;
        int startB2 = startBucket.equals("one") ? 0 : bucketTwoCap;

        queue.offer(new int[]{startB1, startB2, 1});
        visited.add(startB1 + "," + startB2);

        while (!queue.isEmpty()) {
            int[] current = queue.poll();
            int b1 = current[0];
            int b2 = current[1];
            int moves = current[2];

            if (b1 == desiredLiters) {
                totalMoves = moves;
                finalBucket = "one";
                otherBucket = b2;
                return;
            }
            if (b2 == desiredLiters) {
                totalMoves = moves;
                finalBucket = "two";
                otherBucket = b1;
                return;
            }

            int[][] nextStates = {
                {bucketOneCap, b2}, // Fill 1
                {b1, bucketTwoCap}, // Fill 2
                {0, b2},            // Empty 1
                {b1, 0},            // Empty 2
                {b1 - Math.min(b1, bucketTwoCap - b2), b2 + Math.min(b1, bucketTwoCap - b2)}, // Pour 1->2
                {b1 + Math.min(b2, bucketOneCap - b1), b2 - Math.min(b2, bucketOneCap - b1)}  // Pour 2->1
            };

            for (int[] next : nextStates) {
                int nb1 = next[0];
                int nb2 = next[1];

                if (startBucket.equals("one") && nb1 == 0 && nb2 == bucketTwoCap) continue;
                if (startBucket.equals("two") && nb1 == bucketOneCap && nb2 == 0) continue;

                String stateKey = nb1 + "," + nb2;
                if (!visited.contains(stateKey)) {
                    visited.add(stateKey);
                    queue.offer(new int[]{nb1, nb2, moves + 1});
                }
            }
        }
    }

    int getTotalMoves() {
        return totalMoves;
    }

    String getFinalBucket() {
        return finalBucket;
    }

    int getOtherBucket() {
        return otherBucket;
    }
}
