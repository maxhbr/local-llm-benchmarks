```javascript
export class GoCounting {
  constructor(board) {
    this.board = board;
    this.height = board.length;
    this.width = board[0]?.length || 0;
  }

  getTerritory(x, y) {
    if (x < 0 || x >= this.width || y < 0 || y >= this.height) {
      throw new Error('Invalid coordinate');
    }
    if (this.board[y][x] !== ' ') {
      return { owner: 'NONE', territory: [] };
    }

    const territory = [];
    const visited = new Set();
    const queue = [[x, y]];
    visited.add(`${x},${y}`);

    let hasBlack = false;
    let hasWhite = false;

    while (queue.length > 0) {
      const [cx, cy] = queue.shift();
      territory.push([cx, cy]);

      const neighbors = [
        [cx - 1, cy],
        [cx + 1, cy],
        [cx, cy - 1],
        [cx, cy + 1],
      ];

      for (const [nx, ny] of neighbors) {
        if (nx >= 0 && nx < this.width && ny >= 0 && ny < this.height) {
          const cell = this.board[ny][nx];
          if (cell === 'B') hasBlack = true;
          else if (cell === 'W') hasWhite = true;
          else if (cell === ' ' && !visited.has(`${nx},${ny}`)) {
            visited.add(`${nx},${ny}`);
            queue.push([nx, ny]);
          }
        }
      }
    }

    territory.sort((a, b) => a[0] - b[0] || a[1] - b[1]);

    let owner = 'NONE';
    if (hasBlack && !hasWhite) owner = 'BLACK';
    else if (hasWhite && !hasBlack) owner = 'WHITE';

    return { owner, territory };
  }

  getTerritories() {
    const territoryBlack = [];
    const territoryWhite = [];
    const territoryNone = [];
    const visited = new Set();

    for (let y = 0; y < this.height; y++) {
      for (let x = 0; x < this.width; x++) {
        if (this.board[y][x] === ' ' && !visited.has(`${x},${y}`)) {
          const { owner, territory } = this.getTerritory(x, y);
          // Mark all cells in territory as visited
          for (const [tx, ty] of territory) {
            visited.add(`${tx},${ty}`);
          }

          if (owner === 'BLACK') territoryBlack.push(...territory);
          else if (owner === 'WHITE') territoryWhite.push(...territory);
          else territoryNone.push(...territory);
        }
      }
    }

    // Sort all territories
    const sortCoords = (arr) => arr.sort((a, b) => a[0] - b[0] || a[1] - b[1]);
    sortCoords(territoryBlack);
    sortCoords(territoryWhite);
    sortCoords(territoryNone);

    return { territoryBlack, territoryWhite, territoryNone };
  }
}
```

