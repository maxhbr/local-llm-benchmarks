queen_attack.cpp
```cpp
#include "queen_attack.h"
#include <cstdlib>

namespace queen_attack {

positions::positions(std::pair<int, int> white, std::pair<int, int> black)
    : white_(white), black_(black) {
    if (white_.first < 0 || white_.first > 7 || white_.second < 0 || white_.second > 7 ||
        black_.first < 0 || black_.first > 7 || black_.second < 0 || black_.second > 7) {
        throw std::domain_error("Invalid queen position");
    }
    if (white_ == black_) {
        throw std::domain_error("Queens cannot occupy the same square");
    }
}

std::pair<int, int> positions::white() const {
    return white_;
}

std::pair<int, int> positions::black() const {
    return black_;
}

bool positions::can_attack() const {
    int row_diff = std::abs(white_.first - black_.first);
    int col_diff = std::abs(white_.second - black_.second);
    return row_diff == 0 || col_diff == 0 || row_diff == col_diff;
