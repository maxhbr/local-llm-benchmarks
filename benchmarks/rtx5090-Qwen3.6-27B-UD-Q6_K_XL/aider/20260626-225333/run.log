complex_numbers.cpp
```cpp
#include "complex_numbers.h"
#include <cmath>

namespace complex_numbers {

Complex::Complex(double real, double imag)
    : real_part_(real), imag_part_(imag) {}

double Complex::real() const { return real_part_; }
double Complex::imag() const { return imag_part_; }

Complex Complex::conj() const {
    return Complex(real_part_, -imag_part_);
}

double Complex::abs() const {
    return std::sqrt(real_part_ * real_part_ + imag_part_ * imag_part_);
}

Complex Complex::exp() const {
    double exp_real = std::exp(real_part_);
    return Complex(exp_real * std::cos(imag_part_), exp_real * std::sin(imag_part_));
}

Complex Complex::operator+(const Complex& other) const {
    return Complex(real_part_ + other.real_part_, imag_part_ + other.imag_part_);
}

Complex Complex::operator-(const Complex& other) const {
    return Complex(real_part_ - other.real_part_, imag_part_ - other.imag_part_);
}

Complex Complex::operator*(const Complex& other) const {
    return Complex(
        real_part_ * other.real_part_ - imag_part_ * other.imag_part_,
        imag_part_ * other.real_part_ + real_part_ * other.imag_part_
    );
}

Complex Complex::operator/(const Complex& other) const {
    double denom = other.real_part_ * other.real_part_ + other.imag_part_ * other.imag_part_;
    return Complex(
        (real_part_ * other.real_part_ + imag_part_ * other.imag_part_) / denom,
        (imag_part_ * other.real_part_ - real_part_ * other.imag_part_) / denom
    );
}

Complex Complex::operator+(double rhs) const {
    return Complex(real_part_ + rhs, imag_part_);
}

Complex Complex::operator-(double rhs) const {
    return Complex(real_part_ - rhs, imag_part_);
}

Complex Complex::operator*(double rhs) const {
    return Complex(real_part_ * rhs, imag_part_ * rhs);
}

Complex Complex::operator/(double rhs) const {
    return Complex(real_part_ / rhs, imag_part_ / rhs);
}

Complex operator+(double lhs, const Complex& rhs) {
    return Complex(lhs + rhs.real_part_, rhs.imag_part_);
}

Complex operator-(double lhs, const Complex& rhs) {
    return Complex(lhs - rhs.real_part_, -rhs.imag_part_);
}

Complex operator*(double lhs, const Complex& rhs) {
    return Complex(lhs * rhs.real_part_, lhs * rhs.imag_part_);
}

Complex operator/(double lhs, const Complex& rhs) {
    double denom = rhs.real_part_ * rhs.real_part_ + rhs.imag_part_ * rhs.imag_part_;
    return Complex(
        (lhs * rhs.real_part_) / denom,
        (-lhs * rhs.imag_part_) / denom
    );
}

bool Complex::operator==(const Complex& other) const {
    return real_part_ == other.real_part_ && imag_part_ == other.imag_part_;
}

bool Complex::operator!=(const Complex& other) const {
    return !(*this == other);
}

}  // namespace complex_numbers
```
