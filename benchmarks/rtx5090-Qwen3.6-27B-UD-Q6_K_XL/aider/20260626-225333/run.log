```go
package scale

import "strings"

var sharps = []string{"A", "A#", "B", "C", "C#", "D", "D#", "E", "F", "F#", "G", "G#"}
var flats = []string{"A", "Bb", "B", "C", "Db", "D", "Eb", "E", "F", "Gb", "G", "Ab"}

func Scale(tonic, interval string) []string {
        // Determine if we use flats or sharps
        lowerTonic := strings.ToLower(tonic)
        flatTonics := []string{"c", "f", "bb", "ab", "eb", "db", "gb", "d", "g"}
        useFlats := false
        for _, ft := range flatTonics {
                if lowerTonic == ft {
                        useFlats = true
                        break
                }
        }

        chromatic := sharps
        if useFlats {
                chromatic = flats
        }

        // Find start index
        startIdx := 0
        for i, note := range chromatic {
                if strings.ToLower(note) == lowerTonic {
                        startIdx = i
                        break
                }
        }

        result := []string{chromatic[startIdx]}
        
        if interval == "" {
                // Return full chromatic scale
                for i := 1; i < 12; i++ {
                        result = append(result, chromatic[(startIdx+i)%12])
                }
                return result
        }

        currentIdx := startIdx
        for _, step := range interval {
                var skip int
                switch step {
                case 'm':
                        skip = 1
                case 'M':
                        skip = 2
                case 'A':
                        skip = 3
                }
                currentIdx = (currentIdx + skip) % 12
                result = append(result, chromatic[currentIdx])
        }

        return result
}
```

