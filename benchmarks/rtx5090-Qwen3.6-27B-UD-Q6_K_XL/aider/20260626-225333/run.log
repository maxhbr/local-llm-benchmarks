pub fn to_bytes(values: &[u32]) -> Vec<u8> {
    let mut result = Vec::new();
    for &val in values {
        if val == 0 {
            result.push(0);
            continue;
        }
        let mut chunks = Vec::new();
        let mut current = val;
        while current > 0 {
            chunks.push((current & 0x7F) as u8);
            current >>= 7;
        }
        chunks.reverse();
        for (i, chunk) in chunks.iter_mut().enumerate() {
            if i < chunks.len() - 1 {
                *chunk |= 0x80;
            }
        }
        result.extend(chunks);
    }
    result
}
```

