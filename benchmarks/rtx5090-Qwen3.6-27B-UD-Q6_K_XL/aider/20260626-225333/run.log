class LedgerEntry {
  constructor() {
    this.date = undefined;
    this.description = undefined;
    this.change = undefined;
  }
}

export function createEntry(date, description, change) {
  let entry = new LedgerEntry();
  entry.date = new Date(date);
  entry.description = description;
  entry.change = change;
  return entry;
}

const LOCALES = {
  'en-US': {
    header: 'Date'.padEnd(10) + ' | ' + 'Description'.padEnd(25) + ' | ' + 'Change'.padEnd(13),
    formatDate: (d) =>
      `${(d.getMonth() + 1).toString().padStart(2, '0')}/${d.getDate().toString().padStart(2, '0')}/${d.getFullYear()}`,
    formatChange: (val, currency) => {
      const options = {
        style: 'currency',
        currency: currency,
        minimumFractionDigits: 2,
        maximumFractionDigits: 2,
      };
      if (val < 0) {
        return `(${Math.abs(val / 100).toLocaleString('en-US', options)})`;
      }
      return `${(val / 100).toLocaleString('en-US', options)} `;
    },
  },
  'nl-NL': {
    header: 'Datum'.padEnd(10) + ' | ' + 'Omschrijving'.padEnd(25) + ' | ' + 'Verandering'.padEnd(13),
    formatDate: (d) =>
      `${d.getDate().toString().padStart(2, '0')}-${(d.getMonth() + 1).toString().padStart(2, '0')}-${d.getFullYear()}`,
    formatChange: (val, currency) => {
      const options = {
        style: 'currency',
        currency: currency,
        currencyDisplay: 'narrowSymbol',
        minimumFractionDigits: 2,
        maximumFractionDigits: 2,
      };
      return `${(val / 100).toLocaleString('nl-NL', options)} `;
    },
  },
};

const formatDescription = (desc) =>
  desc.length > 25 ? `${desc.substring(0, 22)}...` : desc.padEnd(25, ' ');

export function formatEntries(currency, locale, entries) {
  const config = LOCALES[locale];
  if (!config) return '';

  let table = config.header + '\n';

  const sortedEntries = [...entries].sort((a, b) =>
    a.date - b.date || a.change - b.change || a.description.localeCompare(b.description)
  );

  sortedEntries.forEach((entry) => {
    const dateStr = config.formatDate(entry.date);
    const descStr = formatDescription(entry.description);
    const changeStr = config.formatChange(entry.change, currency).padStart(13, ' ');

    table += `${dateStr} | ${descStr} | ${changeStr}\n`;
  });

  return table.replace(/\n$/, '');
}
