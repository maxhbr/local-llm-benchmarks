```go
package twobucket

import "fmt"

type state struct {
	b1, b2, steps int
}

func Solve(sizeBucketOne, sizeBucketTwo, goalAmount int, startBucket string) (string, int, int, error) {
	if sizeBucketOne <= 0 || sizeBucketTwo <= 0 || goalAmount <= 0 {
		return "", 0, 0, fmt.Errorf("invalid parameters")
	}
	if goalAmount > sizeBucketOne && goalAmount > sizeBucketTwo {
		return "", 0, 0, fmt.Errorf("goal amount larger than both buckets")
	}
	if goalAmount%gcd(sizeBucketOne, sizeBucketTwo) != 0 {
		return "", 0, 0, fmt.Errorf("goal amount not reachable")
	}
	if startBucket != "one" && startBucket != "two" {
		return "", 0, 0, fmt.Errorf("invalid start bucket")
	}

	var q []state
	visited := make(map[[2]int]bool)

	if startBucket == "one" {
		q = append(q, state{sizeBucketOne, 0, 1})
		visited[[2]int{sizeBucketOne, 0}] = true
	} else {
		q = append(q, state{0, sizeBucketTwo, 1})
		visited[[2]int{0, sizeBucketTwo}] = true
	}

	for len(q) > 0 {
		curr := q[0]
		q = q[1:]

		if curr.b1 == goalAmount {
			return "one", curr.steps, curr.b2, nil
		}
		if curr.b2 == goalAmount {
			return "two", curr.steps, curr.b1, nil
		}

		nextStates := []state{
			{sizeBucketOne, curr.b2, curr.steps + 1}, // Fill 1
			{curr.b1, sizeBucketTwo, curr.steps + 1}, // Fill 2
			{0, curr.b2, curr.steps + 1},             // Empty 1
			{curr.b1, 0, curr.steps + 1},             // Empty 2
		}

		// Pour 1 -> 2
		pour12 := curr.b1
		if sizeBucketTwo-curr.b2 < pour12 {
			pour12 = sizeBucketTwo - curr.b2
		}
		nextStates = append(nextStates, state{curr.b1 - pour12, curr.b2 + pour12, curr.steps + 1})

		// Pour 2 -> 1
		pour21 := curr.b2
		if sizeBucketOne-curr.b1 < pour21 {
			pour21 = sizeBucketOne - curr.b1
		}
		nextStates = append(nextStates, state{curr.b1 + pour21, curr.b2 - pour21, curr.steps + 1})

		for _, ns := range nextStates {
			key := [2]int{ns.b1, ns.b2}
			if !visited[key] {
				if startBucket == "one" && ns.b1 == 0 && ns.b2 == sizeBucketTwo {
					continue
				}
				if startBucket == "two" && ns.b1 == sizeBucketOne && ns.b2 == 0 {
					continue
				}
				visited[key] = true
				q = append(q, ns)
			}
		}
	}

	return "", 0, 0, fmt.Errorf("no solution found")
}

func gcd(a, b int) int {
	for b != 0 {
		a, b = b, a%b
	}
	return a
}
