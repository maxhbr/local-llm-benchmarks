dominoes.go
```go
package dominoes

type Domino [2]int

func MakeChain(input []Domino) ([]Domino, bool) {
	if len(input) == 0 {
		return []Domino{}, true
	}

	// Quick pruning: every number must appear an even number of times
	// for an Eulerian circuit (closed chain) to exist.
	degrees := make(map[int]int)
	for _, d := range input {
		degrees[d[0]]++
		degrees[d[1]]++
	}
	for _, deg := range degrees {
		if deg%2 != 0 {
			return nil, false
		}
	}

	used := make([]bool, len(input))
	chain := make([]Domino, 0, len(input))

	var solve func() bool
	solve = func() bool {
		if len(chain) == len(input) {
			// Check if the chain forms a closed loop
			return chain[0][0] == chain[len(chain)-1][1]
		}

		lastVal := chain[len(chain)-1][1]
		for i := 0; i < len(input); i++ {
			if !used[i] {
				d := input[i]
				// Try matching the first side
				if d[0] == lastVal {
					used[i] = true
					chain = append(chain, d)
					if solve() {
						return true
					}
					chain = chain[:len(chain)-1]
					used[i] = false
				}
				// Try matching the second side (rotated)
				if d[1] == lastVal {
					if d[0] != d[1] {
						used[i] = true
						chain = append(chain, Domino{d[1], d[0]})
						if solve() {
							return true
						}
						chain = chain[:len(chain)-1]
						used[i] = false
					}
				}
			}
		}
		return false
	}

	// Fix the first domino to reduce symmetry (any valid cycle can be rotated to start here)
	used[0] = true
	chain = append(chain, input[0])
	if solve() {
		return chain, true
	}
	chain = chain[:0]
	used[0] = false

	// Try the first domino rotated if it's not a double
	if input[0][0] != input[0][1] {
		used[0] = true
		chain = append(chain, Domino{input[0][1], input[0][0]})
		if solve() {
			return chain, true
		}
	}

	return nil, false
}
```
