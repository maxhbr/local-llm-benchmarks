package ledger

import (
        "errors"
        "fmt"
        "sort"
        "strconv"
        "strings"
)

// Refactoring Log:
// - Removed unnecessary goroutines and channels; formatting is now synchronous and sequential.
// - Replaced custom bubble-sort implementation with sort.Slice for clarity and performance.
// - Extracted date, description, and change formatting into dedicated helper functions.
// - Used fmt.Sprintf and strings.Builder for efficient and readable string construction.
// - Simplified currency formatting logic, removing redundant string manipulations.
// - Removed recursive call for empty entries; handled gracefully.
// - Added proper error messages for invalid locale, currency, and date formats.
// - Ensured alignment and padding match original output specifications.
// - Fixed trailing spaces in header strings.
// - Adjusted change column width from 13 to 14 characters to match test expectations.
// - Removed trailing newline from the final output string.

type Entry struct {
        Date        string // "Y-m-d"
        Description string
        Change      int // in cents
}

func FormatLedger(currency string, locale string, entries []Entry) (string, error) {
        if locale != "en-US" && locale != "nl-NL" {
                return "", errors.New("invalid locale")
        }
        if currency != "USD" && currency != "EUR" {
                return "", errors.New("invalid currency")
        }

        // Sort entries by Date, then Description, then Change
        sorted := make([]Entry, len(entries))
        copy(sorted, entries)
        sort.Slice(sorted, func(i, j int) bool {
                if sorted[i].Date != sorted[j].Date {
                        return sorted[i].Date < sorted[j].Date
                }
                if sorted[i].Description != sorted[j].Description {
                        return sorted[i].Description < sorted[j].Description
                }
                return sorted[i].Change < sorted[j].Change
        })

        var sb strings.Builder

        // Write header
        if locale == "en-US" {
                sb.WriteString("Date       | Description               | Change")
        } else {
                sb.WriteString("Datum      | Omschrijving              | Verandering")
        }

        for _, e := range sorted {
                // Validate date format
                if len(e.Date) != 10 || e.Date[4] != '-' || e.Date[7] != '-' {
                        return "", errors.New("invalid date format")
                }

                dateStr := formatDate(e.Date, locale)
                descStr := formatDescription(e.Description)
                changeStr := formatChange(e.Change, currency, locale)

                sb.WriteString(fmt.Sprintf("\n%s | %s | %s", dateStr, descStr, changeStr))
        }

        return sb.String(), nil
}

func formatDate(date string, locale string) string {
        y, m, d := date[0:4], date[5:7], date[8:10]
        if locale == "en-US" {
                return fmt.Sprintf("%s/%s/%s", m, d, y)
        }
        return fmt.Sprintf("%s-%s-%s", d, m, y)
}

func formatDescription(desc string) string {
        if len(desc) > 25 {
                return desc[:22] + "..."
        }
        return fmt.Sprintf("%-25s", desc)
}

func formatChange(change int, currency string, locale string) string {
        negative := change < 0
        if negative {
                change = -change
        }

        cents := change % 100
        amount := change / 100

        amountStr := strconv.Itoa(amount)
        var parts []string
        for len(amountStr) > 3 {
                parts = append([]string{amountStr[len(amountStr)-3:]}, parts...)
                amountStr = amountStr[:len(amountStr)-3]
        }
        parts = append([]string{amountStr}, parts...)

        var sep, dec string
        if locale == "en-US" {
                sep, dec = ",", "."
        } else {
                sep, dec = ".", ","
        }

        formattedAmount := strings.Join(parts, sep)
        centsStr := fmt.Sprintf("%02d", cents)

        var symbol string
        if currency == "USD" {
                symbol = "$"
        } else {
                symbol = "Ōé¼"
        }

        var res string
        if locale == "en-US" {
                if negative {
                        res = fmt.Sprintf("(%s%s%s%s)", symbol, formattedAmount, dec, centsStr)
                } else {
                        res = fmt.Sprintf("%s%s%s%s ", symbol, formattedAmount, dec, centsStr)
                }
        } else {
                if negative {
                        res = fmt.Sprintf("%s %s%s%s-", symbol, formattedAmount, dec, centsStr)
                } else {
                        res = fmt.Sprintf("%s %s%s%s ", symbol, formattedAmount, dec, centsStr)
                }
        }

        // Right-align to 14 characters
        runeLen := len([]rune(res))
        return strings.Repeat(" ", 14-runeLen) + res
}
