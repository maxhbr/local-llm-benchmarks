```javascript
export const solve = (puzzle) => {
  const parts = puzzle.split(/==?/);
  if (parts.length !== 2) return null;
  
  const leftWords = parts[0].split('+').map(w => w.trim());
  const rightWord = parts[1].trim();
  const allWords = [...leftWords, rightWord];
  
  const uniqueLetters = new Set();
  const nonZeroLetters = new Set();
  
  for (const word of allWords) {
    if (word.length > 1) nonZeroLetters.add(word[0]);
    for (const char of word) uniqueLetters.add(char);
  }
  
  const letters = Array.from(uniqueLetters);
  if (letters.length > 10) return null;
  
  const letterToIdx = {};
  letters.forEach((l, i) => letterToIdx[l] = i);
  
  const weights = new Array(letters.length).fill(0);
  
  for (const word of leftWords) {
    for (let i = 0; i < word.length; i++) {
      const char = word[word.length - 1 - i];
      weights[letterToIdx[char]] += 10 ** i;
    }
  }
  
  for (let i = 0; i < rightWord.length; i++) {
    const char = rightWord[rightWord.length - 1 - i];
    weights[letterToIdx[char]] -= 10 ** i;
  }
  
  // Sort indices by absolute weight descending
  const indices = letters.map((_, i) => i);
  indices.sort((a, b) => Math.abs(weights[b]) - Math.abs(weights[a]));
  
  const sortedLetters = indices.map(i => letters[i]);
  const sortedWeights = indices.map(i => weights[i]);
  const sortedNonZero = indices.map(i => nonZeroLetters.has(letters[i]));
  
  const usedDigits = new Array(10).fill(false);
  const assignment = {};
  
  function backtrack(idx, currentSum) {
    if (idx === sortedLetters.length) {
      return currentSum === 0 ? assignment : null;
    }
    
    for (let d = 0; d <= 9; d++) {
      if (usedDigits[d]) continue;
      if (d === 0 && sortedNonZero[idx]) continue;
      
      usedDigits[d] = true;
      assignment[sortedLetters[idx]] = d;
      
      if (backtrack(idx + 1, currentSum + sortedWeights[idx] * d)) {
        return assignment;
      }
      
      usedDigits[d] = false;
      delete assignment[sortedLetters[idx]];
    }
    return null;
  }
  
  return backtrack(0, 0);
};
```

