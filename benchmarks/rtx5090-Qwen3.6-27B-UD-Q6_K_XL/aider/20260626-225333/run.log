pub fn answer(command: &str) -> Option<i32> {
    if !command.starts_with("What is ") || !command.ends_with('?') {
        return None;
    }
    
    let mut expr = &command[8..command.len() - 1];
    if expr.is_empty() {
        return None;
    }
    
    // Replace multi-word operators
    expr = expr.replace("multiplied by", "multiplied");
    expr = expr.replace("divided by", "divided");
    
    let tokens: Vec<&str> = expr.split_whitespace().collect();
    if tokens.is_empty() {
        return None;
    }
    
    let mut iter = tokens.iter();
    
    // First token must be a number
    let mut current: i32 = match iter.next()?.parse() {
        Ok(n) => n,
        Err(_) => return None,
    };
    
    loop {
        match iter.next() {
            Some(op) => {
                let next_num_str = match iter.next() {
                    Some(s) => s,
                    None => return None, // Operator without following number
                };
                
                let next_num: i32 = match next_num_str.parse() {
                    Ok(n) => n,
                    Err(_) => return None, // Expected number after operator
                };
                
                current = match *op {
                    "plus" => current + next_num,
                    "minus" => current - next_num,
                    "multiplied" => current * next_num,
                    "divided" => current / next_num,
                    _ => return None, // Unknown operator
                };
            }
            None => break,
        }
    }
    
    Some(current)
}
```

