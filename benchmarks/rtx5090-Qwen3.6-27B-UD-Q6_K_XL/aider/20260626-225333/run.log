        Node* newNode = new Node(value);
        if (!head_) {
            head_ = tail_ = newNode;
        } else {
            head_->prev = newNode;
            newNode->next = head_;
            head_ = newNode;
        }
        size_++;
    }

    size_t count() const {
        return size_;
    }

    bool erase(T value) {
        Node* current = head_;
        while (current) {
            if (current->data == value) {
                if (current == head_) {
                    head_ = current->next;
                    if (head_) head_->prev = nullptr;
                    else tail_ = nullptr;
                } else {
                    current->prev->next = current->next;
                    if (current->next) current->next->prev = current->prev;
                    else tail_ = current->prev;
                }
                delete current;
                size_--;
                return true;
            }
            current = current->next;
        }
        return false;
    }
};

}  // namespace linked_list
