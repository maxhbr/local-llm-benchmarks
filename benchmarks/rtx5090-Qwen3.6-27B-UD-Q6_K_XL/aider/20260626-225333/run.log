```java
class StateOfTicTacToe {
    public GameState determineState(String[] board) {
        int xCount = 0;
        int oCount = 0;
        for (String row : board) {
            for (char c : row.toCharArray()) {
                if (c == 'X') xCount++;
                else if (c == 'O') oCount++;
            }
        }

        if (oCount > xCount || xCount > oCount + 1) {
            throw new IllegalArgumentException("Invalid turn order");
        }

        boolean xWins = hasWon(board, 'X');
        boolean oWins = hasWon(board, 'O');

        if (xWins && oWins) {
            throw new IllegalArgumentException("Both players cannot win");
        }

        if (xWins && xCount == oCount) {
            throw new IllegalArgumentException("Game continued after X won");
        }

        if (oWins && xCount > oCount) {
            throw new IllegalArgumentException("Game continued after O won");
        }

        if (xWins || oWins) {
            return GameState.WON;
        }

        if (xCount + oCount == 9) {
            return GameState.DRAW;
        }

        return GameState.ONGOING;
    }

    private boolean hasWon(String[] board, char player) {
        // Rows
        for (int i = 0; i < 3; i++) {
            if (board[i].charAt(0) == player && board[i].charAt(1) == player && board[i].charAt(2) == player) {
                return true;
            }
        }
        // Cols
        for (int j = 0; j < 3; j++) {
            if (board[0].charAt(j) == player && board[1].charAt(j) == player && board[2].charAt(j) == player) {
                return true;
            }
        }
        // Diagonals
        if (board[0].charAt(0) == player && board[1].charAt(1) == player && board[2].charAt(2) == player) return true;
        if (board[0].charAt(2) == player && board[1].charAt(1) == player && board[2].charAt(0) == player) return true;

        return false;
    }
}
```

