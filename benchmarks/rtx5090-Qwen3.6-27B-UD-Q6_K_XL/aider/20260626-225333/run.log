type Domino [2]int

func MakeChain(input []Domino) ([]Domino, bool) {
        if len(input) == 0 {
                return []Domino{}, true
        }

        // Quick check: degrees must be even
        degrees := make(map[int]int)
        for _, d := range input {
                degrees[d[0]]++
                degrees[d[1]]++
        }
        for _, deg := range degrees {
                if deg%2 != 0 {
                        return nil, false
                }
        }

        used := make([]bool, len(input))
        chain := make([]Domino, 0, len(input))

        // Start with the first domino. Since it's a cycle, we can fix the first one.
        // Try original orientation
        used[0] = true
        chain = append(chain, input[0])
        if solve(input, used, &chain) {
                return chain, true
        }
        chain = chain[:0]
        used[0] = false

        // Try rotated orientation if different
        if input[0][0] != input[0][1] {
                used[0] = true
                chain = append(chain, Domino{input[0][1], input[0][0]})
                if solve(input, used, &chain) {
                        return chain, true
                }
        }

        return nil, false
}

func solve(input []Domino, used []bool, chain *[]Domino) bool {
        if len(*chain) == len(input) {
                // Check if cycle closes
                return (*chain)[0][0] == (*chain)[len(*chain)-1][1]
        }

        lastVal := (*chain)[len(*chain)-1][1]
        for i := 0; i < len(input); i++ {
                if !used[i] {
                        d := input[i]
                        if d[0] == lastVal {
                                used[i] = true
                                *chain = append(*chain, d)
                                if solve(input, used, chain) {
                                        return true
                                }
                                *chain = (*chain)[:len(*chain)-1]
                                used[i] = false
                        }
                        if d[1] == lastVal {
                                // Only try rotated if different from original to avoid duplicate work
                                if d[0] != d[1] {
                                        used[i] = true
                                        *chain = append(*chain, Domino{d[1], d[0]})
                                        if solve(input, used, chain) {
                                                return true
                                        }
                                        *chain = (*chain)[:len(*chain)-1]
                                        used[i] = false
                                }
                        }
                }
        }
        return false
}
```

