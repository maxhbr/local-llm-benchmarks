    if !command.starts_with("What is ") || !command.ends_with('?') {
        return None;
    }

    let expr = &command[8..command.len() - 1];
    if expr.trim().is_empty() {
        return None;
    }

    let mut tokens: Vec<&str> = expr.split_whitespace().collect();
    
    // Handle "multiplied by" and "divided by"
    let mut cleaned = Vec::new();
    let mut i = 0;
    while i < tokens.len() {
        if (tokens[i] == "multiplied" || tokens[i] == "divided") && i + 1 < tokens.len() && tokens[i+1] == "by" {
            cleaned.push(tokens[i]);
            i += 2;
        } else {
            cleaned.push(tokens[i]);
            i += 1;
        }
    }
    
    let mut iter = cleaned.into_iter();
    
    let mut current: i32 = match iter.next()?.parse() {
        Ok(n) => n,
        Err(_) => return None,
    };
    
    loop {
        match iter.next() {
            Some(op) => {
                let next_num_str = match iter.next() {
                    Some(s) => s,
                    None => return None,
                };
                
                let next_num: i32 = match next_num_str.parse() {
                    Ok(n) => n,
                    Err(_) => return None,
                };
                
                current = match op {
                    "plus" => current + next_num,
                    "minus" => current - next_num,
                    "multiplied" => current * next_num,
                    "divided" => current / next_num,
                    _ => return None,
                };
            }
            None => break,
        }
    }
    
    Some(current)
}
