const (
        N Dir = iota
        E
        S
        W
)

var Robot Robot

func Right() {
        Robot.Dir = (Robot.Dir + 1) % 4
}

func Left() {
        Robot.Dir = (Robot.Dir + 3) % 4
}

func Advance() {
        switch Robot.Dir {
        case N:
                Robot.Point.Y++
        case E:
                Robot.Point.X++
        case S:
                Robot.Point.Y--
        case W:
                Robot.Point.X--
        }
}

func (d Dir) String() string {
        return [4]string{"N", "E", "S", "W"}[d]
}

// Step 2
// Define Action type here.
type Action func()

func StartRobot(command chan Command, action chan Action) {
        for c := range command {
                switch c {
                case 'R':
                        action <- Right
                case 'L':
                        action <- Left
                case 'A':
                        action <- Advance
                }
        }
        close(action)
}

func Room(extent Rect, robot Step2Robot, action chan Action, report chan Step2Robot) {
        for a := range action {
                a()
                if robot.X < extent.Min[0] || robot.X > extent.Max[0] ||
                        robot.Y < extent.Min[1] || robot.Y > extent.Max[1] {
                        switch robot.Dir {
