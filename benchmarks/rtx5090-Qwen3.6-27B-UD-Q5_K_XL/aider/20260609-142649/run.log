package robot

import "fmt"

// See defs.go for other definitions

// Step 1
// Define N, E, S, W here.
const (
        N Dir = iota
        E
        S
        W
)

func Right() {
        Robot.Dir = (Robot.Dir + 1) % 4
}

func Left() {
        Robot.Dir = (Robot.Dir + 3) % 4
}

func Advance() {
        switch Robot.Dir {
        case N:
                Robot.Point.Y++
        case E:
                Robot.Point.X++
        case S:
                Robot.Point.Y--
        case W:
                Robot.Point.X--
        }
}

func (d Dir) String() string {
        return [4]string{"N", "E", "S", "W"}[d]
}

// Step 2
// Define Action type here.
type Action func()

func StartRobot(command chan Command, action chan Action) {
        for c := range command {
                switch c {
                case 'R':
                        action <- Right
                case 'L':
                        action <- Left
                case 'A':
                        action <- Advance
                }
        }
        close(action)
}

func Room(extent Rect, robot Step2Robot, action chan Action, report chan Step2Robot) {
        for a := range action {
                a()
                if robot.Point.X < extent.Min.X || robot.Point.X > extent.Max.X ||
                        robot.Point.Y < extent.Min.Y || robot.Point.Y > extent.Max.Y {
                        switch robot.Dir {
                        case N:
                                robot.Point.Y--
                        case E:
                                robot.Point.X--
                        case S:
                                robot.Point.Y++
                        case W:
                                robot.Point.X++
                        }
                }
        }
        report <- robot
        close(report)
}

// Step 3
// Define Action3 type here.
type Action3 struct {
        Name    string
        Command byte
}

func StartRobot3(name, script string, action chan Action3, log chan string) {
        if name == "" {
                log <- "Robot without a name"
                return
        }
        for _, cmd := range script {
                switch cmd {
                case 'R', 'L', 'A':
                        action <- Action3{Name: name, Command: byte(cmd)}
                default:
                        log <- fmt.Sprintf("Robot %s: undefined command %c", name, cmd)
                }
        }
}

func Room3(extent Rect, robots []Step3Robot, action chan Action3, rep chan []Step3Robot, log chan string) {
        seen := make(map[string]bool)
        places := make(map[Point]bool)

        for i := range robots {
                if robots[i].Name == "" {
                        log <- "Robot without a name"
                        continue
                }
                if seen[robots[i].Name] {
                        log <- fmt.Sprintf("Duplicate robot name: %s", robots[i].Name)
                        continue
                }
                seen[robots[i].Name] = true

                if robots[i].Point.X < extent.Min.X || robots[i].Point.X > extent.Max.X ||
                        robots[i].Point.Y < extent.Min.Y || robots[i].Point.Y > extent.Max.Y {
                        log <- fmt.Sprintf("Robot %s placed outside of room", robots[i].Name)
                        continue
                }

                if places[robots[i].Point] {
                        log <- fmt.Sprintf("Robots placed at the same place: %s", robots[i].Name)
                }
                places[robots[i].Point] = true
        }

        robotMap := make(map[string]*Step3Robot)
        for i := range robots {
                if robots[i].Name != "" {
                        robotMap[robots[i].Name] = &robots[i]
                }
        }

        for act := range action {
                r, ok := robotMap[act.Name]
                if !ok {
                        log <- fmt.Sprintf("Action from unknown robot: %s", act.Name)
                        continue
                }

                oldPoint := r.Point
                switch act.Command {
                case 'R':
                        r.Dir = (r.Dir + 1) % 4
                case 'L':
                        r.Dir = (r.Dir + 3) % 4
                case 'A':
                        switch r.Dir {
                        case N:
                                r.Point.Y++
                        case E:
                                r.Point.X++
                        case S:
                                r.Point.Y--
                        case W:
                                r.Point.X--
                        }
                        if r.Point.X < extent.Min.X || r.Point.X > extent.Max.X ||
                                r.Point.Y < extent.Min.Y || r.Point.Y > extent.Max.Y {
                                log <- fmt.Sprintf("Robot %s attempting to advance into a wall", r.Name)
                                r.Point = oldPoint
                                continue
                        }
                        for name, other := range robotMap {
                                if name != r.Name && other.Point == r.Point {
                                        log <- fmt.Sprintf("Robot %s attempting to advance into another robot", r.Name)
                                        r.Point = oldPoint
                                        break
                                }
                        }
                }
        }
        rep <- robots
        close(rep)
}
