const DAY_MAP = {
  Sunday: 0,
  Monday: 1,
  Tuesday: 2,
  Wednesday: 3,
  Thursday: 4,
  Friday: 5,
  Saturday: 6,
};

export const meetup = (day, week, month, year) => {
  const targetDay = DAY_MAP[day];
  let startDate, endDate;

  if (week === 'teenth') {
    startDate = 13;
    endDate = 19;
  } else if (week === 'last') {
    const lastDayOfMonth = new Date(year, month, 0).getDate();
    startDate = lastDayOfMonth - 6;
    endDate = lastDayOfMonth;
  } else {
    const weekNum = { first: 1, second: 2, third: 3, fourth: 4 }[week];
    startDate = (weekNum - 1) * 7 + 1;
    endDate = weekNum * 7;
  }

  for (let d = startDate; d <= endDate; d++) {
    const date = new Date(year, month - 1, d);
    if (date.getDay() === targetDay) {
      return date;
    }
  }
};
