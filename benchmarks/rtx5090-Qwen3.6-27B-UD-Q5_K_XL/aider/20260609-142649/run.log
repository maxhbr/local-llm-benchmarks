public class AffineCipher {
    private static final int M = 26;

    public String encode(String text, int a, int b) {
        if (gcd(a, M) != 1) {
            throw new IllegalArgumentException("The key and the modulus must be coprime.");
        }
        StringBuilder sb = new StringBuilder();
        for (char c : text.toCharArray()) {
            if (Character.isLetter(c)) {
                int i = Character.toLowerCase(c) - 'a';
                int encoded = mod(a * i + b, M);
                sb.append((char) (encoded + 'a'));
            } else if (Character.isDigit(c)) {
                sb.append(c);
            }
        }
        return groupByFive(sb.toString());
    }

    public String decode(String text, int a, int b) {
        if (gcd(a, M) != 1) {
            throw new IllegalArgumentException("The key and the modulus must be coprime.");
        }
        int mmi = mmi(a, M);
        StringBuilder sb = new StringBuilder();
        for (char c : text.toCharArray()) {
            if (Character.isLetter(c)) {
                int y = Character.toLowerCase(c) - 'a';
                int decoded = mod(mmi * (y - b), M);
                sb.append((char) (decoded + 'a'));
            } else if (Character.isDigit(c)) {
                sb.append(c);
            }
        }
        return sb.toString();
    }

    private int gcd(int a, int b) {
        while (b != 0) {
            int temp = b;
            b = a % b;
            a = temp;
        }
        return a;
    }

    private int mmi(int a, int m) {
        a = mod(a, m);
        for (int x = 1; x < m; x++) {
            if (mod(a * x, m) == 1) {
                return x;
            }
        }
        throw new IllegalArgumentException("Modular inverse does not exist.");
    }

    private int mod(int x, int m) {
        return ((x % m) + m) % m;
    }

    private String groupByFive(String text) {
        if (text.isEmpty()) return text;
        StringBuilder sb = new StringBuilder();
        for (int i = 0; i < text.length(); i++) {
            if (i > 0 && i % 5 == 0) {
                sb.append(' ');
            }
            sb.append(text.charAt(i));
        }
        return sb.toString();
    }
}
```

