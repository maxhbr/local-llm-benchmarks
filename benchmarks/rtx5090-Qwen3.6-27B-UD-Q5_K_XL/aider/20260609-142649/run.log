package dominoes

type Domino [2]int

func MakeChain(input []Domino) ([]Domino, bool) {
	if len(input) == 0 {
		return []Domino{}, true
	}

	used := make([]bool, len(input))
	used[0] = true
	chain := []Domino{input[0]}

	if solve(chain, used, input) {
		return chain, true
	}
	return nil, false
}

func solve(chain []Domino, used []bool, input []Domino) bool {
	if len(chain) == len(input) {
		return chain[0][0] == chain[len(chain)-1][1]
	}

	lastVal := chain[len(chain)-1][1]
	for i := 0; i < len(input); i++ {
		if !used[i] {
			d := input[i]
			if d[0] == lastVal {
				used[i] = true
				chain = append(chain, d)
				if solve(chain, used, input) {
					return true
				}
				chain = chain[:len(chain)-1]
				used[i] = false
			}
			if d[0] != d[1] && d[1] == lastVal {
				rotated := Domino{d[1], d[0]}
				used[i] = true
				chain = append(chain, rotated)
				if solve(chain, used, input) {
					return true
				}
				chain = chain[:len(chain)-1]
				used[i] = false
			}
		}
	}
	return false
}
```
