```cpp
std::vector<int> rebase(int input_base, std::vector<int> digits, int output_base) {
    if (input_base < 2) {
        throw std::domain_error("Input base must be >= 2");
    }
    if (output_base < 2) {
        throw std::domain_error("Output base must be >= 2");
    }
    
    long long value = 0;
    for (int digit : digits) {
        if (digit < 0 || digit >= input_base) {
            throw std::domain_error("Digit must be >= 0 and < input base");
        }
        value = value * input_base + digit;
    }
    
    if (value == 0) {
        return {0};
    }
    
    std::vector<int> result;
    while (value > 0) {
        result.push_back(static_cast<int>(value % output_base));
        value /= output_base;
    }
    
    std::reverse(result.begin(), result.end());
    return result;
}
```
