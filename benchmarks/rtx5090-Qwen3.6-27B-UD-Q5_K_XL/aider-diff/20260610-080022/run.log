    files_with_matches: bool,
    case_insensitive: bool,
    invert_match: bool,
    match_entire_line: bool,
}

impl Flags {
    pub fn new(flags: &[&str]) -> Self {
        Self {
            line_numbers: flags.contains(&"-n"),
            files_with_matches: flags.contains(&"-l"),
            case_insensitive: flags.contains(&"-i"),
            invert_match: flags.contains(&"-v"),
            match_entire_line: flags.contains(&"-x"),
        }
    }
}

pub fn grep(pattern: &str, flags: &Flags, files: &[&str]) -> Result<Vec<String>, Error> {
    let mut results = Vec::new();
    let multiple_files = files.len() > 1;
    
    let search_pattern = if flags.case_insensitive {
        pattern.to_lowercase()
    } else {
        pattern.to_string()
    };

    for file in files {
        let contents = fs::read_to_string(file)?;
        
        for (line_idx, line) in contents.lines().enumerate() {
            let line_to_check = if flags.case_insensitive {
                line.to_lowercase()
            } else {
                line.to_string()
            };

            let matches = if flags.match_entire_line {
                line_to_check == search_pattern
            } else {
                line_to_check.contains(&search_pattern)
            };

            let is_match = if flags.invert_match { !matches } else { matches };

            if is_match {
                if flags.files_with_matches {
                    results.push(file.to_string());
                    break;
                } else {
                    let mut output = String::new();
                    if multiple_files {
                        output.push_str(file);
                        output.push(':');
                    }
                    if flags.line_numbers {
                        output.push_str(&(line_idx + 1).to_string());
                        output.push(':');
                    }
                    output.push_str(line);
                    results.push(output);
                }
            }
        }
    }
    Ok(results)
}
