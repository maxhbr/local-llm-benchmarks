So 'O' connects row 0 to row `height-1`.
'X' connects col 0 to col `width-1`.

Let's implement BFS.
Directions for neighbors:
`[ [0, -1], [0, 1], [-1, 0], [-1, 1], [1, -1], [1, 0] ]`

Check bounds: `r >= 0 && r < rows && c >= 0 && c < cols`

Implementation details:
```javascript
export class Board {
  constructor(board) {
    this.grid = board.map(row => row.replace(/ /g, '').split(''));
    this.rows = this.grid.length;
    this.cols = this.rows > 0 ? this.grid[0].length : 0;
  }

  winner() {
    if (this.checkWin('O')) return 'O';
    if (this.checkWin('X')) return 'X';
    return '';
  }

  checkWin(player) {
    const queue = [];
    const visited = new Set();

    if (player === 'O') {
      // Start from top row
      for (let c = 0; c < this.cols; c++) {
        if (this.grid[0][c] === player) {
          queue.push([0, c]);
          visited.add(`0,${c}`);
        }
      }
    } else {
      // Start from left column
      for (let r = 0; r < this.rows; r++) {
        if (this.grid[r][0] === player) {
          queue.push([r, 0]);
          visited.add(`${r},0`);
        }
      }
    }

    const dirs = [[0, -1], [0, 1], [-1, 0], [-1, 1], [1, -1], [1, 0]];

    while (queue.length > 0) {
      const [r, c] = queue.shift();

      if (player === 'O' && r === this.rows - 1) return true;
      if (player === 'X' && c === this.cols - 1) return true;

