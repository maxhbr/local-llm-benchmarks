export class Forth {
  constructor() {
    this.stack = [];
    this.words = {};
  }

  evaluate(input) {
    const tokens = input.split(/\s+/).filter(t => t !== '');
    this.processTokens(tokens);
  }

  processTokens(tokens) {
    let i = 0;
    while (i < tokens.length) {
      const token = tokens[i].toLowerCase();
      
      if (token === ':') {
        i++;
        if (i >= tokens.length) throw new Error('Unexpected end of definition');
        const wordName = tokens[i].toLowerCase();
        
        if (/^-?\d+$/.test(wordName)) {
          throw new Error('Invalid definition');
        }
        if (this.isBuiltIn(wordName)) {
          throw new Error('Invalid definition');
        }
        
        i++;
        const defTokens = [];
        let foundSemicolon = false;
        while (i < tokens.length) {
          if (tokens[i] === ';') {
            i++;
            foundSemicolon = true;
            break;
          }
          defTokens.push(tokens[i].toLowerCase());
          i++;
        }
        if (!foundSemicolon) {
          throw new Error('Unexpected end of definition');
        }
        this.words[wordName] = defTokens;
      } else if (this.words[token] !== undefined) {
        const def = this.words[token];
        tokens.splice(i, 1, ...def);
      } else if (/^-?\d+$/.test(token)) {
        this.stack.push(parseInt(token, 10));
        i++;
      } else if (this.isBuiltIn(token)) {
        this.executeBuiltIn(token);
        i++;
      } else {
        throw new Error('Unknown command');
      }
    }
  }

  isBuiltIn(token) {
    return ['+', '-', '*', '/', 'dup', 'drop', 'swap', 'over'].includes(token);
  }

  executeBuiltIn(token) {
    switch (token) {
      case '+':
        if (this.stack.length < 2) throw new Error('Stack empty');
        this.stack.push(this.stack.pop() + this.stack.pop());
        break;
