/// A munger which XORs a key with some data
#[derive(Clone)]
pub struct Xorcism<'a> {
    key: &'a [u8],
    offset: usize,
}

pub struct MungeIter<'a, 'b, I> {
    xorcism: &'b mut Xorcism<'a>,
    data_iter: I,
}

impl<'a, 'b, I: Iterator<Item = u8>> Iterator for MungeIter<'a, 'b, I> {
    type Item = u8;

    fn next(&mut self) -> Option<Self::Item> {
        self.data_iter.next().map(|byte| {
            if self.xorcism.key.is_empty() {
                byte
            } else {
                let key_byte = self.xorcism.key[self.xorcism.offset];
                self.xorcism.offset += 1;
                if self.xorcism.offset == self.xorcism.key.len() {
                    self.xorcism.offset = 0;
                }
                byte ^ key_byte
            }
        })
    }
}

impl<'a> Xorcism<'a> {
    /// Create a new Xorcism munger from a key
    ///
    /// Should accept anything which has a cheap conversion to a byte slice.
    pub fn new<Key: AsRef<[u8]>>(key: &'a Key) -> Xorcism<'a> {
        Xorcism {
            key: key.as_ref(),
            offset: 0,
        }
    }

    /// XOR each byte of the input buffer with a byte from the key.
    ///
    /// Note that this is stateful: repeated calls are likely to produce different results,
    /// even with identical inputs.
    pub fn munge_in_place(&mut self, data: &mut [u8]) {
        if self.key.is_empty() {
            return;
        }
        for byte in data.iter_mut() {
            *byte ^= self.key[self.offset];
            self.offset += 1;
            if self.offset == self.key.len() {
                self.offset = 0;
            }
        }
    }

    /// XOR each byte of the data with a byte from the key.
    ///
    /// Note that this is stateful: repeated calls are likely to produce different results,
    /// even with identical inputs.
    ///
    /// Should accept anything which has a cheap conversion to a byte iterator.
    /// Shouldn't matter whether the byte iterator's values are owned or borrowed.
    pub fn munge<Data>(&mut self, data: Data) -> MungeIter<'a, '_, Data::IntoIter>
    where
        Data: IntoIterator<Item = u8>,
    {
        MungeIter {
            xorcism: self,
            data_iter: data.into_iter(),
        }
    }
}

#[cfg(feature = "io")]
use std::io::{Read, Write};

#[cfg(feature = "io")]
pub struct XorReader<'a, R> {
    read: R,
    xorcism: Xorcism<'a>,
}

#[cfg(feature = "io")]
impl<'a, R: Read> Read for XorReader<'a, R> {
    fn read(&mut self, buf: &mut [u8]) -> std::io::Result<usize> {
        let len = self.read.read(buf)?;
        self.xorcism.munge_in_place(&mut buf[..len]);
        Ok(len)
    }
}

#[cfg(feature = "io")]
pub struct XorWriter<'a, W> {
    write: W,
    xorcism: Xorcism<'a>,
}

#[cfg(feature = "io")]
impl<'a, W: Write> Write for XorWriter<'a, W> {
    fn write(&mut self, buf: &[u8]) -> std::io::Result<usize> {
        let mut out = vec![0; buf.len()];
        out.copy_from_slice(buf);
        self.xorcism.munge_in_place(&mut out);
        self.write.write(&out)
    }

    fn flush(&mut self) -> std::io::Result<()> {
        self.write.flush()
    }
}

#[cfg(feature = "io")]
impl<'a> Xorcism<'a> {
    pub fn reader(self, read: impl Read) -> impl Read {
        XorReader { read, xorcism: self }
    }

    pub fn writer(self, write: impl Write) -> impl Write {
        XorWriter { write, xorcism: self }
    }
}
