```rust
pub fn answer(command: &str) -> Option<i32> {
    if !command.starts_with("What is ") || !command.ends_with('?') {
        return None;
    }
    
    let body = &command[8..command.len()-1];
    if body.is_empty() {
        return None;
    }
    
    let mut tokens = body.split_whitespace();
    let mut current = match tokens.next()?.parse::<i32>() {
        Ok(n) => n,
        Err(_) => return None,
    };
    
    loop {
        let op = match tokens.next()? {
            "plus" => Op::Add,
            "minus" => Op::Sub,
            "multiplied" => {
                if tokens.next() != Some("by") { return None; }
                Op::Mul
            }
            "divided" => {
                if tokens.next() != Some("by") { return None; }
                Op::Div
            }
            #[cfg(feature = "exponentials")]
            "raised" => {
                if tokens.next() != Some("to") || tokens.next() != Some("the") {
                    return None;
                }
                let exp_str = tokens.next()?;
                let exp: i32 = exp_str.chars().filter(|c| c.is_ascii_digit()).collect::<String>().parse().ok()?;
                if tokens.next() != Some("power") {
                    return None;
                }
                current = current.pow(exp as u32);
                continue;
            }
            _ => return None,
        };
        
        let next_val = match tokens.next()?.parse::<i32>() {
            Ok(n) => n,
            Err(_) => return None,
        };
        
        current = match op {
            Op::Add => current + next_val,
            Op::Sub => current - next_val,
            Op::Mul => current * next_val,
            Op::Div => current / next_val,
        };
    }
}

#[derive(PartialEq)]
enum Op { Add, Sub, Mul, Div }
