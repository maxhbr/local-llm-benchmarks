```python
class SgfTree:
    def __init__(self, properties=None, children=None):
        self.properties = properties or {}
        self.children = children or []

    def __eq__(self, other):
        if not isinstance(other, SgfTree):
            return False
        for key, value in self.properties.items():
            if key not in other.properties:
                return False
            if other.properties[key] != value:
                return False
        for key in other.properties.keys():
            if key not in self.properties:
                return False
        if len(self.children) != len(other.children):
            return False
        for child, other_child in zip(self.children, other.children):
            if child != other_child:
                return False
        return True

    def __ne__(self, other):
        return not self == other


class Parser:
    def __init__(self, text):
        self.text = text
        self.pos = 0

    def peek(self):
        if self.pos < len(self.text):
            return self.text[self.pos]
        return None

    def advance(self):
        self.pos += 1

    def parse_tree(self):
        if self.peek() != '(':
            raise ValueError("tree missing")
        self.advance()

        if self.peek() != ';':
            raise ValueError("tree with no nodes")

        root = SgfTree(properties=self.parse_node_properties(), children=[])
        current = root
        
        while self.peek() == ';':
            new_node = SgfTree(properties=self.parse_node_properties(), children=[])
            current.children.append(new_node)
            current = new_node
            
        while self.peek() == '(':
            child_tree = self.parse_tree()
            current.children.append(child_tree)
            
        if self.peek() != ')':
            raise ValueError("tree missing")
        self.advance()
        
        return root

    def parse_node_properties(self):
        self.advance() # consume ';'
        properties = {}
        while self.peek() and self.peek() not in (';', '(', ')'):
            key, values = self.parse_property()
            properties[key] = values
        return properties

    def parse_property(self):
        key = []
        while self.peek() and self.peek() != '[':
            key.append(self.peek())
            self.advance()
        key_str = ''.join(key)
        if not key_str:
            raise ValueError("properties without delimiter")
        if key_str != key_str.upper():
            raise ValueError("property must be in uppercase")

        values = []
        while self.peek() == '[':
            values.append(self.parse_value())
            
        if not values:
            raise ValueError("properties without delimiter")
            
        return key_str, tuple(values)

    def parse_value(self):
        if self.peek() != '[':
            raise ValueError("properties without delimiter")
        self.advance() # consume '['
        res = []
        while self.peek() != ']':
            char = self.peek()
            if char is None:
                raise ValueError("properties without delimiter")
            if char == '\\':
                self.advance()
                next_char = self.peek()
                if next_char is None:
                    raise ValueError("properties without delimiter")
                if next_char == '\n':
                    self.advance()
                elif next_char in ' \t\r':
                    res.append(' ')
                    self.advance()
                else:
                    res.append(next_char)
                    self.advance()
            elif char in ' \t\r':
                res.append(' ')
                self.advance()
            else:
                res.append(char)
                self.advance()
        self.advance() # consume ']'
        return ''.join(res)


def parse(input_string):
    if not input_string:
        raise ValueError("tree missing")
    parser = Parser(input_string)
    tree = parser.parse_tree()
    if parser.pos < len(input_string):
        raise ValueError("tree missing")
    return tree
