Implementation details:
```javascript
export const transpose = (input) => {
  if (input.length === 0) return [];
  
  const maxLen = Math.max(...input.map(row => row.length));
  const result = [];
  
  for (let j = 0; j < maxLen; j++) {
    let lastRow = -1;
    // Find the last row that has a character at column j
    for (let i = input.length - 1; i >= 0; i--) {
      if (j < input[i].length) {
        lastRow = i;
        break;
      }
    }
    
    if (lastRow === -1) continue; // Should not happen if j < maxLen, but safe
    
    let newRow = '';
    for (let i = 0; i <= lastRow; i++) {
      if (j < input[i].length) {
        newRow += input[i][j];
      } else {
        newRow += ' ';
      }
    }
    result.push(newRow);
  }
  
  return result;
};
```

