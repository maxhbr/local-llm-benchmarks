def evaluate(input_data):
    stack = []
    definitions = {}
    
    queue = []
    for line in input_data:
        queue.extend(line.split())
        
    while queue:
        token = queue.pop(0).lower()
        
        if token == ':':
            if not queue:
                raise ValueError("undefined operation")
            word_name = queue.pop(0).lower()
            if word_name.lstrip('-').isdigit():
                raise ValueError("illegal operation")
                
            def_tokens = []
            while queue and queue[0].lower() != ';':
                def_tokens.append(queue.pop(0).lower())
            if queue:
                queue.pop(0) # consume ';'
            definitions[word_name] = def_tokens
            continue
            
        if token in definitions:
            # Push definition tokens to the front of the queue in reverse order
            # so they are processed in correct order.
            queue[:0] = definitions[token][::-1]
            continue
            
        if token.lstrip('-').isdigit():
            stack.append(int(token))
            continue
            
        # Built-in operations
        if token == '+':
            if len(stack) < 2: raise StackUnderflowError("Insufficient number of items in stack")
            b, a = stack.pop(), stack.pop()
            stack.append(a + b)
        elif token == '-':
            if len(stack) < 2: raise StackUnderflowError("Insufficient number of items in stack")
            b, a = stack.pop(), stack.pop()
            stack.append(a - b)
        elif token == '*':
            if len(stack) < 2: raise StackUnderflowError("Insufficient number of items in stack")
            b, a = stack.pop(), stack.pop()
            stack.append(a * b)
        elif token == '/':
            if len(stack) < 2: raise StackUnderflowError("Insufficient number of items in stack")
            b, a = stack.pop(), stack.pop()
            if b == 0: raise ZeroDivisionError("divide by zero")
