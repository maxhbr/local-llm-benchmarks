```java
import java.awt.Point;
import java.util.*;

enum Player {
    NONE, BLACK, WHITE
}

class GoCounting {
    private final char[][] board;
    private final int width;
    private final int height;

    GoCounting(String board) {
        String[] lines = board.split("\n", -1);
        height = lines.length;
        width = lines[0].length();
        this.board = new char[height][width];
        for (int y = 0; y < height; y++) {
            this.board[y] = lines[y].toCharArray();
        }
    }

    Player getTerritoryOwner(int x, int y) {
        if (x < 0 || x >= width || y < 0 || y >= height) {
            throw new IllegalArgumentException("Invalid coordinate");
        }
        Set<Point> territory = getTerritory(x, y);
        if (territory.isEmpty()) {
            return Player.NONE;
        }
        
        boolean hasBlack = false;
        boolean hasWhite = false;
        
        for (Point p : territory) {
            int[] dx = {0, 0, 1, -1};
            int[] dy = {1, -1, 0, 0};
            for (int i = 0; i < 4; i++) {
                int nx = p.x + dx[i];
                int ny = p.y + dy[i];
                if (nx >= 0 && nx < width && ny >= 0 && ny < height) {
                    char c = board[ny][nx];
                    if (c == 'B') hasBlack = true;
                    if (c == 'W') hasWhite = true;
                }
            }
        }
        
        if (hasBlack && !hasWhite) return Player.BLACK;
        if (hasWhite && !hasBlack) return Player.WHITE;
        return Player.NONE;
    }

    Set<Point> getTerritory(int x, int y) {
        if (x < 0 || x >= width || y < 0 || y >= height) {
            throw new IllegalArgumentException("Invalid coordinate");
        }
        if (board[y][x] != ' ') {
            return new HashSet<>();
        }
        
        Set<Point> territory = new HashSet<>();
        Set<Point> visited = new HashSet<>();
        Queue<Point> queue = new ArrayDeque<>();
        
        queue.add(new Point(x, y));
        visited.add(new Point(x, y));
        
        while (!queue.isEmpty()) {
            Point p = queue.poll();
            territory.add(p);
            
            int[] dx = {0, 0, 1, -1};
            int[] dy = {1, -1, 0, 0};
            
            for (int i = 0; i < 4; i++) {
                int nx = p.x + dx[i];
                int ny = p.y + dy[i];
                if (nx >= 0 && nx < width && ny >= 0 && ny < height) {
                    Point neighbor = new Point(nx, ny);
                    if (!visited.contains(neighbor)) {
                        if (board[ny][nx] == ' ') {
                            visited.add(neighbor);
                            queue.add(neighbor);
                        }
                    }
                }
            }
        }
        return territory;
    }

    Map<Player, Set<Point>> getTerritories() {
        Map<Player, Set<Point>> territories = new HashMap<>();
        territories.put(Player.BLACK, new HashSet<>());
        territories.put(Player.WHITE, new HashSet<>());
        territories.put(Player.NONE, new HashSet<>());
        
