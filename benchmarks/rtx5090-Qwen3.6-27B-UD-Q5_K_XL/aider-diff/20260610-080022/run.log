package markdown

import (
        "fmt"
        "strings"
)

// Render translates markdown to HTML
func Render(markdown string) string {
        lines := strings.Split(markdown, "\n")
        var html strings.Builder
        inList := false

        for _, line := range lines {
                line = parseInline(line)
                if line == "" {
                        continue
                }
                if strings.HasPrefix(line, "#") {
                        if inList {
                                html.WriteString("</ul>")
                                inList = false
                        }
                        html.WriteString(parseHeader(line))
                } else if strings.HasPrefix(line, "* ") {
                        if !inList {
                                html.WriteString("<ul>")
                                inList = true
                        }
                        html.WriteString("<li>")
                        html.WriteString(line[2:])
                        html.WriteString("</li>")
                } else {
                        if inList {
                                html.WriteString("</ul>")
                                inList = false
                        }
                        html.WriteString("<p>")
                        html.WriteString(line)
                        html.WriteString("</p>")
                }
        }

        if inList {
                html.WriteString("</ul>")
        }

        return html.String()
}

// parseHeader converts a markdown header line to HTML.
// If the line is not a valid header (level > 6 or missing space), it returns a paragraph.
func parseHeader(line string) string {
        level := 0
        for level < len(line) && line[level] == '#' {
                level++
        }
        if level > 6 || level == len(line) || line[level] != ' ' {
                return "<p>" + line + "</p>"
        }
        return fmt.Sprintf("<h%d>%s</h%d>", level, line[level+1:], level)
}

// parseInline handles bold and italic markdown syntax within a line.
func parseInline(line string) string {
        line = strings.Replace(line, "__", "<strong>", 1)
        line = strings.Replace(line, "__", "</strong>", 1)
        line = strings.Replace(line, "_", "<em>", 1)
        line = strings.Replace(line, "_", "</em>", 1)
        return line
}
