pub fn encode(n: u64) -> String {
    if n == 0 {
        return "zero".to_string();
    }

    const ONES: &[&str] = &[
        "", "one", "two", "three", "four", "five", "six", "seven", "eight", "nine",
        "ten", "eleven", "twelve", "thirteen", "fourteen", "fifteen", "sixteen",
        "seventeen", "eighteen", "nineteen",
    ];
    const TENS: &[&str] = &[
        "", "", "twenty", "thirty", "forty", "fifty", "sixty", "seventy", "eighty", "ninety",
    ];
    const SCALES: &[&str] = &[
        "", " thousand", " million", " billion", " trillion", " quadrillion", " quintillion",
    ];

    let mut parts = Vec::new();
    let mut num = n;
    let mut scale_idx = 0;

    while num > 0 {
        let chunk = num % 1000;
        if chunk > 0 {
            let mut chunk_parts = Vec::new();
            if chunk >= 100 {
                chunk_parts.push(format!("{} hundred", ONES[(chunk / 100) as usize]));
            }
            let remainder = chunk % 100;
            if remainder >= 20 {
                let t = TENS[(remainder / 10) as usize];
                let o = ONES[(remainder % 10) as usize];
                if o.is_empty() {
                    chunk_parts.push(t.to_string());
                } else {
                    chunk_parts.push(format!("{}-{}", t, o));
                }
            } else if remainder > 0 {
                chunk_parts.push(ONES[remainder as usize].to_string());
            }
            
            let chunk_str = chunk_parts.join(" ");
            parts.push(format!("{}{}", chunk_str, SCALES[scale_idx]));
        }
        num /= 1000;
        scale_idx += 1;
    }

    parts.reverse();
    parts.join(" ")
}
```

