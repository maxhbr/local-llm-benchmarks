```javascript
export class Robot {
  constructor() {
    this._name = null;
  }

  get name() {
    if (!this._name) {
      this._name = this._generateUniqueName();
    }
    return this._name;
  }

  reset() {
    this._name = null;
  }

  static releaseNames() {
    Robot.usedNames.clear();
  }

  _generateUniqueName() {
    let newName;
    do {
      newName = this._generateRandomName();
    } while (Robot.usedNames.has(newName));
    Robot.usedNames.add(newName);
    return newName;
  }

  _generateRandomName() {
    const letters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
    const digits = '0123456789';
    let name = '';
    for (let i = 0; i < 2; i++) {
      name += letters.charAt(Math.floor(Math.random() * 26));
    }
    for (let i = 0; i < 3; i++) {
      name += digits.charAt(Math.floor(Math.random() * 10));
    }
    return name;
  }
}

Robot.usedNames = new Set();
```

