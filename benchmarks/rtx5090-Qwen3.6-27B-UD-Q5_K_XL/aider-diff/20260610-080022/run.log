class StackUnderflowError(Exception):
    pass


def evaluate(input_data):
    stack = []
    definitions = {}
    
    tokens = []
    for line in input_data:
        tokens.extend(line.split())
        
    i = 0
    while i < len(tokens):
        token = tokens[i].lower()
        
        if token == ':':
            i += 1
            if i >= len(tokens):
                raise ValueError("undefined operation")
            word_name = tokens[i].lower()
            i += 1
            
            if word_name.lstrip('-').isdigit():
                raise ValueError("illegal operation")
                
            def_tokens = []
            while i < len(tokens) and tokens[i].lower() != ';':
                def_tokens.append(tokens[i].lower())
                i += 1
            if i < len(tokens):
                i += 1 # skip ';'
            definitions[word_name] = def_tokens
            continue
            
        if token in definitions:
            tokens[i:i+1] = definitions[token]
            continue
            
        try:
            stack.append(int(token))
            i += 1
            continue
        except ValueError:
            pass
            
        if token == '+':
            if len(stack) < 2: raise StackUnderflowError("Insufficient number of items in stack")
            b, a = stack.pop(), stack.pop()
            stack.append(a + b)
        elif token == '-':
            if len(stack) < 2: raise StackUnderflowError("Insufficient number of items in stack")
            b, a = stack.pop(), stack.pop()
            stack.append(a - b)
        elif token == '*':
            if len(stack) < 2: raise StackUnderflowError("Insufficient number of items in stack")
            b, a = stack.pop(), stack.pop()
            stack.append(a * b)
        elif token == '/':
            if len(stack) < 2: raise StackUnderflowError("Insufficient number of items in stack")
            b, a = stack.pop(), stack.pop()
            if b == 0: raise ZeroDivisionError("divide by zero")
            stack.append(int(a / b))
        elif token == 'dup':
            if len(stack) < 1: raise StackUnderflowError("Insufficient number of items in stack")
            stack.append(stack[-1])
        elif token == 'drop':
            if len(stack) < 1: raise StackUnderflowError("Insufficient number of items in stack")
            stack.pop()
        elif token == 'swap':
            if len(stack) < 2: raise StackUnderflowError("Insufficient number of items in stack")
            stack[-1], stack[-2] = stack[-2], stack[-1]
        elif token == 'over':
            if len(stack) < 2: raise StackUnderflowError("Insufficient number of items in stack")
            stack.append(stack[-2])
        else:
            raise ValueError("undefined operation")
        i += 1
        
    return stack
```

