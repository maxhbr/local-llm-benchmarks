Let's draft the solver:
```go
package zebra

type Solution struct {
        DrinksWater string
        OwnsZebra   string
}

func SolvePuzzle() Solution {
    colors := []string{"Red", "Green", "Ivory", "Yellow", "Blue"}
    nations := []string{"Englishman", "Spaniard", "Ukrainian", "Norwegian", "Japanese"}
    drinks := []string{"Coffee", "Tea", "Milk", "OJ", "Water"}
    smokes := []string{"OldGold", "Kools", "Chesterfields", "LuckyStrike", "Parliaments"}
    pets := []string{"Dog", "Snails", "Fox", "Horse", "Zebra"}

    // We'll use a recursive backtracking approach.
    // State: 5 houses, each has 5 attributes.
    // To simplify, we'll assign attributes house by house.
    // But checking constraints is easier if we assign by category or use a flat array.
    // Let's assign by house index 0..4.
    // For each house, we pick a color, nation, drink, smoke, pet from remaining options.
    // This is 5!^5 worst case, but constraints prune heavily.
    
    // Actually, assigning by category is easier to check constraints like "Green right of Ivory".
    // Let's assign categories one by one: Colors, Nations, Drinks, Smokes, Pets.
    // We'll keep track of the current assignment for each category.
    
    var h [5][5]string // houses[house][attr]
    // attr indices: 0:Color, 1:Nation, 2:Drink, 3:Smoke, 4:Pet
    
    // We'll use a recursive function that fills h[house][attr]
    // But it's easier to just generate permutations for each category and check.
    // Given the small size, let's just do nested loops over permutations with pruning.
    
    // Precompute permutations
    perms := func(arr []string) [][]string {
        var res [][]string
        var perm []string
        used := make([]bool, len(arr))
        var backtrack func()
        backtrack = func() {
            if len(perm) == len(arr) {
                p := make([]string, len(arr))
                copy(p, perm)
                res = append(res, p)
                return
            }
            for i, v := range arr {
                if !used[i] {
                    used[i] = true
                    perm = append(perm, v)
                    backtrack()
                    perm = perm[:len(perm)-1]
                    used[i] = false
                }
            }
        }
        backtrack()
        return res
    }

    pColors := perms(colors)
    pNations := perms(nations)
    pDrinks := perms(drinks)
    pSmokes := perms(smokes)
    pPets := perms(pets)

    for _, c := range pColors {
        if c[1] != "Blue" { continue } // 15. Norwegian(0) next to Blue => Blue is 1
        // 6. Green right of Ivory
        greenIdx := -1
        ivoryIdx := -1
        for i, col := range c {
            if col == "Green" { greenIdx = i }
            if col == "Ivory" { ivoryIdx = i }
        }
        if greenIdx != ivoryIdx+1 { continue }

        for _, n := range pNations {
            if n[0] != "Norwegian" { continue } // 10. Norwegian in first house
            // 2. Englishman in Red
            engIdx := -1
            redIdx := -1
            for i, nat := range n {
                if nat == "Englishman" { engIdx = i }
                if c[i] == "Red" { redIdx = i }
            }
            if engIdx != redIdx { continue }

            for _, d := range pDrinks {
                if d[2] != "Milk" { continue } // 9. Milk in middle
                // 4. Coffee in Green
                coffeeIdx := -1
                for i, drink := range d {
                    if drink == "Coffee" { coffeeIdx = i }
                }
                if c[coffeeIdx] != "Green" { continue }
                // 5. Ukrainian drinks Tea
                ukrIdx := -1
                teaIdx := -1
                for i, nat := range n {
                    if nat == "Ukrainian" { ukrIdx = i }
                }
                for i, drink := range d {
                    if drink == "Tea" { teaIdx = i }
                }
                if ukrIdx != teaIdx { continue }

                for _, s := range pSmokes {
                    // 8. Kools in Yellow
                    koolsIdx := -1
                    yellowIdx := -1
                    for i, smoke := range s {
                        if smoke == "Kools" { koolsIdx = i }
                    }
                    for i, col := range c {
                        if col == "Yellow" { yellowIdx = i }
                    }
                    if koolsIdx != yellowIdx { continue }
                    // 13. LuckyStrike drinks OJ
                    lsIdx := -1
                    ojIdx := -1
                    for i, smoke := range s {
                        if smoke == "LuckyStrike" { lsIdx = i }
                    }
                    for i, drink := range d {
                        if drink == "OJ" { ojIdx = i }
                    }
                    if lsIdx != ojIdx { continue }
                    // 14. Japanese smokes Parliaments
                    japIdx := -1
                    parIdx := -1
                    for i, nat := range n {
                        if nat == "Japanese" { japIdx = i }
                    }
                    for i, smoke := range s {
                        if smoke == "Parliaments" { parIdx = i }
                    }
                    if japIdx != parIdx { continue }

                    for _, p := range pPets {
                        // 3. Spaniard owns Dog
                        spaIdx := -1
                        dogIdx := -1
                        for i, nat := range n {
                            if nat == "Spaniard" { spaIdx = i }
                        }
                        for i, pet := range p {
                            if pet == "Dog" { dogIdx = i }
                        }
                        if spaIdx != dogIdx { continue }
                        // 7. OldGold owns Snails
                        ogIdx := -1
                        snailIdx := -1
                        for i, smoke := range s {
                            if smoke == "OldGold" { ogIdx = i }
                        }
                        for i, pet := range p {
                            if pet == "Snails" { snailIdx = i }
                        }
                        if ogIdx != snailIdx { continue }
                        // 11. Chesterfields next to Fox
                        chIdx := -1
                        foxIdx := -1
                        for i, smoke := range s {
                            if smoke == "Chesterfields" { chIdx = i }
                        }
                        for i, pet := range p {
                            if pet == "Fox" { foxIdx = i }
                        }
                        if abs(chIdx-foxIdx) != 1 { continue }
                        // 12. Kools next to Horse
                        horseIdx := -1
                        for i, pet := range p {
                            if pet == "Horse" { horseIdx = i }
                        }
                        if abs(koolsIdx-horseIdx) != 1 { continue }

                        // Found solution
                        var waterDrinker, zebraOwner string
                        for i := 0; i < 5; i++ {
                            if d[i] == "Water" { waterDrinker = n[i] }
                            if p[i] == "Zebra" { zebraOwner = n[i] }
                        }
                        return Solution{DrinksWater: waterDrinker, OwnsZebra: zebraOwner}
                    }
                }
            }
        }
    }
    return Solution{}
}

func abs(x int) int {
    if x < 0 { return -x }
    return x
}
