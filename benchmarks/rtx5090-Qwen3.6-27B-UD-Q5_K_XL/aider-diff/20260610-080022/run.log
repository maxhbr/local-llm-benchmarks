from collections import deque

class StackUnderflowError(Exception):
    """Exception raised when Stack is not full.
       message: explanation of the error.
    """
    def __init__(self, message):
        self.message = message


def evaluate(input_data):
    stack = []
    definitions = {}
    
    tokens = deque()
    for line in input_data:
        tokens.extend(line.split())
        
    while tokens:
        token = tokens.popleft().lower()
        
        if token == ':':
            if not tokens:
                raise ValueError("undefined operation")
            word_name = tokens.popleft().lower()
            if word_name.lstrip('-').isdigit() and len(word_name.lstrip('-')) > 0:
                raise ValueError("illegal operation")
                
            def_tokens = []
            while tokens:
                t = tokens.popleft().lower()
                if t == ';':
                    break
                def_tokens.append(t)
            else:
                raise ValueError("undefined operation")
            definitions[word_name] = def_tokens
            continue
            
        if token in definitions:
            tokens.extendleft(reversed(definitions[token]))
            continue
            
        try:
            stack.append(int(token))
            continue
        except ValueError:
            pass
            
        if token == '+':
            if len(stack) < 2: raise StackUnderflowError("Insufficient number of items in stack")
            b, a = stack.pop(), stack.pop()
            stack.append(a + b)
        elif token == '-':
            if len(stack) < 2: raise StackUnderflowError("Insufficient number of items in stack")
            b, a = stack.pop(), stack.pop()
            stack.append(a - b)
        elif token == '*':
            if len(stack) < 2: raise StackUnderflowError("Insufficient number of items in stack")
