# Local LLM benchmark matrix.
#
# Lists OpenAI-compatible endpoints, the models to test on each one, and which
# benchmarks should be run for each model.  Used by run_benchmarks.py
# (or `nix run .#run-benchmarks` from the flake).
#
# Available benchmark ids (see `run_benchmarks.py --list-benchmarks`):
#   llama-benchy   -> token-throughput / latency
#   aider          -> aider polyglot coding benchmark (containerised)
#   terminal-bench -> harbor / terminal-bench tasks
#   agent-bench    -> structured-output + tool-call mini agent benchmark

output_dir = "./benchmarks"

# -----------------------------------------------------------------------------
# Endpoint 1: a local llama.cpp / vllm server.
# `benchmarks` here is the default applied to every model under this endpoint
# unless that model overrides it.
# -----------------------------------------------------------------------------
[[endpoints]]
name       = "local-llama-cpp"
url        = "http://localhost:8080/v1"
api_key    = "EMPTY"
benchmarks = ["llama-benchy", "agent-bench"]

  [[endpoints.models]]
  name       = "qwen2.5-coder-32b"
  # Big coder model: also run the heavier aider polyglot suite.
  benchmarks = ["llama-benchy", "aider", "agent-bench"]

  [[endpoints.models]]
  name = "gpt-oss-120b"
  # No `benchmarks` -> inherits endpoint-level default
  # (llama-benchy + agent-bench).

# -----------------------------------------------------------------------------
# Endpoint 2: a remote vllm box, e.g. only good for agentic tests.
# -----------------------------------------------------------------------------
[[endpoints]]
name       = "remote-vllm"
url        = "http://gpu-box.lan:8000/v1"
api_key    = "EMPTY"
benchmarks = ["agent-bench"]

  [[endpoints.models]]
  name = "deepseek-v3"

  [[endpoints.models]]
  name       = "llama-3.3-70b-instruct"
  benchmarks = ["agent-bench", "terminal-bench"]
