  'eight Maids-a-Milking',

  'nine Ladies Dancing',

  'ten Lords-a-Leaping',

  'eleven Pipers Piping',

  'twelve Drummers Drumming'

];



function verse(n) {

  const lines = [];

  for (let i = n; i >= 2; i--) {

    lines.push(GIFTS[i]);

  }

  if (n === 1) {

    lines.push(GIFTS[1]);

  } else {

    lines.push('and ' + GIFTS[1]);

  }

  return `On the ${ORDINALS[n]} day of Christmas my true love gave to me: ${lines.join(', ')}`;

}



export const recite = (start, end) => {

  if (end === undefined) end = start;

  const verses = [];

  for (let i = start; i <= end; i++) {

    verses.push(verse(i));

  }

  return verses.join('\n\n') + '\n';

};

