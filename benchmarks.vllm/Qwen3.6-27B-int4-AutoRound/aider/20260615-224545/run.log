namespace allergies {

allergies::allergies(unsigned int score) : score_(score) {}

bool allergies::allergic_to(const std::string& item) const {
    if (item == "eggs") return (score_ & 1) != 0;
    if (item == "peanuts") return (score_ & 2) != 0;
    if (item == "shellfish") return (score_ & 4) != 0;
    if (item == "strawberries") return (score_ & 8) != 0;
    if (item == "tomatoes") return (score_ & 16) != 0;
    if (item == "chocolate") return (score_ & 32) != 0;
    if (item == "pollen") return (score_ & 64) != 0;
    if (item == "cats") return (score_ & 128) != 0;
    return false;
}

std::vector<std::string> allergies::allergies() const {
    std::vector<std::string> result;
    if (allergic_to("eggs")) result.push_back("eggs");
    if (allergic_to("peanuts")) result.push_back("peanuts");
