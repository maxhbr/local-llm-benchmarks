```
use std::collections::HashMap;

use std::collections::VecDeque;



pub type Value = i32;

pub type Result = std::result::Result<(), Error>;



pub struct Forth {

    stack: Vec<Value>,

    dictionary: HashMap<String, Vec<String>>,

}



#[derive(Debug, PartialEq, Eq)]

pub enum Error {

    DivisionByZero,

    StackUnderflow,

    UnknownWord,

    InvalidWord,

}



impl Forth {

    pub fn new() -> Forth {

        Forth {

            stack: Vec::new(),

            dictionary: HashMap::new(),

        }

    }



    pub fn stack(&self) -> &[Value] {

        &self.stack

    }



    pub fn eval(&mut self, input: &str) -> Result {

        let mut tokens: VecDeque<String> = input

            .split_whitespace()

            .map(|s| s.to_lowercase())

            .collect();



        while let Some(token) = tokens.pop_front() {

            if token == ":" {

                let word_name = tokens.pop_front().ok_or(Error::InvalidWord)?;

                if word_name.parse::<i32>().is_ok() {

                    return Err(Error::InvalidWord);

                }

                let mut def = Vec::new();

                loop {

                    let t = tokens.pop_front().ok_or(Error::InvalidWord)?;

                    if t == ";" {

                        break;

                    }

                    def.push(t);

                }

                self.dictionary.insert(word_name, def);

            } else if let Ok(num) = token.parse::<i32>() {

                self.stack.push(num);

            } else {

                if let Some(def) = self.dictionary.get(&token) {

                    for t in def.iter().rev() {

                        tokens.push_front(t.clone());

                    }

                } else {

                    match token.as_str() {

                        "+" => self.binary_op(|a, b| a + b)?,

                        "-" => self.binary_op(|a, b| a - b)?,

                        "*" => self.binary_op(|a, b| a * b)?,

                        "/" => {

                            let (a, b) = self.pop_two()?;

                            if b == 0 {

                                return Err(Error::DivisionByZero);

                            }

                            self.stack.push(a / b);

                        }

                        "dup" => {

                            let a = *self.stack.last().ok_or(Error::StackUnderflow)?;

                            self.stack.push(a);

                        }

                        "drop" => {

                            self.stack.pop().ok_or(Error::StackUnderflow)?;

                        }

                        "swap" => {

                            if self.stack.len() < 2 {

                                return Err(Error::StackUnderflow);

                            }

                            self.stack.swap(self.stack.len() - 1, self.stack.len() - 2);

                        }

                        "over" => {

                            if self.stack.len() < 2 {

                                return Err(Error::StackUnderflow);

                            }

                            let val = self.stack[self.stack.len() - 2];

                            self.stack.push(val);

                        }

                        _ => return Err(Error::UnknownWord),

                    }

                }

            }

        }

        Ok(())

    }



    fn pop_two(&mut self) -> Result<(Value, Value)> {

        let b = self.stack.pop().ok_or(Error::StackUnderflow)?;

        let a = self.stack.pop().ok_or(Error::StackUnderflow)?;

        Ok((a, b))

    }



    fn binary_op<F>(&mut self, op: F) -> Result<()>

    where

        F: FnOnce(Value, Value) -> Value,

    {

        let (a, b) = self.pop_two()?;

        self.stack.push(op(a, b));

        Ok(())

    }

}

```


