let mut tokens: VecDeque<String> = input.split_whitespace()
    .map(|s| s.to_lowercase())
    .collect();

while let Some(token) = tokens.pop_front() {
    if token == ":" {
        // Start of definition
        let word_name = tokens.pop_front().ok_or(Error::InvalidWord)?;
        // Check if word_name is a number? Forth usually doesn't allow defining numbers as words, but we can just check if it parses as i32.
        if word_name.parse::<i32>().is_ok() {
            return Err(Error::InvalidWord);
        }
        let mut def = Vec::new();
        loop {
            let t = tokens.pop_front().ok_or(Error::InvalidWord)?;
            if t == ";" {
                break;
            }
            def.push(t);
        }
        self.dictionary.insert(word_name, def);
    } else if let Ok(num) = token.parse::<i32>() {
        self.stack.push(num);
    } else {
        // It's a word
        if let Some(def) = self.dictionary.get(&token) {
            // Expand definition: push in reverse order so they are processed in order
            for t in def.iter().rev() {
                tokens.push_front(t.clone());
            }
        } else {
            match token.as_str() {
                "+" => self.binary_op(|a, b| a + b)?,
                "-" => self.binary_op(|a, b| a - b)?,
                "*" => self.binary_op(|a, b| a * b)?,
                "/" => {
                    let b = self.stack.pop().ok_or(Error::StackUnderflow)?;
                    let a = self.stack.pop().ok_or(Error::StackUnderflow)?;
                    if b == 0 { return Err(Error::DivisionByZero); }
                    self.stack.push(a / b);
                }
                "dup" => {
                    let a = self.stack.last().copied().ok_or(Error::StackUnderflow)?;
                    self.stack.push(a);
                }
                "drop" => {
                    self.stack.pop().ok_or(Error::StackUnderflow)?;
                }
                "swap" => {
                    self.stack.swap(self.stack.len() - 1, self.stack.len() - 2);
                }
                "over" => {
                    let a = *self.stack.get(self.stack.len() - 2).ok_or(Error::StackUnderflow)?;
                    self.stack.push(a);
                }
                _ => return Err(Error::UnknownWord),
            }
        }
    }
}
Ok(())
```

