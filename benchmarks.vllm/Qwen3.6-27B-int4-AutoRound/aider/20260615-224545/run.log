#include "allergies.h"
#include <string>
#include <unordered_set>

namespace allergies {

allergy_test::allergy_test(int score) : score_(score) {}

bool allergy_test::is_allergic_to(const std::string& item) const {
    if (item == "eggs") return (score_ & 1) != 0;
    if (item == "peanuts") return (score_ & 2) != 0;
    if (item == "shellfish") return (score_ & 4) != 0;
    if (item == "strawberries") return (score_ & 8) != 0;
    if (item == "tomatoes") return (score_ & 16) != 0;
    if (item == "chocolate") return (score_ & 32) != 0;
    if (item == "pollen") return (score_ & 64) != 0;
    if (item == "cats") return (score_ & 128) != 0;
    return false;
}

std::unordered_set<std::string> allergy_test::get_allergies() const {
    std::unordered_set<std::string> result;
    if (is_allergic_to("eggs")) result.emplace("eggs");
    if (is_allergic_to("peanuts")) result.emplace("peanuts");
    if (is_allergic_to("shellfish")) result.emplace("shellfish");
    if (is_allergic_to("strawberries")) result.emplace("strawberries");
    if (is_allergic_to("tomatoes")) result.emplace("tomatoes");
    if (is_allergic_to("chocolate")) result.emplace("chocolate");
    if (is_allergic_to("pollen")) result.emplace("pollen");
    if (is_allergic_to("cats")) result.emplace("cats");
    return result;
}

}  // namespace allergies
```
