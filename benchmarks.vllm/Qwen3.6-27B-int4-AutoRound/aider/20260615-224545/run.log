                    let a = self.stack.pop().ok_or(Error::StackUnderflow)?;

                    if b == 0 { return Err(Error::DivisionByZero); }

                    self.stack.push(a / b);

                }

                "dup" => {

                    let a = self.stack.last().copied().ok_or(Error::StackUnderflow)?;

                    self.stack.push(a);

                }

                "drop" => {

                    self.stack.pop().ok_or(Error::StackUnderflow)?;

                }

                "swap" => {

                    self.stack.swap(self.stack.len() - 1, self.stack.len() - 2);

                }

                "over" => {

                    let a = *self.stack.get(self.stack.len() - 2).ok_or(Error::StackUnderflow)?;

                    self.stack.push(a);

                }

                _ => return Err(Error::UnknownWord),

            }

        }

    }

}

Ok(())

